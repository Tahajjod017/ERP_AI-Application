@using GCTL.Core.ViewModels.Employee.EmployeeNavigtion
@model GCTL.Core.ViewModels.Employee.EmployeeAllowance.EmployeeAdditionalPostViewModel
<select id="percentageOptionsTemplate" style="display:none">
    @if (ViewBag.PercenatageDD != null)
    {
        foreach (SelectListItem item in (SelectList)ViewBag.PercenatageDD)
        {
            <option value="@item.Value">@item.Text</option>
        }
    }
</select>
<div class="mb-9">
    <div class="row align-items-center justify-content-between g-3 ">
        <div class="col-auto">
        </div>
    </div>

    <div class="px-3 mb-5">

        <form id="EmployeeAllowanceForm" asp-controller="EmployeeAllowance" asp-action="Save" method="post">
            <div class="row">
                <div class="col-12">
                    <input type="hidden" asp-for="EmployeeBaseAllowanceID" id="EmployeeBaseAllowanceID" />
                    <div class="row g-2 align-items-center" id="EmployeeDropDownDiv" style="display:none">
                        <div class="col-md-3">
                            <div class="position-relative">
                 
                            </div>
                        </div>
                        <div class="col-md-3"></div>
                        <div class="col-md-2">
                            <div class="form-floating form-floating-advance-select mb-2">
                                <label asp-for="EmployeePersonalId">@Html.SmartLocalize("Choose Employee")</label>
                                <select class="form-select" asp-for="EmployeePersonalId" id="EmployeePersonalId" asp-items="@ViewBag.EmployeeDD as SelectList">
                                    <option value="">@Html.SmartLocalize("Select Employee")</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2 mb-2">
                            <div class="form-floating">
                                <input asp-for="PersonalEmail" id="PersonalEmail" class="form-control" type="email" placeholder="@Html.SmartLocalize("Email")" />
                                <label asp-for="PersonalEmail">@Html.SmartLocalize("Email")</label>
                            </div>
                        </div>
                        <div class="col-md-2 mb-2">
                            <div class="form-floating">
                                <input asp-for="PersonalPhone" id="PersonalPhone" class="form-control" type="text" placeholder="@Html.SmartLocalize("Enter Phone")" />
                                <label asp-for="PersonalPhone">@Html.SmartLocalize("Phone")</label>
                            </div>
                        </div>
                    </div>

                    <div class="mx-n4 mx-lg-n6 px-lg-6 bg-body-emphasis pb-4">

                        <div class="col-12 col-xl-12 col-xxl-12">

                            @await Html.PartialAsync("Employee/_EmployeeNavigation", ViewBag.Navigation as EmployeeNavigationViewModel)

               

                            <div class="card tab-content bg-white accordion" id="myTabContent">
                                <div class="tab-pane show active fade p-2" role="tabpanel" id="empPayroleInfo" aria-labelledby="empPayroleInfo">
                                    <div class="px-25">
                      
                                        <div class="tab-content mt-3" id="myTabContent">
                                            <div class="tab-pane fade show active" id="tab-empAllowance" role="tabpanel" aria-labelledby="empAllowance-tab">
                                                <div class="">
                                                    <div class="d-flex justify-content-center mt-2">

                                                        <div class="col-12 row flex gy-3">
                                                            <div class="col-md-12">
                                                                <div class="mb-3">
                                                                    <div class="content-head d-flex justify-content-between align-items-center border-bottom">
                                                                        <h5>@Html.SmartLocalize("Add Employee Allowance")</h5>
                                                                        <div class="form-check form-switch">
                                                                            @* <input class="form-check-input" asp-for="IsEmployeeAllowanceEnabled" type="checkbox" role="switch" id="allowanceEnabled" /> *@
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>

                                                            <div class="col-md-4">
                                                                <div class="mb-1">

                                                                    <label>@Html.SmartLocalize("Organization")</label>
                                                                    <select class="form-select choiceDD" id="organizationDD" asp-for="OrganizationID" asp-items="@ViewBag.OrganizationDD as SelectList" disabled>
                                                                        <option value="">@Html.SmartLocalize("No Organization Selected")</option>
                                                                    </select>


                                                                </div>
                                                            </div>

                                                            <div class="card">
                                                                <input type="hidden" name="EmployeeId" id="EmployeeId" />
                                                                <div id="EmployeeAllowanceAccordion"></div>
                                                            </div>
                                                           

                                                            <div class="col-12">
                                                                <div class="row g-3 justify-content-end">
                                                                    <div class="col-auto">
                                                                        <button class="btn btn-phoenix-primary px-5" type="button">@Html.SmartLocalize("Cancel")</button>
                                                                    </div>
                                                                    <div class="col-auto">
                                                                        <button class="btn btn-primary px-5 px-sm-15" type="submit">@Html.SmartLocalize("Save")</button>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>

                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

        </form>
    </div>
</div>

@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/pages/employees/employeevalidator.js"></script>
    <script src="~/js/pages/employees/EmployeeAllownace.js"></script>
    <script src="~/js/pages/employees/employeetabchange.js"></script>
}