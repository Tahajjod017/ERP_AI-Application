<div class="mb-9">
    <div class="row align-items-center justify-content-between g-3 mb-4">
        <div class="col-auto">
        </div>


    </div>

    <div class="px-3 mb-5">
        <div class="row">
            <div class="col-12">

                <div class="search-box me-3 mb-3">
                    <form class="position-relative">
                        <input class="form-control search-input search" type="search" placeholder="Employee Name / Phone / Email" aria-label="Search" />
                        <span class="fas fa-search search-box-icon"></span>

                    </form>
                </div>

                <div class="mx-n4 mx-lg-n6 px-lg-6  bg-body-emphasis pb-4">

                    <form action="">
                        <div class="col-12 col-xl-12 col-xxl-12">

                            <ul class="nav nav-underline fs-9 deal-details scrollbar flex-nowrap w-100 py-2 mb-2 mx-2" id="myTab" role="tablist">

                                <li class="nav-item text-nowrap me-2" role="presentation" id="headingPInfo">
                                    <a class="nav-link active" href="/EmployeePersonal/index" role="tab" aria-selected="true" aria-controls="empPersonalInfo"> <span class="fa-solid fa-user me-2 tab-icon-color"></span>@Html.SmartLocalize("Personal Info.")</a>
                                </li>

                                <li class="nav-item text-nowrap me-2" role="presentation" id="headingEmpOfficialInfo">
                                    <a class="nav-link" href="/EmployeeOfficial/index" role="tab" aria-selected="false" aria-controls="empOfficialInfo"> <span class="fa-solid fa-file-alt me-2 tab-icon-color"></span>@Html.SmartLocalize("Official Info.")</a>
                                </li>

                                <li class="nav-item text-nowrap me-2" role="presentation" id="headingempPayroleInfo">
                                    <a class="nav-link" href="/EmployeeSalary/index" role="tab" aria-selected="false" aria-controls="empPayroleInfo"> <span class="fa-solid fa-file-alt me-2 tab-icon-color"></span>@Html.SmartLocalize("Payroll Info.")</a>
                                </li>

                                <li class="nav-item text-nowrap me-2" role="presentation" id="headingAdditionalInfo">
                                    <a class="nav-link" href="/EmployeeAdditional/index" role="tab" aria-selected="false" aria-controls="additionalInfo"> <span class="fa-solid fa-square-check me-2 tab-icon-color"></span>@Html.SmartLocalize("Additional Info.")</a>
                                </li>

                                <li class="nav-item text-nowrap me-2" role="presentation" id="headingeducationInfo">
                                    <a class="nav-link" href="/EmployeeEducation/index" role="tab" aria-selected="false" aria-controls="educationInfo"> <span class="fa-solid fa-square-check me-2 tab-icon-color"></span>@Html.SmartLocalize("Education Info.")</a>
                                </li>

                                <li class="nav-item text-nowrap me-2" role="presentation" id="headingTranningInfo">
                                    <a class="nav-link" href="/EmployeeTraining/index" role="tab" aria-selected="false" aria-controls="tranningInfo"> <span class="fa-solid fa-square-check me-2 tab-icon-color"></span>@Html.SmartLocalize("Training Info.")</a>
                                </li>

                                <li class="nav-item text-nowrap me-2" role="presentation" id="headingFamilyInfo">
                                    <a class="nav-link" href="/EmployeeFamily/index" role="tab" aria-selected="false" aria-controls="familyInfo"> <span class="fa-solid fa-square-check me-2 tab-icon-color"></span>@Html.SmartLocalize("Family Info.")</a>
                                </li>

                            </ul>

                            <div class="card tab-content bg-white accordion" id="myTabContent">

                             

                                <div class="tab-pane show active fade p-2" role="empPayroleInfo" id="empPayroleInfo" aria-labelledby="empPayroleInfo">

                                    <div class=" px-25 ">

                                        <ul class="nav nav-underline fs-9" id="myTab" role="tablist">
                                            <li class="nav-item" role="presentation"><a class="nav-link " id="empSalary-tab"  href="/EmployeeSalary/index" role="tab" aria-controls="tab-empSalary" aria-selected="true">Employee Salary Settings</a></li>
                                            <li class="nav-item" role="presentation"><a class="nav-link" id="empBenefits-tab"  href="/EmployeeBenifit/index" role="tab" aria-controls="tab-empBenefits" aria-selected="false" tabindex="-1">Employee Benefits</a></li>
                                            <li class="nav-item" role="presentation"><a class="nav-link active" id="empAllowance-tab"  href="#" role="tab" aria-controls="tab-empAllowance" aria-selected="false" tabindex="-1">Employee Allowance</a></li>
                                        </ul>
                                        <div class="tab-content mt-3" id="myTabContent">
                                           

                                      

                                            <div class="tab-pane fade show active" id="tab-empAllowance" role="tabpanel" aria-labelledby="empAllowance-tab">
                                                <div class="card">

                                                    <div class="d-flex justify-content-center mt-2 ">

                                                        <div class="col-12 row flex gy-3 ">


                                                            <form action="add-shift-ui.html" class="row g-3 mb-6">

                                                                <div class="col-md-12">
                                                                    <div class="mb-3">
                                                                        <div class="content-head d-flex justify-content-between align-items-center border-bottom">
                                                                            <h5>Add Employee Allowance</h5>
                                                                            <div class="form-check form-switch">
                                                                                <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>

                                                                <div class="col-md-4">

                                                                    <div class="mb-3">
                                                                        <div class="content-head d-flex justify-content-between align-items-center">
                                                                            <label class="form-label" for="organizerSingle">Company Name</label>
                                                                            <div class="form-check form-switch">
                                                                            </div>
                                                                        </div>
                                                                        <select class="form-multi-select" id="multiple-select-tag" multiple data-coreui-selection-type="tags"
                                                                                data-coreui-search="true">
                                                                            <option value="0">Select Company...</option>
                                                                            <option value="1">CSL</option>
                                                                            <option value="2">GCTL</option>
                                                                        </select>
                                                                    </div>
                                                                </div>

                                                                <div class="col-md-4">
                                                                    <div class="mb-3">
                                                                        <div class="content-head d-flex justify-content-between align-items-center">
                                                                            <label class="form-label" for="timepicker1">Mobile/Internet Allowance</label>
                                                                            <div class="form-check form-switch">
                                                                                <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
                                                                            </div>
                                                                        </div>
                                                                        <input class="form-control" id="" type="text" placeholder="Ex: 1000 tk Monthly">
                                                                    </div>
                                                                </div>

                                                                <div class="col-md-4">
                                                                    <div class="mb-3">
                                                                        <div class="content-head d-flex justify-content-between align-items-center">
                                                                            <label class="form-label" for="timepicker1">Shift Allowance</label>
                                                                            <div class="form-check form-switch">
                                                                                <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
                                                                            </div>
                                                                        </div>
                                                                        <input class="form-control" id="" type="text" placeholder="Ex: 500 tk Per Night Shift">
                                                                    </div>
                                                                </div>

                                                                <div class="col-md-12">
                                                                    <div class="mb-3">
                                                                        <div class="content-head d-flex justify-content-between align-items-center border-bottom">
                                                                            <h5>House Rent Allowance</h5>
                                                                            <div class="form-check form-switch">
                                                                                <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>

                                                                <div class="col-lg-6 col-md-6 col-sm-12">
                                                                    <div class="mb-3">
                                                                        <label class="form-label" for="timepicker1">House Rent Allowance Rate</label>
                                                                        <select class="form-select mb-3" id="organizerSingle" data-choices="data-choices"
                                                                                data-options='{"removeItemButton":true,"placeholder":true}'>
                                                                            <option value="">Select %</option>
                                                                            <option>35 %</option>
                                                                            <option>40 %</option>
                                                                            <option>45 %</option>
                                                                            <option>50 %</option>
                                                                            <option>60 %</option>
                                                                            <option>70 %</option>
                                                                            <option>100 %</option>
                                                                        </select>
                                                                    </div>
                                                                </div>

                                                                <div class="col-lg-6 col-md-6 col-sm-12">
                                                                    <div class="mb-3">
                                                                        <label class="form-label" for="timepicker1">Allowance Depends on</label>
                                                                        <select class="form-select" id="organizerSingle" disabled data-choices="data-choices"
                                                                                data-options='{"removeItemButton":true,"placeholder":true}'>
                                                                            <option value="">Select Salary...</option>
                                                                            <option>Gross Salary</option>
                                                                            <option selected>Basic Salary</option>
                                                                        </select>
                                                                    </div>
                                                                </div>

                                                                <div class="col-md-12">
                                                                    <div class="mb-3">
                                                                        <div class="content-head d-flex justify-content-between align-items-center border-bottom">
                                                                            <h5>Medical Allowance</h5>
                                                                            <div class="form-check form-switch">
                                                                                <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>

                                                                <div class="col-lg-6 col-md-6 col-sm-12">
                                                                    <div class="mb-3">
                                                                        <label class="form-label" for="timepicker1">Medical Allowance Rate</label>
                                                                        <select class="form-select mb-3" id="organizerSingle" data-choices="data-choices"
                                                                                data-options='{"removeItemButton":true,"placeholder":true}'>
                                                                            <option value="">Select %</option>
                                                                            <option>8 %</option>
                                                                            <option>10 %</option>
                                                                            <option>15 %</option>
                                                                        </select>
                                                                    </div>
                                                                </div>

                                                                <div class="col-lg-6 col-md-6 col-sm-12">
                                                                    <div class="mb-3">
                                                                        <label class="form-label" for="timepicker1">Allowance Depends on</label>
                                                                        <select class="form-select" id="organizerSingle" data-choices="data-choices" disabled
                                                                                data-options='{"removeItemButton":true,"placeholder":true}'>
                                                                            <option value="">Select Salary...</option>
                                                                            <option>Gross Salary</option>
                                                                            <option selected>Basic Salary</option>
                                                                        </select>
                                                                    </div>
                                                                </div>

                                                                <div class="col-md-12">
                                                                    <div class="mb-3">
                                                                        <div class="content-head d-flex justify-content-between align-items-center border-bottom">
                                                                            <h5>Conveyance Allowance</h5>
                                                                            <div class="form-check form-switch">
                                                                                <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>

                                                                <div class="col-lg-6 col-md-6 col-sm-12">
                                                                    <div class="mb-3">
                                                                        <label class="form-label" for="timepicker1">Conveyance Allowance Rate</label>
                                                                        <select class="form-select mb-3" id="organizerSingle" data-choices="data-choices"
                                                                                data-options='{"removeItemButton":true,"placeholder":true}'>
                                                                            <option value="">Select %</option>
                                                                            <option>8 %</option>
                                                                            <option>10 %</option>
                                                                            <option>15 %</option>
                                                                        </select>
                                                                    </div>
                                                                </div>

                                                                <div class="col-lg-6 col-md-6 col-sm-12">
                                                                    <div class="mb-3">
                                                                        <label class="form-label" for="timepicker1">Allowance Depends on</label>
                                                                        <select class="form-select" id="organizerSingle" data-choices="data-choices" disabled
                                                                                data-options='{"removeItemButton":true,"placeholder":true}'>
                                                                            <option value="">Select Salary...</option>
                                                                            <option>Gross Salary</option>
                                                                            <option selected>Basic Salary</option>
                                                                        </select>
                                                                    </div>
                                                                </div>



                                                                <div class="col-12">
                                                                    <div class="row g-3 justify-content-end">
                                                                        <div class="col-auto">
                                                                            <button class="btn btn-phoenix-primary px-5">Cancel</button>
                                                                        </div>
                                                                        <div class="col-auto">
                                                                            <button class="btn btn-primary px-5 px-sm-15">Save</button>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </form>
                                                        </div>
                                                    </div>

                                                </div>
                                            </div>

                                        </div>



                                    </div>

                                </div>

                             

                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>



</div>