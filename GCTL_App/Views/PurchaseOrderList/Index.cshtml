
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex" id="scrollspyEcommerce">
    <span class="fa-stack me-2 ms-n1">
        <i class="fas fa-circle fa-stack-2x text-primary"></i>
        <i class="fa-inverse fa-stack-1x text-primary-subtle fas fa-shopping-cart" data-fa-transform="shrink-4"></i>
    </span>
    <div class="col">
        <h3 class="mb-0 text-primary position-relative fw-bold">
            <span class="bg-body pe-2">@Html.SmartLocalize("Purchase Order List")</span>
            <span class="border border-primary position-absolute top-50 translate-middle-y w-100 start-0 z-n1"></span>
        </h3>
    </div>
</div>

<div class="row">
    <div class="col-12 bg-body-emphasis rounded">
        <!-- Error Container -->
        <div id="errorContainer" class="mt-3" style="display: none;">
            <!-- Error messages will be displayed here -->
        </div>

        <div class="row g-3 justify-content-between align-items-end my-2">
            <div class="col-12 col-sm-auto"></div>

            <div class="col-12 col-sm-auto">
                <div class="d-flex align-items-center">
                    <div class="me-3">
                        <div class="columnDrag PurchaseOrderList"></div>
                    </div>

                    <!-- Search Input -->
                    <div class="me-3">
                        <input class="form-control" id="searchInput" type="text" placeholder="Search purchase orders...">
                    </div>

                    <!-- Page Size Selector -->
                    <div class="dropdown me-3">
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text">@Html.SmartLocalize("Showing")</span>
                            </div>
                            <select class="form-select" id="pageSizeSelect" name="pageSizeSelect">
                                <option value="5">5</option>
                                <option selected value="10">10</option>
                                <option value="25">25</option>
                                <option value="50">50</option>
                                <option value="100">100</option>
                            </select>
                        </div>
                    </div>

                    <div class="me-3">
                        <a href="/PurchaseOrder/index" class="btn btn-phoenix-primary">
                            @Html.SmartLocalize("Create Purchase Order")
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="px-4 px-lg-6">
            <div class="mb-9">
                <div id="projectSummary">
                    <!-- Table Container -->
                    <div class="table-responsive ms-n1 ps-1 scrollbar">
                        <table class="table fs-9 mb-0 border-top border-translucent dyn-tableDrag PurchaseOrderList" id="PurchaseOrderList">
                            <thead>
                                <tr>
                                    <th class="white-space-nowrap align-middle ps-0" scope="col" data-sort="PurchaseOrderID">
                                        <a href="#" class="text-decoration-none text-body sort-header" data-column="PurchaseOrderID">
                                            @Html.SmartLocalize("PO_ID")
                                            <i class="fas fa-sort" id="sort-PurchaseOrderID"></i>
                                        </a>
                                    </th>
                                    <th class="white-space-nowrap align-middle ps-0" scope="col" data-sort="POID">
                                        <a href="#" class="text-decoration-none text-body sort-header" data-column="POID">
                                            @Html.SmartLocalize("PO Number")
                                            <i class="fas fa-sort" id="sort-POID"></i>
                                        </a>
                                    </th>
                                    <th class="white-space-nowrap align-middle ps-2" scope="col" data-sort="SupplierName">
                                        <a href="#" class="text-decoration-none text-body sort-header" data-column="SupplierName">
                                            @Html.SmartLocalize("Supplier")
                                            <i class="fas fa-sort" id="sort-SupplierName"></i>
                                        </a>
                                    </th>
                                    <th class="white-space-nowrap align-middle ps-2" scope="col" data-sort="CreatedBy">
                                        <a href="#" class="text-decoration-none text-body sort-header" data-column="CreatedBy">
                                            @Html.SmartLocalize("Created By")
                                            <i class="fas fa-sort" id="sort-CreatedBy"></i>
                                        </a>
                                    </th>
                                    <th class="white-space-nowrap align-middle ps-2" scope="col" data-sort="PurchaseDate">
                                        <a href="#" class="text-decoration-none text-body sort-header" data-column="PurchaseDate">
                                            @Html.SmartLocalize("Purchase Date")
                                            <i class="fas fa-sort" id="sort-PurchaseDate"></i>
                                        </a>
                                    </th>
                                    <th class="white-space-nowrap align-middle ps-2 text-end" scope="col" data-sort="GrandTotalAmount">
                                        <a href="#" class="text-decoration-none text-body sort-header" data-column="GrandTotalAmount">
                                            @Html.SmartLocalize("Grand Total")
                                            <i class="fas fa-sort" id="sort-GrandTotalAmount"></i>
                                        </a>
                                    </th>
                                    <th class="white-space-nowrap align-middle ps-2 text-end" scope="col" data-sort="PaidAmount">
                                        <a href="#" class="text-decoration-none text-body sort-header" data-column="PaidAmount">
                                            @Html.SmartLocalize("Paid Amount")
                                            <i class="fas fa-sort" id="sort-PaidAmount"></i>
                                        </a>
                                    </th>
                                    <th class="white-space-nowrap align-middle ps-2 text-end" scope="col" data-sort="DueAmount">
                                        <a href="#" class="text-decoration-none text-body sort-header" data-column="DueAmount">
                                            @Html.SmartLocalize("Due Amount")
                                            <i class="fas fa-sort" id="sort-DueAmount"></i>
                                        </a>
                                    </th>
                                    <th class="white-space-nowrap align-middle ps-2 text-center" scope="col" data-sort="TotalItems">
                                        <a href="#" class="text-decoration-none text-body sort-header" data-column="TotalItems">
                                            @Html.SmartLocalize("Total Items")
                                            <i class="fas fa-sort" id="sort-TotalItems"></i>
                                        </a>
                                    </th>
                                    <th class="white-space-nowrap align-middle ps-2" scope="col">
                                        @Html.SmartLocalize("Status")
                                    </th>
                                    <th class="text-end white-space-nowrap pe-6" scope="col">
                                        @Html.SmartLocalize("Action")
                                    </th>
                                </tr>
                            </thead>
                            <tbody id="purchase-order-table">
                                <!-- Rows will be loaded dynamically via JS -->
                            </tbody>
                        </table>
                    </div>

                    <!-- Pagination and Showing Info -->
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <div id="showDown2" class="text-muted">
                            @Html.SmartLocalize("Showing 0 to 0 of 0")
                        </div>
                        <nav aria-label="Table pagination" class="pagination-container">
                            <ul class="pagination mb-0">
                                <li class="page-item disabled" data-list-pagination="prev">
                                    <a class="page-link" href="#">@Html.SmartLocalize("Previous")</a>
                                </li>
                                <!-- Dynamic pages will be inserted here -->
                                <li class="page-item disabled" data-list-pagination="next">
                                    <a class="page-link" href="#">@Html.SmartLocalize("Next")</a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

    <script src="~/js/pages/Purchase/PurchaseOrderList.js"></script>
}

