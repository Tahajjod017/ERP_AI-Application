@model GCTL.Core.ViewModels.Finance.OpeningBalancesVM.CreateOpeningBalancesVM

@{
    ViewData["Title"] = @Html.SmartLocalize("Opening Balance");
    var mainAccDD = ViewBag.MainAccDD as List<GCTL.Core.ViewModels.CommonSelectVM>;
}

<div class="card mt-2">
    <div class="card-header border-bottom-1">
        <div class="row justify-content-between align-items-center">
            <div class="col-auto">
                <h4 class="text-body-emphasis mt-2">@Html.SmartLocalize("Add Opening Balance")</h4>
            </div>
        </div>
    </div>

    <div class="card-body mt-1">
        <form asp-action="Create" asp-controller="OpeningBalance" method="post" enctype="multipart/form-data" id="openingBalance-form">
            @Html.AntiForgeryToken()
            <div class="row">
                <input type="hidden" asp-for="OpeningBalanceID" />

                <div class="col-md-4">
                    <div class="mb-3">
                        <label class="form-label" asp-for="OpeningBalanceCode">@Html.SmartLocalize("Opening Balance Code") <span style="color: red;">*</span></label>
                        <input class="form-control bg-light" asp-for="OpeningBalanceCode" type="text" readonly />
                        <span id="OpeningBalanceCodeError" class="text-danger" style="display:none;"></span>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="mb-3">
                        <label class="form-label" asp-for="MainAccountID">@Html.SmartLocalize("Main Account") <span style="color: red;">*</span></label>
                        <select class="form-select" asp-for="MainAccountID">
                            <option value="">@Html.SmartLocalize("Select Main Account")...</option>
                            @foreach (var group in mainAccDD.GroupBy(e => e.GroupName))
                            {
                                <optgroup label="@group.Key">
                                    @foreach (var emp in group)
                                    {
                                        <option value="@emp.Id">@emp.Name</option>
                                    }
                                </optgroup>
                            }
                        </select>
                        <span asp-validation-for="MainAccountID" id="MainAccountIDError" class="text-danger" style="display:none;"></span>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="mb-3">
                        <label class="form-label" asp-for="SubAccountID">@Html.SmartLocalize("Sub Account") <span style="color: red;">*</span></label>
                        <select class="form-select" asp-for="SubAccountID">
                            <option value="">@Html.SmartLocalize("Select Sub Account")...</option>
                        </select>
                        <span asp-validation-for="SubAccountID" id="SubAccountIDError" class="text-danger" style="display:none;"></span>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="mb-3">
                        <label class="form-label" asp-for="TrxAccID">@Html.SmartLocalize("Transaction Account") <span style="color: red;">*</span></label>
                        <select class="form-select" asp-for="TrxAccID">
                            <option value="">@Html.SmartLocalize("Select Transaction Account")</option>
                        </select>
                        <span asp-validation-for="TrxAccID" id="TrxAccIDError" class="text-danger" style="display:none;"></span>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="mb-3">
                        <label class="form-label" asp-for="TrxType">@Html.SmartLocalize("Transaction Type") <span style="color: red;">*</span></label>
                        <select class="form-select" asp-for="TrxType">
                            <option value="">@Html.SmartLocalize("Select Transaction Type")...</option>
                            <option value="D">Debit</option>
                            <option value="C">Credit</option>
                        </select>
                        <span asp-validation-for="TrxType" id="TrxTypeError" class="text-danger" style="display:none;"></span>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="mb-3">
                        <label class="form-label" asp-for="Amount">@Html.SmartLocalize("Amount") <span style="color: red;">*</span></label>
                        <input class="form-control" asp-for="Amount" type="number" placeholder="@Html.SmartLocalize("Amount")" autocomplete="off" />
                        <span id="AmountError" class="text-danger" style="display:none;"></span>
                    </div>
                </div>

                <div class="col-md-12">
                    <div class="mb-3">
                        <label class="form-label" asp-for="Description">@Html.SmartLocalize("Description")</label>
                        <textarea class="form-control" asp-for="Description" rows="2" placeholder="@Html.SmartLocalize("Description")"></textarea>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-12 mb-2">
                    <div class="row g-3 justify-content-end">
                        <div class="col-auto">
                            <button type="reset" class="btn btn-phoenix-primary px-5" id="openingBalance-resetBtn">@Html.SmartLocalize("Reset")</button>
                        </div>
                        <div class="col-auto">
                            <button type="submit" class="btn btn-primary px-5 px-sm-15" id="openingBalance-saveBtn">@Html.SmartLocalize("Save")</button>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card mt-2 mb-2">
    <div class="card-header border-bottom-1">
        <div class="row justify-content-between align-items-center">
            <div class="col-auto">
                <h4 class="text-body-emphasis mt-3">@Html.SmartLocalize("Information of Opening Balance")</h4>
            </div>
        </div>
    </div>

    <div class="card-body">
        <div class="mx-n4 px-4 mx-lg-n6 px-lg-6 bg-body-emphasis py-5 border-y">
            <div class="row g-3 justify-content-between align-items-end mb-4">
                <div class="col-12 col-sm-auto">
                    <div class="d-flex align-items-center me-3" style="width: auto;">
                        <span class="ms-2">@Html.SmartLocalize("Showing"):</span> &nbsp;
                        <div style="width: 100%;">
                            <select id="openingBalance-pageSizeSelect" class="form-select form-select-sm" tabindex="10">
                                <option class="dropdown-item" value="5">@Html.SmartLocalize("5")</option>
                                <option class="dropdown-item" value="10">@Html.SmartLocalize("10")</option>
                                <option class="dropdown-item" value="25">@Html.SmartLocalize("25")</option>
                                <option class="dropdown-item" value="50">@Html.SmartLocalize("50")</option>
                                <option class="dropdown-item" value="100">@Html.SmartLocalize("100")</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-sm-auto">
                    <div class="d-flex align-items-center">
                        <div class="d-none me-3" id="openingBalance-bulkSelectActions">
                            <div class="position-relative">
                                <button type="button" class="btn btn-phoenix-danger btn-sm ms-2" id="openingBalance-delSel">@Html.SmartLocalize("Delete")</button>
                            </div>
                        </div>

                        <div class="search-box me-3" id="openingBalance-searchBox">
                            <form class="position-relative" id="openingBalance-searchForm">
                                <input class="form-control search-input search" id="openingBalance-searchInput" type="search" placeholder="@Html.SmartLocalize("Search here")" aria-label="Search" />
                                <span class="fas fa-search search-box-icon"></span>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <div class="table-responsive ms-n1 ps-1 scrollbar">
                <table class="table fs-9 mb-0 border-top border-translucent">
                    <thead>
                        <tr>
                            <th class="text-center text-middle align-middle ps-0" scope="col" style="width: 5%;">
                                <input type="checkbox" class="form-check-input" id="openingBalance-check-all" />
                            </th>
                            <th class="text-center text-middle align-middle ps-0" scope="col" style="width: 10%;">@Html.SmartLocalize("Sl. No")</th>
                            <th class="sort white-space-nowrap align-middle ps-0" scope="col" data-sort="openingBalanceName">@Html.SmartLocalize("Opening Balance Code")</th>
                            <th class="white-space-nowrap align-middle ps-0" scope="col" style="width: 10%;">@Html.SmartLocalize("Action")</th>
                        </tr>
                    </thead>
                    <tbody id="openingBalance-tBody">
                    </tbody>
                </table>
            </div>

            <div class="d-flex flex-wrap align-items-center justify-content-between py-3 pe-0 fs-9 border-bottom border-translucent">
                <div class="d-flex">
                    <p class="mb-0 d-none d-sm-block me-3 fw-semibold text-body" id="openingBalance-paginationInfo"></p>
                    <p class="mb-0 d-none d-sm-block me-3 fw-semibold text-body" data-list-info="data-list-info"></p>
                </div>
                <div class="d-flex">
                    <button class="page-link" data-list-pagination="prev" id="openingBalance-prevPageBtn"><span class="fas fa-chevron-left"></span></button>
                    <ul class="mb-0 pagination" id="openingBalance-paginationLinks"></ul>
                    <button class="page-link pe-0" data-list-pagination="next" id="openingBalance-nextPageBtn"><span class="fas fa-chevron-right"></span></button>
                </div>
            </div>
        </div>
    </div>
</div>

<partial name="_ConfirmDelete" />

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script src="~/js/pages/finance/openingbalance.js"></script>
    <script>
        $(function () {
            $.openingbalance({
                baseUrl: '@Url.Action("", "OpeningBalance")'
            });
        });
    </script>
}