<style>
    svg:not(:host).svg-inline--fa, svg:not(:root).svg-inline--fa {
       
        padding-right: 3px;
    }
</style>


<div class="container-fluid">
    <div class="row">
        <!-- Left side: User Create -->
        <div class="col-lg-5 mb-4">
            <div class="card p-4 shadow-sm h-100">
                <div class="card-body">
                    <h5 class="fw-bold mb-4 text-primary">Create Multiple Users</h5>

                    <form id="multiUserForm">
                        <div id="userInputsContainer" class="row g-3"></div>

                        <div class="d-flex justify-content-between mt-4">
                            <button type="button" class="btn btn-outline-primary" id="addNewUserBlock">
                                <i class="fas fa-plus me-2"></i>Add Another User
                            </button>

                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-2"></i>Create User
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Right side: User List Datatable -->
        <div class="col-lg-7">
            <div class="card">
                <div class="card-header border-bottom-1">
                    <div class="d-flex justify-content-between align-items-center">
                        <h3 class="text-body-emphasis m-0">User List</h3>
                        @if (ViewBag.CanExportPermission == true)
                        {
                            <div class="dropdown text-end">
                                <button type="button" class="btn btn-phoenix-secondary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                                    Export <i class="fa-solid fa-file-export"></i>
                                </button>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" id="export-pdf-btn"><span data-feather="download"></span> PDF</a></li>
                                    <li><a class="dropdown-item" href="javascript:void(0);" id="exportToExcelButton"><span data-feather="download"></span> Excel</a></li>
                                </ul>
                            </div>
                        }
                        
                    </div>
                </div>


                <div class="card-body py-0 scrollbar to-do-list-body">

                    <div class="mx-n4 px-4 mx-lg-n6 px-lg-6 bg-body-emphasis py-5 border-y">

                        <div class="row g-3 justify-content-between align-items-end mb-4">

                            <div class="col-12 col-sm-auto">
                                <div class="dropdown me-3">
                                    <button class="btn btn-phoenix-secondary dropdown-toggle" type="button" id="userList-pageSizeDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                        <ul class="dropdown-menu" aria-labelledby="userList-pageSizeDropdown">
                                            <li><a class="dropdown-item" href="#" data-size="5">5</a></li>
                                            <li><a class="dropdown-item" href="#" data-size="10">10</a></li>
                                            <li><a class="dropdown-item" href="#" data-size="25">25</a></li>
                                            <li><a class="dropdown-item" href="#" data-size="50">50</a></li>
                                            <li><a class="dropdown-item" href="#" data-size="100">100</a></li>
                                        </ul> Showing: <span id="selectedPageSize">5</span>
                                    </button>

                                </div>

                            </div>

                            <div class="col-12 col-sm-auto">
                                <div class="d-flex align-items-center">
                                    <div class="d-none me-3" id="userList-bulkSelectActions">
                                        <div class="position-relative">
                                            <button type="button" class="btn btn-phoenix-danger btn-sm ms-2" id="userList-delSel">Delete</button>
                                        </div>
                                    </div>

                                    <div class="search-box me-3" id="userList-searchBox">
                                        <form class="position-relative" id="searchForm">
                                            <input class="form-control search-input search" id="userList-searchInput" type="search" placeholder="Search here" aria-label="Search" />
                                            <span class="fas fa-search search-box-icon"></span>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="table-responsive ms-n1 ps-1 scrollbar">
                            <table class="table fs-9 mb-0 border-top border-translucent table-striped table-hover">
                                <thead>
                                    <tr>
                                        @* <th class="text-center text-middle align-middle ps-0" scope="col" style="width: 5%;">
                                <input type="checkbox" id="userList-check-all" />
                            </th> *@
                                        <th class="sort white-space-nowrap align-middle ps-2" scope="col" data-sort="employeeCode">Employee Code</th>
                                        <th class="sort white-space-nowrap align-middle ps-0" scope="col" data-sort="userName">Employee Name</th>
                                        <th class="sort white-space-nowrap align-middle ps-0" scope="col" data-sort="userName">Employee Email</th>
                                        <th class="sort white-space-nowrap align-middle ps-0" scope="col" data-sort="userName">Default Pass</th>
                                        <th class="sort align-middle text-start" scope="col">Action</th>
                                    </tr>
                                </thead>
                                <tbody id="userList-tBody">
                                    <!-- User list will be loaded here dynamically -->
                                </tbody>
                            </table>
                        </div>

                        <div class="d-flex flex-wrap align-items-center justify-content-between py-3 pe-0 fs-9 border-bottom border-translucent">
                            <div class="d-flex">
                                <p class="mb-0 d-none d-sm-block me-3 fw-semibold text-body" id="userList-paginationInfo"></p>
                                <p class="mb-0 d-none d-sm-block me-3 fw-semibold text-body" data-list-info="data-list-info"></p>
                            </div>

                            <div class="d-flex">
                                <button class="page-link" data-list-pagination="prev" id="userList-prevPageBtn"><span class="fas fa-chevron-left"></span></button>
                                <ul class="mb-0 pagination" id="paginationLinks"></ul>
                                <button class="page-link pe-0" data-list-pagination="next" id="userList-nextPageBtn"><span class="fas fa-chevron-right"></span></button>
                            </div>

                        </div>
                    </div>
                </div>
                <div class="card-footer  mb-2"></div>
            </div>
        </div>

    </div>
</div>

<partial name="_ConfirmResetPass" />
<partial name="_ConfirmDelete" />
<partial name="_ConfirmActiveStatusMessg" />
<partial name="_ConfirmInActiveStatusMessg" />

