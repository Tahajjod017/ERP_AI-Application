@using GCTL.Core.ViewModels.POS.Purchase.Rfq
@model RfqViewModel
@{
    ViewData["Title"] = Html.SmartLocalize("Request for Quotation");
}

<link href="~/css/other/multidd.css" rel="stylesheet" />
<style>
    .drag-handle {
        cursor: move;
        color: #6c757d;
    }

    .star {
        color: #f0ad4e;
        font-size: 1.5rem;
        cursor: pointer;
    }

    .best-offer {
        border: 2px solid #198754 !important;
        background: #f8fff8;
    }

    .status-btn {
        padding: 6px 20px;
        border: 1px solid #dee2e6;
        background: #fff;
        color: #666;
        border-radius: 3px;
        cursor: pointer;
        font-size: 13px;
        transition: all 0.2s;
    }

        .status-btn.active {
            background: #875a7b;
            color: white;
            border-color: #875a7b;
        }

    .add-line-btns {
        display: flex;
        gap: 20px;
        margin: 20px 0;
        padding-left: 10px;
    }

    .add-line-btn {
        color: #875a7b;
        background: none;
        border: none;
        cursor: pointer;
        font-size: 13px;
        padding: 8px 0;
    }

        .add-line-btn:hover {
            text-decoration: underline;
        }

</style>

<div class="container-fluid py-3">

    <form asp-action="Save" method="post" id="rfqForm">
        <input asp-for="Id" type="hidden" />

        <!-- Action Bar -->
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="btn-group">
                <button type="button" class="status-btn active me-2" onclick="saveRFQ()">
                    <i class="fas fa-save me-1"></i> Save
                </button>
                <button type="button" class="status-btn " onclick="discardRFQ()">Discard</button>
            </div>

            <div class="btn-group">
                <button type="button" class="status-btn me-2" id="sendEmailBtn">
                    <i class="fas fa-envelope me-1"></i>Email
                </button>
                <button type="button" class="status-btn me-2" onclick="printRFQ()">
                    <i class="fas fa-print me-1"></i>Print
                </button>
                <button type="button" class="status-btn me-2" onclick="confirmOrder()">
                    <i class="fas fa-check-circle me-1"></i>Confirm
                </button>
                <button type="button" class="status-btn me-2" onclick="cancelRFQ()">
                    <i class="fas fa-times-circle me-1"></i>Cancel
                </button>
            </div>
        </div>

        <!-- RFQ Card -->
        <div class="card shadow-sm mb-4">
            <div class="card-header d-flex align-items-center gap-3">
                <span class="star" onclick="toggleStar()">☆</span>
                <h5 class="mb-0">@Html.SmartLocalize("New Request for Quotation")</h5>
            </div>

            <div class="card-body">

                <!-- Form Grid -->
                <div class="row g-3">

                    <div class="col-md-4">
                        <label class="form-label">@Html.SmartLocalize("Vendor")</label>
                        <select asp-for="SelectedVendorId"
                                asp-items="ViewBag.Vendors as SelectList"
                                class="form-select multiDD" multiple></select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">@Html.SmartLocalize("Order Deadline")</label>
                        <input asp-for="OrderDeadline" type="datetime-local" class="form-control datetimepicker caiCon" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">@Html.SmartLocalize("Vendor Reference")</label>
                        <input asp-for="VendorReference" class="form-control" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">@Html.SmartLocalize("Expected Arrival")</label>
                        <input asp-for="ExpectedArrival" type="datetime-local" class="form-control datetimepicker caiCon" />
                    </div>

                    <div class="col-md-4 d-flex align-items-center gap-2">
                        <input asp-for="AskConfirmation" class="form-check-input" type="checkbox" />
                        <label class="form-check-label">@Html.SmartLocalize("Ask confirmation")</label>
                        <input asp-for="ConfirmationDays" class="form-control w-auto" type="number" min="1" />
                        <span>@Html.SmartLocalize("day(s) before")</span>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">@Html.SmartLocalize("Currency")</label>
                        <select asp-for="Currency" class="form-select">
                            <option>USD</option>
                            <option>EUR</option>
                            <option>GBP</option>
                            <option>BDT</option>
                        </select>
                    </div>

                </div>


            </div>
        </div>

        <!-- Tabs -->
        <ul class="nav nav-tabs mb-3">
            <li class="nav-item">
                <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#productsTab">
                    Products
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#alternativesTab">
                    Alternatives
                </button>
            </li>
        </ul>

        <div class="tab-content">

            <!-- PRODUCTS TAB -->
            <div class="tab-pane fade show active" id="productsTab">

                <div class="table-responsive">
                    <table class="table table-bordered table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th></th>
                                <th>Product</th>
                                <th>Description</th>
                                <th class="text-center">Qty</th>
                                <th>UoM</th>
                                <th class="text-end">Unit Price</th>
                                <th class="text-end">Subtotal</th>
                                <th></th>
                            </tr>
                        </thead>

                        <tbody id="productTableBody">
                            @for (int i = 0; i < Model.Items.Count; i++)
                            {
                                <tr draggable="true">
                                    <td class="drag-handle text-center"><i class="fas fa-grip-vertical"></i></td>

                                    <td>@Model.Items[i].ProductName</td>

                                    <td>
                                        <input name="Items[@i].Description" value="@Model.Items[i].Description" class="form-control" />
                                    </td>

                                    <td>
                                        <input name="Items[@i].Quantity" value="@Model.Items[i].Quantity"
                                               class="form-control text-center calc" type="number" />
                                    </td>

                                    <td>
                                        <select name="Items[@i].Uom" class="form-select">
                                            <option>Units</option>
                                            <option>kg</option>
                                            <option>Dozens</option>
                                        </select>
                                    </td>

                                    <td>
                                        <input name="Items[@i].UnitPrice" value="@Model.Items[i].UnitPrice"
                                               class="form-control text-end calc" type="number" />
                                    </td>

                                    <td class="text-end">@Model.Items[i].Subtotal.ToString("C2")</td>

                                    <td class="text-center">
                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteRow(this)">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Add Line Buttons -->
                <div class="add-line-btns">
                    <button type="button" class="add-line-btn" onclick="addProductLine()">
                        <i class="fas fa-plus-circle me-2"></i>@Html.SmartLocalize("Add a product")
                    </button>
                    <button type="button" class="add-line-btn" onclick="addSection()">
                        <i class="fas fa-minus me-2"></i>@Html.SmartLocalize("Add a section")
                    </button>
                    <button type="button" class="add-line-btn" onclick="addNote()">
                        <i class="fas fa-sticky-note me-2"></i>@Html.SmartLocalize("Add a note")
                    </button>
                </div>

                <!-- Terms -->
                <div class="mt-4">
                    <label class="form-label">@Html.SmartLocalize("Terms and Conditions")</label>
                    <textarea asp-for="TermsAndConditions" class="form-control" rows="4"></textarea>
                </div>

                <!-- Totals -->
                <div class="mt-4 d-flex justify-content-end">
                    <div class="border rounded p-3 w-25">
                        <div class="d-flex justify-content-between">
                            <span>Untaxed</span>
                            <span id="untaxedAmount">@Model.UntaxedAmount.ToString("C2")</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span>Tax</span>
                            <span id="taxAmount">@Model.TaxAmount.ToString("C2")</span>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between fw-bold">
                            <span>Total</span>
                            <span id="grandTotal">@Model.TotalAmount.ToString("C2")</span>
                        </div>
                    </div>
                </div>

            </div>

            <!-- ALTERNATIVES TAB -->
            <div class="tab-pane fade" id="alternativesTab">

                <div class="card mt-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-3">
                            <h5>Alternative RFQs</h5>
                            <button class="btn btn-primary">+ Create Alternative</button>
                        </div>

                        @foreach (var alt in Model.AlternativeRfqs)
                        {
                            <div class="border rounded p-3 mb-2 d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>@alt.Reference</strong> - @alt.VendorName<br />
                                    <small>@alt.TotalAmount.ToString("C2") | @alt.Status</small>
                                </div>
                                <div class="btn-group">
                                    <button class="btn btn-sm btn-outline-secondary">View</button>
                                    <button class="btn btn-sm btn-outline-primary">Edit</button>
                                    <button class="btn btn-sm btn-outline-danger">Delete</button>
                                </div>
                            </div>
                        }

                        <button class="btn btn-success mt-3 float-end">
                            <i class="fas fa-balance-scale me-1"></i>Compare
                        </button>

                    </div>
                </div>

            </div>

        </div>

    </form>
</div>


<!-- All your existing modals – REPLACED with pure Bootstrap 5 structure (minimal, no custom classes needed) -->
<!-- Create Alternative RFQ Modal -->
<div class="modal fade" id="createAlternativeModal" tabindex="-1" aria-labelledby="createAlternativeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="createAlternativeModalLabel">Create Alternative RFQ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="form-group mb-3">
                    <label>Select Vendor</label>
                    <select id="alternativeVendor" class="form-select" asp-items="ViewBag.Vendors as SelectList">
                        <option value="">-- Select Vendor --</option>
                    </select>
                </div>
                <div class="form-group mb-3">
                    <label>Alternative Reference</label>
                    <input type="text" id="alternativeReference" class="form-control" value="ALT001" readonly />
                </div>
                <div class="alert alert-info">
                    <i class="fas fa-info-circle me-2"></i>
                    This alternative RFQ will contain all products from the main RFQ. You can edit prices and quantities after creation.
                </div>
                <div class="mt-3">
                    <h6>Products to include:</h6>
                    <ul id="productPreviewList" class="list-unstyled"></ul>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="createAlternativeRfq()">Create Alternative RFQ</button>
            </div>
        </div>
    </div>
</div>

<!-- View Alternative RFQ Modal -->
<div class="modal fade" id="viewAlternativeModal" tabindex="-1" aria-labelledby="viewAlternativeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="viewAlternativeModalLabel">View Alternative RFQ - <span id="viewAltReference"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row mb-4">
                    <div class="col-md-6">
                        <p><strong>Vendor:</strong> <span id="viewAltVendor"></span></p>
                        <p><strong>Date:</strong> <span id="viewAltDate"></span></p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>Status:</strong> <span id="viewAltStatus"></span></p>
                        <p><strong>Total Amount:</strong> <span id="viewAltTotal"></span></p>
                    </div>
                </div>
                <table class="table table-bordered product-table">
                    <thead class="table-light">
                        <tr>
                            <th>Product</th>
                            <th>Quantity</th>
                            <th>Unit Price</th>
                            <th>Tax</th>
                            <th>Subtotal</th>
                        </tr>
                    </thead>
                    <tbody id="viewAltProductsTable"></tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" onclick="useThisAlternative()">Use This Alternative</button>
            </div>
        </div>
    </div>
</div>

<!-- Edit Alternative RFQ Modal -->
<div class="modal fade" id="editAlternativeModal" tabindex="-1" aria-labelledby="editAlternativeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editAlternativeModalLabel">Edit Alternative RFQ - <span id="editAltReference"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="form-group mb-3">
                    <label>Vendor</label>
                    <select id="editAltVendor" class="form-select" asp-items="ViewBag.Vendors as SelectList">
                        <option value="">-- Select Vendor --</option>
                    </select>
                </div>
                <table class="table table-bordered product-table">
                    <thead class="table-light">
                        <tr>
                            <th>Product</th>
                            <th>Quantity</th>
                            <th>Unit Price</th>
                            <th>Tax</th>
                            <th>Subtotal</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="editAltProductsTable"></tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveAlternativeRfq()">Save Changes</button>
            </div>
        </div>
    </div>
</div>

<!-- Comparison View Modal -->
<div class="modal fade" id="comparisonModal" tabindex="-1" aria-labelledby="comparisonModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="comparisonModalLabel">Compare Product Lines - Alternative RFQs</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="comparisonTableContainer">
                    <!-- Table will be injected by JS -->
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" onclick="selectBestOffers()">Select Best Offers</button>
            </div>
        </div>
    </div>
</div>

<!-- Email Modal (already working – kept almost identical but standardized) -->
<div class="modal fade" id="emailModal" tabindex="-1" aria-labelledby="emailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="emailModalLabel">Compose Email</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Recipients</label>
                    <select id="emailRecipients" class="form-select">
                        <option>Vendor</option>
                        <option>Multiple Recipients</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Subject</label>
                    <input type="text" id="emailSubject" class="form-control" value="Request for Quotation (Ref: @Model.RfqNumber)" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Message</label>
                    <textarea id="emailBody" class="form-control" rows="8">
Dear Vendor,
Here is in attachment a request for quotation @Model.RfqNumber from our company.
Please provide your best quotation for the items listed below. We expect your response by @Model.OrderDeadline.ToString("dd MMM yyyy").
If you have any questions, please do not hesitate to contact us.
Best regards,
My Company
                    </textarea>
                </div>
                <div class="p-3 bg-light border rounded">
                    <i class="fas fa-paperclip me-2"></i>
                    <span>RFQ_@(Model.RfqNumber).pdf</span>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="sendEmail">SEND EMAIL</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script src="~/js/layout/other/multidd.js"></script>
    <script src="~/js/pages/pos/rfq/rfq.js"></script>
    <script>

    </script>
}