@using GCTL.Core.ViewModels.POS.Purchase.Rfq
@model RfqViewModel
@{
    ViewData["Title"] = Html.SmartLocalize("Request for Quotation");
}

<link href="~/../Views/Rfq/Rfq.css" rel="stylesheet" />

<div class="rfq-container">
    <form asp-action="Save" method="post" id="rfqForm">
        <input asp-for="Id" type="hidden" />

        <!-- Action Buttons -->
        <div class="action-bar mb-4">
            <button type="button" class="btn btn-phoenix-primary" onclick="saveRFQ()">
                <i class="fas fa-save me-2"></i>SAVE
            </button>
            <button type="button" class="btn btn-phoenix-secondary" onclick="discardRFQ()">
                DISCARD
            </button>
        </div>

        <div class="d-flex justify-content-between">

            <div class="action-bar ">
                <button type="button" class="btn btn-phoenix-warning" id="sendEmailBtn">
                    <i class="fas fa-envelope me-2"></i>SEND BY EMAIL
                </button>
                <button type="button" class="btn btn-phoenix-info" onclick="printRFQ()">
                    <i class="fas fa-print me-2"></i>PRINT RFQ
                </button>
                <button type="button" class="btn btn-phoenix-success" onclick="confirmOrder()">
                    <i class="fas fa-check-circle me-2"></i>CONFIRM ORDER
                </button>
                <button type="button" class="btn btn-phoenix-danger" onclick="cancelRFQ()">
                    <i class="fas fa-times-circle me-2"></i>CANCEL
                </button>
            </div>

            <!-- Status Bar -->
            <div class="status-bar">
                <button type="button" class="status-btn @(Model.Status == "RFQ" ? "active" : "")" onclick="changeStatus('RFQ')">RFQ</button>
                <button type="button" class="status-btn @(Model.Status == "RFQ_SENT" ? "active" : "")" onclick="changeStatus('RFQ_SENT')">RFQ SENT</button>
                <button type="button" class="status-btn @(Model.Status == "PURCHASE_ORDER" ? "active" : "")" onclick="changeStatus('PURCHASE_ORDER')">PURCHASE ORDER</button>
            </div>

        </div>


        

        <!-- Form Card -->
        <div class="form-card">
            <div class="form-header">
                <span class="star" onclick="toggleStar()">☆</span>
                <h2>@Html.SmartLocalize("New Request for Quotation")</h2>
            </div>

            <!-- Form Fields -->
            <div class="form-grid">
                <!-- Vendor Selection -->
                <div class="form-group with-icon">
                    <label>@Html.SmartLocalize("Vendor")</label>
                    <select asp-for="SelectedVendorId"
                            asp-items="ViewBag.Vendors as SelectList"
                            class="form-select searchableSelect"
                            onchange="onVendorChange()">
                        <option value="">@Html.SmartLocalize("-- Select Vendor --")</option>
                    </select>
                    <button type="button" class="search-icon" onclick="openVendorSearchModal()">
                        <i class="fas fa-search"></i>
                    </button>
                </div>

                <!-- Order Deadline -->
                <div class="form-group">
                    <label>@Html.SmartLocalize("Order Deadline")</label>
                    <input asp-for="OrderDeadline" type="datetime-local" class="form-control datetimepicker caiCon" />
                </div>

                <!-- Vendor Reference -->
                <div class="form-group">
                    <label>@Html.SmartLocalize("Vendor Reference")</label>
                    <input asp-for="VendorReference" class="form-control" placeholder="Vendor's reference number" />
                </div>

                <!-- Expected Arrival -->
                <div class="form-group">
                    <label>@Html.SmartLocalize("Expected Arrival")</label>
                    <input asp-for="ExpectedArrival" type="datetime-local" class="form-control datetimepicker caiCon" />
                </div>

                <!-- Purchase Agreement -->
               @*   <div class="form-group">
                     <label>@Html.SmartLocalize("Purchase Agreement")</label>
                     <select asp-for="PurchaseAgreement"
                             asp-items="ViewBag.PurchaseAgreements as SelectList"
                             class="form-select">
                         <option value="">@Html.SmartLocalize("-- Select --")</option>
                     </select>
                 </div> *@

                <!-- Ask Confirmation -->
                <div class="form-group">
                    <div class="form-check">
                        <input asp-for="AskConfirmation" class="form-check-input" type="checkbox" />
                        <label class="form-check-label" for="AskConfirmation">
                            @Html.SmartLocalize("Ask confirmation 1 day(s) before")
                        </label>
                    </div>
                </div>

                <!-- Currency -->
                <div class="form-group with-icon">
                    <label>@Html.SmartLocalize("Currency")</label>
                    <select asp-for="Currency" class="form-select">
                        <option value="USD">USD</option>
                        <option value="EUR">EUR</option>
                        <option value="GBP">GBP</option>
                        <option value="BDT">BDT</option>
                    </select>
                    <button type="button" class="search-icon" onclick="openCurrencySearchModal()">
                        <i class="fas fa-search"></i>
                    </button>
                </div>

                <!-- RFQ Number & Date -->
               @*   <div class="form-group">
                     <label>@Html.SmartLocalize("RFQ Number")</label>
                     <input asp-for="RfqNumber" class="form-control" readonly />
                 </div>

                 <div class="form-group">
                     <label>@Html.SmartLocalize("RFQ Date")</label>
                     <input asp-for="RfqDate" type="datetime-local" class="form-control datetimepicker caiCon" />
                 </div> *@
            </div>

            <!-- Tabs -->
            <div class="tabs">
                <button type="button" class="tab active" onclick="showTab('products')">@Html.SmartLocalize("Products")</button>
                <button type="button" class="tab" onclick="showTab('alternatives')">@Html.SmartLocalize("Alternatives")</button>
            </div>

            <!-- Products Tab -->
            <div id="products-tab" class="tab-content" style="display: block;">
                <!-- Products Table -->
                <table class="product-table">
                    <thead>
                        <tr>
                            <th style="width: 5%"></th>
                            <th style="width: 25%">@Html.SmartLocalize("Product")</th>
                            <th style="width: 25%">@Html.SmartLocalize("Description")</th>
                            <th style="width: 10%">@Html.SmartLocalize("Quantity")</th>
                            <th style="width: 10%">@Html.SmartLocalize("UoM")</th>
                            <th style="width: 12%">@Html.SmartLocalize("Unit Price")</th>
                           @*   <th style="width: 10%">@Html.SmartLocalize("Taxes")</th> *@
                            <th style="width: 12%">@Html.SmartLocalize("Subtotal")</th>
                            <th style="width: 3%"></th>
                        </tr>
                    </thead>
                    <tbody id="productTableBody">
                        @for (int i = 0; i < Model.Items.Count; i++)
                        {
                            var item = Model.Items[i];
                            <tr class="item-row" draggable="true">
                                <td class="drag-handle">
                                    <i class="fas fa-grip-vertical"></i>
                                </td>
                                <td>
                                    @if (!item.IsSection && !item.IsNote)
                                    {
                                        <input type="hidden" name="Items[@i].ProductId" value="@item.ProductId" />
                                        <div class="product-name-display">@item.ProductName</div>
                                    }
                                    else if (item.IsSection)
                                    {
                                        <input type="text" name="Items[@i].SectionTitle" class="form-control" value="@item.SectionTitle" placeholder="Section title..." />
                                    }
                                </td>
                                <td>
                                    @if (!item.IsSection && !item.IsNote)
                                    {
                                        <input type="text" name="Items[@i].Description" class="form-control" value="@item.Description" />
                                    }
                                    else if (item.IsNote)
                                    {
                                        <textarea name="Items[@i].NoteText" class="form-control" rows="2" placeholder="Note...">@item.NoteText</textarea>
                                    }
                                </td>
                                <td>
                                    @if (!item.IsSection && !item.IsNote)
                                    {
                                        <input type="number" name="Items[@i].Quantity" class="form-control text-center calc quantity" value="@item.Quantity" step="0.01" />
                                    }
                                </td>
                                <td>
                                    @if (!item.IsSection && !item.IsNote)
                                    {
                                        <select name="Items[@i].Uom" class="form-select">
                                            <option value="Units" selected="@(item.Uom == "Units")">Units</option>
                                            <option value="kg" selected="@(item.Uom == "kg")">kg</option>
                                            <option value="Dozens" selected="@(item.Uom == "Dozens")">Dozens</option>
                                            <option value="Hours" selected="@(item.Uom == "Hours")">Hours</option>
                                        </select>
                                    }
                                </td>
                                <td>
                                    @if (!item.IsSection && !item.IsNote)
                                    {
                                        <input type="number" name="Items[@i].UnitPrice" class="form-control text-end calc unit-price" value="@item.UnitPrice" step="0.01" />
                                    }
                                </td>
                               @*  <td>
                                    @if (!item.IsSection && !item.IsNote)
                                    {
                                        <select name="Items[@i].TaxRate" class="form-select calc tax-select">
                                            <option value="0.15" selected="@(item.TaxRate == 0.15m)">Purchase Tax 15%</option>
                                            <option value="0" selected="@(item.TaxRate == 0)">No Tax</option>
                                        </select>
                                    }
                                </td> *@
                                <td class="text-end subtotal">
                                    @if (!item.IsSection && !item.IsNote)
                                    {
                                        <span>@item.Subtotal.ToString("C2")</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteRow(this)">
                                        <i class="far fa-trash-alt"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <!-- Add Line Buttons -->
                <div class="add-line-btns">
                    <button type="button" class="add-line-btn" onclick="addProductLine()">
                        <i class="fas fa-plus-circle me-2"></i>@Html.SmartLocalize("Add a product")
                    </button>
                    <button type="button" class="add-line-btn" onclick="addSection()">
                        <i class="fas fa-minus me-2"></i>@Html.SmartLocalize("Add a section")
                    </button>
                    <button type="button" class="add-line-btn" onclick="addNote()">
                        <i class="fas fa-sticky-note me-2"></i>@Html.SmartLocalize("Add a note")
                    </button>
                </div>

                <!-- Terms and Conditions -->
                <div class="terms-section mt-4">
                    <label>@Html.SmartLocalize("Terms and Conditions")</label>
                    <textarea asp-for="TermsAndConditions" class="form-control" rows="4" placeholder="Define your terms and conditions..."></textarea>
                </div>

                <!-- Totals -->
                <div class="totals-section">
                    <div class="totals">
                        <div class="total-row">
                            <span>@Html.SmartLocalize("Untaxed Amount"):</span>
                            <span id="untaxedAmount">@Model.UntaxedAmount.ToString("C2")</span>
                        </div>
                        <div class="total-row">
                            <span>@Html.SmartLocalize("Tax"):</span>
                            <span id="taxAmount">@Model.TaxAmount.ToString("C2")</span>
                        </div>
                        <div class="total-row grand-total">
                            <span>@Html.SmartLocalize("Total"):</span>
                            <span id="grandTotal">@Model.TotalAmount.ToString("C2")</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Alternatives Tab -->
            <div id="alternatives-tab" class="tab-content" style="display: none;">
                <div class="alternative-rfq-section">
                    <div class="alternative-rfq-header">
                        <h3>@Html.SmartLocalize("Alternative Requests for Quotation")</h3>
                        <button type="button" class="btn btn-phoenix-primary" id="createAlternativeBtn">
                            <i class="fas fa-plus me-2"></i>@Html.SmartLocalize("Create Alternative")
                        </button>
                    </div>

                    <div class="alternative-rfq-list" id="alternativeRFQList">
                        @foreach (var alt in Model.AlternativeRfqs)
                        {
                            <div class="rfq-item" data-id="@alt.Id">
                                <div class="rfq-item-info">
                                    <h4>@alt.Reference - @alt.VendorName</h4>
                                    <p>Date: @alt.Date.ToString("dd MMM yyyy") | Total: @alt.TotalAmount.ToString("C2") | Status: @alt.Status</p>
                                </div>
                                <div class="rfq-item-actions">
                                    <button type="button" class="icon-btn" onclick="viewAlternativeRfq(@alt.Id)" title="View">
                                        <i class="fas fa-eye"></i> View
                                    </button>
                                    <button type="button" class="icon-btn" onclick="editAlternativeRfq(@alt.Id)" title="Edit">
                                        <i class="fas fa-edit"></i> Edit
                                    </button>
                                    <button type="button" class="icon-btn" onclick="deleteAlternativeRfq(@alt.Id)" title="Delete">
                                        <i class="fas fa-trash"></i> Delete
                                    </button>
                                </div>
                            </div>
                        }
                    </div>

                    <button type="button" class="comparison-btn" id="compareBtn" onclick="openComparisonView()">
                        <i class="fas fa-balance-scale me-2"></i>@Html.SmartLocalize("Compare Product Lines")
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>

<!-- Create Alternative RFQ Modal -->
<div class="modal fade" id="createAlternativeModal" tabindex="-1" aria-labelledby="modelForCreateAlternativeModalLabel" aria-hidden="true">
    <div class="modal modal-large">
        <div class="modal-content">
        <div class="modal-header">
            <h3>@Html.SmartLocalize("Create Alternative RFQ")</h3>
            <button class="btn btn-close p-1" type="button" data-bs-dismiss="modal" aria-label="Close" onclick="closeCreateAlternativeModal()"></button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label>@Html.SmartLocalize("Select Vendor")</label>
                <select id="alternativeVendor" class="form-select" asp-items="ViewBag.Vendors as SelectList">
                    
                        <option value="">select</option>
                    
                </select>
            </div>
            <div class="form-group">
                <label>@Html.SmartLocalize("Alternative Reference")</label>
                <input type="text" id="alternativeReference" class="form-control" value="ALT001" readonly />
            </div>
            <div class="alert alert-info">
                <i class="fas fa-info-circle me-2"></i>
                @Html.SmartLocalize("This alternative RFQ will contain all products from the main RFQ. You can edit prices and quantities after creation.")
            </div>
            <div class="product-preview">
                <h5>@Html.SmartLocalize("Products to include:")</h5>
                <ul id="productPreviewList">
                    <!-- Products will be populated by JavaScript -->
                </ul>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-phoenix-secondary" onclick="closeCreateAlternativeModal()">@Html.SmartLocalize("Cancel")</button>
            <button type="button" class="btn btn-phoenix-primary" onclick="createAlternativeRfq()">@Html.SmartLocalize("Create Alternative RFQ")</button>
        </div>
    </div>
</div>
</div>

<!-- View Alternative RFQ Modal -->
<div class="modal fade" id="viewAlternativeModal" tabindex="-1" aria-labelledby="modelForViewAlternativeModalLabel" aria-hidden="true">
    <div class="modal modal-large">

        <div class="modal-content">

        <div class="modal-header">
            <h3>@Html.SmartLocalize("View Alternative RFQ") - <span id="viewAltReference"></span></h3>
                <button class="btn btn-close p-1" type="button" data-bs-dismiss="modal" aria-label="Close" onclick="closeViewAlternativeModal()"></button>
        </div>
        <div class="modal-body">
            <div class="row mb-4">
                <div class="col-md-6">
                    <p><strong>@Html.SmartLocalize("Vendor"):</strong> <span id="viewAltVendor"></span></p>
                    <p><strong>@Html.SmartLocalize("Date"):</strong> <span id="viewAltDate"></span></p>
                </div>
                <div class="col-md-6">
                    <p><strong>@Html.SmartLocalize("Status"):</strong> <span id="viewAltStatus"></span></p>
                    <p><strong>@Html.SmartLocalize("Total Amount"):</strong> <span id="viewAltTotal"></span></p>
                </div>
            </div>
            <table class="product-table">
                <thead>
                    <tr>
                        <th>@Html.SmartLocalize("Product")</th>
                        <th>@Html.SmartLocalize("Quantity")</th>
                        <th>@Html.SmartLocalize("Unit Price")</th>
                        <th>@Html.SmartLocalize("Tax")</th>
                        <th>@Html.SmartLocalize("Subtotal")</th>
                    </tr>
                </thead>
                <tbody id="viewAltProductsTable">
                    <!-- Products will be populated by JavaScript -->
                </tbody>
            </table>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-phoenix-secondary" onclick="closeViewAlternativeModal()">@Html.SmartLocalize("Close")</button>
            <button type="button" class="btn btn-phoenix-primary" onclick="useThisAlternative()">@Html.SmartLocalize("Use This Alternative")</button>
        </div>
    </div>
</div>
</div>

<!-- Edit Alternative RFQ Modal -->
<div class="modal fade" id="editAlternativeModal" tabindex="-1" aria-labelledby="modelForEditAlternativeModalLabel" aria-hidden="true">
    <div class="modal modal-large">
        <div class="modal-content">
        <div class="modal-header">
            <h3>@Html.SmartLocalize("Edit Alternative RFQ") - <span id="editAltReference"></span></h3>
            <button class="btn btn-close p-1" type="button" data-bs-dismiss="modal" aria-label="Close" onclick="closeEditAlternativeModal()"></button>
        </div>
        <div class="modal-body">
            <div class="form-group mb-3">
                <label>@Html.SmartLocalize("Vendor")</label>
               @*   <select id="editAltVendor" class="form-select">
                     @foreach (var vendor in ViewBag.Vendors as SelectList)
                     {
                         <option value="@vendor.Value">@vendor.Text</option>
                     }
                 </select> *@

                <select id="editAltVendor" class="form-select" asp-items="ViewBag.Vendors as SelectList">

                    <option value="">select</option>

                </select>

            </div>
            <table class="product-table">
                <thead>
                    <tr>
                        <th>@Html.SmartLocalize("Product")</th>
                        <th>@Html.SmartLocalize("Quantity")</th>
                        <th>@Html.SmartLocalize("Unit Price")</th>
                        <th>@Html.SmartLocalize("Tax")</th>
                        <th>@Html.SmartLocalize("Subtotal")</th>
                        <th>@Html.SmartLocalize("Actions")</th>
                    </tr>
                </thead>
                <tbody id="editAltProductsTable">
                    <!-- Products will be populated by JavaScript -->
                </tbody>
            </table>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-phoenix-secondary" onclick="closeEditAlternativeModal()">@Html.SmartLocalize("Cancel")</button>
            <button type="button" class="btn btn-phoenix-primary" onclick="saveAlternativeRfq()">@Html.SmartLocalize("Save Changes")</button>
        </div>
    </div>
</div>
</div>

<!-- Comparison View Modal -->
<div class="modal fade" id="comparisonModal" tabindex="-1" aria-labelledby="modelForComparisonModalLabel" aria-hidden="true">
    <div class="modal modal-large">
        <div class="modal-content">
        <div class="modal-header">
            <h3>@Html.SmartLocalize("Compare Product Lines - Alternative RFQs")</h3>
                <button class="btn btn-close p-1" type="button" data-bs-dismiss="modal" aria-label="Close" onclick="closeComparisonModal()"></button>
        </div>
        <div class="modal-body">
            <div id="comparisonTableContainer">
                <!-- Comparison table will be generated here -->
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-phoenix-secondary" onclick="closeComparisonModal()">@Html.SmartLocalize("Close")</button>
            <button type="button" class="btn btn-phoenix-primary" onclick="selectBestOffers()">@Html.SmartLocalize("Select Best Offers")</button>
        </div>
    </div>
</div>
</div>








<!-- Email Modal -->
<div class="modal fade" id="emailModal" tabindex="-1" aria-labelledby="modelForEmailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">

        <div class="modal-content">

        <div class="modal-header">
            <h3>@Html.SmartLocalize("Compose Email")</h3>
            <button class="btn btn-close p-1" type="button" data-bs-dismiss="modal" aria-label="Close" onclick="closeEmailModal()"></button>
        </div>
        <div class="modal-body ">
            <div class="form-group">
                <label>@Html.SmartLocalize("Recipients")</label>
                <select id="emailRecipients" class="form-select">
                    <option>@Html.SmartLocalize("Vendor")</option>
                    <option>@Html.SmartLocalize("Multiple Recipients")</option>
                </select>
            </div>
            <div class="form-group">
                <label>@Html.SmartLocalize("Subject")</label>
                <input type="text" id="emailSubject" class="form-control" value="Request for Quotation (Ref: @Model.RfqNumber)" />
            </div>
            <div class="form-group">
                <label>@Html.SmartLocalize("Message")</label>
                <textarea id="emailBody" class="form-control" rows="8">
Dear Vendor,

Here is in attachment a request for quotation @Model.RfqNumber from our company.

Please provide your best quotation for the items listed below. We expect your response by @Model.OrderDeadline.ToString("dd MMM yyyy").

If you have any questions, please do not hesitate to contact us.

Best regards,
My Company
                </textarea>
            </div>
            <div class="attachments">
                <i class="fas fa-paperclip me-2"></i>
                <span>RFQ_@(Model.RfqNumber).pdf</span>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-phoenix-primary" id="sendEmail">@Html.SmartLocalize("SEND EMAIL")</button>
            <button type="button" class="btn btn-phoenix-secondary" onclick="closeEmailModal()">@Html.SmartLocalize("CANCEL")</button>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
   
    
    <script src="~/js/pages/pos/rfq/rfq.js"></script>
    <script>
        
    </script>
}