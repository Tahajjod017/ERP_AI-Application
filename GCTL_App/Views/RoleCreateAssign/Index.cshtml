<!-- 🟦 Right-side Offcanvas for Role Assign -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="offcanvasRoleAssign" aria-labelledby="offcanvasRoleAssignLabel" data-bs-scroll="true" data-bs-backdrop="false">
    <div class="offcanvas-header border-bottom">
        <h5 class="offcanvas-title" id="offcanvasRoleAssignLabel">Assign Role</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>

    <div class="offcanvas-body py-4">
        <form id="assignRoleForm" class="needs-validation" novalidate>
            <input type="hidden" id="tenantId" name="tenantId" value="1" />

            <div class="mb-4">
                <label for="companySelect" class="form-label fw-semibold">Select Company <span class="text-danger">*</span></label>
                <select class="form-select" id="companySelect" name="companyId" required>
                    <option value="" disabled selected>Select company</option>
                    @* Example: dynamically populate company options *@
                    <option value="1">Google</option>
                    <option value="2">Microsoft</option>
                    <option value="3">Meta</option>
                </select>
                <div class="invalid-feedback">
                    Please select a company.
                </div>
            </div>

            <div class="mb-4">
                <label for="roleSelect" class="form-label fw-semibold">Select Role <span class="text-danger">*</span></label>
                <select class="form-select" id="roleSelect" name="roleId" required disabled>
                    <option value="" disabled selected>Select role</option>
                    <!-- roles loaded dynamically -->
                </select>
                <div class="invalid-feedback">
                    Please select a role.
                </div>
            </div>

            <div class="mb-4 position-relative">
                <label for="userSearch" class="form-label fw-semibold">Search User <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="userSearch" placeholder="Type to search users..." autocomplete="off" required />
                <ul id="userSearchResults" class="list-group position-absolute w-100 shadow-sm" style="z-index: 1050; max-height: 180px; overflow-y: auto; display: none;"></ul>
                <input type="hidden" id="selectedUserId" name="userId" required />
                <div class="invalid-feedback">
                    Please select a user from the list.
                </div>
            </div>

            <div class="d-grid mt-3">
                <button type="submit" class="btn btn-primary fw-semibold" id="assignRoleBtn" disabled>Assign Role</button>
            </div>
        </form>
    </div>
</div>

