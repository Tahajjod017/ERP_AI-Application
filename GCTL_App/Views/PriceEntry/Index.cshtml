@using GCTL.Core.ViewModels.POS.Purchase.Rfq

@model PriceEntryViewModel

@{
    ViewData["Title"] = "Price Entry";
}

<style>
    .comparison-container {
        display: flex;
        overflow-x: auto;
        width: 100%;
    }

    .fixed-column {
        position: sticky;
        left: 0;
        background: white;
        z-index: 10;
        box-shadow: 3px 0 5px rgba(0,0,0,0.1);
        width: 400px;
        flex-shrink: 0;
    }

    .vendor-column {
/*        width: 500px;*/
        flex-shrink: 0;
    }

    .table th {
        position: sticky;
        top: 0;
        background: white;
        z-index: 5;
    }

    .table {
        margin-bottom: 0;
    }

    .fixed-column .table tbody tr,
    .vendor-column .card .table tbody tr {
        height: 60px;
    }

    .fixed-column .table td,
    .vendor-column .card .table td {
        vertical-align: middle;
        padding: 12px 8px;
    }

    .status-btn {
        padding: 6px 20px;
        border: 1px solid #dee2e6;
        background: #fff;
        color: #666;
        border-radius: 3px;
        font-size: 13px;
        cursor: pointer;
        transition: all 0.3s;
    }

        .status-btn.active {
            background: #28a745;
            color: white;
            border-color: #28a745;
        }

        .status-btn:hover {
            background: #f8f9fa;
        }

        .status-btn.active:hover {
            background: #218838;
        }

    .vat-toggle-btn {
        background: #6c757d;
        color: white;
        border-color: #6c757d;
    }

        .vat-toggle-btn:hover {
            background: #5a6268;
        }

    .original-footer {
        font-size: 14px;
    }

  

    .total-cell {
        font-weight: bold;
        color: #155724;
        background-color: #f8f9fa;
    }

    #saveBtn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .alert-message {
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 1000;
        min-width: 300px;
        display: none;
    }
</style>

<div class="container-fluid mt-3">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center">
            <h1 class="h3 me-4">Total Vendors: <span id="totalVendors">@Model.Vendors.Count</span></h1>
            <div class="vr mx-4"></div>
            <h1 class="h3">Total Products: <span id="totalProducts">@Model.Items.Count</span></h1>
        </div>
        <div id="actionButtons">
            <button id="saveBtn" class="btn btn-success">
                <i class="bi bi-save"></i> Save Prices
            </button>
        </div>
    </div>

    <!-- Alert Message -->
    <div id="alertMessage" class="alert alert-success alert-message" role="alert">
        <div class="d-flex justify-content-between">
            <span id="alertText"></span>
            <button type="button" class="btn-close" onclick="$('#alertMessage').fadeOut()"></button>
        </div>
    </div>

    <!-- Comparison Table -->
    <div class="comparison-container">
        <!-- Fixed Items Column -->
        <div class="fixed-column">
            <div class="card">
                <div class="card-header">
                    <h4 class="my-2 text-center">Items</h4>
                </div>
                <div class="card-body p-0">
                    <table class="table table-bordered mb-0">
                        <thead>
                            <tr>
                                <th>Item Code</th>
                                <th>Item Name</th>
                                <th class="">Qty</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td class="text-center">@item.Code</td>
                                    <td>@item.Name</td>
                                    <td style="width: 17%;" class="">@item.Quantity</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="card-footer"><br><br></div>
            </div>
        </div>

        <!-- Vendor Columns -->
        <div id="vendorColumns" class="d-flex">
            @for (int vIndex = 0; vIndex < Model.Vendors.Count; vIndex++)
            {
                var vendor = Model.Vendors[vIndex];
                <div class="vendor-column">
                    <div class="card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-0">@vendor.Name</h6>
                                <small class="text-muted">@vendor.Code</small>
                            </div>
                            <div class="d-flex align-items-center">
                                <button type="button" class="status-btn vat-toggle-btn me-2 vat-toggle"
                                        data-vendor="@vIndex" data-vendor-code="@vendor.Code">
                                    <i class="bi bi-percent"></i>
                                    @(vendor.VatIncluded ? "VAT Included" : "VAT Excluded")
                                </button>
                            </div>
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-bordered vendor-table">
                                <thead>
                                    <tr>
                                        <th>Price</th>
                                        <th>Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < Model.Items.Count; i++)
                                    {
                                        var item = Model.Items[i];
                                        var price = vendor.Prices[i];
                                        var total = price * item.Quantity;

                                        <tr>
                                            <td>
                                                <div class="input-group input-group-sm">
                                                    <span class="input-group-text">$</span>
                                                    <input type="number" class="form-control form-control-sm price-input"
                                                           value="@price.ToString("F2")"
                                                           data-vendor="@vIndex"
                                                           data-vendor-code="@vendor.Code"
                                                           data-row="@i"
                                                           min="0"
                                                           step="0.01">
                                                </div>
                                            </td>
                                            <td class="total-cell" data-row="@i">$@total.ToString("F2")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="card-footer" data-vendor="@vIndex">
                            <div class="original-footer">
                                <div><strong>Sub-Total:</strong> $<span class="sub-total">@vendor.SubTotal.ToString("F2")</span></div>
                                <div class="d-none"><strong>VAT (10%):</strong> $<span class="vat-amount">@vendor.VatAmount.ToString("F2")</span></div>
                                <div class="fw-bold text-success">Total: $<span class="grand-total">@vendor.Total.ToString("F2")</span></div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-12 text-end">
            <strong>Date:</strong> <span id="currentDate">@Model.CurrentDate</span>
        </div>
    </div>
</div>

@section Scripts {

    <script src="~/js/pages/POS/rfq/PriceEntry.js"></script>
    <script>
        
    </script>
}