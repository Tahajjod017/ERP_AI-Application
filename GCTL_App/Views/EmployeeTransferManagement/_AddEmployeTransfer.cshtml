                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label req">To Designation</label>
                                <select class="form-select choiceDD" id="ToDesignationID" required asp-items="@ViewBag.DesignationDD as SelectList">
                                    <option value="">Select Organization</option>
                                </select>

                            </div>
                        </div>
