                            <div class="mb-3">
                                <label class="form-label req">From Department</label>
                                <select class="form-select choiceDD" id="FromDepartmentID" required asp-items="@ViewBag.DepartmentDD as SelectList">
                                    <option value="">Select Organization</option>
                                </select>

                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label req">To Department</label>
                                <select class="form-select choiceDD" id="ToDepartmentID" required asp-items="@ViewBag.DepartmentDD as SelectList">
                                    <option value="">Select Organization</option>
                                </select>

                            </div>
                        </div>
                    </div>

                </div>
                <div class="tab-pane fade" id="tab-Department" role="tabpanel" aria-labelledby="Department-tab">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label req">From Designation</label>
                                <select class="form-select choiceDD" id="FromOrganizationBranchID" required asp-items="@ViewBag.DesignationDD as SelectList">
