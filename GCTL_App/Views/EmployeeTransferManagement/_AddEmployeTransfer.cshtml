

<style>
    input[readonly] {
        background-color: #f4f6f9;
        pointer-events: none;
        cursor: default;
        color: #6c757d;
    }
</style>

<form method="post" id="employeeTransferForm">
    <div class="modal-body pb-0">
        <div class="row">
            <div class="col-md-12">
