                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <div class="table-responsive scrollbar mx-n1 px-1">
                <table class="table table-sm fs-9 leads-table">
                    <thead>
                        <tr>
                            <th class="text-center text-middle align-middle ps-0" scope="col" style="width: 5%;">
                                <input type="checkbox" class="form-check-input" id="PageElements-check-all" />
                            </th>
                            <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="EmailCompanyName">@Html.SmartLocalize("SL")</th>
                            <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="EmailCompanyName">@Html.SmartLocalize("Role Name")</th>
                            <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="EmailServerName">@Html.SmartLocalize("Page Name")</th>
                            <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="EmailSSLRequired">@Html.SmartLocalize("Element Name")</th>
                            <th class="text-end align-middle pe-0 ps-5 text-uppercase" scope="col">@Html.SmartLocalize("Action")</th>
                        </tr>
                    </thead>
                    <tbody id="PageElements-tBody">

                    </tbody>
                </table>
            </div>

            <div class="d-flex flex-wrap align-items-center justify-content-between py-3 pe-0 fs-9 border-bottom border-translucent">
                <div class="d-flex">
                    <p class="mb-0 d-none d-sm-block me-3 fw-semibold text-body" id="PageElements-paginationInfo"></p>

                    <p class="mb-0 d-none d-sm-block me-3 fw-semibold text-body" data-list-info="data-list-info"></p>
                </div>
                <div class="d-flex">
                    <button class="page-link" data-list-pagination="prev" id="PageElements-prevPageBtn"><span class="fas fa-chevron-left"></span></button>
                    <ul class="mb-0 pagination" id="PageElements-paginationLinks"></ul>
                    <button class="page-link pe-0" data-list-pagination="next" id="PageElements-nextPageBtn"><span class="fas fa-chevron-right"></span></button>
                </div>
            </div>
        </div>
    </div>
</main>

<partial name="~/Views/Shared/RolesAlert/_ConfirmPermissionChangeModal.cshtml" />

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery/dist/jquery.js"></script>


<script src="~/choices/choices.min.js"></script>


<script>
    $(document).ready(function () {
        $('#companySelect').change(function () {
            var companyId = $(this).val();
            $('#roleSelect2').empty().append('<option>Loading...</option>');

            if (companyId) {
                $.ajax({
                    url: '/RolePermission/GetRolesByCompany', // 🔁 update controller name
                    type: 'GET',
                    data: { companyId: companyId || null},
                    success: function (data) {
                        $('#roleSelect2').empty().append('<option value="">-- Select Role --</option>');
                        $.each(data, function (i, role) {
                            $('#roleSelect2').append('<option value="' + role.id + '">' + role.name + '</option>');
                        });
                    },
                    error: function () {
                        $('#roleSelect2').empty().append('<option>Error loading roles</option>');
                    }
                });
            } else {
                $('#roleSelect2').empty().append('<option value="">-- Select Role --</option>');
            }
        });
    });
</script>
<script src="~/js/pages/authjs/rolepermission.js"></script>
<script src="~/js/pages/authjs/elementpermission.js"></script>
