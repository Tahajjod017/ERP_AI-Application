                                <button type="button" class="btn btn-phoenix-danger btn-sm ms-2" id="PageElements-bulkDelBtn">@Html.SmartLocalize("Delete")</button>
                            </div>
                        </div>

                        <div class="search-box me-3" id="addShift-searchBox">
                            <form class="position-relative" id="PageElements-searchForm">
                                <input class="form-control search-input search" id="PageElements-searchInput" type="search" placeholder="@Html.SmartLocalize("Search here")" aria-label="Search" />
