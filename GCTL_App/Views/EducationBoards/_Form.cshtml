@model GCTL.Core.ViewModels.MasterSetup.EducationBoard.EducationBoardVM

<div class="card">
    <div class="card-header border-bottom-1">
        <div class="row justify-content-between align-items-center">
            <div class="col-auto">
                <h3 class="text-body-emphasis mt-3">@Html.SmartLocalize("Add Education Board")</h3>
            </div>
        </div>
    </div>

    <div class="card-body mt-3">
        <form asp-action="Create" asp-controller="EducationBoards" method="post" enctype="multipart/form-data" id="educationBoard-form">
            @Html.AntiForgeryToken()
            <div class="col-sm-12 col-md-12 mb-4">
                <input type="hidden" asp-for="EducationBoardID" />

                <div class="flatpickr-input-container">
                    <div class="form-floating">
                        <input class="form-control" asp-for="EducationBoardName" type="text" placeholder="@Html.SmartLocalize("Education Board Name")" autocomplete="off" />
                        <label asp-for="EducationBoardName">@Html.SmartLocalize("Education Board Name") <span style="color: red;">*</span></label>
                    </div>
                    <span id="nameError" class="text-danger" style="display:none;"></span>
                </div>
            </div>

            <div class="col-12 mb-4">
                <div class="row g-3 justify-content-end">
                    <div class="col-auto">
                        <button type="reset" class="btn btn-phoenix-primary px-5" id="educationBoard-resetBtn">@Html.SmartLocalize("Reset")</button>
                    </div>
                    <div class="col-auto">
                        <button type="submit" class="btn btn-primary px-5 px-sm-15" id="educationBoard-saveBtn">@Html.SmartLocalize("Save")</button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
