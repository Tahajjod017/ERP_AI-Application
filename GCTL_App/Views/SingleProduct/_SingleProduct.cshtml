            const materialsCheckbox = document.getElementById('singleMaterialsCheckbox');
            const sizeDiv = document.getElementById('singleSizeDiv');
            const colorDiv = document.getElementById('singleColorDiv');
            const materialsDiv = document.getElementById('singleMaterialsDiv');

            if (sizeCheckbox) {
                sizeCheckbox.addEventListener('change', function () {
                    sizeDiv.style.display = this.checked ? 'block' : 'none';
                });
            }

            if (colorCheckbox) {
                colorCheckbox.addEventListener('change', function () {
                    colorDiv.style.display = this.checked ? 'block' : 'none';
                });
            }

            if (materialsCheckbox) {
                materialsCheckbox.addEventListener('change', function () {
                    materialsDiv.style.display = this.checked ? 'block' : 'none';
                });
            }

            // Barcode template toggle
            const barcodeTemplate = document.getElementById('singleBarcodeTemplate');
            const divStandard = document.getElementById('singleDivStandard');
            const divA4 = document.getElementById('singleDivA4');
            const divJewelry = document.getElementById('singleDivJewelry');

            function updateBarcodeDisplay(selectedTemplate) {
                divStandard.style.display = 'none';
                divA4.style.display = 'none';
                divJewelry.style.display = 'none';

                switch (selectedTemplate) {
                    case 'Standard':
                        divStandard.style.display = 'flex';
                        break;
                    case 'A4':
                        divA4.style.display = 'flex';
                        break;
                    case 'Jewelry':
                        divJewelry.style.display = 'flex';
                        break;
                }
            }

            if (barcodeTemplate) {
                updateBarcodeDisplay(barcodeTemplate.value);
                barcodeTemplate.addEventListener('change', function () {
                    updateBarcodeDisplay(this.value);
                });
            }
        });







        const uploadZone = document.getElementById('uploadZone');
        const uploadZoneWrapper = document.getElementById('uploadZoneWrapper');
        const fileInput = document.getElementById('fileInput');
        const browseBtn = document.getElementById('browseBtn');
        const previewContainer = document.getElementById('previewContainer');
        const uploadComplete = document.getElementById('uploadComplete');
        const cropModal = document.getElementById('cropModal');
        const cropImage = document.getElementById('cropImage');
        const previewCanvas = document.getElementById('previewCanvas');
        const cropWidth = document.getElementById('cropWidth');
        const cropHeight = document.getElementById('cropHeight');
        const fitButtons = document.querySelectorAll('.fit-btn');

        let files = [];
        let currentEditIndex = -1;
        let currentFit = 'contain';

        // Update upload zone size based on files
        function updateUploadZoneSize() {
            if (files.length > 0) {
                uploadZoneWrapper.classList.add('has-images');
            } else {
                uploadZoneWrapper.classList.remove('has-images');
            }
        }

        // Click to browse
        uploadZone.addEventListener('click', () => fileInput.click());
        browseBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            fileInput.click();
        });

        // Drag and drop events
        uploadZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            uploadZone.classList.add('drag-over');
        });

        uploadZone.addEventListener('dragleave', () => {
            uploadZone.classList.remove('drag-over');
        });

        uploadZone.addEventListener('drop', (e) => {
            e.preventDefault();
            uploadZone.classList.remove('drag-over');

            const droppedFiles = Array.from(e.dataTransfer.files).filter(
                file => file.type.startsWith('image/')
            );

            handleFiles(droppedFiles);
        });

        // File input change
        fileInput.addEventListener('change', (e) => {
            handleFiles(Array.from(e.target.files));
        });

        function handleFiles(newFiles) {
            files = [...files, ...newFiles];
            renderPreviews();
            updateUploadZoneSize();
            simulateUpload();
        }

        function renderPreviews() {
            previewContainer.innerHTML = '';

            files.forEach((file, index) => {
                const reader = new FileReader();

                reader.onload = (e) => {
                    const previewItem = document.createElement('div');
                    previewItem.className = 'preview-item';
                    previewItem.innerHTML = `
            <img src="${e.target.result}" alt="${file.name}">
                <div class="preview-overlay">
                    <div class="file-name">${file.name}</div>
                    <button class="overlay-btn" onclick="editImage(${index})">
                        <i class="lucide lucide-edit"></i>
                        Edit
                    </button>
                    <button class="overlay-btn" onclick="viewImage(${index})">
                        <i class="lucide lucide-eye"></i>
                        Preview
                    </button>
                    <button class="overlay-btn remove" onclick="removeFile(${index})">
                        <i class="lucide lucide-trash-2"></i>
                        Remove
                    </button>
                </div>
                <div class="progress-bar">
                    <div class="progress-fill" id="progress-${index}"></div>
                </div>
                `;
                    previewContainer.appendChild(previewItem);
                };

                reader.readAsDataURL(file);
            });
        }

        function removeFile(index) {
            files.splice(index, 1);
            renderPreviews();
            updateUploadZoneSize();

            if (files.length === 0) {
                uploadComplete.classList.remove('show');
            }
        }

        function editImage(index) {
            currentEditIndex = index;
            const file = files[index];
            const reader = new FileReader();

            reader.onload = (e) => {
                cropImage.src = e.target.result;
                cropModal.classList.add('active');
                document.body.style.overflow = 'hidden';
                updatePreview();
            };

            reader.readAsDataURL(file);
        }

        function viewImage(index) {
            const file = files[index];
            const reader = new FileReader();

            reader.onload = (e) => {
                const imageUrl = e.target.result;
                const previewWindow = document.createElement('div');
                previewWindow.style.cssText = `
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: rgba(0, 0, 0, 0.95);
                z-index: 10000;
                display: flex;
                justify-content: center;
                align-items: center;
                padding: 20px;
                `;

                previewWindow.innerHTML = `
                <img src="${imageUrl}" style="max-width: 100%; max-height: 100%; object-fit: contain;" alt="${file.name}">
                    <button style="
                            position: absolute;
                            top: 20px;
                            right: 20px;
                            background: white;
                            border: none;
                            width: 40px;
                            height: 40px;
                            border-radius: 50%;
                            cursor: pointer;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            font-size: 24px;
                            color: #1f2937;
                        " onclick="this.parentElement.remove()">×</button>
                    `;

                document.body.appendChild(previewWindow);
                previewWindow.addEventListener('click', (e) => {
                    if (e.target === previewWindow) {
                        previewWindow.remove();
                    }
                });
            };

            reader.readAsDataURL(file);
        }

        // Fit button handlers
        fitButtons.forEach(btn => {
            btn.addEventListener('click', () => {
                fitButtons.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                currentFit = btn.dataset.fit;
                updatePreview();
            });
        });

        // Input handlers
        cropWidth.addEventListener('input', updatePreview);
        cropHeight.addEventListener('input', updatePreview);

        function updatePreview() {
            const img = cropImage;
            if (!img.src) return;

            const width = parseInt(cropWidth.value) || 400;
            const height = parseInt(cropHeight.value) || 400;

            previewCanvas.width = width;
            previewCanvas.height = height;
            const ctx = previewCanvas.getContext('2d');

            // Clear canvas
            ctx.fillStyle = '#f3f4f6';
            ctx.fillRect(0, 0, width, height);

            // Wait for image to load
            if (img.complete && img.naturalWidth > 0) {
                drawImageWithFit(ctx, img, width, height);
            } else {
                img.onload = () => drawImageWithFit(ctx, img, width, height);
            }
        }

        function drawImageWithFit(ctx, img, canvasWidth, canvasHeight) {
            const imgRatio = img.naturalWidth / img.naturalHeight;
            const canvasRatio = canvasWidth / canvasHeight;

            let drawWidth, drawHeight, offsetX, offsetY;

            if (currentFit === 'contain') {
                if (imgRatio > canvasRatio) {
                    drawWidth = canvasWidth;
                    drawHeight = canvasWidth / imgRatio;
                    offsetX = 0;
                    offsetY = (canvasHeight - drawHeight) / 2;
                } else {
                    drawHeight = canvasHeight;
                    drawWidth = canvasHeight * imgRatio;
                    offsetX = (canvasWidth - drawWidth) / 2;
                    offsetY = 0;
                }
            } else if (currentFit === 'cover') {
                if (imgRatio > canvasRatio) {
                    drawHeight = canvasHeight;
                    drawWidth = canvasHeight * imgRatio;
                    offsetX = (canvasWidth - drawWidth) / 2;
                    offsetY = 0;
                } else {
                    drawWidth = canvasWidth;
                    drawHeight = canvasWidth / imgRatio;
                    offsetX = 0;
                    offsetY = (canvasHeight - drawHeight) / 2;
                }
            } else { // fill
                drawWidth = canvasWidth;
                drawHeight = canvasHeight;
                offsetX = 0;
                offsetY = 0;
            }

            ctx.drawImage(img, offsetX, offsetY, drawWidth, drawHeight);
        }

        // Modal handlers
        document.getElementById('closeModal').addEventListener('click', () => {
            cropModal.classList.remove('active');
            document.body.style.overflow = '';
        });

        document.getElementById('cancelCrop').addEventListener('click', () => {
            cropModal.classList.remove('active');
            document.body.style.overflow = '';
        });

        document.getElementById('applyCrop').addEventListener('click', () => {
            previewCanvas.toBlob((blob) => {
                const file = new File([blob], files[currentEditIndex].name, { type: 'image/png' });
                files[currentEditIndex] = file;
                renderPreviews();
                cropModal.classList.remove('active');
                document.body.style.overflow = '';
            });
        });

        // Close modal on escape key
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && cropModal.classList.contains('active')) {
                cropModal.classList.remove('active');
                document.body.style.overflow = '';
            }
        });

        function simulateUpload() {
            uploadComplete.classList.remove('show');

            files.forEach((file, index) => {
                let progress = 0;
                const progressFill = document.getElementById(`progress-${index}`);

                const interval = setInterval(() => {
                    progress += Math.random() * 30;

                    if (progress >= 100) {
                        progress = 100;
                        clearInterval(interval);

                        if (index === files.length - 1) {
                            setTimeout(() => {
                                uploadComplete.classList.add('show');
                            }, 300);
                        }
                    }

                    if (progressFill) {
                        progressFill.style.width = progress + '%';
                    }
                }, 200);
            });
        }

        // Make functions available globally
        window.removeFile = removeFile;
        window.editImage = editImage;
        window.viewImage = viewImage;







    </script>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }