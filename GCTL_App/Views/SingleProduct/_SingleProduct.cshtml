                                        <option value="">@Html.SmartLocalize("Select")</option>

                                    </select>
                                    <span asp-validation-for="Warranty" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-lg-2 col-sm-6 col-12">
                                <div class="form-check form-switch my-3">
                                    <input asp-for="TrackBatch" id="singleTrackBatch" type="checkbox" class="form-check-input" />
                                    <label class="form-check-label" for="singleTrackBatch">@Html.SmartLocalize("Batch")</label>
                                </div>
                            </div>

                            <div class="col-lg-2 col-sm-6 col-12">
                                <div class="form-check form-switch my-3">
                                    <input asp-for="IsActive" id="singleIsActive" type="checkbox" class="form-check-input" />
                                    <label class="form-check-label" for="singleIsActive">@Html.SmartLocalize("Is Active")</label>
                                </div>
                            </div>

                            <div class="col-lg-2 col-sm-6 col-12">
                                <div class="form-check form-switch my-3">
