<div class="modal fade" id="advancedPricing" tabindex="-1" aria-labelledby="advancedPricingModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="advancedPricingModalLabel">@Html.SmartLocalize("Advanced Price")</h5>
                <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <!-- Special Price Section -->
                    <div class="col-12 mb-4">
                        <h6 class="mb-3 text-primary">
                            <i class="bi bi-tag-fill me-2"></i>@Html.SmartLocalize("Special Pricing")
                        </h6>
                        <div class="row">
                            <div class="col-md-6 col-sm-12">
                                <div class="mb-3">
                                    <label class="form-label">@Html.SmartLocalize("Special Price")</label>
                                    <input class="form-control" id="specialPrice" type="number" step="0.01" placeholder="0.00" />
                                </div>
                            </div>
                            <div class="col-md-6 col-sm-12">
