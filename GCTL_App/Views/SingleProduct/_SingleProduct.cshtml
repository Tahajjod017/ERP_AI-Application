                </div>


                <button class="btn " type="button" data-bs-toggle="modal" data-bs-target="#advancedPricing">Set Advances Price</button>



                @*<button class="btn " type="button" data-bs-toggle="modal" data-bs-target="#advancedPricing">Set Advances Pricffe</button>*@
            </div>





