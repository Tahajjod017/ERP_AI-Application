                                                <td>
                                                    <select class="form-select" id="" data-choices="data-choices">
                                                        <option value="">Fixed</option>
                                                        <option selected>Discount</option>
                                                    </select>
                                                </td>

                                                <td>
                                                    <input class="form-control " style="max-width: 5rem;" id="exampleFormControlInput"
                                                           type="email" placeholder="%" />
                                                </td>

                                                <td>
                                                    <a href=""><i class="fa fa-trash text-danger" aria-hidden="true"></i> </a>
                                                </td>
                                            </tr>
