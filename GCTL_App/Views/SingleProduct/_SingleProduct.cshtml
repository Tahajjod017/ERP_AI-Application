                                    <label class="form-check-label" for="singleTraceManufacturingDate">@Html.SmartLocalize("Manufacturing Date")</label>
                                </div>
                            </div>

                            <div class="col-lg-2 col-sm-6 col-12">
                                <div class="form-check form-switch my-3">
                                    <input asp-for="TraceExpiryDate" id="singleTraceExpiryDate" type="checkbox" class="form-check-input" />
                                    <label class="form-check-label" for="singleTraceExpiryDate">@Html.SmartLocalize("Expiry Date")</label>
                                </div>
                            </div>

                            <div class="col-lg-2 col-sm-6 col-12">
                                <div class="form-check form-switch my-3">
                                    <input asp-for="SerialNumber" id="singleSerialNumber" type="checkbox" class="form-check-input" />
                                    <label class="form-check-label" for="singleSerialNumber">@Html.SmartLocalize("Serial Number")</label>
                                </div>
                            </div>

                            <div class="col-lg-2 col-sm-6 col-12">
                                <div class="form-check form-switch my-3">
                                    <input asp-for="HasSize" id="singleHasSize" type="checkbox" class="form-check-input" />
                                    <label class="form-check-label" for="singleHasSize">@Html.SmartLocalize("Size")</label>
                                </div>
                            </div>

                            <div class="col-lg-2 col-sm-6 col-12">
                                <div class="form-check form-switch my-3">
                                    <input asp-for="HasManufacturer" id="singleManufacturer" type="checkbox" class="form-check-input" />
                                    <label class="form-check-label" for="singleManufacturer">@Html.SmartLocalize("Manufacturer")</label>
                                </div>
                            </div>

                        </div>

                        <div class="row">
                            <div class="col-lg-12 mt-2">
                                <div class="accordion" id="descriptionAccordion1">
                                    <div class="">
                                        <h2 class="accordion-header" id="headingDescription">
                                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseDescription1" aria-expanded="false" aria-controls="collapseDescription1">


                                                <i class="bi bi-file-earmark-text me-2"></i>@Html.SmartLocalize("Upload Your Images")

                                                <small class="text-muted text-end ms-2">(@Html.SmartLocalize("Drag and drop or click to upload, then edit and crop as needed"))</small>


                                            </button>
                                        </h2>

                                        <div id="collapseDescription1" class="accordion-collapse collapse" aria-labelledby="headingDescription" data-bs-parent="#descriptionAccordion1">
                                            <div class="content-wrapper">
                                                <div class="preview-container" id="previewContainer"></div>

                                                <div class="upload-zone-wrapper" id="uploadZoneWrapper">
                                                    <div class="upload-zone" id="uploadZone">

                                                        <svg class="upload-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
                                                        </svg>
                                                        <div class="upload-icon-wrapper">
                                                            <i class="lucide lucide-cloud-upload upload-icon"></i>
                                                        </div>
                                                        <div class="upload-text">
                                                            Drag & Drop your images here
                                                        </div>
                                                        <div class="upload-subtext">
                                                            or <span class="browse-btn" id="browseBtn">browse</span> to choose files
                                                        </div>
                                                        <input type="file" id="fileInput" accept="image/*" multiple>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="upload-complete bg-body-highlight" id="uploadComplete">
                                                <i class="lucide lucide-check-circle"></i>
                                                Images uploaded successfully!
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-lg-12 mt-2">
                                <div class="accordion" id="descriptionAccordion">
                                    <div class="">
                                        <h2 class="accordion-header" id="headingDescription">
                                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseDescription" aria-expanded="false" aria-controls="collapseDescription">
                                                <i class="bi bi-file-earmark-text me-2"></i>@Html.SmartLocalize("Description") <small class="text-muted ms-2">(@Html.SmartLocalize("Maximum 60 Words"))</small>
                                            </button>
                                        </h2>
                                        <div id="collapseDescription" class="accordion-collapse collapse" aria-labelledby="headingDescription" data-bs-parent="#descriptionAccordion">
                                            <div class="accordion-body">
                                                <div class="summer-description-box">
                                                    <textarea asp-for="Description" id="singleDescription" class="tinymce form-control" data-tinymce="{}" rows="5" placeholder="@Html.SmartLocalize("Provide a concise and informative description of the asset...")"></textarea>
                                                    <div class="d-flex justify-content-end mt-2">
                                                        <small class="text-muted me-2" id="wordCounter">0 / 60 @Html.SmartLocalize("words")</small>
                                                        <button type="button" class="btn btn-sm btn-outline-primary" onclick="clearDescription()">
                                                            <i class="bi bi-x-circle me-1"></i>@Html.SmartLocalize("Clear")
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <script>

                                document.getElementById('singleDescription').addEventListener('input', function() {
                                    const words = this.value.trim().split(/\s+/).filter(word => word.length > 0).length;
                                    document.getElementById('wordCounter').textContent = words + ' / 60 @Html.SmartLocalize("words")';
                                    if (words > 60) {
                                        this.classList.add('is-invalid');
                                    } else {
                                        this.classList.remove('is-invalid');
                                    }
                                });

                                function clearDescription() {
                                    document.getElementById('singleDescription').value = '';
                                    document.getElementById('wordCounter').textContent = '0 / 60 @Html.SmartLocalize("words")';
                                    document.getElementById('singleDescription').classList.remove('is-invalid');
                                }
                        </script>






                    </div>
                </div>
            </div>

            <!-- Pricing Section -->
