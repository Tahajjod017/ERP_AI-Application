@model GCTL.Core.ViewModels.POS.Product.SingleProduct.SingleProductViewModel

<form asp-action="AddSingleProduct" asp-controller="SingleProduct" method="post" enctype="multipart/form-data" class="">
    <div class="add-product">

        <div class="accordions-items-seperate border-0" id="accordionSpacingExample">

            <!-- Product Information Section -->
            <div class="accordion-item mb-4">
                <h2 class="accordion-header" id="headingSpacingOne">
                    <div class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#SpacingOne"
                         aria-expanded="true" aria-controls="SpacingOne">
                        <div class="d-flex align-items-center justify-content-between flex-fill">
                            <h5 class="d-flex align-items-center my-3">
                                <i data-feather="info" class="text-primary me-2"></i>
                                <span>@Html.SmartLocalize("Product Information (Single Product)")</span>
                            </h5>
                        </div>
                    </div>
                </h2>
                <div id="SpacingOne" class="accordion-collapse collapse show" aria-labelledby="headingSpacingOne">
                    <div class="accordion-body">

                        <div class="row mt-4">
                            <div class="col-sm-12 col-12">
                                <div class="mb-3">
                                    <label asp-for="ProductType" class="form-label">@Html.SmartLocalize("Product Type")</label>
                                    <select asp-for="ProductType" id="singleProductType" class="form-select searchableSelect">
                                        <option value="sp">@Html.SmartLocalize("Single Product")</option>
                                        <option value="ap">@Html.SmartLocalize("Attribute Product")</option>
                                    </select>
                                    <span asp-validation-for="ProductType" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-sm-6 col-12">
                                <div class="mb-3">
                                    <label asp-for="ProductName" class="form-label">@Html.SmartLocalize("Product Name")</label>
                                    <input asp-for="ProductName" id="singleProductName" type="text" class="form-control border-1">
                                    <span asp-validation-for="ProductName" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-sm-6 col-12">
                                <div class="mb-3">
                                    <label asp-for="SKU" class="form-label">@Html.SmartLocalize("SKU")</label>
                                    <input asp-for="SKU" id="singleSKU" type="text" class="form-control border-secondary-light">
                                    <span asp-validation-for="SKU" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="addservice-info">
                            <div class="row">
                                <div class="col-sm-6 col-12">
                                    <div class="mb-3">
                                        <div class="add-newplus">
                                            <label asp-for="Category" class="form-label">@Html.SmartLocalize("Category")</label>
                                            <a href="#" data-bs-toggle="modal" data-bs-target="#add-product-category" class="text-decoration-none">
                                                <i data-feather="plus-circle" class="plus-down-add me-1"></i><span>@Html.SmartLocalize("Add New")</span>
                                            </a>
                                        </div>
                                        <select asp-for="Category" id="singleCategory" class="form-select searchableSelect">
                                            <option value="">@Html.SmartLocalize("Select")</option>
                                            <option>@Html.SmartLocalize("Computers")</option>
                                            <option>@Html.SmartLocalize("Electronics")</option>
                                            <option>@Html.SmartLocalize("Shoe")</option>
                                            <option>@Html.SmartLocalize("Cosmetics")</option>
                                            <option>@Html.SmartLocalize("Groceries")</option>
                                            <option>@Html.SmartLocalize("Furniture")</option>
                                            <option>@Html.SmartLocalize("Bags")</option>
                                            <option>@Html.SmartLocalize("Phone")</option>
                                        </select>
                                        <span asp-validation-for="Category" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-sm-6 col-12">
                                    <div class="mb-3">
                                        <label asp-for="SubCategory" class="form-label">@Html.SmartLocalize("Sub Category")</label>
                                        <select asp-for="SubCategory" id="singleSubCategory" class="form-select searchableSelect">
                                            <option value="">@Html.SmartLocalize("Select")</option>
                                            <option>@Html.SmartLocalize("Laptop")</option>
                                            <option>@Html.SmartLocalize("Desktop")</option>
                                            <option>@Html.SmartLocalize("Sneakers")</option>
                                            <option>@Html.SmartLocalize("Formals")</option>
                                            <option>@Html.SmartLocalize("Wearables")</option>
                                            <option>@Html.SmartLocalize("Speakers")</option>
                                            <option>@Html.SmartLocalize("Handbags")</option>
                                            <option>@Html.SmartLocalize("Travel")</option>
                                            <option>@Html.SmartLocalize("Sofa")</option>
                                        </select>
                                        <span asp-validation-for="SubCategory" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="add-product-new">
                            <div class="row">
                                <div class="col-sm-6 col-12">
                                    <div class="mb-3">
                                        <div class="add-newplus">
                                            <label asp-for="Brand" class="form-label">@Html.SmartLocalize("Brand")</label>
                                        </div>
                                        <select asp-for="Brand" id="singleBrand" class="form-select searchableSelect">
                                            <option value="">@Html.SmartLocalize("Select")</option>
                                            <option>Lenovo</option>
                                            <option>Beats</option>
                                            <option>Nike</option>
                                            <option>Apple</option>
                                            <option>Amazon</option>
                                        </select>
                                        <span asp-validation-for="Brand" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-sm-6 col-12">
                                    <div class="mb-3 list position-relative">
                                        <label asp-for="ModelNo" class="form-label">@Html.SmartLocalize("Model No")</label>
                                        <input asp-for="ModelNo" id="singleModelNo" type="text" class="form-control list">
                                        <span asp-validation-for="ModelNo" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-sm-6 col-12">
                                <div class="mb-3 list position-relative">
                                    <label asp-for="PartNo" class="form-label mt-3">@Html.SmartLocalize("Part No")</label>
                                    <input asp-for="PartNo" id="singlePartNo" type="text" class="form-control list mt-1">
                                    <span asp-validation-for="PartNo" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-sm-6 col-12">
                                <div class="list position-relative">
                                    <label class="form-label">
                                        <span class="me-3">@Html.SmartLocalize("Barcode")</span>
                                        <span class="text-danger ms-1">*</span>

                                        <div class="form-check form-check-inline">
                                            <input asp-for="BarcodeType" id="singleBarcodeTypeSKU" type="radio" value="SKU" class="form-check-input" />
                                            <label class="form-label" for="singleBarcodeTypeSKU">@Html.SmartLocalize("SKU")</label>
                                        </div>

                                        <div class="form-check form-check-inline">
                                            <input asp-for="BarcodeType" id="singleBarcodeTypeEAN" type="radio" value="EAN" class="form-check-input" />
                                            <label class="form-label" for="singleBarcodeTypeEAN">@Html.SmartLocalize("EAN")</label>
                                        </div>

                                        <div class="form-check form-check-inline">
                                            <input asp-for="BarcodeType" id="singleBarcodeTypeUPC" type="radio" value="UPC" class="form-check-input" />
                                            <label class="form-label" for="singleBarcodeTypeUPC">@Html.SmartLocalize("UPC")</label>
                                        </div>

                                        <div class="form-check form-check-inline">
                                            <input asp-for="BarcodeType" id="singleBarcodeTypeISBN" type="radio" value="ISBN" class="form-check-input" />
                                            <label class="form-label" for="singleBarcodeTypeISBN">@Html.SmartLocalize("ISBN")</label>
                                        </div>
                                    </label>
                                    <input asp-for="Barcode" id="singleBarcode" type="text" class="form-control list">
                                    <span asp-validation-for="Barcode" class="text-danger"></span>
                                </div>
                            </div>

                            <div id="singleWeightDiv" class="col-sm-6 col-12">
                                <div class="mb-3 list position-relative">
                                    <label asp-for="Weight" class="form-label">@Html.SmartLocalize("Weight")</label>
                                    <input asp-for="Weight" id="singleWeight" type="text" class="form-control list">
                                    <span asp-validation-for="Weight" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-sm-6 col-12">
                                <div class="mb-3">
                                    <div class="add-newplus">
                                        <label asp-for="Unit" class="form-label">@Html.SmartLocalize("Unit")</label>
                                    </div>
                                    <select asp-for="Unit" id="singleUnit" class="form-select searchableSelect">
                                        <option value="">@Html.SmartLocalize("Select")</option>
                                        <option>Kg</option>
                                        <option>Pcs</option>
                                        <option>L</option>
                                        <option>dz</option>
                                        <option>bx</option>
                                    </select>
                                    <span asp-validation-for="Unit" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-sm-6">
                                <div class="mb-3">
                                    <div class="add-newplus">
                                        <label asp-for="AssetsType" class="form-label">@Html.SmartLocalize("Assets Type")</label>
                                    </div>
                                    <select asp-for="AssetsType" id="singleAssetsType" class="form-select searchableSelect">
                                        <option value="">@Html.SmartLocalize("Select")</option>
                                        <option>@Html.SmartLocalize("Current Assets")</option>
                                        <option>@Html.SmartLocalize("Fixed Assets")</option>
                                    </select>
                                    <span asp-validation-for="AssetsType" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-lg-6 col-sm-6 col-12">
                                <div class="mb-3">
                                    <label asp-for="QuantityAlert" class="form-label">@Html.SmartLocalize("Quantity Alert")</label>
                                    <input asp-for="QuantityAlert" id="singleQuantityAlert" type="number" class="form-control">
                                    <span asp-validation-for="QuantityAlert" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-lg-2 col-sm-6 col-12">
                                <div class="form-check form-switch my-3">
                                    <input asp-for="TrackBatch" id="singleTrackBatch" type="checkbox" class="form-check-input" />
                                    <label class="form-check-label" for="singleTrackBatch">@Html.SmartLocalize("Track Batch")</label>
                                </div>
                            </div>

                            <div class="col-lg-2 col-sm-6 col-12">
                                <div class="form-check form-switch my-3">
                                    <input asp-for="IsActive" id="singleIsActive" type="checkbox" class="form-check-input" />
                                    <label class="form-check-label" for="singleIsActive">@Html.SmartLocalize("Is Active")</label>
                                </div>
                            </div>

                            <div class="col-lg-2 col-sm-6 col-12">
                                <div class="form-check form-switch my-3">
                                    <input asp-for="TraceManufacturingDate" id="singleTraceManufacturingDate" type="checkbox" class="form-check-input" />
                                    <label class="form-check-label" for="singleTraceManufacturingDate">@Html.SmartLocalize("Trace Manufacturing Date")</label>
                                </div>
                            </div>

                            <div class="col-lg-2 col-sm-6 col-12">
                                <div class="form-check form-switch my-3">
                                    <input asp-for="TraceExpiryDate" id="singleTraceExpiryDate" type="checkbox" class="form-check-input" />
                                    <label class="form-check-label" for="singleTraceExpiryDate">@Html.SmartLocalize("Trace Expiry Date")</label>
                                </div>
                            </div>

                            <div class="col-lg-2 col-sm-6 col-12">
                                <div class="form-check form-switch my-3">
                                    <input asp-for="SerialNumber" id="singleSerialNumber" type="checkbox" class="form-check-input" />
                                    <label class="form-check-label" for="singleSerialNumber">@Html.SmartLocalize("Serial Number")</label>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-lg-12">
                                <div class="add-choosen">
                                    <div class="mb-3">
                                        <div class="image-upload image-upload-two">
                                            <input asp-for="ProductImages" id="singleProductImages" type="file" multiple>
                                            <div class="image-uploads">
                                                <i data-feather="plus-circle" class="plus-down-add me-0"></i>
                                                <h4>@Html.SmartLocalize("Add Images")</h4>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="phone-img mb-3">
                                        <img src="~/media/products/phone-add-1.png" alt="image">
                                       
                                        <a href="javascript:void(0);"><i data-feather="x" class="x-square-add remove-product"></i></a>
                                    </div>

                                    <div class="phone-img mb-3">
                                        <img src="~/media/products/phone-add-2.png" alt="image">
                                        <a href="javascript:void(0);"><i data-feather="x" class="x-square-add remove-product"></i></a>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Editor -->
                        <div class="col-lg-12">
                            <div class="summer-description-box">
                                <label asp-for="Description" class="form-label">@Html.SmartLocalize("Description")</label>
                                <textarea asp-for="Description" id="singleDescription" class="tinymce" data-tinymce="{}"></textarea>
                                <p class="fs-9 mt-1 ms-2">@Html.SmartLocalize("Maximum 60 Words")</p>
                            </div>
                        </div>
                        <!-- /Editor -->

                    </div>
                </div>
            </div>

            <!-- Pricing Section -->
            <div class="accordion-item mb-4">
                <h2 class="accordion-header" id="headingSpacingTwo">
                    <div class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#SpacingTwo"
                         aria-expanded="true" aria-controls="SpacingTwo">
                        <div class="d-flex align-items-center justify-content-between flex-fill">
                            <h5 class="d-flex align-items-center my-3">
                                <div id="singlePriceAt">
                                    <i data-feather="life-buoy" class="text-primary me-2"></i><span>@Html.SmartLocalize("Pricing")</span>
                                </div>
                            </h5>
                        </div>
                    </div>
                </h2>

                <div id="SpacingTwo" class="accordion-collapse collapse show" aria-labelledby="headingSpacingTwo">
                    <div class="accordion-body">
                        <div class="text-editor add-list add mt-4">
                            <div class="col-md-12">
                                <div id="singleDiv1" class="p-3">
                                    <div class="row">
                                        <div class="col-lg-6 col-sm-6 col-12">
                                            <div class="mb-3">
                                                <label asp-for="SellingPrice" class="form-label">@Html.SmartLocalize("Selling Price (Excluding VAT)")</label>
                                                <input asp-for="SellingPrice" id="singleSellingPrice" type="number" step="0.01" class="form-control">
                                                <span asp-validation-for="SellingPrice" class="text-danger"></span>
                                            </div>
                                        </div>

                                        <div class="col-lg-6 col-sm-6 col-12">
                                            <div class="mb-3">
                                                <label asp-for="VATPercentage" class="form-label">@Html.SmartLocalize("VAT %")</label>
                                                <select asp-for="VATPercentage" id="singleVATPercentage" class="form-select searchableSelect">
                                                    <option value="">@Html.SmartLocalize("Select")</option>
                                                    <option>8%</option>
                                                    <option>12%</option>
                                                    <option>13%</option>
                                                    <option>15%</option>
                                                </select>
                                                <span asp-validation-for="VATPercentage" class="text-danger"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <a class="btn" type="button" data-bs-toggle="modal" data-bs-target="#advancedPricing">@Html.SmartLocalize("Set Advanced Price")</a>
            </div>

          
