                        <div class="d-flex align-items-center justify-content-between flex-fill">
                            <h5 class="d-flex align-items-center my-3">
                                <i data-feather="info" class="text-primary me-2"></i><span>@Html.SmartLocalize("Product Information")</span>
                            </h5>
                        </div>
                    </div>
                </h2>
                <div id="SpacingOneAP" class="accordion-collapse collapse show" aria-labelledby="headingSpacingOneAP">
