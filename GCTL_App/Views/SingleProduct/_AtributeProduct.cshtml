@model GCTL.Core.ViewModels.POS.Product.SingleProduct.AttrProductAddViewModel





<form asp-controller="Product" asp-action="Add" method="post" enctype="multipart/form-data">
    <div class="add-product">
        <div class="accordions-items-seperate border-0" id="accordionSpacingExampleAP">
            <div class="accordion-item mb-4">
