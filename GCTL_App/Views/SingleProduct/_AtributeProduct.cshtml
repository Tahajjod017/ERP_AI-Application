                                <script>
                document.addEventListener('DOMContentLoaded', function () {
                  const barcodeTemplateSelect = document.getElementById('barcodeTemplate');
                  const divStandard = document.getElementById('divStandard');
                  const divA4 = document.getElementById('divA4');
                  const divJewelry = document.getElementById('divJewelry');

                  function updateDivVisibility(selectedTemplate) {
                    divStandard.style.display = 'none';
                    divA4.style.display = 'none';
                    divJewelry.style.display = 'none';

                    switch (selectedTemplate) {
                      case 'Standard':
                        divStandard.style.display = 'flex';
                        divA4.style.display = 'none';
                        divJewelry.style.display = 'none';
                        break;
                      case 'A4':
                        divStandard.style.display = 'none';
                        divA4.style.display = 'flex';
                        divJewelry.style.display = 'none';
                        break;
                      case 'Jewelry':
                        divJewelry.style.display = 'flex';
                        divStandard.style.display = 'none';
                        divA4.style.display = 'none';
                        break;
                      default:
                        console.warn('Unexpected template value:', selectedTemplate); // Log the unexpected value
                        break;
                    }
                  }

                  // Initial setup
                  updateDivVisibility(barcodeTemplateSelect.value);

                  // Event listener
                  barcodeTemplateSelect.addEventListener('change', function () {
                    updateDivVisibility(barcodeTemplateSelect.value);
                  });
                });
