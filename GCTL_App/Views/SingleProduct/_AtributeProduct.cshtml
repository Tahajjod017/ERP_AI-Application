                                    <span asp-validation-for="AttrProductType" class="text-danger"></span>
                                    <select asp-for="AttrProductType" class="form-select searchableSelect" id="attrProductType">
                                        <option value="sp">@Html.SmartLocalize("Single Product")</option>
                                        <option value="ap">@Html.SmartLocalize("Attribute Product")</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-sm-6 col-12">
                                <div class="mb-3">
                                    <label asp-for="AttrProductName">@Html.SmartLocalize("Product Name")</label>
                                    <span asp-validation-for="AttrProductName" class="text-danger"></span>
                                    <input asp-for="AttrProductName" type="text" class="form-control border-1" id="attrProductName">
                                </div>
                            </div>
                            <div class="col-sm-6 col-12">
