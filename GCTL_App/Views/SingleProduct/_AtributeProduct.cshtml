<script>
document.getElementById('attrDescription').addEventListener('input', function () {
    const words = this.value.trim().split(/\s+/).filter(word => word.length > 0).length;
    document.getElementById('attrWordCounter').textContent = words + ' / 60 @Html.SmartLocalize("words")';
    if (words > 60) {
        this.classList.add('is-invalid');
    } else {
        this.classList.remove('is-invalid');
    }
});

function clearAttrDescription() {
    document.getElementById('attrDescription').value = '';
    document.getElementById('attrWordCounter').textContent = '0 / 60 @Html.SmartLocalize("words")';
    document.getElementById('attrDescription').classList.remove('is-invalid');
}
</script>

<script>
    const attrUploadZone = document.getElementById('attrUploadZone');
    const attrUploadZoneWrapper = document.getElementById('attrUploadZoneWrapper');
    const attrFileInput = document.getElementById('attrFileInput');
    const attrBrowseBtn = document.getElementById('attrBrowseBtn');
    const attrPreviewContainer = document.getElementById('attrPreviewContainer');
    const attrUploadComplete = document.getElementById('attrUploadComplete');

    let attrFiles = [];

    function updateAttrUploadZoneSize() {
        if (attrFiles.length > 0) {
            attrUploadZoneWrapper.classList.add('has-images');
        } else {
            attrUploadZoneWrapper.classList.remove('has-images');
        }
    }

    attrUploadZone.addEventListener('click', () => attrFileInput.click());
    attrBrowseBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        attrFileInput.click();
    });

    attrUploadZone.addEventListener('dragover', (e) => {
        e.preventDefault();
        attrUploadZone.classList.add('drag-over');
    });

    attrUploadZone.addEventListener('dragleave', () => {
        attrUploadZone.classList.remove('drag-over');
    });

    attrUploadZone.addEventListener('drop', (e) => {
        e.preventDefault();
        attrUploadZone.classList.remove('drag-over');
        const droppedFiles = Array.from(e.dataTransfer.files).filter(file => file.type.startsWith('image/'));
        handleAttrFiles(droppedFiles);
    });

    attrFileInput.addEventListener('change', (e) => {
        handleAttrFiles(Array.from(e.target.files));
    });

    function handleAttrFiles(newFiles) {
        attrFiles = [...attrFiles, ...newFiles];
        renderAttrPreviews();
        updateAttrUploadZoneSize();
        simulateAttrUpload();
    }

    function renderAttrPreviews() {
        attrPreviewContainer.innerHTML = '';
        attrFiles.forEach((file, index) => {
            const reader = new FileReader();
            reader.onload = (e) => {
                const previewItem = document.createElement('div');
                previewItem.className = 'preview-item';
                previewItem.innerHTML = `
                                        <img src="${e.target.result}" alt="${file.name}">
                                        <div class="preview-overlay">
                                            <div class="file-name">${file.name}</div>
                                            <button class="overlay-btn remove" onclick="removeAttrFile(${index})">
                                                <i class="lucide lucide-trash-2"></i>
                                                Remove
                                            </button>
                                        </div>
                                        <div class="progress-bar">
                                            <div class="progress-fill" id="attr-progress-${index}"></div>
                                        </div>
                                    `;
                attrPreviewContainer.appendChild(previewItem);
            };
            reader.readAsDataURL(file);
        });
    }

    function removeAttrFile(index) {
        attrFiles.splice(index, 1);
        renderAttrPreviews();
        updateAttrUploadZoneSize();
        if (attrFiles.length === 0) {
            attrUploadComplete.classList.remove('show');
        }
    }

    function simulateAttrUpload() {
        attrUploadComplete.classList.remove('show');
        attrFiles.forEach((file, index) => {
            let progress = 0;
            const progressFill = document.getElementById(`attr-progress-${index}`);
            const interval = setInterval(() => {
                progress += Math.random() * 30;
                if (progress >= 100) {
                    progress = 100;
                    clearInterval(interval);
                    if (index === attrFiles.length - 1) {
                        setTimeout(() => {
                            attrUploadComplete.classList.add('show');
                        }, 300);
                    }
                }
                if (progressFill) {
                    progressFill.style.width = progress + '%';
                }
            }, 200);
        });
    }

    window.removeAttrFile = removeAttrFile;
</script>