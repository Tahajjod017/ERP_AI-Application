                                                        </div>
                                                        <input type="file" id="attrFileInput" accept="image/*" multiple>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="upload-complete bg-body-highlight" id="attrUploadComplete">
                                                <i class="lucide lucide-check-circle"></i>
                                                Images uploaded successfully!
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                       
