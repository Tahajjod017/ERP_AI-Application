@model GCTL.Core.ViewModels.POS.Product.SingleProduct.ServiceViewModel

<div class="col-12 row p-3 mt-2">
    <div class="col-md-12">
        <h4>@Html.SmartLocalize("Customer Buys")</h4>
        <div class="bg-body-emphasis p-3 mt-3">
            <form id="serviceForm">
                <div class="row mb-3">
                    <div class="col-md-4">
                        <label asp-for="ServiceSelectService">@Html.SmartLocalize("Service Name")</label>
                        <span asp-validation-for="ServiceSelectService" class="text-danger"></span>
                        <input asp-for="ServiceSelectService" id="serviceSelectService" class="form-control" placeholder="@Html.SmartLocalize("Enter Service Name")" required />
                    </div>
                    <div class="col-md-2">
                        <label asp-for="ServiceHourlyRate">@Html.SmartLocalize("Hourly Rate")</label>
                        <input asp-for="ServiceHourlyRate" id="serviceHourlyRate" class="form-control" placeholder="@Html.SmartLocalize("Enter Hourly Rate")" type="number" step="0.01" />
                    </div>
                    <div class="col-md-2">
                        <label asp-for="ServiceDailyRate">@Html.SmartLocalize("Daily Rate")</label>
                        <input asp-for="ServiceDailyRate" id="serviceDailyRate" class="form-control" placeholder="@Html.SmartLocalize("Enter Daily Rate")" type="number" step="0.01" />
                    </div>
                    <div class="col-md-2">
                        <label asp-for="ServicePerJobRate">@Html.SmartLocalize("Per Job Rate")</label>
                        <input asp-for="ServicePerJobRate" id="servicePerJobRate" class="form-control" placeholder="@Html.SmartLocalize("Enter Per Job Rate")" type="number" step="0.01" />
                    </div>
                    <div class="col-md-2">
                        <label asp-for="ServicePerMeterRate">@Html.SmartLocalize("Per Meter Rate")</label>
                        <input asp-for="ServicePerMeterRate" id="servicePerMeterRate" class="form-control" placeholder="@Html.SmartLocalize("Enter Per Meter Rate")" type="number" step="0.01" />
                    </div>
                </div>
                <div class="d-flex justify-content-end">
                    <button type="submit" class="btn btn-sm btn-primary px-4" id="serviceCreateButton">
                        @Html.SmartLocalize("Create")
                    </button>
                </div>
            </form>
        </div>

        <div class="d-flex align-items-center justify-content-between flex-wrap row-gap-3 mb-2 mt-4 pt-3">
            <h3>@Html.SmartLocalize("Service List")</h3>
            <div class="d-flex align-items-center flex-wrap row-gap-3">
                <div class="input-group me-3" style="width: 250px;">
                    <input class="form-control" id="serviceSearch" type="text" placeholder="@Html.SmartLocalize("Search")" />
                    <span class="input-group-text"><i class="fa fa-search"></i></span>
                </div>
                <select class="form-select" id="serviceShow" style="width: 100px;">
                    <option value="5">5</option>
                    <option value="10" selected>10</option>
                    <option value="20">20</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                </select>
            </div>
        </div>

        <div class="bg-body-emphasis p-3">
            <div id="serTable">
                <div class="table-responsive">
                    <table class="table table-sm fs-9 table-hover">
                        <thead class="">
                            <tr>
                                <th class="ps-4"><input class="form-check-input" type="checkbox" /></th>
                                <th class="sort" data-sort="serviceName">@Html.SmartLocalize("Service Name")</th>
                                <th class="sort" data-sort="hourlyRate">@Html.SmartLocalize("Hourly Rate")</th>
                                <th class="sort" data-sort="dailyRate">@Html.SmartLocalize("Daily Rate")</th>
                                <th class="sort" data-sort="perJobRate">@Html.SmartLocalize("Per Job Rate")</th>
                                <th class="sort" data-sort="perMeterRate">@Html.SmartLocalize("Per Meter Rate")</th>
                                @*<th class="text-end pe-4">@Html.SmartLocalize("Actions")</th>*@
                            </tr>
                        </thead>
                        <tbody id="serTable-body"></tbody>
                    </table>
                </div>

                <div class="d-flex flex-wrap align-items-center justify-content-between py-3">
                    <p class="mb-0 fw-semibold text-body" id="showingText"></p>
                    <div class="d-flex">
                        <button class="page-link" id="prevBtn"><span class="fas fa-chevron-left"></span></button>
                        <ul class="mb-0 pagination" id="pagination"></ul>
                        <button class="page-link" id="nextBtn"><span class="fas fa-chevron-right"></span></button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>









