@using GCTL.Core.ViewModels.Employee.EmployeeBulkRegister

@model EmpPagedResult<EmployeeExcelVM>

<table class="table table-hover">
    <thead>
        <tr>
            <th>Code</th>
            <th>Name</th>
            <th>Email</th>
            <th>Department</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var e in Model.Data)
        {
            <tr>
                <td class="hl">@e.EmployeeCode</td>
                <td class="hl">@e.FirstName @e.LastName</td>
                <td class="hl">@e.Email</td>
                <td>@e.DepartmentName</td>
            </tr>
        }
    </tbody>
</table>

<ul class="pagination">
    @for (int i = 1; i <= Model.TotalPages; i++)
    {
        <li class="page-item @(i == Model.PageNumber ? "active" : "")">
            <a href="#" class="page-link ajax-page" data-page="@i">@i</a>
        </li>
    }
</ul>
