@model GCTL.Core.ViewModels.Finance.ThirdTabVM.CreateThirdTabVM

<div class="row">
    <form asp-action="Create" asp-controller="ThirdTab" method="post" enctype="multipart/form-data" id="thirdTab-form">
        
        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label" asp-for="ClassID">@Html.SmartLocalize("First Layer Account")</label>
                <select class="form-select" asp-for="ClassID" asp-items="@ViewBag.ClassDD as SelectList">
                    <option value="">@Html.SmartLocalize("Select First Layer Account")...</option>
                </select>
                <span asp-validation-for="ClassID" id="ClassIDError" class="text-danger" style="display:none;"></span>
            </div>
        </div>

        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label" for="">Second Layer Account Name</label>
                <input class="form-control" id="" type="text" placeholder="" />
            </div>
        </div>
        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label" for="">Code</label>
                <input class="form-control" id="" type="text" placeholder="" />
            </div>
        </div>


        <div class="col-12 mb-3">
            <div class="row g-3 justify-content-end">
                <div class="col-auto">
                    <button class="btn btn-phoenix-primary px-5">Cancel</button>
                </div>
                <div class="col-auto">
                    <button class="btn btn-primary px-5 px-sm-15">Create</button>
                </div>
            </div>
        </div>
    </form>
</div>