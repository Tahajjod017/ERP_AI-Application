@{
    var activeTab = "ProbationSetting";
}

<partial name="~/Views/Shared/HRMsettingsNavs/HRMsettingNavPartial.cshtml" model="activeTab" />


<div class="col-xl-12">
    <div class="card mb-4 mt-2">
        <div class="card-body">
            <div class="border-bottom mb-3 pb-3">
                <h4>Probetion Period Settings</h4>
            </div>
            <form id="probationPeriodSettingForm" asp-controller="ProbationPeriodSetting" asp-action="Create" method="post">
                <div class="mb-3">
                    <div class="row">
                        <!-- Company Name Dropdown -->
                        <div class="col-sm-6 col-md-4">
                            <div class="mb-3">
                                <label class="form-label" for="OrganizationID">Company Name</label>
                                <select id="OrganizationID" name="OrganizationID" class="form-select choiceDD">
                                    <option value="">-- Select Organization --</option>
                                    @if (ViewBag.Organizations != null)
                                    {
                                        foreach (var org in ViewBag.Organizations)
                                        {
                                            <option value="@org.Value">@org.Text</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>

                        <!-- Probation Period Number Dropdown -->
                        <div class="col-sm-6 col-md-4">
                            <div class="mb-3">
                                <label class="form-label" for="probationPeriod">Probation Period (Number)</label>
                                <input type="number" class="form-control" id="probationPeriod" name="Period" placeholder="Enter number (e.g., 1)" min="1" aria-label="Probation Period">
                            </div>
                        </div>

                        <!-- Probation Period Type Dropdown -->
                        <div class="col-sm-6 col-md-4">
                            <div class="mb-3">
                                <label class="form-label" for="periodType">Probation Period Type</label>
                                <select class="form-select" id="periodType" name="PeriodType" aria-label="Probation Period Type">
                                    <option selected="selected">Select Period Type</option>
                                    <option value="month">Month</option>
                                    <option value="year">Year</option>
                                </select>
                            </div>
                        </div>

                        <!-- Start Date Picker -->
                        <div class="col-sm-6 col-md-4">
                            <div class="mb-3">
                                <label class="form-label" for="datepicker"> From Joining Date</label>
                                <input class="form-control datetimepicker flatpickr-input" id="datepicker"  type="text"
                                       placeholder="dd/mm/yyyy"
                                       data-options="{&quot;disableMobile&quot;:true,&quot;dateFormat&quot;:&quot;d/m/Y&quot;}"
                                       readonly="readonly">
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="d-flex align-items-center justify-content-end">
                    <button type="reset" class="btn btn-outline-secondary border me-3">Reset</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>

        </div>
    </div>

   
</div>

<partial name="_ProbationPeriodTableList"/>

@section Scripts {
    <script src="~/js/pages/adminsettings/hrmsetting/probationsetting.js"></script>

}
