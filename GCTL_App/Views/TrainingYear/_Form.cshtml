@model GCTL.Core.ViewModels.MasterSetup.TrainingYear.TrainingYearVM

<div class="card">
    <div class="card-header border-bottom-1">
        <div class="row justify-content-between align-items-center">
            <div class="col-auto">
                <h3 class="text-body-emphasis mt-3">Add Training Year</h3>
            </div>
        </div>
    </div>

    <div class="card-body mt-3">
        <form asp-action="Create" asp-controller="TrainingYear" method="post" enctype="multipart/form-data" id="trainingYear-form">
            @Html.AntiForgeryToken()
            <div class="col-sm-12 col-md-12 mb-4">
                <input type="hidden" asp-for="TrainingYearID" />
                <div class="flatpickr-input-container">
                    <div class="form-floating">
                        <input class="form-control" asp-for="TrainingYearName" type="text" placeholder="Training Year Name" />
                        <label asp-for="TrainingYearName">Training Year Name <span style="color: red;">*</span></label>
                    </div>
                    <span asp-validation-for="TrainingYearName" class="text-danger"></span>
                    <span id="nameError" class="text-danger" style="display:none;"></span>
                </div>
            </div>

            <div class="col-12 mb-4">
                <div class="row g-3 justify-content-end">
                    <div class="col-auto">
                        <button type="reset" class="btn btn-phoenix-primary px-5" id="trainingYear-resetBtn">Reset</button>
                    </div>
                    <div class="col-auto">
                        <button type="submit" class="btn btn-primary px-5 px-sm-15" id="trainingYear-saveBtn">Save</button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
