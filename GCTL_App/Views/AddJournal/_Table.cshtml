<div class="card mt-2 mb-3">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap row-gap-3 mb-4">
        <h4 class="mb-1">@Html.SmartLocalize("Journal List")</h4>
    </div>

    <div class="border-translucent p-3">
        <div class="row g-3 justify-content-between align-items-end mb-4">
            <div class="col-12 col-sm-auto">
                <div class="d-flex align-items-center me-3" style="width: auto;">
                    <span class="ms-2">@Html.SmartLocalize("Showing"):</span> &nbsp;
                    <div style="width: 100%;">
                        <select id="addJournals-pageSizeSelect" class="form-select form-select-sm" tabindex="10">
                            <option class="dropdown-item" value="5">@Html.SmartLocalize("5")</option>
                            <option class="dropdown-item" value="10">@Html.SmartLocalize("10")</option>
                            <option class="dropdown-item" value="25">@Html.SmartLocalize("25")</option>
                            <option class="dropdown-item" value="50">@Html.SmartLocalize("50")</option>
                            <option class="dropdown-item" value="100">@Html.SmartLocalize("100")</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-auto">
                <div class="d-flex align-items-center">
                    <div class="d-none me-3" id="addJournals-bulkSelectActions">
                        <div class="position-relative">
                            <button type="button" class="btn btn-phoenix-danger btn-sm ms-2" id="addJournals-bulkDelBtn">@Html.SmartLocalize("Delete")</button>
                        </div>
                    </div>

                    <div class="search-box me-3" id="addJournals-searchBox">
                        <form class="position-relative" id="addJournals-searchForm">
                            <input class="form-control search-input search" id="addJournals-searchInput" type="search" placeholder="@Html.SmartLocalize("Search here")" aria-label="Search" />
                            <span class="fas fa-search search-box-icon"></span>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <div class="table-responsive scrollbar mx-n1 px-1">
            <table class="table table-sm fs-9 leads-table">
                <thead>
                    <tr>
                        <th class="text-center text-middle align-middle ps-0" scope="col" style="width: 5%;">
                            <input type="checkbox" class="form-check-input" id="addJournals-check-all" />
                        </th>
                        <th class="sort align-middle text-start text-uppercase text-nowrap" scope="col" data-sort="JournalCode">@Html.SmartLocalize("Journal ID")</th>
                        <th class="sort align-middle text-start text-uppercase text-nowrap" scope="col" data-sort="JournalTypeID">@Html.SmartLocalize("Journal Type")</th>
                        <th class="sort align-middle text-start text-uppercase text-nowrap" scope="col" data-sort="ScenarioTypeID">@Html.SmartLocalize("Scenario Type")</th>
                        <th class="sort align-middle text-start text-uppercase text-nowrap" scope="col" data-sort="JournalDate">@Html.SmartLocalize("Date")</th>
                        <th class="sort align-middle text-start text-uppercase text-nowrap" scope="col" data-sort="Note">@Html.SmartLocalize("Note")</th>
                        <th class="sort align-middle text-start text-uppercase text-nowrap" scope="col" data-sort="FileLink">@Html.SmartLocalize("Attachment")</th>
                        <th class="align-middle text-start white-space-nowrap ps-0 text-uppercase" scope="col" style="width: 5%;">@Html.SmartLocalize("Action")</th>
                    </tr>
                </thead>
                <tbody id="addJournals-tBody">
                </tbody>
            </table>
        </div>

        <div class="d-flex flex-wrap align-items-center justify-content-between py-3 pe-0 fs-9 border-bottom border-translucent">
            <div class="d-flex">
                <p class="mb-0 d-none d-sm-block me-3 fw-semibold text-body" id="addJournals-paginationInfo"></p>

                <p class="mb-0 d-none d-sm-block me-3 fw-semibold text-body" data-list-info="data-list-info"></p>
            </div>
            <div class="d-flex">
                <button class="page-link" data-list-pagination="prev" id="addJournals-prevPageBtn"><span class="fas fa-chevron-left"></span></button>
                <ul class="mb-0 pagination" id="addJournals-paginationLinks"></ul>
                <button class="page-link pe-0" data-list-pagination="next" id="addJournals-nextPageBtn"><span class="fas fa-chevron-right"></span></button>
            </div>
        </div>
    </div>
</div>

﻿
<div class="modal fade" id="addJournalDetailsModal" tabindex="-1" aria-labelledby="addJournalDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body text-center">
                @* <h4 class="mb-1">Confirm Delete</h4> *@
                <div class="table-responsive scrollbar mx-n1 px-1">
                    <table class="table table-sm fs-9 leads-table">
                        <thead>
                            <tr>
                                <th class="align-middle text-start text-uppercase text-nowrap" scope="col">@Html.SmartLocalize("Transaction Type")</th>
                                <th class="align-middle text-start text-uppercase text-nowrap" scope="col">@Html.SmartLocalize("Amount")</th>
                                <th class="align-middle text-start text-uppercase text-nowrap" scope="col">@Html.SmartLocalize("Description")</th>
                            </tr>
                        </thead>
                        <tbody id="addJournalsDetails-tBody">
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Html.SmartLocalize("Close")</button>
            </div>
        </div>
    </div>
</div>