<div class="content bg-white">
    <div class="mb-3 border-bottom">
        <h4>New Journal</h4>
    </div>




    <div class="tab-content mt-3">
        <div class="col-xl-10">
            <form action="" class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label" for="">Journal Id</label>
                        <input class="form-control no-border-input bg-transparent" id="" type="text" placeholder="32" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label" for="">Journal Type</label>
                        <select class="form-select " id="journalType">
                            <option selected>Select Journal Type</option>
                            <option value="Manual Journal">Manual Journal</option>
                            <option value="Recurring Journal">Recurring Journal</option>
                        </select>
                    </div>
                </div>

                <div id="showRecurringJournal" style="display:none;">
                    <div class="col-md-12">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label" for="">Recurrence Pattern</label>
                                    <select class="form-select ">
                                        <option selected>Select Recurrence Pattern</option>
                                        <option value="1">Monthly</option>
                                        <option value="2">Quarterly</option>
                                        <option value="2">Annually</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label" for="">Start Date</label>
                                    <input class="form-control no-border-input datetimepicker" id="" type="text" placeholder="dd/mm/yyyy" data-options='{"disableMobile":true,"dateFormat":"d/m/Y"}' />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label" for="">End Date</label>
                                    <input class="form-control no-border-input datetimepicker" id="" type="text" placeholder="dd/mm/yyyy" data-options='{"disableMobile":true,"dateFormat":"d/m/Y"}' />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label" for="">Auto Post</label>
                                    <select class="form-select bg-transparent">
                                        <option selected>Select Auto Post Type</option>
                                        <option value="1">Yes</option>
                                        <option value="2">No</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <script>
                    document.getElementById("journalType").addEventListener("change", function() {
                      const recurringDiv = document.getElementById("showRecurringJournal");
                      if (this.value === "Recurring Journal") {
                        recurringDiv.style.display = "block";
                      } else {
                        recurringDiv.style.display = "none";
                      }
                    });
                </script>
                <div class="col-md-6">
