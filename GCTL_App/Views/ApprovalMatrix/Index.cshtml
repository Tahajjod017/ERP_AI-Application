@model GCTL.Core.ViewModels.POS.Settings.ApprovalSettingViewModel
@{
    ViewData["Title"] = "Approval Matrix";
}

<style>
    .custom-padding-left {
        padding-left: 4.5em;
        margin-bottom: -0.656rem;
        padding-top: 1rem;
    }

    .select2-selection__clear {
        
        top: 15% !important;
      
    }

</style>

<div class="d-flex mb-3 pb-3" id="scrollspyApprovalMatrix">
    <span class="fa-stack me-2 ms-n1">
        <i class="fas fa-circle fa-stack-2x text-primary"></i>
        <i class="fa-inverse fa-stack-1x text-primary-subtle fas fa-check" data-fa-transform="shrink-4"></i>
    </span>
    <div class="col">
        <h3 class="mb-0 text-primary position-relative fw-bold">
            <span class="bg-body pe-2">Add New Approval Setting</span>
            <span class="border border-primary position-absolute top-50 translate-middle-y w-100 start-0 z-n1"></span>
        </h3>

    </div>
</div>

<div class="row mt-2">
    <div class="col-12">
        <div class="px-4 px-lg-6 bg-body-emphasis rounded">
            <div class="col-12 col-xl-12 col-xxl-12">
                <div class="col-12 row flex gy-3 pb-3">
                    <form asp-action="Create" method="post" id="createApprovalSettingForm">
                        @Html.AntiForgeryToken()

                        <div class="row">
                            <div class="col-md-3">
                                <label asp-for="OrganizationID" class="form-label"></label>
                                <select asp-for="OrganizationID" asp-items="@ViewBag.Organizations as SelectList" class="form-select choiceDD">
                                    <option value="">Select Organization</option>
                                </select>
                                <span asp-validation-for="OrganizationID" class="text-danger"></span>
                            </div>
                            <div class="col-md-3">
                                <label asp-for="OrganizationBranchID" class="form-label"></label>
                                <select asp-for="OrganizationBranchID" asp-items="@ViewBag.OrganizationBranches as SelectList" class="form-select choiceDD">
                                    <option value="">Select Branch</option>
                                </select>
                                <span asp-validation-for="OrganizationBranchID" class="text-danger"></span>
                            </div>
                            @*<div class="col-md-4">
                                    <label asp-for="ApprovalTypeID" class="form-label"></label>
                                    <select asp-for="ApprovalTypeID" asp-items="@ViewBag.ApprovalTypes as SelectList" class="form-select choiceDD">
                                        <option value="">Select Approval Type</option>
                                    </select>
                                    <span asp-validation-for="ApprovalTypeID" class="text-danger"></span>
                                </div>*@
                            <div class="col-md-3">
                                <label asp-for="StartDate" class="form-label"></label>
                                <input asp-for="StartDate" placeholder="Select Start Date" class="form-control datetimepicker caiCon" type="text" />
                                <span asp-validation-for="StartDate" class="text-danger"></span>
                            </div>
                            <div class="col-md-3">
                                <label asp-for="EndDate" class="form-label"></label>
                                <input asp-for="EndDate" placeholder="Select End Date" class="form-control datetimepicker caiCon" type="text" />
                                <span asp-validation-for="EndDate" class="text-danger"></span>
                            </div>

                            @*<div class="col-md-4">
                                    <label asp-for="SelfExceptionApprovalID" class="form-label"></label>
                                    <input asp-for="AllowSelfApproval" type="checkbox" class="form-check-input" />
                                    <select asp-for="SelfExceptionApprovalID" asp-items="@ViewBag.Employees as SelectList" class="form-select choiceDD">
                                        <option value="">Select Exception Approver</option>
                                    </select>
                                    <span asp-validation-for="SelfExceptionApprovalID" class="text-danger"></span>
                                </div>

                                <div class="col-md-4">
                                    <label asp-for="AllowSelfApproval" class="form-label"></label>
                                    <input asp-for="AllowSelfApproval" type="checkbox" class="form-check-input" />
                                    <span asp-validation-for="AllowSelfApproval" class="text-danger"></span>
                                </div>



                                <div class="col-md-4" id="selfApprovalSection">

                                    <div class="mb-3">
                                        <div class="row">
                                            <div class="form-check form-switch col-12 custom-padding-left">
                                                <input class="form-check-input" type="checkbox" id="AllowSelfApproval" asp-for="AllowSelfApproval"" />
                                                <label class="form-check-label" sp-for="AllowSelfApproval">Self-Approval</label>
                                            </div>
                                        </div>


                                        <div class="mt-3">
                                            <select class="form-select choiceDD"
                                                    id="SelfExceptionApprovalID"
                                                    asp-for="SelfExceptionApprovalID"
                                                    asp-items="@ViewBag.Employees as SelectList">
                                                <option value="">
                                                    Select Higher authority in case of Self approval
                                                </option>
                                            </select>
                                        </div>

                                    </div>


                                </div>*@





                        </div>

                        <div class="container mt-5">
                            <h4 class="mb-4">Approval Levels</h4>
                            <table class="table table-bordered">
                                <thead class="table-light">
                                    <tr>
                                        @*<th>Level Number</th>*@
                                        <th>Approver</th>
                                        @*<th>Is Enabled</th>*@
                                        <th style="width: 5% !important;">Action</th>
                                    </tr>
                                </thead>
                                <tbody id="approvalLevelTableBody">
                                </tbody>
                            </table>
                            <button type="button" class="btn btn-primary" onclick="addNewLevelRow()">Add New Level</button>
                        </div>

                        <div class="row justify-content-end mt-3">
                            <div class="col-auto">
                                <button type="reset" class="btn btn-secondary">Reset</button>
                            </div>
                            <div class="col-auto">
                                <button type="submit" class="btn btn-primary">Save</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<table style="display:none;">
    <tbody>
        <tr id="approvalLevelRowTemplate">
            <td class="p-2 d-none">
                <input type="hidden" name="ApprovalLevels.Index" value="" />
                <input type="hidden" name="ApprovalLevels[INDEX].LevelNumber" class="form-control" value="INDEX" placeholder="e.g. 1" min="1" />
            </td>
            <td class="p-2">
                <select name="ApprovalLevels[INDEX].ApproverEmployeeID" class="form-select ">
                    <option value="">Select Approver</option>
                    @foreach (var emp in (SelectList)ViewBag.Employees)
                    {
                        <option value="@emp.Value">@emp.Text</option>
                    }
                </select>
            </td>
            <td class="p-2 d-none">
                <input type="hidden" name="ApprovalLevels[INDEX].IsEnabled" class="form-check-input" />
            </td>
            <td class="p-2 ">
                <button type="button" class="btn btn-danger btn-sm" onclick="removeLevelRow(this)">Delete</button>
            </td>
        </tr>
    </tbody>
</table>

<div class="d-flex mb-5 mt-3 pt-3">
    <span class="fa-stack me-2 ms-n1">
        <i class="fas fa-circle fa-stack-2x text-primary"></i>
        <i class="fa-inverse fa-stack-1x text-primary-subtle fas fa-list" data-fa-transform="shrink-4"></i>
    </span>
    <div class="col">
        <h3 class="mb-0 text-primary position-relative fw-bold">
            <span class="bg-body pe-2">Approval Settings List</span>
            <span class="border border-primary position-absolute top-50 translate-middle-y w-100 start-0 z-n1"></span>
        </h3>
    </div>
</div>

<div class="px-4 px-lg-6 bg-body-emphasis rounded">
    <div class="mb-9">
        <div id="approvalSummary">
            <div class="row g-3 justify-content-between align-items-end mb-4">
                <div class="col-12 col-sm-auto">
                    <div class="d-flex align-items-center">
                        <div class="dropdown me-3">
                            <select class="form-select choiceDD" id="organizationFilter" asp-items="@ViewBag.Organizations as SelectList">
                                <option value="">Select Organization</option>
                            </select>
                        </div>
                        <div class="dropdown me-3">
                            <select class="form-select choiceDD" id="approvalTypeFilter" asp-items="@ViewBag.ApprovalTypes as SelectList">
                                <option value="">Select Approval Type</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-sm-auto">
                    <div class="d-flex align-items-center">
                        <div class="me-3">
                            <input class="form-control" id="searchInput" type="text" placeholder="Search">
                        </div>
                        <div class="dropdown me-3">
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">Showing</span>
                                </div>
                                <select class="form-select" id="pageSizeSelect">
                                    <option value="10">10</option>
                                    <option value="25">25</option>
                                    <option value="50">50</option>
                                    <option value="100">100</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="table-responsive ms-n1 ps-1 scrollbar">
                <table class="table fs-9 mb-0 border-top border-translucent dyn-tableDrag" id="ApprovalSettingsTable">
                    <thead>
                        <tr>
                            <th class="sort white-space-nowrap align-middle ps-0" scope="col" data-sort="ApprovalSettingID">ID</th>
                            <th class="sort white-space-nowrap align-middle ps-2" scope="col" data-sort="ApprovalTypeName">Approval Type</th>
                            <th class="sort white-space-nowrap align-middle ps-2" scope="col" data-sort="OrganizationName">Organization</th>
                            <th class="sort white-space-nowrap align-middle ps-2" scope="col" data-sort="BranchName">Branch</th>
                            @*<th class="sort white-space-nowrap align-middle ps-2" scope="col" data-sort="StartDate">Start Date</th>
                                <th class="sort white-space-nowrap align-middle ps-2" scope="col" data-sort="EndDate">End Date</th>*@
                            <th class="sort white-space-nowrap align-middle ps-2" scope="col" data-sort="AllowSelfApproval">Self Approval</th>
                            <th class="sort white-space-nowrap align-middle ps-2" scope="col" data-sort="SelfExceptionApprovalName">Exception Approver</th>
                            <th class="sort align-middle text-end" scope="col" style="width:100px;"></th>
                        </tr>
                    </thead>
                    <tbody class="list" id="approval-settings-table">
                    </tbody>
                </table>
            </div>
            <div class="d-flex flex-wrap align-items-center justify-content-between py-3 pe-0 fs-9 border-bottom border-translucent">
                <div class="d-flex">
                    <p class="mb-0 d-none d-sm-block me-3 fw-semibold text-body" data-list-info="data-list-info"></p>

                </div>
                <div class="d-flex">
                    <button class="page-link" data-list-pagination="prev"><span class="fas fa-chevron-left"></span></button>
                    <ul class="mb-0 pagination"></ul>
                    <button class="page-link pe-0" data-list-pagination="next"><span class="fas fa-chevron-right"></span></button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editApprovalSettingModal" tabindex="-1" aria-labelledby="editApprovalSettingModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editApprovalSettingModalLabel">Edit Approval Setting</h5>
                <button class="btn btn-close p-1" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="editApprovalSettingForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="edit_ApprovalSettingID" name="ApprovalSettingID" />
                    <div class="col-12 col-xl-12 col-xxl-12">
                        <div class="col-12 row flex gy-3">
                            <div class="col-12 col-sm-12 col-md-6">
                                <div class="form-floating form-floating-advance-select">
                                    <select class="form-select choiceDD" id="edit_OrganizationID" name="OrganizationID" required asp-items="@ViewBag.Organizations as SelectList">
                                        <option value="">Select Organization</option>
                                    </select>
                                    <label for="edit_OrganizationID">Organization</label>
                                </div>
                            </div>
                            <div class="col-12 col-sm-12 col-md-6">
                                <div class="form-floating form-floating-advance-select">
                                    <select class="form-select choiceDD" id="edit_OrganizationBranchID" name="OrganizationBranchID" required asp-items="@ViewBag.OrganizationBranches as SelectList">
                                        <option value="">Select Branch</option>
                                    </select>
                                    <label for="edit_OrganizationBranchID">Branch</label>
                                </div>
                            </div>
                            <div class="col-12 col-sm-12 col-md-6 mt-6">
                                <div class="form-floating form-floating-advance-select">
                                    <select class="form-select choiceDD" id="edit_ApprovalTypeID" name="ApprovalTypeID" required asp-items="@ViewBag.ApprovalTypes as SelectList">
                                        <option value="">Select Approval Type</option>
                                    </select>
                                    <label for="edit_ApprovalTypeID">Approval Type</label>
                                </div>
                            </div>
                            <div class="col-12 col-sm-12 col-md-6">
                                <div class="form-floating">
                                    <input class="form-control" id="edit_StartDate" name="StartDate" type="date" required />
                                    <label for="edit_StartDate">Start Date</label>
                                </div>
                            </div>
                            <div class="col-12 col-sm-12 col-md-6">
                                <div class="form-floating">
                                    <input class="form-control" id="edit_EndDate" name="EndDate" type="date" />
                                    <label for="edit_EndDate">End Date</label>
                                </div>
                            </div>

                            <div class="col-12 col-sm-12 col-md-6">
                                <div class="form-floating form-floating-advance-select">
                                    <select class="form-select choiceDD" id="edit_SelfExceptionApprovalID" name="SelfExceptionApprovalID" asp-items="@ViewBag.Employees as SelectList">
                                        <option value="">Select Exception Approver</option>
                                    </select>
                                    <input class="form-check-input" id="edit_AllowSelfApproval" name="AllowSelfApproval" type="checkbox" />
                                    <label for="edit_SelfExceptionApprovalID">Exception Approver</label>
                                </div>
                            </div>


                            <div class="col-12 col-sm-12 col-md-6 mt-0" id="selfApprovalSection">

                                <div class="mb-3">
                                    <div class="row">
                                        <div class="form-check form-switch col-12 custom-padding-left">
                                            <input class="form-check-input" type="checkbox" id="edit_AllowSelfApproval" name="AllowSelfApproval" />
                                            <label class="form-check-label" for="chkSelfApproval">Self-Approval</label>
                                        </div>
                                    </div>


                                    <div class="mt-3">
                                        <select class="form-select choiceDD"
                                                id="edit_SelfExceptionApprovalID"
                                                name="SelfExceptionApprovalID"
                                                asp-items="@ViewBag.Employees as SelectList">
                                            <option value="">
                                                Select Higher authority in case of Self approval
                                            </option>
                                        </select>
                                    </div>

                                </div>
                            </div>



                            <div class="col-12 col-sm-12 col-md-6">
                                <div class="form-floating">
                                    <input class="form-check-input" id="edit_AllowSelfApproval" name="AllowSelfApproval" type="checkbox" />
                                    <label for="edit_AllowSelfApproval">Allow Self Approval</label>
                                </div>
                            </div>

                            <div class="container mt-5">
                                <h4 class="mb-4">Approval Levels</h4>
                                <table class="table table-bordered">
                                    <thead class="table-light">
                                        <tr>
                                            @*<th>Level Number</th>*@
                                            <th>Approver</th>
                                            @*<th>Is Enabled</th>*@
                                            <th>Action</th>
                                        </tr>
                                    </thead>
                                    <tbody id="editApprovalLevelTableBody">
                                    </tbody>
                                </table>
                                <button type="button" class="btn btn-primary" onclick="addNewLevelRow('editApprovalLevelTableBody')">Add New Level</button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-primary" type="button" onclick="saveEditApprovalSetting()">Okay</button>
                <button class="btn btn-outline-primary rmvModal" type="button" data-bs-dismiss="modal">Cancel</button>
            </div>
        </div>
    </div>
</div>






<div class="modal fade" id="deleteConfirmModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button class="btn btn-close p-1 closeDltModal" type="button" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this approval setting?</p>
                <input type="hidden" id="deleteApprovalSettingId" />
            </div>
            <div class="modal-footer">
                <button class="btn btn-danger" type="button" onclick="confirmDelete()">Delete</button>
                <button class="btn btn-secondary closeDltModal" type="button" data-bs-dismiss="modal">Cancel</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="~/lib/toastr/toastr.min.js"></script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }


    <script src="~/js/pages/POS/Settings/approvalSettings.js"></script>
}