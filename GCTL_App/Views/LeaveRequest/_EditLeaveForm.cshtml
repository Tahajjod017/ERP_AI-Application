 @model GCTL.Core.ViewModels.AttendanceManagement.LeaveManagements.LeaveRequest.LeaveApplicationEditVM
<form asp-action="SaveLeaveRequest" asp-controller="LeaveRequest" method="post" id="LeaveRequestForm">
    <div class="modal-body pb-0">
        <div class="row">
            <div class="col-md-12">
                <input asp-for="LeaveApplicationID" type="hidden" />
                <div class="mb-3">
                   
                    <label class="form-label req" for="organizerSingle">Name</label>
                    <select class="form-select choiceDD" asp-for="EmployeeIDEdit" required>
                        <option value="">Select Employee</option>
                    </select>
                    <span asp-validation-for="EmployeeIDEdit" class="text-danger small"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label req">Leave Type</label>
                    <select class="form-select choiceDD" asp-for="LeaveTypeIDEdit" required asp-items="@ViewBag.LeaveTypeDD as SelectList">
                        <option value="">Select Leave</option>
                    </select>
                    <span asp-validation-for="LeaveTypeIDEdit" class="text-danger small"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label">Available No of Days</label>
                    <input type="text" class="form-control" asp-for="LeaveDaysEdit" disabled>
                </div>
            </div>

            <div class="d-flex col-md-6">
                <div class="form-check me-3">
                    <input class="form-check-input" type="radio" asp-for="IsFullDayEdit" id="option1" value="true" checked>
                    <label class="form-check-label" for="option1">Full Day</label>
                </div>

                <div class="form-check">
                    <input class="form-check-input" type="radio" asp-for="IsFullDayEdit" id="option2" value="false">
                    <label class="form-check-label" for="option2">Partial Day</label>
                </div>
            </div>

            <!-- Full Day Section -->
            <div id="FullDayDivEdit">
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3 flatpickr-input-container">
                            <label class="form-label req">From</label>
                            <div class="input-icon-end position-relative flatpickr">
                                <input type="text" asp-for="FromDateEdit" id="FromDateEdit" class="form-control datetimepicker" required placeholder="dd/mm/yyyy">
                                <span class="uil uil-calendar-alt position-absolute top-50 end-0 translate-middle-y me-3 text-body-tertiary"></span>
                                <span asp-validation-for="FromDateEdit" class="text-danger small"></span>
                            </div>
                            <span id="FromDateError" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label req">To</label>
                            <div class="input-icon-end position-relative">
                                <input type="text" asp-for="ToDateEdit" id="ToDateEdit" class="form-control datetimepicker" required placeholder="dd/mm/yyyy">
                                <span class="uil uil-calendar-alt position-absolute top-50 end-0 translate-middle-y me-3 text-body-tertiary"></span>
                                <span asp-validation-for="ToDateEdit" class="text-danger small"></span>
                            </div>
                            <span id="ToDateError" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">Subsequent Holiday Days</label>
                            <input type="text" id="SubsequentHolydayDaysTT" class="form-control"  disabled/>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">Total Applied Days</label>
                            <input type="text" id="TotalAppliedDaysTT" class="form-control"  disabled/>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Partial Day Section -->
            <div id="PartialDayDivEdit" class="mt-4 d-none">
                <div class="row">
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label req">Date</label>
                            <div class="input-icon-end position-relative">
                                <input type="text" class="form-control datetimepicker" id="ToDateFromDateCombinedEdit" asp-for="ToDateFromDateCombinedEdit" required placeholder="dd/mm/yyyy">
                                <span class="uil uil-calendar-alt position-absolute top-50 end-0 translate-middle-y me-3 text-body-tertiary"></span>
                                <span asp-validation-for="ToDateFromDateCombinedEdit" class="text-danger small"></span>
                            </div>
                            <span id="ToDateFromDateCombinedError" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label req">Start Time</label>
                            <input class="form-control datetimepicker" asp-for="PartialFromTimeEdit" type="text" placeholder="hour : minute" data-options='{"enableTime":true,"noCalendar":true,"dateFormat":"H:i","disableMobile":true}' />
                            <span asp-validation-for="PartialFromTimeEdit" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label req">End Time</label>
                            <input class="form-control datetimepicker" asp-for="PartialToTimeEdit" type="text" placeholder="hour : minute" data-options='{"enableTime":true,"noCalendar":true,"dateFormat":"H:i","disableMobile":true}' />
                            <span asp-validation-for="PartialToTimeEdit" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Reason -->
            <div class="col-md-12">
                <div class="mb-3">
                    <label class="form-label">Reason</label>
                    <textarea asp-for="ReasonEdit" class="form-control" rows="3"></textarea>
                </div>
            </div>

        </div>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-1 mb-2 me-3">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
        <button id="ApplyLeaveSubmitButtonUpdate" class="btn btn-primary">Apply Leave</button>
    </div>
</form>
<script>
        document.addEventListener('DOMContentLoaded', function () {
      const radios = document.querySelectorAll('input[name="IsFullDayEdit"]');
      const div1 = document.getElementById('FullDayDivEdit');
      const div2 = document.getElementById('PartialDayDivEdit');

      function toggleLeaveSections() {
        const isFullDay = document.querySelector('input[name="IsFullDayEdit"]:checked').value === 'true';
        if (isFullDay) {
          div1.classList.remove('d-none');
          div2.classList.add('d-none');
        } else {
          div1.classList.add('d-none');
          div2.classList.remove('d-none');
        }
      }

      radios.forEach(radio => {
        radio.addEventListener('change', toggleLeaveSections);
      });

      toggleLeaveSections();
    });

</script>