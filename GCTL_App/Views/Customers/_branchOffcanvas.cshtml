<div class="branchOffcanvas offcanvas offcanvas-bottom" tabindex="-1" id="branchOffcanvasBottom" aria-labelledby="branchOffcanvasBottomLabel">
    <div class="offcanvas-header p-2">
        <h5 class="offcanvas-title ms-3 fs-7" id="offcanvasBottomLabel">Branch Information</h5>
        <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="branchOffcanvas-body small p-1" style="position: relative;">
        <div class="card-body py-0 scrollbar to-do-list-body">
            <div class="mx-n4 px-4 mx-lg-n6 px-lg-6 bg-body-emphasis">
                <div class="row g-3 justify-content-between align-items-end mb-2 mt-1">
                    <div class="col-12 col-sm-auto mt-0">
                        <div class="d-flex align-items-center me-3" style="width: auto;">
                            <span class="ms-2">@Html.SmartLocalize("Showing"):</span> &nbsp;
                            <div style="width: 100%;">
                                <select id="branch-pageSizeSelect" class="form-select form-select-sm" tabindex="10">
                                    <option class="dropdown-item" value="5">@Html.SmartLocalize("5")</option>
                                    <option class="dropdown-item" value="10">@Html.SmartLocalize("10")</option>
                                    <option class="dropdown-item" value="25">@Html.SmartLocalize("25")</option>
                                    <option class="dropdown-item" value="50">@Html.SmartLocalize("50")</option>
                                    <option class="dropdown-item" value="100">@Html.SmartLocalize("100")</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-sm-auto mt-0">
                        <div class="d-flex align-items-center">
                            <div class="d-none me-3" id="branch-bulkSelectActions">
                                <div class="position-relative">
                                    <button type="button" class="btn btn-phoenix-danger btn-sm ms-2" id="branch-delSel">@Html.SmartLocalize("Delete")</button>
                                </div>
                            </div>

                            <div class="search-box me-3" id="branch-searchBox">
                                <form class="position-relative" id="branch-searchForm">
                                    <input class="form-control search-input search" id="branch-searchInput" type="search" placeholder="@Html.SmartLocalize("Search here")" aria-label="Search" />
                                    <span class="fas fa-search search-box-icon"></span>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="table-responsive ms-n1 ps-1 scrollbar">
                    <table class="table fs-9 mb-0 border-top border-translucent">
                        <thead>
                            <tr>
                                <th class="text-center text-middle align-middle ps-0" scope="col" style="width: 5%;">
                                    <input type="checkbox" class="form-check-input" id="branch-check-all" />
                                </th>
                                <th class="text-center text-middle align-middle ps-0" scope="col" style="width: 10%;">@Html.SmartLocalize("Sl. No")</th>
                                <th class="sort white-space-nowrap align-middle ps-0" scope="col" data-sort="branchName">@Html.SmartLocalize("Branch Name")</th>
                                <th class="sort white-space-nowrap align-middle ps-0" scope="col" data-sort="branchName">@Html.SmartLocalize("Branch Type")</th>
                                <th class="white-space-nowrap align-middle ps-0" scope="col" style="width: 10%;">@Html.SmartLocalize("Contact Person")</th>
                                <th class="white-space-nowrap align-middle ps-0" scope="col" style="width: 10%;">@Html.SmartLocalize("Phone")</th>
                                <th class="white-space-nowrap align-middle ps-0" scope="col" style="width: 10%;">@Html.SmartLocalize("Email")</th>
                                <th class="white-space-nowrap align-middle ps-0" scope="col" style="width: 10%;">@Html.SmartLocalize("Full Address")</th>
                                <th class="white-space-nowrap align-middle ps-0" scope="col" style="width: 10%;">@Html.SmartLocalize("Action")</th>
                            </tr>
                        </thead>
                        <tbody id="branchOffcanvas-body"></tbody>
                    </table>
                </div>

                <div class="d-flex flex-wrap align-items-center justify-content-between py-3 pe-0 fs-9 border-bottom border-translucent">
                    <div class="d-flex">
                        <p class="mb-0 d-none d-sm-block me-3 fw-semibold text-body" id="branch-paginationInfo"></p>
                        <p class="mb-0 d-none d-sm-block me-3 fw-semibold text-body" data-list-info="data-list-info"></p>
                    </div>
                    <div class="d-flex">
                        <button class="page-link" data-list-pagination="prev" id="branch-prevPageBtn"><span class="fas fa-chevron-left"></span></button>
                        <ul class="mb-0 pagination" id="branch-paginationLinks"></ul>
                        <button class="page-link pe-0" data-list-pagination="next" id="branch-nextPageBtn"><span class="fas fa-chevron-right"></span></button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>