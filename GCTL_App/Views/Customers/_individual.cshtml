<div class="row m-0">
    <div class="col-2 border-end p-0">
        <div class="nav flex-sm-column border fs-9 vertical-tab justify-content-between" role="tablist" aria-orientation="vertical">
            <a class="nav-link border text-center text-sm-start cursor-pointer outline-none d-sm-flex align-items-sm-center active" id="addCustommerTab" data-bs-toggle="tab" data-bs-target="#person" role="tab" aria-controls="person" aria-selected="true">
                <span class="me-sm-2 fs-4 nav-icons" data-feather="tag"></span>
                <span class="d-none d-sm-inline">Create Custommer</span>
            </a>
            <a class="nav-link border-end border text-sm-start cursor-pointer outline-none d-sm-flex align-items-sm-center" id="shippingAddressTab" data-bs-toggle="tab" data-bs-target="#shippingAddressTabContent" role="tab" aria-controls="shippingAddressTabContent" aria-selected="false">
                <span class="me-sm-2 fs-4 nav-icons" data-feather="package"></span>
                <span class="d-none d-sm-inline">Add Shiping Address </span>
            </a>
        </div>
    </div>
    <div class="col-10">
        <div class="tab-content py-3 ps-sm-3 h-100">
            <div class="tab-pane fade show active" id="person" role="tabpanel">
                <h5 class="mb-3 text-body-highlight">Add Custommer</h5>
                <div class="row g-3">
                    <form action="" id="customerForm">
                        <input type="number" id="personID" name="name" hidden />
                        <input type="text" name="name" value="" id="countryCodePerson" hidden />
                        <div class="row">
                            <div class="col-md-6 col-sm-12">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="row">
                                            <div class="col-md-6 pe-1 col-sm-6">
                                                <div class="mb-3 form-floating">
                                                    <input type="text" id="firstNamePerson" class="form-control" placeholder="">
                                                    <label class="form-label req">First Name</label>
                                                    <span class="text-danger small"></span>
                                                </div>
                                            </div>
                                            <div class="col-md-6 ps-1 col-sm-6">
                                                <div class="mb-3 form-floating">
                                                    <input type="text" id="lastNamePerson" class="form-control" placeholder="">
                                                    <label class="form-label">Last Name</label>
                                                    <span class="text-danger small"></span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-12">
                                        <div class="mb-3 form-floating">
                                            <input type="text" id="autocompletePerson" class="form-control" placeholder="Customer name">
                                            <label class="form-label">Full Address</label>
                                            <span class="text-danger small"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-12">
                                        <div class="row">
                                            <div class="col-md-6 pe-1 col-sm-6">
                                                <div class="mb-3 form-floating">
                                                    <input type="text" id="streetPerson" class="form-control" placeholder="Street">
                                                    <label class="form-label">Street</label>
                                                    <span class="text-danger small"></span>
                                                </div>
                                            </div>
                                            <div class="col-md-6 ps-1 col-sm-6">
                                                <div class="mb-3 form-floating">
                                                    <input type="text" id="cityPerson" class="form-control" placeholder="City">
                                                    <label class="form-label">City</label>
                                                    <span class="text-danger small"></span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-12">
                                        <div class="row">
                                            <div class="col-md-6 pe-1 col-sm-6">
                                                <div class="mb-3 form-floating">
                                                    <input type="text" id="additionalAddressPerson" class="form-control" placeholder="">
                                                    <label class="form-label">Additional Address</label>
                                                    <span class="text-danger small"></span>
                                                </div>
                                            </div>
                                            <div class="col-md-6 ps-1 col-sm-6">
                                                <div class="mb-3 form-floating">
                                                    <input type="text" id="statePerson" class="form-control" placeholder="">
                                                    <label class="form-label">State/Province</label>
                                                    <span class="text-danger small"></span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-12">
                                        <div class="row">
                                            <div class="col-md-6 pe-1 col-sm-6">
                                                <div class="mb-3 form-floating">
                                                    <input id="postalCodePerson" type="text" class="form-control" placeholder="">
                                                    <label class="form-label">Zip/Postal Code</label>
                                                    <span class="text-danger small"></span>
                                                </div>
                                            </div>
                                            <div class="col-md-6 ps-1 col-sm-6">
                                                <div class="form-floating form-floating-advance-select">
                                                    <label class="form-label">@Html.SmartLocalize("Country")</label>
                                                    <select class="form-select choiceDD" id="countryPerson" asp-items="@ViewBag.CountryDD as SelectList">
                                                        <option value="" selected>@Html.SmartLocalize("Select Country")</option>
                                                    </select>
                                                </div>
                                            </div>

                                        </div>
                                    </div>
                                    <div class="col-md-12">
                                        <div class="row">
                                            <div class="col-md-6 pe-1 col-sm-6">
                                                <div class="mb-3 form-floating">
                                                    <input type="text" id="latitudePerson" class="form-control" placeholder="">
                                                    <label class="form-label">Latitude</label>
                                                    <span class="text-danger small"></span>
                                                </div>
                                            </div>
                                            <div class="col-md-6 ps-1 col-sm-6">
                                                <div class="mb-3 form-floating">
                                                    <input type="text" id="longitudePerson" class="form-control" placeholder="">
                                                    <label class="form-label">Longitude</label>
                                                    <span class="text-danger small"></span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6 col-sm-12">
                                <div class="row">

                                    <div class="col-12 mb-3">
                                        <input class="form-control" id="pPhone" type="tel" placeholder="Phone Number" />
                                        <div class="text-danger" id="errorShow"></div>
                                    </div>
                                    <div class="col-12 mb-3">
                                        <input class="form-control" id="pOtherPhone" type="tel" placeholder="Other Phone" />
                                        <div class="text-danger" id="errorShow"></div>
                                    </div>

                                    <div class="col-12">
                                        <div class="mb-3 form-floating">
                                            <input type="text" id="emailPerson" class="form-control" placeholder="">
                                            <label class="form-label">Email</label>
                                            <div class="text-danger" id="errorShow"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer border-0 pt-0 pb-2">
                            <button type="button" class="btn btn-light" id="goToShippingTab">Save & Add Shipping Address</button>
                            <button type="button" class="btn btn-primary" id="personSaveAndExit">Save & Exit</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="tab-pane fade h-100" id="shippingAddressTabContent" role="tabpanel" aria-labelledby="shippingAddressTab">
                <div class="d-flex flex-column h-100">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h5 class="text-body-highlight mb-0">Add Shipping Address</h5>
                        <div class="form-check mb-0">
                            <input class="form-check-input" type="checkbox" value="" id="sameAsShippingBtn">
                            <label class="form-check-label" for="flexCheckChecked">
                                Same as Customer Address
                            </label>
                        </div>
                    </div>
                    <div class="row g-3">
                        <form action="" id="shippingForm">
                            <input type="number" id="sId" name="name" hidden />
                            <input type="text" name="name" value="" id="sCountryCode" hidden />
                            <div class="row">
                                <!-- Left Section -->
                                <div class="col-md-6">
                                    <div class="col-12 mb-3 customerDiv" id="personCustomerSearchMainDiv">
                                        <div class="form-floating mbs-4 position-relative">
                                            <input type="text" id="personSearch" class="form-control searchField" placeholder="@Html.SmartLocalize("Search ContactName...")">
                                            <input type="number" class="idBank" id="sCId" hidden>

                                            <label for="personContactNameSearch"><i class="fa-solid fa-magnifying-glass"></i> @Html.SmartLocalize("Customer Search")</label>

                                            <div class="list-group bg-white p-0 border position-absolute" id="sCustomerList" style="display: none; width:100%; z-index:10012;">
                                                <!-- ContactName items will be populated here -->
                                            </div>
                                        </div>

                                    </div>
                                    <div class="row">
                                        <div class="col-md-6 pe-1 col-sm-6">
                                            <div class="mb-3 form-floating">
                                                <input type="text" id="sFirstName" class="form-control" placeholder="">
                                                <label class="form-label req">First Name</label>
                                                <span class="text-danger small"></span>
                                            </div>
                                        </div>
                                        <div class="col-md-6 ps-1 col-sm-6">
                                            <div class="mb-3 form-floating">
                                                <input type="text" id="sLastName" class="form-control" placeholder="">
                                                <label class="form-label">Last Name</label>
                                                <span class="text-danger small"></span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-12 mb-3">
                                        <input class="form-control" id="sPhone" type="tel" placeholder="Phone Number" />
                                        <div class="text-danger" id="errorShow"></div>
                                    </div>
                                    <div class="col-12 mb-3">
                                        <input class="form-control" id="sOtherPhone" type="tel" placeholder="Other Phone" />
                                        <div class="text-danger" id="errorShow"></div>
                                    </div>
                                    <div class="col-12">
                                        <div class="mb-3 form-floating">
                                            <input type="text" id="sEmail" class="form-control" placeholder="">
                                            <label class="form-label">Email</label>
                                            <div class="text-danger" id="errorShow"></div>
                                        </div>
                                    </div>
                                </div>
                                <!-- Right Section -->
                                <div class="col-md-6">
                                    @* <div class="form-floating mb-3">
                                              <select id="customer" class="form-select" required>
                                                  <option selected>Select Customer</option>
                                                  <option>Customer Name 1</option>
                                                  <option>Customer Name 2</option>
                                              </select>
                                              <label for="customer" class="form-label">Customer *</label>
                                          </div> *@



                                    <div class="col-md-12">
                                        <div class="mb-3 form-floating">
                                            <input type="text" id="sFullAddress" class="form-control" placeholder="Address">
                                            <label class="form-label">Full Address</label>
                                            <span class="text-danger small"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-12">
                                        <div class="row">
                                            <div class="col-md-6 pe-1 col-sm-6">
                                                <div class="mb-3 form-floating">
                                                    <input type="text" id="sStreet" class="form-control" placeholder="Street">
                                                    <label class="form-label">Street</label>
                                                    <span class="text-danger small"></span>
                                                </div>
                                            </div>
                                            <div class="col-md-6 ps-1 col-sm-6">
                                                <div class="mb-3 form-floating">
                                                    <input type="text" id="sCity" class="form-control" placeholder="City">
                                                    <label class="form-label">City</label>
                                                    <span class="text-danger small"></span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-12">
                                        <div class="row">
                                            <div class="col-md-6 pe-1 col-sm-6">
                                                <div class="mb-3 form-floating">
                                                    <input type="text" id="sAdditionalAddress" class="form-control" placeholder="">
                                                    <label class="form-label">Additional Address</label>
                                                    <span class="text-danger small"></span>
                                                </div>
                                            </div>
                                            <div class="col-md-6 ps-1 col-sm-6">
                                                <div class="mb-3 form-floating">
                                                    <input type="text" id="sState" class="form-control" placeholder="">
                                                    <label class="form-label">State/Province</label>
                                                    <span class="text-danger small"></span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-12">
                                        <div class="row">
                                            <div class="col-md-6 pe-1 col-sm-6">
                                                <div class="mb-3 form-floating">
                                                    <input id="sPostalCode" type="text" class="form-control" placeholder="">
                                                    <label class="form-label">Zip/Postal Code</label>
                                                    <span class="text-danger small"></span>
                                                </div>
                                            </div>
                                            <div class="col-md-6 ps-1 col-sm-6">
                                                <div class="form-floating form-floating-advance-select">
                                                    <label class="form-label">@Html.SmartLocalize("Country")</label>
                                                    <select class="form-select choiceDD" id="sCountry" asp-items="@ViewBag.CountryDD as SelectList">
                                                        <option value="" selected>@Html.SmartLocalize("Select Country")</option>
                                                    </select>
                                                </div>
                                            </div>
                                            @* <div class="col-md-6 ps-1 col-sm-6">
                                                      <div class="mb-3 form-floating">
                                                          <input id="countryShiping" type="text" class="form-control" placeholder="" required>
                                                          <label class="form-label req">Country</label>
                                                          <span class="text-danger small"></span>
                                                      </div>
                                                  </div> *@
                                        </div>
                                    </div>
                                    <div class="col-md-12">
                                        <div class="row">
                                            <div class="col-md-6 pe-1 col-sm-6">
                                                <div class="mb-3 form-floating">
                                                    <input type="text" id="sLatitude" class="form-control" placeholder="">
                                                    <label class="form-label">Latitude</label>
                                                </div>
                                            </div>
                                            <div class="col-md-6 ps-1 col-sm-6">
                                                <div class="mb-3 form-floating">
                                                    <input type="text" id="sLongitude" class="form-control" placeholder="">
                                                    <label class="form-label">Longitude</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div>
                            <div class="modal-footer border-0 pt-0 pb-2">
                                <button type="button" class="btn btn-primary" id="shippingAddressSaveBtn">Save</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>