<div class="d-flex" id="scrollspyEcommerce">
    <span class="fa-stack me-2 ms-n1">
        <i class="fas fa-circle fa-stack-2x text-primary"></i>
        <i class="fa-inverse fa-stack-1x text-primary-subtle fas fa-users" data-fa-transform="shrink-4"></i>
    </span>
    <div class="col">
        <h3 class="mb-0 text-primary position-relative fw-bold">
            <span class="bg-body pe-2">@Html.SmartLocalize("Price Quotation List")</span>
            <span class="border border-primary position-absolute top-50 translate-middle-y w-100 start-0 z-n1"></span>
        </h3>
    </div>
</div>

<div class="row">
    <div class="col-12 bg-body-emphasis rounded">
        <!-- Error Container -->
        <div id="errorContainer" class="mt-3" style="display: none;">
            <!-- Error messages will be displayed here -->
        </div>

        <div class="row g-3 justify-content-between align-items-end my-2">
            <div class="col-12 col-sm-auto"></div>

            <div class="col-12 col-sm-auto">
                <div class="d-flex align-items-center">
                    <div class="me-3">
                        <div class="columnDrag PriceQuotationList"></div>
                    </div>

                    <!-- Search Input -->
                    <div class="me-3">
                        <input class="form-control" id="searchInput" type="text" placeholder="Search requests...">
                    </div>
                   

                  

                   


                    <!-- Page Size Selector -->
                    <div class="dropdown me-3">
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text">@Html.SmartLocalize("Showing")</span>
                            </div>
                            <select class="form-select" id="pageSizeSelect" name="pageSizeSelect">
                                <option value="5">5</option>
                                <option selected value="10">10</option>
                                <option value="25">25</option>
                                <option value="50">50</option>
                                <option value="100">100</option>
                            </select>
                        </div>
                    </div>


                    <div class="me-3">
                        <a href="/PriceQuotation/index" class="btn btn-phoenix-primary">
                              @Html.SmartLocalize("Price Quotation")
                        </a>
                    </div>



                </div>
            </div>
        </div>

        <div class="px-4 px-lg-6">
            <div class="mb-9">
                <div id="projectSummary">
                    <!-- Table Container -->
                    <div class="table-responsive ms-n1 ps-1 scrollbar">
                        <table class="table fs-9 mb-0 border-top border-translucent dyn-tableDrag PriceQuotationList" id="PriceQuotationList">
                            <thead>
                                <tr>
                                    <th class="white-space-nowrap align-middle ps-0" scope="col" data-sort="PriceQuotationID">
                                        <a href="#" class="text-decoration-none text-body sort-header" data-column="PriceQuotationID">
                                            @Html.SmartLocalize("PQ_ID")
                                            <i class="fas fa-sort" id="sort-PriceQuotationID"></i>
                                        </a>
                                    </th>
                                    <th class="white-space-nowrap align-middle ps-0" scope="col" data-sort="QuotationNumber">
                                        <a href="#" class="text-decoration-none text-body sort-header" data-column="QuotationNumber">
                                            @Html.SmartLocalize("Quotation Number")
                                            <i class="fas fa-sort" id="sort-QuotationNumber"></i>
                                        </a>
                                    </th>
                                    <th class="white-space-nowrap align-middle ps-2" scope="col" data-sort="CustomerName">
                                        <a href="#" class="text-decoration-none text-body sort-header" data-column="CustomerName">
                                            @Html.SmartLocalize("Customer")
                                            <i class="fas fa-sort" id="sort-CustomerName"></i>
                                        </a>
                                    </th>
                                    <th class="white-space-nowrap align-middle ps-2" scope="col" data-sort="CreatedBy">
                                        <a href="#" class="text-decoration-none text-body sort-header" data-column="CreatedBy">
                                            @Html.SmartLocalize("Created By")
                                            <i class="fas fa-sort" id="sort-CreatedBy"></i>
                                        </a>
                                    </th>
                                    <th class="white-space-nowrap align-middle ps-2" scope="col" data-sort="QuotationDate">
                                        <a href="#" class="text-decoration-none text-body sort-header" data-column="QuotationDate">
                                            @Html.SmartLocalize("Quotation Date")
                                            <i class="fas fa-sort" id="sort-QuotationDate"></i>
                                        </a>
                                    </th>
                                    <th class="white-space-nowrap align-middle ps-2" scope="col" data-sort="TotalItems">
                                        <a href="#" class="text-decoration-none text-body sort-header" data-column="TotalItems">
                                            @Html.SmartLocalize("Total Items")
                                            <i class="fas fa-sort" id="sort-TotalItems"></i>
                                        </a>
                                    </th>
                                    <th class="white-space-nowrap align-middle ps-2" scope="col" data-sort="VatPercentage">
                                        <a href="#" class="text-decoration-none text-body sort-header" data-column="VatPercentage">
                                            @Html.SmartLocalize("VAT %")
                                            <i class="fas fa-sort" id="sort-VatPercentage"></i>
                                        </a>
                                    </th>
                                    @*<th class="white-space-nowrap align-middle ps-2" scope="col">
                                        Status
                                    </th>*@
                                    <th class="white-space-nowrap align-middle ps-2" scope="col">
                                        @Html.SmartLocalize("Note")

                                    </th>
                                    <th class="text-end white-space-nowrap pe-6" scope="col">
                                        @Html.SmartLocalize("Export")

                                    </th>
                                    <th class="text-end white-space-nowrap pe-6" scope="col">
                                        @Html.SmartLocalize("Action")

                                    </th>
                                </tr>
                            </thead>
                            <tbody id="product-Requisition-history-table">
                                <!-- Rows will be loaded dynamically via JS -->
                            </tbody>
                        </table>
                    </div>

                    <!-- Pagination and Showing Info -->
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <div id="showDown2" class="text-muted">
                            @Html.SmartLocalize("Showing 0 to 0 of 0")

                        </div>
                        <nav aria-label="Table pagination" class="pagination-container">
                            <ul class="pagination mb-0">
                                <li class="page-item disabled" data-list-pagination="prev">
                                    <a class="page-link" href="#">@Html.SmartLocalize("Previous")</a>
                                </li>
                                <!-- Dynamic pages will be inserted here -->
                                <li class="page-item disabled" data-list-pagination="next">
                                    <a class="page-link" href="#">@Html.SmartLocalize("Next")</a>
                                </li>
                            </ul>
                        </nav>
                    </div>


                  

                </div>
            </div>
        </div>
    </div>
</div>





@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

    <script src="~/js/pages/Sales/PriceQuotationList.js"></script>

   
}