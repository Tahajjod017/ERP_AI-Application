                                    <option value="">Select Receiver</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-sm-6 col-md-6">
                            <div class="mb-3">
                                <label for="warehouseName">Warehouse Name</label>
                                <select class="form-select choiceDD" id="warehouseName" asp-items="@ViewBag.WareHouseDD as SelectList">
                                    <option value="0">Select Warehouse</option>
                                </select>
                            </div>
                        </div>

                    </form>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-primary" type="button">Okay</button>
                <button class="btn btn-outline-primary" type="button" data-bs-dismiss="modal">Cancel</button>
            </div>
        </div>
    </div>
</div>



<script src="~/lib/jquery/dist/jquery.min.js"></script>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="~/js/pages/RequisitionDistribtion/ProductPurchase.js"></script>
}