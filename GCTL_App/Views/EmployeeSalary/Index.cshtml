@model GCTL.Core.ViewModels.Employee.EmployeeSalary.EmployeeSalaryPostViewModel

<div class="mb-9">
    <div class="row align-items-center justify-content-between g-3 mb-4">
        <div class="col-auto">
        </div>
    </div>

    <div class="px-3 mb-5">
        <div class="row">
            <div class="col-12">
                <form asp-action="Index" method="post">
                    <div class="row g-2 align-items-center">
                        <div class="col-md-3">
                            <div class="position-relative">
                                <input class="form-control search-input search" type="search" placeholder="@Html.SmartLocalize("Employee Name / Phone / Email")" aria-label="Search" />
                                <span class="fas fa-search search-box-icon position-absolute top-50 end-0 translate-middle-y me-3"></span>
                            </div>
                        </div>

                        <div class="col-md-3"></div>

                        <div class="col-md-2">
                            <div class="form-floating form-floating-advance-select mb-2">
                                <label asp-for="EmployeePersonalId">@Html.SmartLocalize("Choose Employee")</label>
                                <select class="form-select" asp-for="EmployeePersonalId" asp-items="@ViewBag.EmployeeDD as SelectList">
                                    <option value="">@Html.SmartLocalize("Select Employee")</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-floating">
                                <input asp-for="PersonalEmail" class="form-control" type="email" placeholder="@Html.SmartLocalize("Email")" />
                                <label asp-for="PersonalEmail">@Html.SmartLocalize("Email")</label>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-floating">
                                <input asp-for="PersonalPhone" class="form-control" type="text" placeholder="@Html.SmartLocalize("Enter Phone")" />
                                <label asp-for="PersonalPhone">@Html.SmartLocalize("Phone")</label>
                            </div>
                        </div>
                    </div>

                    <div class="mx-n4 mx-lg-n6 px-lg-6 bg-body-emphasis pb-4">
                        <div class="col-12 col-xl-12 col-xxl-12">
                            <ul class="nav nav-underline fs-9 deal-details scrollbar flex-nowrap w-100 py-2 mb-2 mx-2" id="myTab" role="tablist">
                                <li class="nav-item text-nowrap me-2" role="presentation" id="headingPInfo">
                                    <a class="nav-link" href="/EmployeePersonal/index" role="tab" aria-selected="true" aria-controls="empPersonalInfo">
                                        <span class="fa-solid fa-user me-2 tab-icon-color"></span>@Html.SmartLocalize("Personal Info.")
                                    </a>
                                </li>
                                <li class="nav-item text-nowrap me-2" role="presentation" id="headingEmpOfficialInfo">
                                    <a class="nav-link" href="/EmployeeOfficial/index" role="tab" aria-selected="false" aria-controls="empOfficialInfo">
                                        <span class="fa-solid fa-file-alt me-2 tab-icon-color"></span>@Html.SmartLocalize("Official Info.")
                                    </a>
                                </li>
                                <li class="nav-item text-nowrap me-2" role="presentation" id="headingempPayroleInfo">
                                    <a class="nav-link active" href="/EmployeeSalary/index" role="tab" aria-selected="false" aria-controls="empPayroleInfo">
                                        <span class="fa-solid fa-file-alt me-2 tab-icon-color"></span>@Html.SmartLocalize("Payroll Info.")
                                    </a>
                                </li>
                                <li class="nav-item text-nowrap me-2" role="presentation" id="headingAdditionalInfo">
                                    <a class="nav-link" href="/EmployeeAdditional/index" role="tab" aria-selected="false" aria-controls="additionalInfo">
                                        <span class="fa-solid fa-square-check me-2 tab-icon-color"></span>@Html.SmartLocalize("Additional Info.")
                                    </a>
                                </li>
                                <li class="nav-item text-nowrap me-2" role="presentation" id="headingeducationInfo">
                                    <a class="nav-link" href="/EmployeeEducation/index" role="tab" aria-selected="false" aria-controls="educationInfo">
                                        <span class="fa-solid fa-square-check me-2 tab-icon-color"></span>@Html.SmartLocalize("Education Info.")
                                    </a>
                                </li>
                                <li class="nav-item text-nowrap me-2" role="presentation" id="headingTranningInfo">
                                    <a class="nav-link" href="/EmployeeTraining/index" role="tab" aria-selected="false" aria-controls="tranningInfo">
                                        <span class="fa-solid fa-square-check me-2 tab-icon-color"></span>@Html.SmartLocalize("Training Info.")
                                    </a>
                                </li>
                                <li class="nav-item text-nowrap me-2" role="presentation" id="headingFamilyInfo">
                                    <a class="nav-link" href="/EmployeeFamily/index" role="tab" aria-selected="false" aria-controls="familyInfo">
                                        <span class="fa-solid fa-square-check me-2 tab-icon-color"></span>@Html.SmartLocalize("Family Info.")
                                    </a>
                                </li>
                            </ul>
                            <div class="card tab-content bg-white accordion" id="myTabContent">
                                <div class="tab-pane fade show active p-2" role="tabpanel" id="empPayroleInfo" aria-labelledby="empPayroleInfo">
                                    <div class="px-25">
                                        <ul class="nav nav-underline fs-9" id="myTab" role="tablist">
                                            <li class="nav-item" role="presentation">
                                                <a class="nav-link active" id="empSalary-tab" href="#" role="tab" aria-controls="tab-empSalary" aria-selected="true">@Html.SmartLocalize("Employee Salary Settings")</a>
                                            </li>
                                            <li class="nav-item" role="presentation">
                                                <a class="nav-link" id="empBenefits-tab" href="/EmployeeAllowance/index" role="tab" aria-controls="tab-empBenefits" aria-selected="false" tabindex="-1">@Html.SmartLocalize("Employee Benefits")</a>
                                            </li>
                                            <li class="nav-item" role="presentation">
                                                <a class="nav-link" id="empAllowance-tab" href="/EmployeeBenifit/index" role="tab" aria-controls="tab-empAllowance" aria-selected="false" tabindex="-1">@Html.SmartLocalize("Employee Allowance")</a>
                                            </li>
                                        </ul>
                                        <div class="tab-content mt-3" id="myTabContent">
                                            <div class="tab-pane fade show active" id="tab-empSalary" role="tabpanel" aria-labelledby="empSalary-tab">
                                                <div class="card">
                                                    <div class="d-flex justify-content-center mt-2">
                                                        <div class="col-12 row flex gy-3">
                                                            <p class="border-bottom mt-6">@Html.SmartLocalize("Salary Account Information")</p>

                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating">
                                                                    <input asp-for="BankName" class="form-control" type="text" placeholder="@Html.SmartLocalize("Bank Name")" />
                                                                    <label asp-for="BankName">@Html.SmartLocalize("Bank Name")</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating">
                                                                    <input asp-for="BranchName" class="form-control" type="text" placeholder="@Html.SmartLocalize("Branch Name")" />
                                                                    <label asp-for="BranchName">@Html.SmartLocalize("Branch Name")</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating">
                                                                    <input asp-for="Address" class="form-control" type="text" placeholder="@Html.SmartLocalize("Address")" />
                                                                    <label asp-for="Address">@Html.SmartLocalize("Address")</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating">
                                                                    <input asp-for="AccountName" class="form-control" type="text" placeholder="@Html.SmartLocalize("A/C Name")" />
                                                                    <label asp-for="AccountName">@Html.SmartLocalize("A/C Name")</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating">
                                                                    <input asp-for="AccountNo" class="form-control" type="text" placeholder="@Html.SmartLocalize("A/C Number")" />
                                                                    <label asp-for="AccountNo">@Html.SmartLocalize("A/C Number")</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating">
                                                                    <input asp-for="ATMCardNo" class="form-control" type="text" placeholder="@Html.SmartLocalize("ATM Card No")" />
                                                                    <label asp-for="ATMCardNo">@Html.SmartLocalize("ATM Card No")</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating">
                                                                    <input asp-for="RoutingNo" class="form-control" type="text" placeholder="@Html.SmartLocalize("Routing No")" />
                                                                    <label asp-for="RoutingNo">@Html.SmartLocalize("Routing No")</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating">
                                                                    <input asp-for="SWIFTCode" class="form-control" type="text" placeholder="@Html.SmartLocalize("Swift Code")" />
                                                                    <label asp-for="SWIFTCode">@Html.SmartLocalize("Swift Code")</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating">
                                                                    <input asp-for="IFSCCode" class="form-control" type="text" placeholder="@Html.SmartLocalize("IFSC Code")" />
                                                                    <label asp-for="IFSCCode">@Html.SmartLocalize("IFSC Code")</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating">
                                                                    <input asp-for="bKashAccountNo" class="form-control" type="text" placeholder="@Html.SmartLocalize("Bkash A/C Number")" />
                                                                    <label asp-for="bKashAccountNo">@Html.SmartLocalize("Bkash A/C Number")</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating">
                                                                    <input asp-for="RoketAccountNo" class="form-control" type="text" placeholder="@Html.SmartLocalize("Rocket A/C Number")" />
                                                                    <label asp-for="RoketAccountNo">@Html.SmartLocalize("Rocket A/C Number")</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating">
                                                                    <input asp-for="NagodAccountNo" class="form-control" type="text" placeholder="@Html.SmartLocalize("Nagad A/C Number")" />
                                                                    <label asp-for="NagodAccountNo">@Html.SmartLocalize("Nagad A/C Number")</label>
                                                                </div>
                                                            </div>

                                                            <p class="border-bottom mt-6">@Html.SmartLocalize("Salary Information")</p>

                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating">
                                                                    <input asp-for="EmployeeGID" class="form-control" type="text" placeholder="@Html.SmartLocalize("Employee ID")" />
                                                                    <label asp-for="EmployeeGID">@Html.SmartLocalize("Employee ID")</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating form-floating-advance-select">
                                                                    <select class="form-select" id="salaryType" data-choices="data-choices" data-options='{"removeItemButton":true,"placeholder":true}'>
                                                                        <option selected="selected" value="">@Html.SmartLocalize("Select Salary Type")</option>
                                                                        <option value="Basic">Basic Salary</option>
                                                                        <option value="Gross">Gross Salary</option>
                                                                    </select>
                                                                    <label for="salaryType">@Html.SmartLocalize("Salary Type")</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating form-floating-advance-select">
                                                                    <select asp-for="GradeID" class="form-select" id="gradeNo" data-choices="data-choices" data-options='{"removeItemButton":true,"placeholder":true}'>
                                                                        <option selected="selected" value="">@Html.SmartLocalize("Select Grade No")</option>
                                                                        <option value="3">G-3</option>
                                                                        <option value="4">G-4</option>
                                                                        <option value="6">G-6</option>
                                                                        <option value="9">G-9</option>
                                                                        <option value="10">G-10</option>
                                                                        <option value="11">G-11</option>
                                                                    </select>
                                                                    <label asp-for="GradeID">@Html.SmartLocalize("Grade No")</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating">
                                                                    <input asp-for="Salary" class="form-control" type="number" step="0.01" placeholder="@Html.SmartLocalize("Enter Salary")" />
                                                                    <label asp-for="Salary">@Html.SmartLocalize("Salary")</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating form-floating-advance-select">
                                                                    <select asp-for="CurrencyID" class="form-select" id="currency" data-choices="data-choices" data-options='{"removeItemButton":true,"placeholder":true}'>
                                                                        <option selected="selected" value="">@Html.SmartLocalize("Select Currency")</option>
                                                                        <option value="1">BDT</option>
                                                                        <option value="2">USD</option>
                                                                    </select>
                                                                    <label asp-for="CurrencyID">@Html.SmartLocalize("Currency")</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating form-floating-advance-select">
                                                                    <select class="form-select" id="paymentPeriod" data-choices="data-choices" data-options='{"removeItemButton":true,"placeholder":true}'>
                                                                        <option selected="selected" value="Monthly">@Html.SmartLocalize("Monthly")</option>
                                                                        <option value="Daily">@Html.SmartLocalize("Daily")</option>
                                                                        <option value="Weekly">@Html.SmartLocalize("Weekly")</option>
                                                                        <option value="Quaterly">@Html.SmartLocalize("Quarterly")</option>
                                                                        <option value="Half-Yearly">@Html.SmartLocalize("Half-Yearly")</option>
                                                                        <option value="Yearly">@Html.SmartLocalize("Yearly")</option>
                                                                    </select>
                                                                    <label for="paymentPeriod">@Html.SmartLocalize("Payment Period")</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-12 col-md-4 mb-4">
                                                                <div class="form-floating form-floating-advance-select">
                                                                    <label for="paymentMode">@Html.SmartLocalize("Payment Mode")</label>
                                                                    <select class="form-select" id="paymentMode" data-choices="data-choices" multiple="multiple" data-options='{"removeItemButton":true,"placeholder":true}'>
                                                                        <option value="Bank Account">@Html.SmartLocalize("Bank Account")</option>
                                                                        <option value="Cash" selected>@Html.SmartLocalize("Cash")</option>
                                                                        <option value="CHK">@Html.SmartLocalize("CHK")</option>
                                                                        <option value="Bkash">@Html.SmartLocalize("Bkash")</option>
                                                                        <option value="Rocket">@Html.SmartLocalize("Rocket")</option>
                                                                        <option value="Nagad">@Html.SmartLocalize("Nagad")</option>
                                                                    </select>
                                                                </div>
                                                            </div>

                                                            <div class="row" id="multyPayment" style="display: none;">
                                                                <div class="d-flex">
                                                                    <div class="col-sm-6 col-md-4 me-3">
                                                                        <div class="form-floating form-floating-advance-select">
                                                                            <select class="form-select" id="primaryPaymentMode" data-choices="data-choices" data-options='{"removeItemButton":true,"placeholder":true}'>
                                                                                <option selected="selected" value="">@Html.SmartLocalize("Select Payment Mode")</option>
                                                                                <option value="Bank Account">@Html.SmartLocalize("Bank Account")</option>
                                                                                <option value="Cash">@Html.SmartLocalize("Cash")</option>
                                                                                <option value="CHK">@Html.SmartLocalize("CHK")</option>
                                                                                <option value="Bkash">@Html.SmartLocalize("Bkash")</option>
                                                                                <option value="Rocket">@Html.SmartLocalize("Rocket")</option>
                                                                                <option value="Nagad">@Html.SmartLocalize("Nagad")</option>
                                                                            </select>
                                                                            <label for="primaryPaymentMode">@Html.SmartLocalize("Primary Payment Mode")</label>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-sm-6 col-md-4 me-3">
                                                                        <div class="form-floating">
                                                                            <input class="form-control" id="primaryPaymentPercentage" type="text" placeholder="@Html.SmartLocalize("% of Primary Payment Mode")" />
                                                                            <label for="primaryPaymentPercentage">@Html.SmartLocalize("% of Primary Payment Mode")</label>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-sm-6 col-md-4">
                                                                        <div class="form-floating form-floating-advance-select">
                                                                            <select class="form-select" id="secondaryPaymentMode" data-choices="data-choices" data-options='{"removeItemButton":true,"placeholder":true}'>
                                                                                <option selected="selected" value="">@Html.SmartLocalize("Select Payment Mode")</option>
                                                                                <option value="Bank Account">@Html.SmartLocalize("Bank Account")</option>
                                                                                <option value="Cash">@Html.SmartLocalize("Cash")</option>
                                                                                <option value="CHK">@Html.SmartLocalize("CHK")</option>
                                                                                <option value="Bkash">@Html.SmartLocalize("Bkash")</option>
                                                                                <option value="Rocket">@Html.SmartLocalize("Rocket")</option>
                                                                                <option value="Nagad">@Html.SmartLocalize("Nagad")</option>
                                                                            </select>
                                                                            <label for="secondaryPaymentMode">@Html.SmartLocalize("Secondary Payment Mode")</label>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>

                                                            <div class="col-12 mb-3">
                                                                <div class="row g-3 justify-content-end">
                                                                    <div class="col-auto">
                                                                        <button class="btn btn-phoenix-primary px-5" type="button">@Html.SmartLocalize("Cancel")</button>
                                                                    </div>
                                                                    <div class="col-auto">
                                                                        <button class="btn btn-primary px-5 px-sm-15" type="submit">@Html.SmartLocalize("Save")</button>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>



<script>
    document.addEventListener('DOMContentLoaded', function() {
        const selectElement = document.getElementById('organizerMultiple');
        const multiPaymentDiv = document.getElementById('multyPayment');

        selectElement.addEventListener('change', function() {
            // Get all selected options (excluding the placeholder if selected)
            const selectedOptions = Array.from(this.selectedOptions)
                .filter(option => option.value !== '');

            // Show the div if more than one option is selected, otherwise hide it
            if (selectedOptions.length > 1) {
                multiPaymentDiv.style.display = 'block';
            } else {
                multiPaymentDiv.style.display = 'none';
            }
        });
    });
</script>