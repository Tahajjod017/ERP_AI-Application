@using GCTL.Core.ViewModels.Employee.EmployeeNavigtion
@model GCTL.Core.ViewModels.Employee.EmployeeSalary.EmployeeSalaryPostViewModel

<div class="mb-9">
    <div class="row align-items-center justify-content-between g-3 mb-4">
        <div class="col-auto">
        </div>
    </div>

    <div class="px-3 mb-5">
        <div class="row">
            <div class="col-12">
                <form asp-controller="EmployeeSalary" asp-action="Index" method="post">

                    <input type="hidden" asp-for="EmployeeSalarySettingsID" />

                    <div class="row g-2 align-items-center">
                        <div class="col-md-3">
                            <div class="position-relative">
                                <input class="form-control search-input search" type="search" placeholder="@Html.SmartLocalize("Employee Name / Phone / Email")" aria-label="Search" />
                                <span class="fas fa-search search-box-icon position-absolute top-50 end-0 translate-middle-y me-3"></span>
                            </div>
                        </div>

                        <div class="col-md-3"></div>

                        <div class="col-md-2">
                            <div class="form-floating form-floating-advance-select mb-2">
                                <label asp-for="EmployeePersonalId">@Html.SmartLocalize("Choose Employee")</label>
                                <select class="form-select" asp-for="EmployeePersonalId" asp-items="@ViewBag.EmployeeDD as SelectList">
                                    <option value="">@Html.SmartLocalize("Select Employee")</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2  mb-2">
                            <div class="form-floating">
                                <input asp-for="PersonalEmail" class="form-control" type="email" placeholder="@Html.SmartLocalize("Email")" />
                                <label asp-for="PersonalEmail">@Html.SmartLocalize("Email")</label>
                            </div>
                        </div>
                        <div class="col-md-2 mb-2">
                            <div class="form-floating">
                                <input asp-for="PersonalPhone" class="form-control" type="text" placeholder="@Html.SmartLocalize("Enter Phone")" />
                                <label asp-for="PersonalPhone">@Html.SmartLocalize("Phone")</label>
                            </div>
                        </div>
                    </div>

                    <div class="mx-n4 mx-lg-n6 px-lg-6 bg-body-emphasis pb-4">
                        <div class="col-12 col-xl-12 col-xxl-12">

                            @await Html.PartialAsync("Employee/_EmployeeNavigation", ViewBag.Navigation as EmployeeNavigationViewModel)

                           

                            <div class="card tab-content bg-white accordion" id="myTabContent">
                                <div class="tab-pane fade show active p-2" role="tabpanel" id="empPayroleInfo" aria-labelledby="empPayroleInfo">
                                    <div class="px-25">
                                        
                                        <div class="tab-content mt-3" id="myTabContent">
                                            <div class="tab-pane fade show active" id="tab-empSalary" role="tabpanel" aria-labelledby="empSalary-tab">
                                                <div class="card">
                                                    <div class="d-flex justify-content-center mt-2">
                                                        <div class="col-12 row flex gy-3">
                                                            <p class="border-bottom mt-6">@Html.SmartLocalize("Salary Account Information")</p>

                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating">
                                                                    <input asp-for="BankName" class="form-control" type="text" placeholder="@Html.SmartLocalize("Bank Name")" />
                                                                    <label asp-for="BankName">@Html.SmartLocalize("Bank Name")</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating">
                                                                    <input asp-for="BranchName" class="form-control" type="text" placeholder="@Html.SmartLocalize("Branch Name")" />
                                                                    <label asp-for="BranchName">@Html.SmartLocalize("Branch Name")</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating">
                                                                    <input asp-for="Address" class="form-control" type="text" placeholder="@Html.SmartLocalize("Address")" />
                                                                    <label asp-for="Address">@Html.SmartLocalize("Address")</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating">
                                                                    <input asp-for="AccountName" class="form-control" type="text" placeholder="@Html.SmartLocalize("A/C Name")" />
                                                                    <label asp-for="AccountName">@Html.SmartLocalize("A/C Name")</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating">
                                                                    <input asp-for="AccountNo" class="form-control" type="text" placeholder="@Html.SmartLocalize("A/C Number")" />
                                                                    <label asp-for="AccountNo">@Html.SmartLocalize("A/C Number")</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating">
                                                                    <input asp-for="ATMCardNo" class="form-control" type="text" placeholder="@Html.SmartLocalize("ATM Card No")" />
                                                                    <label asp-for="ATMCardNo">@Html.SmartLocalize("ATM Card No")</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating">
                                                                    <input asp-for="RoutingNo" class="form-control" type="text" placeholder="@Html.SmartLocalize("Routing No")" />
                                                                    <label asp-for="RoutingNo">@Html.SmartLocalize("Routing No")</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating">
                                                                    <input asp-for="SWIFTCode" class="form-control" type="text" placeholder="@Html.SmartLocalize("Swift Code")" />
                                                                    <label asp-for="SWIFTCode">@Html.SmartLocalize("Swift Code")</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating">
                                                                    <input asp-for="IFSCCode" class="form-control" type="text" placeholder="@Html.SmartLocalize("IFSC Code")" />
                                                                    <label asp-for="IFSCCode">@Html.SmartLocalize("IFSC Code")</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating">
                                                                    <input asp-for="bKashAccountNo" class="form-control" type="text" placeholder="@Html.SmartLocalize("Bkash A/C Number")" />
                                                                    <label asp-for="bKashAccountNo">@Html.SmartLocalize("Bkash A/C Number")</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating">
                                                                    <input asp-for="RoketAccountNo" class="form-control" type="text" placeholder="@Html.SmartLocalize("Rocket A/C Number")" />
                                                                    <label asp-for="RoketAccountNo">@Html.SmartLocalize("Rocket A/C Number")</label>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating">
                                                                    <input asp-for="NagodAccountNo" class="form-control" type="text" placeholder="@Html.SmartLocalize("Nagad A/C Number")" />
                                                                    <label asp-for="NagodAccountNo">@Html.SmartLocalize("Nagad A/C Number")</label>
                                                                </div>
                                                            </div>

                                                            <p class="border-bottom mt-6">@Html.SmartLocalize("Salary Information")</p>


                                                           
                                                            

                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating form-floating-advance-select mb-2">
                                                                    <label asp-for="GradeID">@Html.SmartLocalize("Grade No")</label>
                                                                    <select class="form-select" asp-for="GradeID" asp-items="@ViewBag.GradeDD as SelectList">
                                                                        <option value="">@Html.SmartLocalize("Select Grade No")</option>
                                                                    </select>
                                                                </div>
                                                            </div>


                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating">
                                                                    <input asp-for="Salary" class="form-control" type="number" step="0.01" placeholder="@Html.SmartLocalize("Enter Salary")" />
                                                                    <label asp-for="Salary">@Html.SmartLocalize("Salary")</label>
                                                                </div>
                                                            </div>
                                                           

                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating form-floating-advance-select mb-2">
                                                                    <label asp-for="CurrencyID">@Html.SmartLocalize("Currency")</label>
                                                                    <select class="form-select" asp-for="CurrencyID" asp-items="@ViewBag.CurrencyDD as SelectList">
                                                                        <option value="">@Html.SmartLocalize("Select Currency")</option>
                                                                    </select>
                                                                </div>
                                                            </div>

                                                            <div class="col-sm-12 col-md-4">
                                                                <div class="form-floating form-floating-advance-select mb-2">
                                                                    <label asp-for="PaymenPeriodTypeID">@Html.SmartLocalize("Payment Period")</label>
                                                                    <select class="form-select" asp-for="PaymenPeriodTypeID" asp-items="@ViewBag.PaymenPeriodTypeDD as SelectList">
                                                                        <option value="">@Html.SmartLocalize("Select Payment Period")</option>
                                                                    </select>
                                                                </div>
                                                            </div>
                                                            

                                                            
                                                            <div class="col-sm-12 col-md-4 mb-3">
                                                                <div class="form-floating form-floating-advance-select mb-2">
                                                                    <label asp-for="PaymentModeIds">@Html.SmartLocalize("Payment Mode")</label>
                                                                 
                                                                    <select class="form-select" asp-for="PaymentModeIds" asp-items="@ViewBag.PaymenModeDD as SelectList" id="PaymentModeId" multiple>
                                                                        <option value="">@Html.SmartLocalize("Select Payment Mode")</option>
                                                                    </select>

                                                                </div>
                                                            </div>


                                                            

                                                            <div class="row" id="multyPayment" style="display: none;">
                                                                <div class="d-flex">
                                                                    <div class="col-sm-6 col-md-4 me-3">
                                                                        


                                                                        <div class="form-floating form-floating-advance-select mb-2">
                                                                            <label asp-for="PrimaryPaymentModeId">@Html.SmartLocalize("Primary Payment Mode")</label>
                                                                            <select class="form-select" asp-for="PrimaryPaymentModeId" id="primaryPaymentMode" asp-items="@ViewBag.PaymenModeDD as SelectList">
                                                                                <option value="">@Html.SmartLocalize("Select Primary Payment Mode")</option>
                                                                            </select>
                                                                        </div>


                                                                    </div>
                                                                    <div class="col-sm-6 col-md-4 me-3">
                                                                        <div class="form-floating">
                                                                            <input class="form-control" asp-for="PrimaryPaymentPercent" id="primaryPaymentPercentage" type="text" placeholder="@Html.SmartLocalize("% of Primary Payment Mode")" />
                                                                            <label asp-for="PrimaryPaymentPercent">@Html.SmartLocalize("% of Primary Payment Mode")</label>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-sm-6 col-md-4">
                                                                        

                                                                        <div class="form-floating form-floating-advance-select mb-2">
                                                                            <label asp-for="SecondaryPaymentModeId">@Html.SmartLocalize("Secondary Payment Mode")</label>
                                                                            <select class="form-select" asp-for="SecondaryPaymentModeId" id="secondaryPaymentMode" asp-items="@ViewBag.PaymenModeDD as SelectList">
                                                                                <option value="">@Html.SmartLocalize("Select Secondary Payment Mode")</option>
                                                                            </select>
                                                                        </div>

                                                                    </div>
                                                                </div>
                                                            </div>

                                                            <div class="col-12 mb-3">
                                                                <div class="row g-3 justify-content-end">
                                                                    <div class="col-auto">
                                                                        <button class="btn btn-phoenix-primary px-5" type="button">@Html.SmartLocalize("Cancel")</button>
                                                                    </div>
                                                                    <div class="col-auto">
                                                                        <button class="btn btn-primary px-5 px-sm-15" type="submit">@Html.SmartLocalize("Save")</button>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="mb-3">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success" role="alert">
            @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger" role="alert">
            @TempData["ErrorMessage"]
        </div>
    }
</div>




@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
	
    <script src="~/js/pages/employees/employeesalary.js"></script>
    <script src="~/js/pages/employees/employeetabchange.js"></script>

}