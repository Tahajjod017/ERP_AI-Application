@model GCTL.Core.ViewModels.MasterSetup.Country.CountryVM

<div class="card h-100">
    <div class="card-header border-bottom-1">
        <div class="row justify-content-between align-items-center">
            <div class="col-auto">
                <h3 class="text-body-emphasis mt-3">@Html.SmartLocalize("Add Country")</h3>
            </div>
        </div>
    </div>

    <div class="card-body mt-2">
        <form asp-action="Create" asp-controller="Countrys" method="post" enctype="multipart/form-data" id="country-form">
            @Html.AntiForgeryToken()
            <div class="col-sm-12 col-md-12 mb-2">
                <input type="hidden" asp-for="CountryID" />
                <div class="flatpickr-input-container">
                    <div class="form-floating">
                        <input class="form-control" asp-for="CountryCode" type="text" placeholder="@Html.SmartLocalize("Country Code")" autocomplete="off" />
                        <label asp-for="CountryCode">@Html.SmartLocalize("Country Code")</label>
                    </div>
                </div>
            </div>

            <div class="col-sm-12 col-md-12 mb-2">
                <div class="flatpickr-input-container">
                    <div class="form-floating">
                        <input class="form-control" asp-for="CountryName" type="text" placeholder="@Html.SmartLocalize("Country Name")" autocomplete="off" />
                        <label asp-for="CountryName">@Html.SmartLocalize("Country Name") <span style="color: red;">*</span></label>
                    </div>
                    <span id="nameError" class="text-danger" style="display:none;"></span>
                </div>
            </div>

            <div class="col-12 mb-2">
                <div class="row g-3 justify-content-end">
                    <div class="col-auto">
                        <button type="reset" class="btn btn-phoenix-primary px-5" id="country-resetBtn">@Html.SmartLocalize("Reset")</button>
                    </div>
                    <div class="col-auto">
                        <button type="submit" class="btn btn-primary px-5 px-sm-15" id="country-saveBtn">@Html.SmartLocalize("Save")</button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
