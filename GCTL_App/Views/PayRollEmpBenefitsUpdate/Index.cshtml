
<select id="percentageOptionsTemplate" style="display:none">
    @if (ViewBag.PercenatageDD != null)
    {
        foreach (SelectListItem item in (SelectList)ViewBag.PercenatageDD)
        {
            <option value="@item.Value">@item.Text</option>
        }
    }
</select>


<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/plugins/monthSelect/style.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/themes/dark.css">

<style>
    .flatpickr-monthSelect-months {
        display: grid;
        grid-template-columns: repeat(3, 1fr); /* 3 equal columns */
        gap: 10px; /* Space between months */
        margin: 10px 1px 3px 1px;
    }

    /* Styling for individual months */
    .flatpickr-monthSelect-month {
        background: none;
        border: 1px solid transparent;
        border-radius: 4px;
        box-sizing: border-box;
        color: #393939;
        cursor: pointer;
        display: flex; /* Use flexbox to center the text inside the month */
        justify-content: center;
        padding: 10px;
        position: relative;
        text-align: center;
        width: 100%; /* Make sure it takes full width of the column */
    }

        /* Disabled month styling */
        .flatpickr-monthSelect-month.flatpickr-disabled {
            color: #eee;
        }

            .flatpickr-monthSelect-month.flatpickr-disabled:hover,
            .flatpickr-monthSelect-month.flatpickr-disabled:focus {
                cursor: not-allowed;
                background: none !important;
            }

    /* Dark theme adjustments */
    .flatpickr-monthSelect-theme-dark {
        background: #3f4458;
    }

        .flatpickr-monthSelect-theme-dark .flatpickr-monthSelect-month {
            color: rgba(255, 255, 255, 0.95);
        }

            .flatpickr-monthSelect-theme-dark .flatpickr-monthSelect-month.selected {
                background-color: #80cbc4;
                color: #fff;
                border-color: #80cbc4;
            }

    /* Styling for today’s month */
    .flatpickr-monthSelect-month.today {
        border-color: #959ea9;
    }

    .flatpickr-monthSelect-month.selected,
    .flatpickr-monthSelect-month.startRange,
    .flatpickr-monthSelect-month.endRange {
        background-color: #569ff7;
        box-shadow: none;
        color: #fff;
        border-color: #569ff7;
    }

    /* Range selection */
    .flatpickr-monthSelect-month.startRange {
        border-radius: 50px 0 0 50px;
    }

    .flatpickr-monthSelect-month.endRange {
        border-radius: 0 50px 50px 0;
    }

    .flatpickr-monthSelect-month.inRange {
        border-radius: 0;
        box-shadow: -5px 0 0 #e6e6e6, 5px 0 0 #e6e6e6;
    }
</style>

<div class="mb-2">

    <div class="card">

        <div class="card-header ">
            <h4 class="mb-1">Add Employee Benefits</h4>

            <div class="">
                <form id="payrollEmpBenefitsForm" class="row g-3">

                    <div class="col-md-6">
                        
                        <div class="mb-0">
                            <div class="content-head d-flex justify-content-between align-items-center">
                                <label class="form-label" for="organizerSingle">Company Name</label>
                            </div>
                            <select class="form-multi-select choiceDD" id="OrganizationID" asp-items="@ViewBag.OrganizationDD">
                                <option value="">Select Company</option>
                            </select>
                            <span id="OrganizationID-error" class="text-danger"></span>
                        </div>

                    </div>

                    <div class="card">

                        <div id="EmployeeAllowanceAccordion"></div>
                    </div>

                </form>
            </div>
        </div>

    </div>


</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/js/pages/payrollmanagements/payrollpolicy/PayRollEmpBenefitsUpdate.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/plugins/monthSelect/index.js"></script>
  

}
