<!-- Waiting for Promotion Approval Table -->
<div class="mb-4">
    <div class="card">
        <div class="card-header d-flex align-items-center justify-content-between flex-wrap row-gap-3 mb-1">
            <h4 class="mb-1">@Html.SmartLocalize("Waiting for Promotion Approval")</h4>
            <div class="d-flex my-xl-auto right-content align-items-center flex-wrap row-gap-3">

                <div class="me-3">
                    <input class="form-control" id="searchInputPe" type="text" placeholder="@Html.SmartLocalize("Search by Employee Name")">
                </div>

                <div class="dropdown me-3">
                    <div class="columnDrag PromotionPendingTblDy"></div>
                </div>

                <div class="dropdown me-3">
                    <select class="form-select choiceDD" id="department" asp-items="@ViewBag.DepartmentDD as SelectList">
                        <option value="">@Html.SmartLocalize("Select department")</option>

                    </select>
                </div>


                <div class="dropdown me-3">
                    <div class="input-icon-end position-relative">
                        <input class="form-control datetimepicker flatpickr-input caiCon" id="timepicker2" type="text" placeholder="@Html.SmartLocalize("d/m/y to d/m/y")" data-options='{"mode":"range","dateFormat":"d/m/y","disableMobile":true}' readonly="readonly">
                    </div>
                </div>


                <div class="dropdown me-3">
                    <select class="form-select choiceDD" id="promotionType" asp-items="@ViewBag.IncrementTypeList as SelectList">
                        <option value="">@Html.SmartLocalize("Promotion Type")</option>

                    </select>
                </div>

                <div class="dropdown me-3">
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text">@Html.SmartLocalize("Showing")</span>
                        </div>
                        <select class="form-select" id="pageSizeSelect" data-choices="data-choices" size="1" name="pageSizeSelect" data-options='{"removeItemButton":true,"placeholder":true}'>
                            <option value="10">10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                            <option value="100">100</option>
                        </select>
                    </div>
                </div>

                @*<div class="dropdown me-3">
                        <select class="form-select" id="statusSelect" data-choices="data-choices" size="1" required="required" name="statusSelect" data-options='{"removeItemButton":true,"placeholder":true}'>
                            <option value="">@Html.SmartLocalize("Select Status")</option>
                            <option>@Html.SmartLocalize("Approved")</option>
                            <option>@Html.SmartLocalize("Declined")</option>
                            <option>@Html.SmartLocalize("Pending")</option>
                        </select>
                    </div>*@


            </div>
        </div>

        <div class="border-translucent p-3">
            <div id="promotionApprovalTable">
                <div class="table-responsive scrollbar mx-n1 px-1">
                    <table class="table table-sm fs-9 leads-table dyn-tableDrag PromotionPendingTblDy" id="promPending">
                        <thead>
                            <tr>
                                <th class="white-space-nowrap fs-9 align-middle ps-0" style="max-width:20px; width:18px;">
                                    <div class="form-check mb-0 fs-8">
                                        <input class="form-check-input" type="checkbox" data-bulk-select='{"body":"promotion-approval-body"}' />
                                    </div>
                                </th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="employeeName" data-column="0">@Html.SmartLocalize("Employee Name")</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="currentPosition" data-column="1">@Html.SmartLocalize("Current Position")</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="proposedPosition" data-column="2">@Html.SmartLocalize("Proposed Position")</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="currentSalary" data-column="3">@Html.SmartLocalize("Current Salary")</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="proposedSalary" data-column="4">@Html.SmartLocalize("Proposed Salary")</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="effectiveDate" data-column="5">@Html.SmartLocalize("Effective Date")</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="decision" data-column="6">@Html.SmartLocalize("Decision")</th>

                            </tr>
                        </thead>
                        <tbody class="list" id="pending-promotion-body">
                        </tbody>
                    </table>
                </div>

                <div class="row align-items-center justify-content-between pe-0 fs-9">
                    <div class="col-auto d-flex">
                        <p class="mb-0 d-none d-sm-block me-3 fw-semibold text-body" data-list-info="data-list-info"></p>
                        @*<a class="fw-semibold" href="#!" data-list-view="*">@Html.SmartLocalize("View all")<span class="fas fa-angle-right ms-1" data-fa-transform="down-1"></span></a>
                            <a class="fw-semibold d-none" href="#!" data-list-view="less">@Html.SmartLocalize("View Less")<span class="fas fa-angle-right ms-1" data-fa-transform="down-1"></span></a>*@
                    </div>
                    <div class="col-auto d-flex">
                        <button class="page-link" data-list-pagination="prev"><span class="fas fa-chevron-left"></span></button>
                        <ul class="mb-0 pagination"></ul>
                        <button class="page-link pe-0" data-list-pagination="next"><span class="fas fa-chevron-right"></span></button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>



