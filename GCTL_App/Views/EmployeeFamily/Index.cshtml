                                                    </div>
                                                </div>

                                                <div class="col-sm-6 col-md-6">
                                                    <div class="form-floating">
                                                        <input class="form-control" id="" type="text" placeholder="Occupation" required />
                                                        <label for="">Occupation</label>
                                                    </div>
                                                </div>

                                                <div class="col-sm-6 col-md-6">
                                                    <div class="form-floating">
                                                        <select class="form-select" id="year-of-passing" name="year-of-passing" required>
