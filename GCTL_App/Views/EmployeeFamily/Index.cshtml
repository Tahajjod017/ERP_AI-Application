                                                <script>
                                                    // Get the file input element and image preview element
                                                    const epImageUpload = document.getElementById('epImageUpload');
                                                    const epImagePreview = document.getElementById('epImagePreview');
                                                    const esImageUpload = document.getElementById('esImageUpload');
                                                    const esImagePreview = document.getElementById('esImagePreview');

                                                    // Event listener for the file input
                                                    epImageUpload.addEventListener('change', function(event) {
                                                        const file = event.target.files[0]; // Get the first file selected

                                                        // If a file is selected
                                                        if (file) {
                                                            // Create a FileReader object to read the file
                                                            const reader = new FileReader();

                                                            // Set up the callback function that will run once the file is read
                                                            reader.onload = function(e) {
                                                                // Set the image source to the loaded file
                                                                epImagePreview.src = e.target.result;

                                                                epImagePreview.style.visibility = 'visible';
                                                            };

                                                            // Read the image file as a data URL (base64 string)
                                                            reader.readAsDataURL(file);
                                                        }
                                                    });

                                                    esImageUpload.addEventListener('change', function(event) {
                                                        const file = event.target.files[0]; // Get the first file selected

                                                        // If a file is selected
                                                        if (file) {
                                                            // Create a FileReader object to read the file
                                                            const reader = new FileReader();

                                                            // Set up the callback function that will run once the file is read
                                                            reader.onload = function(e) {
                                                                // Set the image source to the loaded file
                                                                esImagePreview.src = e.target.result;

                                                                esImagePreview.style.visibility = 'visible';
                                                            };

                                                            // Read the image file as a data URL (base64 string)
                                                            reader.readAsDataURL(file);
                                                        }
                                                    });

                                                </script>



