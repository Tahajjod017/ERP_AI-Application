                                                    </div>
                                                </div>

                                                <div class="col-sm-6 col-md-6">
                                                    <div class="form-floating">
                                                        <input class="form-control" id="" type="text" placeholder="Email" />
                                                        <label for="">Email</label>
                                                    </div>
                                                </div>

                                                <div class="col-sm-12 col-md-12">
                                                    <div class="form-floating">
                                                        <input class="form-control" id="" type="text" placeholder="Address" />
