<script>
        //linechart
    // Function to render the "Yearly Attendance Status" line chart with dynamic JSON data
    function renderAttendanceLineChart(data) {
        var dom = document.getElementById('yearly-employee-attendance-status-linechart');
        var myChart = echarts.init(dom, null, {
            renderer: 'canvas',
            useDirtyRect: false
        });

        var option = {
            title: {
                text: 'Attendance Status',
                subtext: 'Latest Year'
            },
            tooltip: {
                trigger: 'axis'
            },
            legend: {
                data: ['Present', 'Absent', 'Late Entry', 'Early Leave', 'Casual Leave', 'Medical Leave']
            },
            grid: {
                left: '3%',
                right: '4%',
                bottom: '4%',
                containLabel: true
            },
            toolbox: {
                feature: {
                    saveAsImage: {}
                }
            },
            xAxis: {
                type: 'category',
                boundaryGap: false,
                data: data.months // Data for the months
            },
            yAxis: {
                type: 'value'
            },
            series: [
                {
                    name: 'Casual Leave',
                    type: 'line',
                    stack: 'Total',
                     itemStyle: {
                    color: '#17A2B8'  // Set color
                },
                    data: data.casualLeave
                },
                {
                    name: 'Medical Leave',
                    type: 'line',
                    stack: 'Total',
                    itemStyle: {
                    color: '#28A745'  // Set color
                     },
                    data: data.medicalLeave
                },
                {
                    name: 'Early Leave',
                    type: 'line',
                    stack: 'Total',
                        itemStyle: {
                        color: '#FFA500'  // Set color
                    },
                    data: data.earlyLeave
                },
                {
                    name: 'Late Entry',
                    type: 'line',
                    stack: 'Total',
                        itemStyle: {
                                        color: 'red'  // Set color
                                    },
                    data: data.lateEntry
                },
                {
                    name: 'Absent',
                    type: 'line',
                    stack: 'Total',
                        itemStyle: {
                            color: '#B0B0B0'  // Set color
                        },
                    data: data.absent
                },
                {
                    name: 'Present',
                    type: 'line',
                    stack: 'Total',
                        itemStyle: {
                            color: '#4A90E2'  // Set color
                        },
                    data: data.present
                }
            ]
        };

        // Set the chart options
        myChart.setOption(option);

        // Resize the chart on window resize
        window.addEventListener('resize', myChart.resize);
    }
        function renderAttendanceBarChartControllers() {
        $.ajax({
            url: '/EmployeesAttendance/GetEmployeeStatusYearReport',  // Your backend endpoint to fetch the pre-calculated session data
            type: 'GET',  // HTTP method (GET, POST, etc.)
            dataType: 'json',  // Expected response type
            success: function (response) {
                if (response) {
                    // Update session hours using pre-calculated data
                    //  updateAttendancePieChart(response.present, response.absent, response.late, response.early);
                    renderAttendanceLineChart(response);

                } else {
                    console.error("Invalid data received");
                }
            },
            error: function (xhr, status, error) {
                console.error("Error fetching session data: ", error);
            }
        });
    }
    // Example of passing dynamic data as a JSON object
    var jsonData = {
        "months": ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'],
        "casualLeave": [1, 2, 0, 2, 1, 1, 1, 0, 2, 0, 1, 1],
        "medicalLeave": [1, 1, 0, 2, 0, 1, 0, 0, 1, 4, 0, 1],
        "earlyLeave": [4, 2, 1, 3, 2, 3, 2, 3, 2, 3, 2, 1],
        "lateEntry": [2, 2, 2, 2, 2, 1, 1, 1, 2, 3, 1, 1],
        "absent": [3, 2, 1, 3, 2, 1, 0, 1, 2, 3, 1, 1],
        "present": [20, 21, 19, 21, 18, 20, 21, 19, 21, 18, 20, 21]
    };

    // Call the function with the dynamic data (this can be done on the fly)
    //renderAttendanceLineChart(jsonData);
</script>