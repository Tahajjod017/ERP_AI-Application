<div class="d-md-flex d-block align-items-center justify-content-between page-breadcrumb mb-3">
    <div class="my-auto mb-2">
        <h2 class="mb-1">Employee Increment</h2>
        <nav>
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item">
                    <a href="#"><i class="ti ti-smart-home"></i></a>
                </li>
                <li class="breadcrumb-item">Employee</li>
                <li class="breadcrumb-item active" aria-current="page">Increment</li>
            </ol>
        </nav>
    </div>
    <div class="d-flex my-xl-auto right-content align-items-center flex-wrap">
        <div class="mb-2">
            <a href="#" data-bs-toggle="modal" data-bs-target="#add_increment" class="btn btn-primary d-flex align-items-center">
                <i class="ti ti-circle-plus me-2"></i>Add Increment
            </a>
        </div>
    </div>
</div>

<div class="row my-4">
    <div class="col-xl-3 col-md-6">
        <div class="card bg-black-le">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="text-start">
                        <p class="mb-1">Pending Increments</p>
                        <h4 id="pendingIncrements">0</h4>
                    </div>
                    <div class="d-flex">
                        <div class="flex-shrink-0 me-2">
                            <span class="avatar avatar-md d-flex">
                                <i class="ti ti-clock fs-5 text-white"></i>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card bg-purple-le">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="text-start">
                        <p class="mb-1">Approved Increments</p>
                        <h4 id="approvedIncrements">0</h4>
                    </div>
                    <div class="d-flex">
                        <div class="flex-shrink-0 me-2">
                            <span class="avatar avatar-md d-flex">
                                <i class="ti ti-check fs-5 text-white"></i>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card bg-pink-le">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="text-start">
                        <p class="mb-1">This Month</p>
                        <h4 id="thisMonthIncrements">0</h4>
                    </div>
                    <div class="d-flex">
                        <div class="flex-shrink-0 me-2">
                            <span class="avatar avatar-md d-flex">
                                <i class="ti ti-calendar-month fs-5 text-white"></i>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card bg-blue-le">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="text-start">
                        <p class="mb-1">Total Amount</p>
                        <h4 id="totalIncrementAmount">৳0</h4>
                    </div>
                    <div class="d-flex">
                        <div class="flex-shrink-0 me-2">
                            <span class="avatar avatar-md d-flex">
                                <i class="ti ti-currency-taka fs-5 text-white"></i>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="mb-4">
    <div class="card">
        <div class="card-header d-flex align-items-center justify-content-between flex-wrap row-gap-3 mb-1">
            <h4 class="mb-1">Employee Increment List</h4>
            <div class="d-flex my-xl-auto right-content align-items-center flex-wrap row-gap-3">
                <div class="me-3">
                    <input class="form-control" id="searchInput" type="text" placeholder="Search by Employee Name">
                </div>
                <div class="me-3">
                    <div class="input-icon-end position-relative">
                        <input class="form-control datetimepicker flatpickr-input" id="dateRangePicker" type="text" placeholder="d/m/y ">
                    </div>
                </div>
                <div class="dropdown me-3">
                    <select class="form-select choiceDD" id="departmentFilter" data-choices="data-choices" size="1" name="departmentFilter" asp-items="@ViewBag.DepartmentDD as SelectList" >
                        <option value="" >@Html.SmartLocalize("Select Department")</option>

                    </select>
                </div>
                <div class="dropdown me-3">
                    <select class="form-select choiceDD" id="incrementTypeFilter" asp-items="@ViewBag.IncrementTypeList as SelectList">
                        <option value="">@Html.SmartLocalize("Select Type")</option>
                    </select>
                </div>

                <div class="dropdown me-3">
                    <select class="form-select" id="pageSizeSelect" data-choices="data-choices" size="1" name="pageSizeSelect" data-options='{"removeItemButton":true,"placeholder":true}'>
                        <option value="10">10 per page</option>
                        <option value="25">25 per page</option>
                        <option value="50">50 per page</option>
                        <option value="100">100 per page</option>
                    </select>
                </div>

            </div>
        </div>
        <div class="border-translucent p-3 pt-0">
            <div id="incrementListTable">
                <div class="table-responsive scrollbar mx-n1 px-1">
                    <table class="table table-sm fs-9 leads-table">
                        <thead>
                            <tr>
                                <th class="white-space-nowrap fs-9 align-middle ps-0" style="max-width:20px; width:18px;">
                                    <div class="form-check mb-0 fs-8">
                                        <input class="form-check-input" type="checkbox" id="checkAll" />
                                    </div>
                                </th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="employeeName">Employee</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="department">Department</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="currentSalary">Current Salary</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="incrementAmount">Increment Amount</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="newSalary">New Salary</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="effectiveDate">Effective Date</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="incrementType">Type</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="status">Status</th>
                            </tr>
                        </thead>
                        <tbody class="list" id="incrementList-body">
                            <!-- Data will be populated by JavaScript -->
                        </tbody>
                    </table>
                </div>
                <div class="row align-items-center justify-content-between pe-0 fs-9">
                    <div class="col-auto d-flex">
                        <p class="mb-0 d-none d-sm-block me-3 fw-semibold text-body" data-list-info="data-list-info"></p>
                    </div>
                    <div class="col-auto d-flex">
                        <button class="page-link" data-list-pagination="prev"><span class="fas fa-chevron-left"></span></button>
                        <ul class="mb-0 pagination"></ul>
                        <button class="page-link pe-0" data-list-pagination="next"><span class="fas fa-chevron-right"></span></button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Increment Modal -->
<div class="modal fade" id="add_increment">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">Add Increment</h4>
                <button type="button" class="btn-close custom-btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="incrementForm">
                <div class="modal-body pb-0">
                    <div class="row mb-3">
                        <div class="col-md-3">
                            <div class="form-floating form-floating-advance-select">
                                <select class="form-select choiceDD" id="incrementEmpId" asp-items="@ViewBag.EmployeeDD">
                                    <option value="" selected disabled>Select Employee Name</option>

                                </select>
                                <label for="incrementEmpId">Employee Name</label>
                                <span class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-floating form-floating-advance-select">
                                <select class="form-select choiceDD" id="incrementOrganization" asp-items="@ViewBag.OrganizationDD">
                                    <option value="" selected disabled>Select Organization</option>

                                </select>
                                <label for="incrementOrganization">Organization</label>
                                <span class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-floating form-floating-advance-select">
                                <select class="form-select choiceDD" id="incrementDesigantion" asp-items="@ViewBag.DesignationDD">
                                    <option value="" selected disabled>Select Designation</option>

                                </select>
                                <label for="incrementDesigantion">Designation</label>
                                <span class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-floating form-floating-advance-select">
                                <select class="form-select choiceDD" id="incrementDepatment" asp-items="@ViewBag.DepartmentDD">
                                    <option value="" selected disabled>Select Department</option>

                                </select>
                                <label for="incrementDepatment">Department</label>
                                <span class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Radio Button Section -->
                    <div class="d-flex mb-3">
                        <div class="form-check me-4">
                            <input class="form-check-input" type="radio" name="changeType2" id="incrementRadio" value="increment" checked>
                            <label class="form-check-label" for="increment">Increment</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="changeType2" id="decrementRadio" value="decrement">
                            <label class="form-check-label" for="decrement">Decrement</label>
                        </div>
                    </div>

                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">Change Details</h5>
                        </div>
                        <div class="card-body">
                            <!-- Date Field -->
                            <div class="row mb-3">



                                <div class="col-md-6">
                                    <div class="flatpickr-input-container">
                                        <div class="form-floating">
                                            <input id="incrementWef" class="form-control datetimepicker" type="text" placeholder="dd/mm/yyyy" data-options='{"disableMobile":true}' />
                                            <label class="ps-6" id="incrementWef">Effective Date</label>
                                            <span class="uil uil-calendar-alt flatpickr-icon text-body-tertiary"></span>
                                            <span class="text-danger small"></span>
                                        </div>
                                    </div>
                                </div>



                            </div>



                            <!-- 2 Input Fields -->
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input type="number" class="form-control" id="incrementPrevSalary" placeholder="Current Salary" required>
                                        <label for="incrementPrevSalary">Current Salary</label>
                                    </div>
                                    <span class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input type="number" class="form-control" id="incrementNewSalary" placeholder="New Salary" required>
                                        <label for="incrementNewSalary">New Salary</label>
                                    </div>
                                    <span class="text-danger small"></span>
                                </div>
                            </div>

                            <!-- Remarks -->
                            <div class="row mb-3">
                                <div class="col-md-12">
                                    <div class="form-floating">
                                        <textarea class="form-control" rows="3" id="incrementRemark" placeholder="Reason / Remarks" style="height: 100px;"></textarea>
                                        <label for="incrementRemark">Reason / Remarks</label>
                                    </div>
                                    <span class="text-danger small"></span>
                                </div>
                            </div>
                        </div>



                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" id="btnIncrementCancel" class="btn btn-light">Cancel Button</button>
                    <button type="submit" id="btnIncrementSubmit" class="btn btn-primary">Submit Button</button>
                </div>
            </form>
        </div>
    </div>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="~/js/pages/Employees/EmployeeStatus/Increment/IncrementForm.js"></script>
    <script src="~/js/pages/Employees/EmployeeStatus/Increment/IncrementList.js"></script>
}