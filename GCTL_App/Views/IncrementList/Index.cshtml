

<div class="d-md-flex d-block align-items-center justify-content-between page-breadcrumb mb-3">
    <div class="my-auto mb-2">
        <h2 class="mb-1">@Html.SmartLocalize("Employee Increment")</h2>
        <nav>
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item">
                    <a href="#"><i class="ti ti-smart-home"></i></a>
                </li>
                <li class="breadcrumb-item">@Html.SmartLocalize("Employee")</li>
                <li class="breadcrumb-item active" aria-current="page">@Html.SmartLocalize("Increment")</li>
            </ol>
        </nav>
    </div>
    <div class="d-flex my-xl-auto right-content align-items-center flex-wrap">
        <div class="mb-2">
            <a href="#" data-bs-toggle="modal" data-bs-target="#add_increment" class="btn btn-primary d-flex align-items-center">
                <i class="ti ti-circle-plus me-2"></i>@Html.SmartLocalize("Add Increment")
            </a>
        </div>
    </div>
</div>

<div class="row my-4">
    <div class="col-xl-3 col-md-6">
        <div class="card bg-black-le">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="text-start">
                        <p class="mb-1">@Html.SmartLocalize("Pending Increments")</p>
                        <h4 id="pendingIncrements">0</h4>
                    </div>
                    <div class="d-flex">
                        <div class="flex-shrink-0 me-2">
                            <span class="avatar avatar-md d-flex">
                                <i class="ti ti-clock fs-5 text-white"></i>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card bg-purple-le">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="text-start">
                        <p class="mb-1">@Html.SmartLocalize("Approved Increments")</p>
                        <h4 id="approvedIncrements">0</h4>
                    </div>
                    <div class="d-flex">
                        <div class="flex-shrink-0 me-2">
                            <span class="avatar avatar-md d-flex">
                                <i class="ti ti-check fs-5 text-white"></i>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card bg-pink-le">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="text-start">
                        <p class="mb-1">@Html.SmartLocalize("This Month")</p>
                        <h4 id="thisMonthIncrements">0</h4>
                    </div>
                    <div class="d-flex">
                        <div class="flex-shrink-0 me-2">
                            <span class="avatar avatar-md d-flex">
                                <i class="ti ti-calendar-month fs-5 text-white"></i>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card bg-blue-le">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="text-start">
                        <p class="mb-1">@Html.SmartLocalize("Total Amount")</p>
                        <h4 id="totalIncrementAmount">৳0</h4>
                    </div>
                    <div class="d-flex">
                        <div class="flex-shrink-0 me-2">
                            <span class="avatar avatar-md d-flex">
                                <i class="ti ti-currency-taka fs-5 text-white"></i>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>




<div class="mb-4">
    <div class="card">
        <div class="card-header d-flex align-items-center justify-content-between flex-wrap row-gap-3 mb-1">
            <h4 class="mb-1">@Html.SmartLocalize("Employee Increment List")</h4>
            <div class="d-flex my-xl-auto right-content align-items-center flex-wrap row-gap-3">

                <!-- Column Visibility Toggle -->
                <div class="dropdown me-3">
                    <button class="btn btn-light dropdown-toggle bg-white text-muted" type="button" id="columnToggleBtn" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="fas fa-columns me-2"></i>@Html.SmartLocalize("Columns")
                    </button>
                    <div class="dropdown-menu column-toggle-dropdown p-2" aria-labelledby="columnToggleBtn">
                        <div class="fw-bold mb-2 text-muted">@Html.SmartLocalize("Show/Hide Columns")</div>
                        <div class="column-toggle-item">
                            <div class="form-check">
                                <input class="form-check-input column-toggle" type="checkbox" id="col-employee" data-column="0" checked>
                                <label class="form-check-label" for="col-employee">@Html.SmartLocalize("Employee")</label>
                            </div>
                        </div>
                        <div class="column-toggle-item">
                            <div class="form-check">
                                <input class="form-check-input column-toggle" type="checkbox" id="col-department" data-column="1" checked>
                                <label class="form-check-label" for="col-department">@Html.SmartLocalize("Department")</label>
                            </div>
                        </div>
                        <div class="column-toggle-item">
                            <div class="form-check">
                                <input class="form-check-input column-toggle" type="checkbox" id="col-current-salary" data-column="2" checked>
                                <label class="form-check-label" for="col-current-salary">@Html.SmartLocalize("Current Salary")</label>
                            </div>
                        </div>
                        <div class="column-toggle-item">
                            <div class="form-check">
                                <input class="form-check-input column-toggle" type="checkbox" id="col-increment-amount" data-column="3" checked>
                                <label class="form-check-label" for="col-increment-amount">@Html.SmartLocalize("Increment Amount")</label>
                            </div>
                        </div>
                        <div class="column-toggle-item">
                            <div class="form-check">
                                <input class="form-check-input column-toggle" type="checkbox" id="col-new-salary" data-column="4" checked>
                                <label class="form-check-label" for="col-new-salary">@Html.SmartLocalize("New Salary")</label>
                            </div>
                        </div>
                        <div class="column-toggle-item">
                            <div class="form-check">
                                <input class="form-check-input column-toggle" type="checkbox" id="col-effective-date" data-column="5" checked>
                                <label class="form-check-label" for="col-effective-date">@Html.SmartLocalize("Effective Date")</label>
                            </div>
                        </div>
                        <div class="column-toggle-item">
                            <div class="form-check">
                                <input class="form-check-input column-toggle" type="checkbox" id="col-type" data-column="6" checked>
                                <label class="form-check-label" for="col-type">@Html.SmartLocalize("Type")</label>
                            </div>
                        </div>
                        <div class="column-toggle-item">
                            <div class="form-check">
                                <input class="form-check-input column-toggle" type="checkbox" id="col-status" data-column="7" checked>
                                <label class="form-check-label" for="col-status">@Html.SmartLocalize("Status")</label>
                            </div>
                        </div>
                        <hr class="my-2">
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-outline-primary" id="selectAllColumns">@Html.SmartLocalize("Select All")</button>
                            <button class="btn btn-sm btn-outline-secondary" id="resetColumns">@Html.SmartLocalize("Reset")</button>
                        </div>
                    </div>
                </div>


                <!-- Existing filters -->
                <div class="me-3">
                    <input class="form-control" id="searchInput" type="text" placeholder="@Html.SmartLocalize("Search by Employee Name")">
                </div>
                <div class="me-3">
                    <div class="input-icon-end position-relative">
                        <input class="form-control datetimepicker flatpickr-input" id="dateRangePicker" type="text" placeholder="@Html.SmartLocalize("d/m/y")">
                    </div>
                </div>
                <div class="dropdown me-3">
                    <select class="form-select choiceDD" id="departmentFilter" data-choices="data-choices" size="1" name="departmentFilter" asp-items="@ViewBag.DepartmentDD as SelectList">
                        <option value="">@Html.SmartLocalize("Select Department")</option>
                    </select>
                </div>
                <div class="dropdown me-3">
                    <select class="form-select choiceDD" id="incrementTypeFilter" asp-items="@ViewBag.IncrementTypeList as SelectList">
                        <option value="">@Html.SmartLocalize("Select Type")</option>
                    </select>
                </div>
                <div class="dropdown me-3">
                    <select class="form-select" id="pageSizeSelect" data-choices="data-choices" size="1" name="pageSizeSelect" data-options='{"removeItemButton":true,"placeholder":true}'>
                        <option value="10">@Html.SmartLocalize("10 per page")</option>
                        <option value="25">@Html.SmartLocalize("25 per page")</option>
                        <option value="50">@Html.SmartLocalize("50 per page")</option>
                        <option value="100">@Html.SmartLocalize("100 per page")</option>
                    </select>
                </div>
            </div>
        </div>
        <div class="border-translucent p-3 pt-0">
            <div id="incrementListTable">
                <div class="table-responsive scrollbar mx-n1 px-1">
                    <table class="table table-sm fs-9 leads-table">
                        <thead class="sticky-header">
                            <tr>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="employeeName" data-column="0">@Html.SmartLocalize("Employee")</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="department" data-column="1">@Html.SmartLocalize("Department")</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="currentSalary" data-column="2">@Html.SmartLocalize("Current Salary")</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="incrementAmount" data-column="3">@Html.SmartLocalize("Increment Amount")</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="newSalary" data-column="4">@Html.SmartLocalize("New Salary")</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="effectiveDate" data-column="5">@Html.SmartLocalize("Effective Date")</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="incrementType" data-column="6">@Html.SmartLocalize("Type")</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="status" data-column="7">@Html.SmartLocalize("Status")</th>
                            </tr>
                        </thead>
                        <tbody class="list" id="incrementList-body">
                            <!-- The body will be populated dynamically by JavaScript -->
                        </tbody>
                    </table>
                </div>
                <div class="row align-items-center justify-content-between pe-0 fs-9">
                    <div class="col-auto d-flex">
                        <p class="mb-0 d-none d-sm-block me-3 fw-semibold text-body" data-list-info="data-list-info"></p>
                    </div>
                    <div class="col-auto d-flex">
                        <button class="page-link" data-list-pagination="prev"><span class="fas fa-chevron-left"></span></button>
                        <ul class="mb-0 pagination"></ul>
                        <button class="page-link pe-0" data-list-pagination="next"><span class="fas fa-chevron-right"></span></button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .column-toggle-dropdown {
        min-width: 280px;
        max-height: 400px;
        overflow-y: auto;
    }

    .column-toggle-item {
        padding: 0.375rem 0.75rem;
        border-radius: 0.25rem;
        transition: background-color 0.15s ease-in-out;
    }

        .column-toggle-item:hover {
            background-color: #f8f9fa;
        }

    .sticky-header th {
        position: sticky;
        top: 0;
        background-color: white;
        z-index: 10;
        box-shadow: 0 2px 2px -1px rgba(0, 0, 0, 0.1);
    }

    .sort-icon {
        opacity: 0.7;
        transition: opacity 0.15s ease-in-out;
    }

    .sort:hover .sort-icon {
        opacity: 1;
    }

    /* Loading animation */
    .spinner-border-sm {
        width: 1rem;
        height: 1rem;
    }

    /* Badge improvements */
    .badge {
        font-size: 0.75em;
        font-weight: 500;
    }

    /* Avatar improvements */
    .avatar img {
        object-fit: cover;
    }
</style>


<div class="modal fade" id="add_increment">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">@Html.SmartLocalize("Add Increment")</h4>
                <button type="button" class="btn-close custom-btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="incrementForm">
                <div class="modal-body pb-0">
                    <div class="row mb-3">
                        <div class="col-md-3">
                            <div class="form-floating form-floating-advance-select">
                                <select class="form-select choiceDD" id="incrementEmpId" asp-items="@ViewBag.EmployeeDD">
                                    <option value="" selected disabled>@Html.SmartLocalize("Select Employee Name")</option>

                                </select>
                                <label for="incrementEmpId">@Html.SmartLocalize("Employee Name")</label>
                                <span class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-floating form-floating-advance-select">
                                <select class="form-select choiceDD" id="incrementOrganization" asp-items="@ViewBag.OrganizationDD" disabled>
                                    <option value="" selected disabled>@Html.SmartLocalize("Select Organization")</option>

                                </select>
                                <label for="incrementOrganization">@Html.SmartLocalize("Organization")</label>
                                <span class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-floating form-floating-advance-select">
                                <select class="form-select choiceDD" id="incrementDesigantion" asp-items="@ViewBag.DesignationDD" disabled>
                                    <option value="" selected disabled>@Html.SmartLocalize("Select Designation")</option>

                                </select>
                                <label for="incrementDesigantion">@Html.SmartLocalize("Designation")</label>
                                <span class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-floating form-floating-advance-select">
                                <select class="form-select choiceDD" id="incrementDepatment" asp-items="@ViewBag.DepartmentDD" disabled>
                                    <option value="" selected disabled>@Html.SmartLocalize("Select Department")</option>

                                </select>
                                <label for="incrementDepatment">@Html.SmartLocalize("Department")</label>
                                <span class="text-danger small"></span>
                            </div>
                        </div>
                    </div>


                    <div class="d-flex mb-3">
                        <div class="form-check me-4">
                            <input class="form-check-input" type="radio" name="changeType2" id="incrementRadio" value="increment" checked>
                            <label class="form-check-label" for="increment">@Html.SmartLocalize("Increment")</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="changeType2" id="decrementRadio" value="decrement">
                            <label class="form-check-label" for="decrement">@Html.SmartLocalize("Decrement")</label>
                        </div>
                    </div>

                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">@Html.SmartLocalize("Change Details")</h5>
                        </div>
                        <div class="card-body">
                            <!-- Date Field -->
                            <div class="row mb-3">



                                <div class="col-md-6">
                                    <div class="flatpickr-input-container">
                                        <div class="form-floating">
                                            <input id="incrementWef" class="form-control datetimepicker" type="text" placeholder="dd/mm/yyyy" data-options='{"disableMobile":true}' />
                                            <label class="ps-6" id="incrementWef">@Html.SmartLocalize("Effective Date")</label>
                                            <span class="uil uil-calendar-alt flatpickr-icon text-body-tertiary"></span>
                                            <span class="text-danger small"></span>
                                        </div>
                                    </div>
                                </div>



                            </div>




                            <div class="row mb-3">
                                <div class="col-md-4">
                                    <div class="form-floating">
                                        <input type="number" class="form-control" id="incrementPrevSalary" placeholder="@Html.SmartLocalize("Current Salary")" required>
                                        <label for="incrementPrevSalary">@Html.SmartLocalize("Current Salary")</label>
                                    </div>
                                    <span class="text-danger small"></span>
                                </div>

                                <div class="col-md-4">
                                    <div class="input-group">
                                        <div class="form-floating">
                                            <input type="number" class="form-control" id="incrementAmt" placeholder="@Html.SmartLocalize("Increment / Decrement Amount")" required>
                                            <label for="incrementAmt">@Html.SmartLocalize("Increment / Decrement Amount")</label>
                                        </div>
                                        <span class="text-danger small"></span>

                                        <div class="form-floating">
                                            <input type="number" class="form-control" id="incrementPercent" placeholder="@Html.SmartLocalize("Increment / Decrement Percent")" required>
                                            <label for="incrementPercent">@Html.SmartLocalize("Increment / Decrement Percent")</label>
                                        </div>
                                        <span class="text-danger small"></span>
                                    </div>

                                </div>

                                <div class="col-md-4">
                                    <div class="form-floating">
                                        <input type="number" class="form-control" id="incrementNewSalary" placeholder="@Html.SmartLocalize("New Salary")" required>
                                        <label for="incrementNewSalary">@Html.SmartLocalize("New Salary")</label>
                                    </div>
                                    <span class="text-danger small"></span>
                                </div>
                            </div>


                            <div class="row mb-3">
                                <div class="col-md-12">
                                    <div class="form-floating">
                                        <textarea class="form-control" rows="3" id="incrementRemark" placeholder="@Html.SmartLocalize("Reason / Remarks")" style="height: 100px;"></textarea>
                                        <label for="incrementRemark">@Html.SmartLocalize("Reason / Remarks")</label>
                                    </div>
                                    <span class="text-danger small"></span>
                                </div>
                            </div>
                        </div>



                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" id="btnIncrementCancel" class="btn btn-light">@Html.SmartLocalize("Cancel ")</button>
                    <button type="submit" id="btnIncrementSubmit" class="btn btn-primary">@Html.SmartLocalize("Submit ")</button>
                </div>
            </form>
        </div>
    </div>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="~/js/pages/Employees/EmployeeStatus/Increment/IncrementForm.js"></script>
    <script src="~/js/pages/Employees/EmployeeStatus/Increment/IncrementList.js"></script>
}






