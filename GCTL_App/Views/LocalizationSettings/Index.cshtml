@{
    var mainTab = "GeneralSetting";
    var subTab = "LocalizationSettings";
}

<partial name="~/Views/Shared/AdminsettingsNavs/CompanySettingsNavs/_MainSettingsTabPartial.cshtml" model="mainTab" />
<partial name="~/Views/Shared/AdminsettingsNavs/CompanySettingsNavs/_NavGeneralSettingsPartial.cshtml" model="subTab" />

<div class="col-xl-12 mt-3">
    <div class="card mb-4">
        <div class="card-body">
            <div class="border-bottom mb-3 pb-3">
                <h4>Localization</h4>
            </div>
            <form id="localizationForm" asp-controller="LocalizationSettings" asp-action="Create" method="post">
                <div class="mb-3">
                    <div class="row">
                        <!-- Organization Dropdown -->
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label" for="organization">Organization</label>
                                <select class="form-select choiceDD" id="organization" name="OrganizationID">
                                    <option value="1">CSL</option>
                                    <option value="2">GCTL</option>
                                </select>
                            </div>
                        </div>

                        <!-- Language Dropdown -->
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label" for="languageId">Language</label>
                                <select class="form-select choiceDD" id="languageId" name="LanguageID">
                                    <option >Select</option>
                                    <option value="1">English</option>
                                    <option value="2">Bangla</option>
                                    <option value="3">French</option>
                                    <option value="4">Spanish</option>
                                </select>
                            </div>
                        </div>

                        <!-- Timezone Dropdown -->
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label" for="timezoneId">Timezone</label>
                                <select class="form-select choiceDD" id="timezoneId" name="TimezoneID">
                                    <option>Select</option>
                                    <option value="1">(UTC -12:00) Baker/Howland Island</option>
                                    <option value="2">(UTC -11:00) American Samoa</option>
                                    <option value="3">(UTC -10:00) Hawaii</option>
                                    <option value="4">(UTC -09:00) Alaska</option>
                                    <option value="5">(UTC -08:00) Pacific Time (US & Canada)</option>
                                    <option value="6">(UTC -07:00) Mountain Time (US & Canada)</option>
                                    <option value="7">(UTC -06:00) Central Time (US & Canada)</option>
                                    <option value="8">(UTC -05:00) Eastern Time (US & Canada)</option>
                                    <option value="9">(UTC -04:00) Atlantic Time (Canada)</option>
                                    <option value="10">(UTC -03:00) Argentina, Brazil, Paraguay</option>
                                    <option value="11">(UTC -02:00) South Georgia & the South Sandwich Islands</option>
                                    <option value="12">(UTC -01:00) Azores, Cape Verde Islands</option>
                                    <option value="13">(UTC +00:00) London, Dublin, Lisbon, Casablanca</option>
                                    <option value="14">(UTC +01:00) Central European Time</option>
                                    <option value="15">(UTC +02:00) Eastern European Time</option>
                                    <option value="16">(UTC +03:00) Moscow, St. Petersburg, Volgograd</option>
                                    <option value="17">(UTC +04:00) Samara Time</option>
                                    <option value="18">(UTC +05:00) Pakistan Standard Time</option>
                                    <option value="19">(UTC +05:30) India Standard Time</option>
                                    <option value="20">(UTC +06:00) Bangladesh Standard Time (Dhaka)</option> <!-- Added Dhaka -->
                                    <option value="21">(UTC +07:00) Indochina Time (Thailand, Vietnam, Cambodia)</option>
                                    <option value="22">(UTC +08:00) China Standard Time</option>
                                    <option value="23">(UTC +09:00) Japan Standard Time</option>
                                    <option value="24">(UTC +10:00) Australian Eastern Standard Time</option>
                                    <option value="25">(UTC +11:00) Solomon Islands Time</option>
                                    <option value="26">(UTC +12:00) Fiji Time</option>
                                </select>
                            </div>
                        </div>


                        <!-- Date Format Dropdown -->
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label" for="dateFormatId">Date Format</label>
                                <select class="form-select choiceDD" id="dateFormatId" name="DateFormatID">
                                    <option>Select</option>
                                    <option value="1">YYYY-MM-DD</option>
                                    <option value="2">MM/DD/YYYY</option>
                                    <option value="3">DD/MM/YYYY</option>
                                    <option value="4">YYYY/MM/DD</option>
                                </select>
                            </div>
                        </div>

                        <!-- Time Format Dropdown -->
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label" for="timeFormatId">Time Format</label>
                                <select class="form-select choiceDD" id="timeFormatId" name="TimeFormatID">
                                    <option>Select</option>
                                    <option value="1">12 Hours</option>
                                    <option value="2">24 Hours</option>
                                </select>
                            </div>
                        </div>

                        <!-- Currency Dropdown -->
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label" for="currencyId">Currency</label>
                                <select class="form-select choiceDD" id="currencyId" name="CurrencyID">
                                    <option>Select</option>
                                    <option value="1">USD</option>
                                    <option value="2">EURO</option>
                                    <option value="3">BDT</option>
                                </select>
                            </div>
                        </div>

                        <!-- Currency Symbol Dropdown -->
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label" for="currencySymbolId">Currency Symbol</label>
                                <select class="form-select" id="currencySymbolId" name="CurrencySymbol">
                                    <option>Select</option>
                                    <option value="$">$</option>
                                    <option value="€">€</option>
                                    <option value="৳">৳</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="d-flex align-items-center justify-content-end">
                    <button type="reset" class="btn btn-outline-secondary me-2">Reset</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
    <partial name="_localizationListTable" />
</div>



