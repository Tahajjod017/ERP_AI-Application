
<div id="add_new_leave" class="modal custom-modal fade" role="dialog">
    <div class="modal-dialog modal-dialog-centered modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Configure New Leave</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
          
                <form id="addNewLeaveForm">
                    <div class="input-block  leave-duallist">
                        <label class="col-form-label req">Organization Name</label>
                        <select class="form-multi-select" id="OrganizationID" name="OrganizationID" asp-items="@ViewBag.organizationDD as SelectList" multiple data-coreui-multiple="true" data-coreui-search="true">
                            <option value="">Select Organizer</option>
                        </select>
                    </div>

                    <div class="input-block ">
                        <label class="col-form-label req">Leave Name</label>
                        <input type="text" class="form-control" id="LeaveTypeName" name="LeaveTypeName">
                    </div>

                    <div class="input-block">
                        <label class="col-form-label req">Short Code</label>
                        <input type="text" class="form-control" id="Code" name="Code">
                    </div>
                    <div class="input-block  leave-duallist">
                        <label class="col-form-label d-block">Paid Type</label>

                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="IsPaid" id="IsApidPaid" value="true" checked>
                            <label class="col-form-check-label" for="IsApidPaid">Paid</label>
                        </div>

                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="IsPaid" id="IsApidUnpaid" value="false">
                            <label class="form-check-label" for="IsApidUnpaid">Unpaid</label>
                        </div>
                    </div>

                    <div class="input-block">
                        <label class="col-form-label req">Maximum Days</label>
                        <input type="number" class="form-control" id="LeaveDays" name="LeaveDays">
                    </div>

                    <div class="row">

                        <div class="col-md-3">
                            <div class="mb-3">
                                <label class="col-form-label" >Effective From</label>
                                <input type="text" id="EffectiveFrom" class="form-control" placeholder="6">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="col-form-label mt-3" for="exampleFormControlInput"></label>
                            <select class="form-select" id="EffectiveFromMonthYear" data-choices="data-choices" data-options='{"removeItemButton":true,"placeholder":true}'>
                                <option value="Years">Years</option>
                                <option value="Months" selected>Months</option>
                            </select>
                        </div>

                        <div class="col-md-5">
                            <label class="col-form-label" for="exampleFormControlInput">After</label>
                            <select class="form-select" id="EffectiveAfter" data-choices="data-choices" data-options='{"removeItemButton":true,"placeholder":true}'>
                                <option value="Joining Date">Joining Date</option>
                                <option value="Conformation Date">Conformation Date</option>
                            </select>
                        </div>

                    </div>
                    

                    <div class="submit-section text-end mt-1">
                        <button type="button" class="btn btn-outline-light border" id="resetBtn">Cancel</button>
                        <button type="submit" class="btn btn-primary submit-btn" id="AddNewLeaveSubmitButton">Save</button>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

