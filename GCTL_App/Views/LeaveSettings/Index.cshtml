@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/js/pages/attendancemanagement/leavemanagements/leaverequest/leavepolicyconfig.js"></script>
    <script src="~/js/pages/attendancemanagement/leavemanagements/leaverequest/leavesettings.js"></script>
    <script>
        const checkbox = document.getElementById('toggleEncashementCheckbox');
        //const checkbox1 = document.getElementById('toggleCarryForwardCheckbox');
        const hiddenEncashmentDiv = document.getElementById('hiddenEncashmentDiv');
        //const hiddenCaryforwardDiv = document.getElementById('hiddenCaryforwardDiv');

        checkbox.addEventListener('change', function() {
          hiddenEncashmentDiv.style.display = this.checked ? 'block' : 'none';
        });


    </script>
}



