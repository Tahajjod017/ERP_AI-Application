<!-- Annual Leave settings-->
<div class="modal fade" id="annual_leave_settings">
    <div class="modal-dialog modal-dialog-centered modal-md">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title" id="LeaveNameTitle"></h4>
                <button type="button" class="btn-close custom-btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="LeaveUpdateForm">
                <div class="tab-content px-3">
                    <div class="modal-body">
                        <div class="modal-body pb-0">
                            <div class="row">
                                <input type="hidden" class="form-control" id="LeaveTypeIDEdit" />

                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label">Leave Name</label>
                                        <input type="text" id="LeaveTypeNameEdit" class="form-control" />
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label">Code</label>
                                        <input type="text" id="CodeEdit" class="form-control" />
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="mb-3 mt-1">
                                        <label class="form-label d-block mb-2">Paid Type</label>
                                        <div class="form-check form-check-inline">
                                            <input class="form-check-input" type="radio" name="IsPaidEdit" id="IsPaidPaidEdit" value="true">
                                            <label class="form-check-label" for="IsPaidPaidEdit">Paid</label>
                                        </div>
                                        <div class="form-check form-check-inline">
                                            <input class="form-check-input" type="radio" name="IsPaidEdit" id="IsPaidUnpaidEdit" value="false">
                                            <label class="form-check-label" for="IsPaidUnpaidEdit">Unpaid</label>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label">Maximum No of Days</label>
                                        <input type="text" id="LeaveDaysEdit" class="form-control" />
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <label class="form-label">Effective From</label>
                                            <input type="text" class="form-control" id="EffectiveFromEdit" />
                                        </div>
                                    </div>

                                    <div class="col-md-4 mt-4">
                                        <select class="form-select choiceDD" id="EffectiveFromMonthYearEdit">
                                            <option value="">Select</option>
                                            <option value="Years">Years</option>
                                            <option value="Months">Months</option>
                                        </select>
                                    </div>

                                    <div class="col-md-4">
                                        <label class="form-label" style="visibility: hidden;">Placeholder</label>
                                        <input type="text" class="form-control" id="EffectiveAfterEdit" value="After Joining Date" readonly />
                                    </div>
                                </div>

                                <div class="col-md-6" id="encashmentSection" style="display: none;">
                                    <div class="col-md-12">
                                        <div class="form-check form-switch ms-3">
                                            <input class="form-check-input" id="toggleEncashementCheckbox" type="checkbox" />
                                            <label class="form-check-label" for="flexSwitchCheckDefault">Encashement</label>
                                        </div>
                                    </div>

                                    <div id="hiddenEncashmentDiv" class="card p-3 mb-4">
                                        <div class="row">
                                            <div class="col-md-12 mb-3">
                                                <label class="form-label">Minimum Days Required For Encashement</label>
                                                <input type="text" class="form-control" id="minEncash">
                                            </div>
                                            <div class="col-md-12 mb-3">
                                                <label class="form-label">Maximum Days Allowed For Encashement</label>
                                                <input type="text" class="form-control" id="maxEncash">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div> <!-- end row -->
                        </div> <!-- end modal-body inner -->

                        <div class="modal-footer">
                            <button type="button" class="btn btn-phoenix-primary" id="resetBtnUpdated">Reset</button>
                           @*  <button type="button" class="btn btn-outline-light border me-2" id="resetBtnUpdated">Cancel</button> *@
                            <button type="submit" class="btn btn-primary" id="updateLeaveBtn">Save</button>
                        </div>
                    </div>
                </div>
            </form>

        </div>
    </div>
</div>
<!-- /Annual Leave settings-->
