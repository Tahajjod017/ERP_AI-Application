<div class="col-12 col-md-12 col-lg-12 ">

    <ul class="nav nav-underline fs-9" id="myTab" role="tablist">
        <li class="nav-item"><a class="nav-link active" id="LeaveSettings-tab" data-bs-toggle="tab" href="#tab-LeaveSettings" role="tab" aria-controls="tab-LeaveSettings" aria-selected="true">Leave Type Settings</a></li>
        <li class="nav-item"><a class="nav-link" id="AttendanceSettings-tab" data-bs-toggle="tab" href="#tab-AttendanceSettings" role="tab" aria-controls="tab-AttendanceSettings" aria-selected="false">Leave policy configuration</a></li>
    </ul>
    <div class="tab-content mt-3" id="myTabContent0">
        <div class="tab-pane fade show active" id="tab-LeaveSettings" role="tabpanel" aria-labelledby="LeaveSettings-tab">
            <div class="row">
                <div class="d-flex justify-content-end mb-2">
                    <a class="text-decoration-none btn btn-primary me-2" data-bs-toggle="modal" data-bs-target="#add_new_leave">Add New Leave</a>
                </div>
            </div>

            <div class="px-25">
                <div class="d-flex justify-content-center mt-2 ">
                    <div class="col-12 col-md-12 col-lg-12 ">
                        <div class="row" id="leaveTypesContainer">

                         

                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="tab-AttendanceSettings" role="tabpanel" aria-labelledby="AttendanceSettings-tab">

            <div class="row">
                <div class="d-flex justify-content-end mb-2">
                    <button class="btn btn-primary submit-btn" id="AddLeavePolicyBtn">Save Leave Policy</button>
                </div>
            </div>

            <div class="px-25">
                <div class="d-flex justify-content-center mt-2">
                    <div class="col-12 col-md-12 col-lg-12 ">
                        <div class="row">

                            <div class="col-xl-6 col-md-6">

                                <div class="card">
                                    <div class="card-header"><h4>Restrictions</h4> </div>
                                   

                                    
                                    <div class="card-body d-block ">
                                        <div class="mb-2">
                                            <p class="border-bottom h5">Weekent between leave period</p>
                                            <div class="d-flex align-items-center justify-content-between">
                                                <form action="">
                                                   
                                                    <div class="form-check">
                                                        <input class="form-check-input" id="IsWeekendCountedAsLeaveYes" type="radio" name="IsWeekendCountedAsLeave" checked value="true" />
                                                        <label class="form-check-label" for="IsWeekendCountedAsLeaveYes">Count as leave</label>
                                                    </div>
                                                    <div class="form-check">
                                                        <input class="form-check-input" id="IsWeekendCountedAsLeaveNo" type="radio" name="IsWeekendCountedAsLeave" value="false" />
                                                        <label class="form-check-label" for="IsWeekendCountedAsLeaveNo">Don't count as leave</label>
                                                    </div>

                                                </form>

                                            </div>
                                        </div>
                                        <div class="mb-2">
                                            <p class="border-bottom h5">Holiday between leave period</p>
                                            <div class="d-flex align-items-center justify-content-between">
                                                <form action="">
                                                    <div class="form-check">
                                                        <input class="form-check-input" id="IsHolidayCountedAsLeaveYes" type="radio" name="IsHolidayCountedAsLeave" value="true" checked />
                                                        <label class="form-check-label" for="IsHolidayCountedAsLeaveYes">Count as leave</label>
                                                    </div>
                                                    <div class="form-check">
                                                        <input class="form-check-input" id="IsHolidayCountedAsLeaveNo" type="radio" name="IsHolidayCountedAsLeave" value="false" />
                                                        <label class="form-check-label" for="IsHolidayCountedAsLeaveNo">Don't count as leave</label>
                                                    </div>
                                                </form>

                                            </div>
                                        </div>
                                        <div>
                                            <p class="border-bottom h5">While Applying Leave, Exceed Leave Balance</p>
                                            <div class="d-flex align-items-center justify-content-between">
                                                <form action="">
                                                    <div class="form-check">
                                                        <input class="form-check-input" id="IsExceedLeaveBalanceYes" type="radio" name="IsExceedLeaveBalance" value="true" checked/>
                                                        <label class="form-check-label" for="IsExceedLeaveBalanceYes">Allow (Exceed leave mark as LOP)</label>
                                                    </div>
                                                    <div class="form-check">
                                                        <input class="form-check-input" id="IsExceedLeaveBalanceNo" type="radio" name="IsExceedLeaveBalance" value="false" />
                                                        <label class="form-check-label" for="IsExceedLeaveBalanceNo">Don't allow</label>
                                                    </div>

                                                </form>
                                            </div>
                                        </div>


                                    </div>
                                   
                                </div>
                            </div>

                            <div class="col-xl-6 col-md-6">
                                <div class="card">
                                    <div class="card-header"><h4>Allow requests for</h4> </div>
                                    <div class="card-body d-flex align-items-center justify-content-between">
                                        <div class="mb-2">

                                            <div class="d-flex align-items-center justify-content-between">
                                                <form action="">
                                                    <div class="form-check">
                                                        <input class="form-check-input" id="IsAllowRequestForPastDates" name="IsAllowRequestForPastDates" type="checkbox" value="true" />
                                                        <label class="form-check-label" for="flexCheckDefault">Past dates not allowed</label>
                                                    </div>

                                                   @*  <div class="form-check mb-3">
                                                        <input class="form-check-input" id="IsAllowRequestForFutureDays" name="IsAllowRequestForFutureDays" type="checkbox" value="true" />
                                                        <label class="form-check-label" for="flexCheckChecked">Future dates</label>
                                                        <div class="form-check ms-5 d-flex">
                                                           
                                                            <label class="form-check-label mt-2" for="flexCheckChecked">To be applied</label>
                                                            <input type="text" class="form-control mx-2" placeholder="5" id="AllowRequestForFutureDays" style="width: 3rem;">
                                                            <label class="form-check-label mt-2" for="flexCheckChecked">Days in advance</label>
                                                        </div>
                                                    </div> *@

                                                    <div class="form-check d-flex align-items-center mb-3">
                                                        <input class="form-check-input me-2" id="IsAllowRequestForFutureDays" name="IsAllowRequestForFutureDays" type="checkbox" value="true" />
                                                        <label class="form-check-label me-2" for="IsAllowRequestForFutureDays">Future dates To be applied</label>
                                                        <input type="text" class="form-control me-2" placeholder="5" id="AllowRequestForFutureDays" style="width: 4rem;" />
                                                        <label class="form-check-label" for="AllowRequestForFutureDays">Days in advance</label>
                                                    </div>

                                                 
                                                    <!-- Maximum leave per application -->
                                                    <div class="form-check d-flex align-items-center mb-3">
                                                        <input class="form-check-input me-2" id="IsMaximumleaveDaysPerAplication" name="IsMaximumleaveDaysPerAplication" type="checkbox" value="true" />
                                                        <label class="form-check-label me-2" for="IsMaximumleaveDaysPerAplication">Maximum leave that can be availed per application</label>
                                                        <input type="text" class="form-control" id="MaxLeavePerApplication" placeholder="5" style="width: 4rem;" />
                                                    </div>

                                                    <!-- Maximum gap between applications -->
                                                    <div class="form-check d-flex align-items-center mb-3">
                                                        <input class="form-check-input me-2" id="IsMaximumGapDaysBetweenAplications" name="IsMaximumGapDaysBetweenAplications" type="checkbox" value="true" />
                                                        <label class="form-check-label me-2" for="IsMaximumGapDaysBetweenAplications">Maximum gap (in days) between two applications</label>
                                                        <input type="text" class="form-control" id="MaxGapBetweenApplications" name="MaxGapBetweenApplications" placeholder="5" style="width: 4rem;" />
                                                    </div>

                                                </form>

                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-xl-6 col-md-6">
                                <div class="card">
                                    <div class="card-header"><h4>Prorate Accrual</h4> </div>
                                    <div class="card-body d-flex align-items-center justify-content-between">
                                        

                                            <div class="d-flex align-items-center justify-content-between">
                                                <form action="">

                                                    <h5>Round off</h5>
                                                    <div class="form-check d-flex mb-1">
                                                    <input class="form-check-input me-2 mt-2 " id="IsRoundOffHour" name="IsRoundOffHour" value="true" type="checkbox" />
                                                     <label class="form-check-label mt-2 me-2" for="flexCheckChecked">Round of</label>

                                                    <div style="width:167px;">
                                                        <select class="form-select choiceDD" id="RoundOffHour">
                                                            <option value="">Select</option>
                                                            <option value="Hour">Hour</option>
                                                            <option value="Half an Hour">Half an Hour </option>
                                                            <option value="Quarter">Quarter</option>
                                                        </select>
                                                        </div>
                                                       

                                                      
                                                    </div>

                                                </form>

                                            </div>
                                        
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
       


        </div>

    </div>


</div>
