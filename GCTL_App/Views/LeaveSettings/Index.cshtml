<!-- Edit Custom Policy Modal -->
<div id="edit_custom_policy" class="modal custom-modal fade" role="dialog">
    <div class="modal-dialog modal-dialog-centered modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Custom Policy</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form>
                    <div class="input-block mb-3">
                        <label class="col-form-label">Policy Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" value="LOP">
                    </div>
                    <div class="input-block mb-3">
                        <label class="col-form-label">Days <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" value="4">
                    </div>
                    <div class="input-block mb-3 leave-duallist">
                        <label class="col-form-label">Add employee</label>
                        <div class="row">
                            <div class="col-lg-5 col-sm-5">
                                <select name="edit_customleave_from" id="edit_customleave_select" class="form-control form-select"
                                        size="5" multiple="multiple">
                                    <option value="1">Bernardo Galaviz </option>
                                    <option value="2">Jeffrey Warden</option>
                                    <option value="2">John Doe</option>
                                    <option value="2">John Smith</option>
                                    <option value="3">Mike Litorus</option>
                                </select>
                            </div>
                            <div class="multiselect-controls col-lg-2 col-sm-2 d-grid gap-2">
                                <button type="button" id="edit_customleave_select_rightAll" class="btn w-100 btn-white">
                                    <i class="fa fa-forward"></i>
                                </button>
                                <button type="button" id="edit_customleave_select_rightSelected" class="btn w-100 btn-white">
                                    <i class="fa fa-chevron-right"></i>
                                </button>
                                <button type="button" id="edit_customleave_select_leftSelected" class="btn w-100 btn-white">
                                    <i class="fa fa-chevron-left"></i>
                                </button>
                                <button type="button" id="edit_customleave_select_leftAll" class="btn w-100 btn-white">
                                    <i class="fa fa-backward"></i>
                                </button>
                            </div>
                            <div class="col-lg-5 col-sm-5">
                                <select name="customleave_to" id="edit_customleave_select_to" class="form-control form-select" size="8"
                                        multiple="multiple"></select>
                            </div>
                        </div>
                    </div>

                    <div class="submit-section">
                        <button class="btn btn-primary submit-btn">Submit</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="col-12 col-md-12 col-lg-12 ">

    <ul class="nav nav-underline fs-9" id="myTab" role="tablist">
        <li class="nav-item"><a class="nav-link active" id="LeaveSettings-tab" data-bs-toggle="tab" href="#tab-LeaveSettings" role="tab" aria-controls="tab-LeaveSettings" aria-selected="true">Leave Type Settings</a></li>
        <li class="nav-item"><a class="nav-link" id="AttendanceSettings-tab" data-bs-toggle="tab" href="#tab-AttendanceSettings" role="tab" aria-controls="tab-AttendanceSettings" aria-selected="false">Leave policy configuration</a></li>
    </ul>
    <div class="tab-content mt-3" id="myTabContent0">
        <div class="tab-pane fade show active" id="tab-LeaveSettings" role="tabpanel" aria-labelledby="LeaveSettings-tab">
            <div class="row">
                <div class="d-flex justify-content-end mb-2">
                    <a class="text-decoration-none btn btn-primary me-2" data-bs-toggle="modal" data-bs-target="#add_new_leave">Add New Leave</a>
                </div>
            </div>

            <div class="px-25">
                <div class="d-flex justify-content-center mt-2 ">
                    <div class="col-12 col-md-12 col-lg-12 ">
                        <div class="row" id="leaveTypesContainer">

                         

                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="tab-AttendanceSettings" role="tabpanel" aria-labelledby="AttendanceSettings-tab">

            <div class="row">
                <div class="d-flex justify-content-end mb-2">
                    <a class="text-decoration-none btn btn-primary me-2" data-bs-toggle="modal" data-bs-target="#add_new_leave">Add New Leave</a>
                </div>
            </div>

            <div class="px-25">
                <div class="d-flex justify-content-center mt-2">
                    <div class="col-12 col-md-12 col-lg-12 ">
                        <div class="row">

                            <div class="col-xl-6 col-md-6">

                                <div class="card mb-2">
                                    <div class="card-header"><h4>Restrictions</h4> </div>
                                    <div class="card-body d-block ">
                                        <div class="mb-2">
                                            <p class="border-bottom h5">Weekent between leave period</p>
                                            <div class="d-flex align-items-center justify-content-between">
                                                <form action="">
                                                    <div class="form-check">
                                                        <input class="form-check-input" id="flexRadioDefault1" type="radio" name="flexRadioDefault" />
                                                        <label class="form-check-label" for="flexRadioDefault1">Count as leave</label>
                                                    </div>
                                                    <div class="form-check">
                                                        <input class="form-check-input" id="flexRadioDefault2" type="radio" name="flexRadioDefault" checked="" />
                                                        <label class="form-check-label" for="flexRadioDefault2">Don't count as leave</label>
                                                    </div>
                                                </form>

                                            </div>
                                        </div>
                                        <div class="mb-2">
                                            <p class="border-bottom h5">Holiday between leave period</p>
                                            <div class="d-flex align-items-center justify-content-between">
                                                <form action="">
                                                    <div class="form-check">
                                                        <input class="form-check-input" id="flexRadioDefault1" type="radio" name="flexRadioDefault" />
                                                        <label class="form-check-label" for="flexRadioDefault1">Count as leave</label>
                                                    </div>
                                                    <div class="form-check">
                                                        <input class="form-check-input" id="flexRadioDefault2" type="radio" name="flexRadioDefault" checked="" />
                                                        <label class="form-check-label" for="flexRadioDefault2">Don't count as leave</label>
                                                    </div>
                                                </form>

                                            </div>
                                        </div>
                                        <div>
                                            <p class="border-bottom h5">While Applying Leave, Exceed Leave Balance</p>
                                            <div class="d-flex align-items-center justify-content-between">
                                                <form action="">
                                                    <div class="form-check">
                                                        <input class="form-check-input" id="flexRadioDefault1" type="radio" name="flexRadioDefault" />
                                                        <label class="form-check-label" for="flexRadioDefault1">Allow (Exceed leave mark as LOP)</label>
                                                    </div>
                                                    <div class="form-check">
                                                        <input class="form-check-input" id="flexRadioDefault2" type="radio" name="flexRadioDefault" checked="" />
                                                        <label class="form-check-label" for="flexRadioDefault2">Don't allow</label>
                                                    </div>

                                                </form>
                                            </div>
                                        </div>


                                    </div>
                                </div>
                            </div>

                            <div class="col-xl-6 col-md-6">
                                <div class="card mb-2">
                                    <div class="card-header"><h4>Allow requests for</h4> </div>
                                    <div class="card-body d-flex align-items-center justify-content-between">
                                        <div class="mb-2">

                                            <div class="d-flex align-items-center justify-content-between">
                                                <form action="">
                                                    <div class="form-check">
                                                        <input class="form-check-input" id="flexCheckDefault" type="checkbox" value="" />
                                                        <label class="form-check-label" for="flexCheckDefault">Past dates not allowed</label>
                                                    </div>

                                                    <div class="form-check mb-3">
                                                        <input class="form-check-input" id="flexCheckChecked" type="" value="" checked="" />
                                                        <label class="form-check-label" for="flexCheckChecked">Future dates</label>
                                                        <div class="form-check ms-5 d-flex">
                                                            <input class="form-check-input me-2 mt-2" id="flexCheckChecked" type="" value="" checked="" />
                                                            <label class="form-check-label mt-2" for="flexCheckChecked">To be applied</label>
                                                            <input type="text" class="form-control mx-2" placeholder="5" style="width: 3rem;">
                                                            <label class="form-check-label mt-2" for="flexCheckChecked">Days in advance</label>
                                                        </div>
                                                    </div>

                                                    <div class="form-check d-flex mb-3">
                                                        <input class="form-check-input me-2 mt-2 " id="flexCheckChecked" type="" value="" checked="" />
                                                        <label class="form-check-label mt-2 me-2" for="flexCheckChecked">Maximum leave that can be availed per application</label>
                                                        <input type="text" class="form-control" placeholder="5" style="width: 3rem;">
                                                    </div>

                                                    <div class="form-check d-flex mb-3">
                                                        <input class="form-check-input me-2 mt-2" id="flexCheckChecked" type="" value="" checked="" />
                                                        <label class="form-check-label mt-2 me-2 " for="flexCheckChecked">Maximum gap (In days) between two application</label>
                                                        <input type="text" class="form-control " placeholder="5" style="width: 3rem;">
                                                    </div>
                                                </form>

                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-xl-6 col-md-6">
                                <div class="card mb-2">
                                    <div class="card-header"><h4>Prorate Accrual</h4> </div>
                                    <div class="card-body d-flex align-items-center justify-content-between">
                                        

                                            <div class="d-flex align-items-center justify-content-between">
                                                <form action="">

                                                    <h5>Round off</h5>
                                                    <div class="form-check d-flex mb-2">
                                                        <input class="form-check-input me-2 mt-2 " id="flexCheckChecked" type="" value="" checked="" />
                                                        <label class="form-check-label mt-2 me-2" for="flexCheckChecked">Round of</label>
                                                        <select class="form-select" aria-label="Default select example" style="width: 12rem;">
                                                            <option selected="">Our</option>
                                                            <option value="1">Half an Hour </option>
                                                          <option value="2">Quarter</option>
                                                        </select>

                                                      
                                                    </div>

                                                </form>

                                            </div>
                                        
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
       


        </div>

    </div>


</div>
