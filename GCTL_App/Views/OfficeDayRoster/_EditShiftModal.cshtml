<!-- Modal  for edit shift  used-->
<div class="modal fade" id="editShiftModal" tabindex="-1" aria-labelledby="editShiftModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="shiftModalLabel">Edit shift</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p id="shiftModalDetails" class="mb-3 text-muted"></p>
                <div class="row mb-3">
                    <div class="col">
                        <label class="form-label" for="organizerSingle">Select Shift</label>
                        <select class="form-select">
                            <option value="">Select Shift</option>
                            <option>Shift 1 (09:00 - 17:00)</option>
                            <option>Shift 2 (08:00 - 16:00)</option>
                            <option>Shift 3 (10:00 - 18:00)</option>
                            <option>Day off</option>
                        </select>
                    </div>


                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="saveShift">Save shift</button>
            </div>
        </div>
    </div>
</div>