<!-- Delete Modal -->
<div class="modal fade" id="rosterInOfficeDays-delModal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body text-center">
                <span class="avatar avatar-xl bg-transparent-danger text-danger mb-1">
                    <i class="fa fa-trash fs-5"></i>
                </span>
                <h4 class="mb-1">@Html.SmartLocalize("Confirm Delete")</h4>
                <p class="mb-3">@Html.SmartLocalize("You want to delete this shift? This cant be undone once you delete").</p>
                <div class="d-flex justify-content-center">
                    <a href="javascript:void(0);" class="btn btn-light me-3" data-bs-dismiss="modal">@Html.SmartLocalize("Cancel")</a>
                    <a class="btn btn-danger" id="rosterInOfficeDays-delModal-delBtn">@Html.SmartLocalize("Yes"), @Html.SmartLocalize("Delete")</a>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- /Delete Modal -->