
<style>
    

    .dashboard-container {
   
        margin-top: 90px !important;
    }

    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 15px;
        margin-top: 15px;
        margin-bottom: 15px;
    }

    .card {
        background: white;
        border-radius: 12px;
        padding: 15px;
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
        cursor: pointer;
        position: relative;
        overflow: hidden;
        height:85px;
    }

        .card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, var(--card-color), var(--card-color-light));
            transform: scaleX(0);
            transition: transform 0.3s ease;
        }

        .card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.15);
        }

            .card:hover::before {
                transform: scaleX(1);
            }

    .card-body {
        display: flex;
        align-items: center;
        gap: 20px;
        padding-top: 0px;
        padding-bottom: 0px;
        padding-right: 0px;
    }


    .card-icon {
        width: 50px;
        height: 50px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        color: white;
        background: linear-gradient(135deg, var(--card-color), var(--card-color-light));
        flex-shrink: 0; /* Prevents icon from shrinking */
    }

    .card-content {
        display: flex;
        flex-direction: column;
        justify-content: center;
        flex: 1;
    }

    .card-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: #2c3e50;
        margin: 0;
        line-height: 1.2;
    }

    /* Color schemes for different cards */
    .card:nth-child(1) {
        --card-color: #3498db;
        --card-color-light: #5dade2;
    }

    .card:nth-child(2) {
        --card-color: #2ecc71;
        --card-color-light: #58d68d;
    }

    .card:nth-child(3) {
        --card-color: #e74c3c;
        --card-color-light: #ec7063;
    }

    .card:nth-child(4) {
        --card-color: #f39c12;
        --card-color-light: #f7dc6f;
    }

    .card:nth-child(5) {
        --card-color: #9b59b6;
        --card-color-light: #bb8fce;
    }

    .card:nth-child(6) {
        --card-color: #1abc9c;
        --card-color-light: #5dbeaa;
    }

    .card:nth-child(7) {
        --card-color: #34495e;
        --card-color-light: #5d6d7e;
    }

    .card:nth-child(8) {
        --card-color: #e67e22;
        --card-color-light: #f0ad4e;
    }

    .card:nth-child(9) {
        --card-color: #8e44ad;
        --card-color-light: #a569bd;
    }

    .card:nth-child(10) {
        --card-color: #27ae60;
        --card-color-light: #52c882;
    }

    .card:nth-child(11) {
        --card-color: #2980b9;
        --card-color-light: #5499c7;
    }

    .card:nth-child(12) {
        --card-color: #c0392b;
        --card-color-light: #cd6155;
    }

    @@media (max-width: 768px) {
        .dashboard-container

    {
        padding: 20px;
        margin: 10px;
    }

    .dashboard-grid {
        grid-template-columns: 1fr;
        gap: 20px;
    }

    }

    .pulse {
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0%

    {
        opacity: 1;
    }

    50% {
        opacity: 0.7;
    }

    100% {
        opacity: 1;
    }

    }
</style>

