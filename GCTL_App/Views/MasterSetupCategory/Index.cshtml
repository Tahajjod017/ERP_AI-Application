
<style>

    .settings-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 15px;
        background-color: #fff;
        padding: 8px;
        border-radius: 16px;
        box-shadow: 0 5px 30px rgba(0, 0, 0, 0.05);
    }

    .setting-item {
        display: flex;
        align-items: flex-start;
        gap: 15px;
        padding: 10px;
        transition: background-color 0.2s;
    }

        .setting-item:hover {
            background-color: #f0f0f0;
            border-radius: 8px;
        }

    .setting-icon {
        font-size: 28px;
        color: #7f8c8d;
        flex-shrink: 0;
    }

    .setting-text {
        flex-grow: 1;
    }

    .setting-title a {
        font-weight: 600;
        font-size: 16px;
        color: #2c3e50;
        text-decoration: none;
    }

        .setting-title a:hover {
            text-decoration: underline;
        }

</style>


<!-- Container for dynamic settings -->
<div class="settings-grid mb-2" id="settingsContainer"></div>

<!-- jQuery (for AJAX) -->
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script>
    $(document).ready(function () {
        $.ajax({
            url: '/MasterSetupCategory/GetMasterSetupCategoriesAsync',
            type: 'GET',
            success: function (data) {
                if (Array.isArray(data)) {
                    $('#settingsContainer').empty();

                    data.forEach(function (item) {
                        const iconClass = item.icon || 'fa-solid fa-circle-question';
                        const title = item.title || 'Untitled';
                        const controller = item.controllerName || '#';
                        const html = `
                            <div class="setting-item">
                                <div class="setting-icon"><i class="${iconClass}"></i></div>
                                <div class="setting-text">
                                    <div class="setting-title"><a href="/${controller}/Index">${title}</a></div>

                                </div>
                            </div>
                        `;
                        $('#settingsContainer').append(html);
                    });
                } else {
                    $('#settingsContainer').html('<p>No data found.</p>');
                }
            },
            error: function (xhr, status, error) {
                console.error('Error loading settings:', error);
                $('#settingsContainer').html('<p style="color:red;">Failed to load settings.</p>');
            }
        });
    });
</script>




