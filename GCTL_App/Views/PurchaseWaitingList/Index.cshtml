<div class="card mb-5">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap row-gap-3">
        <div class="col-auto">
            <div class="d-flex" id="scrollspyEcommerce">
                <span class="fa-stack me-2 ms-n1">
                    <i class="fas fa-circle fa-stack-2x text-primary"></i>
                    <i class="fa-inverse fa-stack-1x text-primary-subtle fas fa-users" data-fa-transform="shrink-4"></i>
                </span>
                <div class="col">
                    <h3 class="mb-0 text-primary position-relative fw-bold">
                        <span>Purchase Waiting List</span>
                        <span class="border border-primary position-absolute top-50 translate-middle-y w-100 start-0 z-n1"></span>
                    </h3>
                </div>
            </div>
        </div>

        <div class="col-auto text-end">
            <a href="/manualpo/index" class="btn btn-primary">Purchase Order</a>
        </div>
    </div>
    <div class="card-body pt-3">
        <div class="row mb-3">
            <div id="errorContainer" style="display: none;">
                <!-- Error messages will be displayed here -->
            </div>

            @* <div class="col-12 col-sm-auto">

            </div> *@
            <div class="d-flex align-items-center justify-content-between flex-wrap row-gap-3">
                <!-- Page Size Selector -->
                <div class="col-auto dropdown">
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text">Showing</span>
                        </div>
                        <select class="form-select" id="pageSizeSelect" name="pageSizeSelect">
                            <option value="5">5</option>
                            <option selected value="10">10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                            <option value="100">100</option>
                        </select>
                    </div>
                </div>

                <div class="col-auto">
                    <div class="columnDrag PurchaseWaitingList"></div>
                </div>

                <!-- Product Type Filter -->
                <div class="col-auto dropdown">
                    <select class="form-select choiceDD" id="productType">
                        <option value="">Search by Product Type</option>
                    </select>
                </div>

                <!-- Project Filter -->
                <div class="col-auto dropdown">
                    <select class="form-select choiceDD" id="project">
                        <option value="">Search by Project</option>
                    </select>
                </div>

                <!-- Product Filter -->
                <div class="col-auto dropdown">
                    <select class="form-select choiceDD" id="product">
                        <option value="">Search by Product</option>
                    </select>
                </div>

                <!-- Search Input -->
                <div class="col-auto">
                    <input class="form-control" id="searchInput" type="text" placeholder="Search requests...">
                </div>
            </div>
        </div>

        <div id="projectSummary">
            <!-- Table Container -->
            <div class="table-responsive ms-n1 ps-1 scrollbar">
                <table class="table fs-9 mb-0 border-top border-translucent dyn-tableDrag PurchaseWaitingList" id="PurchaseWaitingList">
                    <thead>
                        <tr>
                            <th class=" white-space-nowrap align-middle ps-0" scope="col" data-sort="reqId">
                                <a href="#" onclick="sortTable('poId')" class="text-decoration-none text-body">
                                    PO_ID <i class="fas fa-sort" id="sort-poId"></i>
                                </a>
                            </th>
                            <th class=" white-space-nowrap align-middle ps-0" scope="col" data-sort="reqId">
                                <a href="#" onclick="sortTable('reqId')" class="text-decoration-none text-body">
                                    RequitionID <i class="fas fa-sort" id="sort-reqId"></i>
                                </a>
                            </th>
                            <th class=" white-space-nowrap align-middle ps-2" scope="col" data-sort="projectName">
                                <a href="#" onclick="sortTable('projectName')" class="text-decoration-none text-body">
                                    Project <i class="fas fa-sort" id="sort-projectName"></i>
                                </a>
                            </th>
                            <th class=" white-space-nowrap align-middle ps-2" scope="col" data-sort="requestedBy">
                                <a href="#" onclick="sortTable('requestedBy')" class="text-decoration-none text-body">
                                    Requested By <i class="fas fa-sort" id="sort-requestedBy"></i>
                                </a>
                            </th>
                            <th class=" white-space-nowrap align-middle ps-2" scope="col" data-sort="requestDate">
                                <a href="#" onclick="sortTable('requestDate')" class="text-decoration-none text-body">
                                    Request Date <i class="fas fa-sort" id="sort-requestDate"></i>
                                </a>
                            </th>
                            <th class=" white-space-nowrap align-middle ps-2" scope="col" data-sort="productType">
                                <a href="#" onclick="sortTable('productType')" class="text-decoration-none text-body">
                                    Product Type <i class="fas fa-sort" id="sort-productType"></i>
                                </a>
                            </th>
                            <th class=" white-space-nowrap align-middle ps-2" scope="col" data-sort="productName">
                                <a href="#" onclick="sortTable('productName')" class="text-decoration-none text-body">
                                    Product Name <i class="fas fa-sort" id="sort-productName"></i>
                                </a>
                            </th>
                            <th class=" white-space-nowrap align-middle ps-2" scope="col" data-sort="status">
                                <a href="#" onclick="sortTable('status')" class="text-decoration-none text-body">
                                    Status <i class="fas fa-sort" id="sort-status"></i>
                                </a>
                            </th>
                            <th class=" white-space-nowrap align-middle ps-2" scope="col" data-sort="quantity">
                                <a href="#" onclick="sortTable('quantity')" class="text-decoration-none text-body">
                                    Quantity <i class="fas fa-sort" id="sort-quantity"></i>
                                </a>
                            </th>
                            <th class="text-end white-space-nowrap pe-6" scope="col">
                                Export
                            </th>
                            <th class="text-end white-space-nowrap pe-6" scope="col">
                                Action
                            </th>
                        </tr>
                    </thead>
                    <tbody id="product-Requisition-history-table">
                        <!-- Rows will be loaded dynamically via JS -->
                    </tbody>
                </table>
            </div>

            <!-- Pagination and Showing Info -->
            <div class="d-flex justify-content-between align-items-center mt-3">
                <div id="showDown2" class="text-muted">
                    Showing 0 to 0 of 0
                </div>
                <nav aria-label="Table pagination" class="pagination-container">
                    <ul class="pagination mb-0">
                        <li class="page-item disabled" data-list-pagination="prev">
                            <a class="page-link" href="#">Previous</a>
                        </li>
                        <!-- Dynamic pages will be inserted here -->
                        <li class="page-item disabled" data-list-pagination="next">
                            <a class="page-link" href="#">Next</a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

    <script src="~/js/pages/RequisitionDistribtion/Purchase/PurchaseWaitingList.js"></script>
}