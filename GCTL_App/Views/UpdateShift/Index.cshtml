<div class="content">

    <div class="mb-9 mt-4">

        <div class="card">



            <div class="card-header d-flex align-items-center justify-content-between flex-wrap row-gap-3 mb-4">
                <h4 class="mb-1">Update Shift</h4>

            </div>
            <div class="card-body">
                <div class="d-flex my-xl-auto right-content align-items-center flex-wrap row-gap-3">

                    <form action="update-shift-ui.html">
                        <div class="modal-body pb-0">
                            <div class="row">

                                <div class="col-md-4">
                                    <div class="mb-3">
                                        <label class="form-label" for="organizerSingleCompany">Company</label>
                                        <select class="form-multi-select" multiple data-coreui-search="true">
                                            <option value="1">CSL</option>
                                            <option value="2">GCTL</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="col-md-4">
                                    <div class="mb-3">
                                        <label class="form-label" for="organizerSingle">Department</label>
                                        <select class="form-multi-select" multiple data-coreui-search="true">
                                            <option value="0">Developer</option>
                                            <option value="1">Manager</option>
                                            <option value="2">Designer</option>
                                            <option value="3">Finance</option>
                                        </select>
                                    </div>

                                </div>

                                <div class="col-md-4">
                                    <div class="mb-3">
                                        <label class="form-label" for="organizerSingle">Employee Name</label>
                                        <select class="form-multi-select" id="multiple-emp-select" multiple data-coreui-selection-type="counter" data-coreui-search="true">
                                            <optgroup label="Developer">
                                                <option value="2">Alam</option>
                                                <option value="3">Momin</option>
                                            </optgroup>
                                            <optgroup label="Designer">
                                                <option value="4">Name (id)</option>
                                                <option value="5">Name (id)</option>
                                            </optgroup>
                                        </select>
                                    </div>

                                </div>

                                <div class="d-flex my-xl-auto right-content align-items-center flex-wrap ">

                                    <div class="container mt-2">
                                        <div id="addDateContainer">
                                            <!-- Initial "addDate" div -->
                                            <div id="addDate" class="d-flex my-xl-auto right-content align-items-center flex-wrap">
                                                <div class="col-md-5 me-4">
                                                    <div class="mb-3">
                                                        <label class="form-label" for="organizerSingle">Select Date</label>
                                                        <input class="form-control datetimepicker1" type="text" placeholder="dd/mm/yyyy" data-input>
                                                    </div>
                                                </div>
                                                <div class="col-md-5 me-4">
                                                    <div class="mb-3">
                                                        <label class="form-label" for="organizerSingle">Select Shift</label>
                                                        <select class="form-select">
                                                            <option value="">Select Shift</option>
                                                            <option>Shift 1 (09:00 - 17:00)</option>
                                                            <option>Shift 2 (08:00 - 16:00)</option>
                                                            <option>Shift 3 (10:00 - 18:00)</option>
                                                            <option>Day off</option>
                                                        </select>
                                                    </div>
                                                </div>
                                                <div class="col-md-1">
                                                    <div class="mb-4">
                                                        <button type="button" class="btn btn-primary addDateForShift">+</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <script>
                                        document.addEventListener('DOMContentLoaded', function () {
                                          const addDateContainer = document.getElementById('addDateContainer');
                                          let blockCount = 1; // Counter to track the number of blocks

                                          // Function to disable Fridays
                                          function disableFridays(date) {
                                            return date.getDay() === 5; // Disable Fridays (5 is the day index for Friday)
                                          }

                                          // Initialize Flatpickr for the initial date picker
                                          flatpickr(".datetimepicker1", {
                                            dateFormat: "d/m/Y", // Date format
                                            disableMobile: true, // Disable mobile native picker
                                            disable: [disableFridays], // Disable Fridays
                                          });

                                          // Function to add a new "addDate" div
                                          function addNewDateDiv() {
                                            if (blockCount >= 5) {
                                              alert('Maximum of 5 blocks reached.');
                                              return; // Stop adding new blocks
                                            }

                                            // Clone the original "addDate" div
                                            const originalDiv = document.querySelector('#addDate');
                                            const clonedDiv = originalDiv.cloneNode(true);

                                            // Clear input and select values in the cloned div
                                            clonedDiv.querySelector('input').value = '';
                                            clonedDiv.querySelector('select').selectedIndex = 0;

                                            // Hide the "+" button in the cloned div
                                            const clonedButton = clonedDiv.querySelector('.addDateForShift');
                                            clonedButton.classList.add('hidden');

                                            // Append the cloned div to the container
                                            addDateContainer.appendChild(clonedDiv);

                                            // Initialize Flatpickr for the new date picker
                                            flatpickr(clonedDiv.querySelector(".datetimepicker1"), {
                                              dateFormat: "d/m/Y", // Date format
                                              disableMobile: true, // Disable mobile native picker
                                              disable: [disableFridays], // Disable Fridays
                                            });

                                            // Increment the block counter
                                            blockCount++;

                                            // Disable the "+" button if the maximum limit is reached
                                            if (blockCount >= 5) {
                                              const buttons = document.querySelectorAll('.addDateForShift');
                                              buttons.forEach(button => {
                                                button.disabled = true;
                                              });
                                            }
                                          }

                                          // Event delegation for dynamically added buttons
                                          addDateContainer.addEventListener('click', function (event) {
                                            if (event.target.classList.contains('addDateForShift')) {
                                              addNewDateDiv();
                                            }
                                          });
                                        });
                                    </script>



                                </div>





                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="submit" class="btn btn-primary">Save</button>
                        </div>
                    </form>




                </div>
            </div>



        </div>

    </div>
</div>