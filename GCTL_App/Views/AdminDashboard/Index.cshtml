@{
}
<script src="~/js/layout/echarts/echarts.min.js"></script>
<div class="col-12 col-md-12 col-lg-12 d-flex">
    <div class="col-md-4">
        <div class="mb-3">
            <label class="form-label fs-7" for="organizerSingleCompany">Select Company</label>
            <select class="form-multi-select" multiple data-coreui-search="true">
                <option value="1">CSL</option>
                <option value="2">GCTL</option>
            </select>
        </div>
    </div>
</div>

@* Total Employee  *@
<div class="col-12 col-md-12 col-lg-12 d-flex">
    <div class="row flex-fill">
        <partial name="_TotalRelatedEmployee" />
    </div>
</div>

@* Employee Average Attendance *@
<div class="col-12 col-md-12 col-lg-12 d-flex">
    <div class="row flex-fill">
        <partial name="_EmployeeAverageAttendance" />
    </div>
</div>

@* Employee working Location and overall attendence *@
<div class="col-12 col-md-12 col-lg-12 d-flex">
    <div class="row flex-fill">
        <partial name="_EmployeeLocationAndOverall" />
    </div>
</div>

@* Employee Absence And Status *@
<div class="col-12 col-md-12 col-lg-12 d-flex">
    <div class="row flex-fill">
        <partial name="_EmployeeAbsenceAndStatus" />
    </div>
</div>
@* Employee Ateendence by Departmen And comparing Best Employee *@
<div class="col-12 col-md-12 col-lg-12 d-flex">
    <div class="row flex-fill">
        <partial name="_EmployeeDepartmentAndBestEmployee" />
    </div>
</div>
