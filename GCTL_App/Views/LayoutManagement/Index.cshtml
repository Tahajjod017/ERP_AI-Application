@{
    ViewData["Title"] = "Add Logo";
}

<nav class="mb-3 crm-deals-breadcrumb" aria-label="breadcrumb">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item active"><h3 class="text-body-emphasis">@ViewData["Title"]</h3></li>
    </ol>
</nav>

<div class="row">
    <div class="col-12">
        <div class="mx-n4 px-4 mx-lg-n6 px-lg-6 bg-body-emphasis border-top">

        </div>
    </div>
</div>

<div class="mt-4 mx-lg-n4">
    <div class="row g-4">
        <div class="col-12 col-md-7 col-xl-5 col-xxl-5">
            <div class="card">
                <div class="card-header border-bottom-1">
                    <div class="row justify-content-between align-items-center">
                        <div class="col-auto">
                            <h3 class="text-body-emphasis mt-3">Add Logo</h3>
                        </div>
                    </div>
                </div>

                <div class="card-body mt-3">
                    <form asp-action="Create" asp-controller="LayoutManagement" method="post" enctype="multipart/form-data" id="layoutManagement-form">
                        @Html.AntiForgeryToken()

                        <div class="dropzone dropzone-single p-0" id="dropzone-single">
                            <div class="fallback mb-4">
                                <input type="file" name="file" class="form-control" id="actualFileInput" />
                            </div>
                            
                            <div class="dz-preview d-block m-0">
                                <div class="rounded-2 position-relative">
                                    <img class="rounded-2 w-100 h-100 object-fit-cover" src="~/assets/img/icons/file-bg.png" alt="Preview" id="previewImage" />
                                    <button type="button" class="btn border-0 position-absolute top-0 end-0 z-5 bg-black bg-opacity-50 text-white mt-3 me-3 px-3" id="removeImage">
                                        <span class="fa-solid fa-xmark"></span>
                                    </button>
                                </div>
                            </div>
                        </div>
						
                        <div class="col-12 mb-4 mt-4">
                            <div class="row g-3 justify-content-end">
                                <div class="col-auto">
                                    <button type="submit" class="btn btn-primary px-5 px-sm-15">Save</button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script src="~/js/layout/logo.js"></script>
    <script>
        $(function () {
            var options = {
                baseUrl: '@Url.Action("", "LayoutManagement")'
            };
            options.load = () => { };
            $.logo(options);
        });
    </script>
}