@model GCTL.Core.ViewModels.RoleModule.RoleManagementViewModel

@{
    ViewBag.Title = "User Role Management";
}

<h2 class="text-center mt-4 mb-4">@ViewBag.Title</h2>

@if (TempData["Message"] != null)
{
    <div id="successAlert" class="alert alert-success text-center alert-dismissible fade show" role="alert">
        @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div id="errorAlert" class="alert alert-danger text-center alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="px-25">
    <div class="d-flex justify-content-center mt-2">
        <div class="col-12 row flex gy-3 pb-3">
            <!-- Form to Create New Role -->
            <div class="col-12">
                <div class="card shadow-sm mb-5">
                    <div class="card-header bg-light">
                        <h5 class="m-0">Create New Role</h5>
                    </div>
                    <div class="card-body">
                        <form asp-action="CreateRole" method="post">
                            @Html.AntiForgeryToken()
                            <div class="form-floating">
                                <input asp-for="NewRoleName" class="form-control" placeholder="Enter role name" />
                                <label asp-for="NewRoleName">Role Name</label>
                                <span asp-validation-for="NewRoleName" class="text-danger"></span>
                            </div>
                            @* @if (ViewBag.CanCreate == true)
                            {
                                <button type="submit" class="btn btn-primary mt-3">Add Role</button>
                            } *@
                            <button type="submit" class="btn btn-primary mt-3">Add Role</button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Assign Users to Roles Section -->
            <div class="col-12">
                <div class="card shadow-sm mb-5">
                    <div class="card-header bg-light">
                        <h5 class="m-0">Assign Users to Roles</h5>
                    </div>
                    <div class="card-body">
                        <table class="table table-hover">
                            <thead class="thead-light">
                                <tr>
                                    <th>Role Name</th>
                                    <th>Search Users</th>
                                    <th>Selected Users</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var role in ViewBag.AvailableRoles)
                                {
                                    <tr>
                                        <td class="align-middle">@role</td>
                                        <td>
                                            <input type="text" id="userSearch-@role" class="form-control user-search" data-role="@role" placeholder="Search Users" />
                                            <ul id="userSearchResults-@role" class="list-unstyled mt-2"></ul>
                                        </td>
                                        <td>
                                            <ul id="selectedUsers-@role" class="list-unstyled mt-2"></ul>
                                        </td>
                                        <td>
                                            <button class="btn btn-success assign-role-btnR" data-role="@role">Assign</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- List of Assigned Users for Each Role -->
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-header bg-light">
                        <h5 class="m-0">Assigned Users for Each Role</h5>
                    </div>
                    <div class="card-body">
                        <table class="table table-hover">
                            <thead class="thead-light">
                                <tr>
                                    <th>Role Name</th>
                                    <th>User Name</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var roleAssignment in Model.RoleUserAssignments)
                                {
                                    var roleName = roleAssignment.Key;
                                    var usersInRole = roleAssignment.Value;

                                    @foreach (var user in usersInRole)
                                    {
                                        <tr>
                                            <td>@roleName</td>
                                            <td>@user.UserName</td>
                                            <td>
                                                <form class="remove-user-form" method="post" action="/AccessPermission/RemoveUserFromRole">
                                                    @Html.AntiForgeryToken()  <!-- Include Anti-Forgery Token -->
                                                    <input type="hidden" name="roleName" value="@roleName" />
                                                    <input type="hidden" name="userName" value="@user.UserName" />
                                                    <button type="submit" class="btn btn-danger btn-sm">
                                                        <i class="fas fa-trash-alt"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery/dist/jquery.js"></script>
<script src="~/js/pages/authjs/accesspermission.js"></script>

<!-- Add jQuery (if not already included) -->
<script>
    $(document).ready(function () {
        // Function to hide alerts after 4 seconds
        function hideAlert(alertId) {
            setTimeout(function () {
                $(alertId).fadeOut('slow', function () {
                    $(this).remove(); // Remove the alert from the DOM after fading out
                });
            }, 4000); // 4000 milliseconds = 4 seconds
        }

        // Hide success alert if it exists
        if ($("#successAlert").length) {
            hideAlert("#successAlert");
        }

        // Hide error alert if it exists
        if ($("#errorAlert").length) {
            hideAlert("#errorAlert");
        }
    });
</script>