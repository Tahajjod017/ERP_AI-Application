@model GCTL.Core.ViewModels.RoleModule.RoleManagementViewModel

@{

    ViewBag.Title = "User Role Management";
}

<h2 class="text-center mt-4 mb-4">@ViewBag.Title</h2>
<style>
    /* Make the user results scrollable */
    .user-results-scroll {
        display: none;
        position: absolute;
        max-height: 240px; /* Adjust this value based on the height of 5 items */
        overflow-y: auto; /* Add vertical scrolling */
        padding: 10px;
        border: 1px solid #ddd;
        border-radius: 5px;
        background-color: #f9f9f9;
        transition: opacity 0.3s ease-in-out;
        z-index: 1;
        width: 26.5%;
    }

        /* Ensure the results list scrolls smoothly */
        .user-results-scroll::-webkit-scrollbar {
            width: 6px;
        }

        .user-results-scroll::-webkit-scrollbar-thumb {
            background-color: #ced4da;
            border-radius: 4px;
        }

        /* When results are displayed, fade them in */
        .user-results-scroll.show {
            display: block;
        }

    /* Style for the selected users list */
    .user-item {
        color: #333; /* Dark color for the user name */
        display: inline-flex;
        align-items: center;
        margin-right: -6px; /* Space between each user name */
        margin-bottom: 5px; /* Space between rows */
    }

    /* Styling for the Windows-style cross (X) icon */
    .remove-user-btn {
        font-size: 1.2rem; /* Larger "X" icon */
        cursor: pointer; /* Ensure it looks clickable */
        color: #dc3545; /* Red color for the "X" icon */
        margin-left: 5px; /* Space between the user name and the icon */
    }

        .remove-user-btn:hover {
            color: #c82333; /* Darker red on hover */
        }

    /* Ensuring proper spacing between user items */
    #selectedUsers-role {
        display: block;
        margin-top: 10px;
    }

        /* Preventing wrapping if the line is too long */
        #selectedUsers-role span {
            white-space: nowrap;
        }

    .scrollable-user-list {
        max-height: 75px; /* 3 users * ~40px each */
        overflow-y: auto;
        overflow-x: hidden;
        border: 0px solid #e3e3e3;
        border-radius: 4px;
        padding-right: 10px;
    }


</style>
@if (TempData["Message"] != null)
{
    <div id="successAlert" class="alert alert-success text-center alert-dismissible fade show" role="alert">
        @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div id="errorAlert" class="alert alert-danger text-center alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

