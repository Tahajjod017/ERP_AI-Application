@model GCTL.Core.ViewModels.AttendanceManagement.AttendenceReportAlls.AttendanceEmployeeReportVM 
@{
    var departments = ViewBag.DepartmentDD as List<GCTL.Core.ViewModels.CommonSelectVM>;
    var employees = ViewBag.EmployeeList as List<GCTL.Core.ViewModels.CommonSelectVM>;
   
}


<div class="card-header d-flex align-items-center justify-content-between flex-wrap row-gap-3 mb-4">

    <h4 class="mb-1">Monthly Employees Attendance</h4>
    <div class="d-flex my-xl-auto right-content align-items-center flex-wrap row-gap-3">

        <div class="dropdown me-3">

            <select class="form-select choiceDD" asp-items="@ViewBag.OrganizationDD as SelectList" id="organizationid" name="OrganizationID">
                <option value="">Select Company</option>
            </select>
        </div>
        <div class="dropdown me-2">
            <select class="form-multi-select" asp-for="DepartmentIDs"
                    id="departmentid"
                    multiple data-coreui-selection-type="counter"
                    data-coreui-placeholder="@Html.SmartLocalize("Select Department")..."
                    data-coreui-search="true">
                @foreach (var group in departments.GroupBy(e => e.GroupName))
                {
                    <optgroup label="@group.Key">
                        @foreach (var emp in group)
                        {
                            <option value="@emp.Id">@emp.Name</option>
                        }
                    </optgroup>
                }
            </select>
        </div>


        <div class="dropdown me-2">
            <select class="form-multi-select" asp-for="EmployeeIDs"
                    id="employeeid"
                    multiple data-coreui-selection-type="counter"
                    data-coreui-placeholder="@Html.SmartLocalize("Select Employee")..."
                    data-coreui-search="true">
                @foreach (var group in employees?.GroupBy(e => e.GroupName))
                {
                    <optgroup label="@group.Key">
                        @foreach (var emp in group)
                        {
                            <option value="@emp.Id">@emp.Name</option>
                        }
                    </optgroup>
                }
            </select>
        </div>

        <div class="flatpickr-input-container me-3">
            <input class="form-control ps-6 flatpickr-input" id="year-month-picker" type="text" readonly="readonly" placeholder="Select Month">
            <span class="uil uil-calendar-alt flatpickr-icon text-body-tertiary"></span>
        </div>
        <!-- Year Dropdown -->
        
    </div>
</div>

<div class="border-translucent p-3">


    <div class="table-responsive scrollbar mx-n1 px-1">

        <table class="table table-bordered fw-bold">
            <thead>
                <tr>
                    <th>Employee</th>
                    <th>01</th>
                    <th>02</th>
                    <th>03</th>
                    <th>04</th>
                    <th>05</th>
                    <th>06</th>
                    <th>07</th>
                    <th>08</th>
                    <th>09</th>
                    <th>10</th>
                    <th>11</th>
                    <th>12</th>
                    <th>13</th>
                    <th>14</th>
                    <th>15</th>
                    <th>16</th>
                    <th>17</th>
                    <th>18</th>
                    <th>19</th>
                    <th>20</th>
                    <th>21</th>
                    <th>22</th>
                    <th>23</th>
                    <th>24</th>
                    <th>25</th>
                    <th>27</th>
                    <th>28</th>
                    <th>29</th>
                    <th>30</th>
                    <th>31&nbsp;</th>
                </tr>
            </thead>
            <tbody id="empMonthlyAll-tbody">
               
            </tbody>
        </table>

    </div>

    <div class="d-flex flex-wrap align-items-center justify-content-between py-3 pe-0 fs-9 border-bottom border-translucent">
        <div class="d-flex">
            <p class="mb-0 d-none d-sm-block me-3 fw-semibold text-body" id="empMonthlyAll-paginationInfo"></p>

            <p class="mb-0 d-none d-sm-block me-3 fw-semibold text-body" data-list-info="data-list-info"></p>
        </div>
        <div class="d-flex">
            <button class="page-link" data-list-pagination="prev" id="empMonthlyAll-prevPageBtn"><span class="fas fa-chevron-left"></span></button>
            <ul class="mb-0 pagination" id="empMonthlyAll-paginationLinks"></ul>
            <button class="page-link pe-0" data-list-pagination="next" id="empMonthlyAll-nextPageBtn"><span class="fas fa-chevron-right"></span></button>
        </div>
    </div>
    <div class="d-flex my-3 flex-wrap border-bottom ">
        <div class="full-present me-2">
            <p class="badge text-bg-success">P</p>
            <span>Present</span>
        </div>
        <div class="me-2">
            <p class="badge text-bg-danger">A</p>
            <span>Absence</span>
        </div>
        <div class="me-2">
            <p class="badge text-bg-warning">W</p>
            <span>Weekend</span>
        </div>
        <div class="me-2">
            <p class="badge badge-phoenix badge-phoenix-warning">H</p>
            <span>Holiday</span>
        </div>
        <!-- Annual Leave (AL) - Blue -->
        <div class="me-2">
            <p class="badge text-bg-info">AL</p>
            <span>Annual Leave</span>
        </div>
        <!-- Sick Leave (SL) - Lighter Blue -->
        <div class="me-2">
            <p class="badge text-bg-primary">ML</p>
            <span>Medical Leave</span>
        </div>
        <!-- Casual Leave (C) - Dark Gray -->
        <div class="me-2">
            <p class="badge badge-phoenix badge-phoenix-warning">C</p>
            <span>Casual Leave</span>
        </div>
        <!-- Maternity/Paternity Leave (ML/PL) - Muted Gray -->
        <div class="me-2">
            <p class="badge text-bg-info">ML/PL</p>
            <span>Maternity Leave</span>
        </div>
        <!-- Paternity Leave (PL) - Muted Gray -->
        <div class="me-2">
            <p class="badge text-bg-info">PL</p>
            <span>Paternity Leave</span>
        </div>
        <!-- Leave Without Pay (LWP) - Light Gray -->
        <div class="me-2">
            <p class="badge text-bg-light">LWP</p>
            <span>Leave Without Pay</span>
        </div>
    </div>


</div>

