<!-- Termination Approval Modal -->
<div class="modal fade" id="termination_approval_modal" tabindex="-1" aria-labelledby="terminationApprovalModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="terminationApprovalModalLabel">@Html.SmartLocalize("Review Termination Request")</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">@Html.SmartLocalize("Department")</label>
                            <input type="text" class="form-control" id="modalDepartment" value="IT Department" readonly>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">@Html.SmartLocalize("Current Position")</label>
                            <input type="text" class="form-control" id="modalPosition" value="Software Developer" readonly>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">@Html.SmartLocalize("Employee Name")</label>
                            <input type="text" class="form-control" id="modalEmployeeId" value="EMP-002" readonly>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">@Html.SmartLocalize("Termination Type")</label>
                            <input type="text" class="form-control" id="modalTerminationType" value="Performance Issues" readonly>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">@Html.SmartLocalize("Years of Service")</label>
                            <input type="text" class="form-control" id="modalYearsOfService" value="2 Years 8 Months" readonly>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">@Html.SmartLocalize("Notice Date")</label>
                            <input type="text" class="form-control" id="modalNoticeDate" value="10 Jan 2024" readonly>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">@Html.SmartLocalize("Termination Date")</label>
                            <input type="text" class="form-control" id="modalTerminationDate" value="10 Feb 2024" readonly>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">@Html.SmartLocalize("Current Salary")</label>
                            <input type="text" class="form-control" id="modalCurrentSalary" value="৳45,000" readonly>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">@Html.SmartLocalize("Pending Dues")</label>
                            <input type="text" class="form-control" id="modalPendingDues" value="৳0" readonly>
                        </div>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">@Html.SmartLocalize("Reason for Termination")</label>
                    <textarea class="form-control" id="modalTerminationReason" rows="3" readonly>Employee consistently failed to meet performance targets despite multiple warnings and improvement plans. Performance evaluation scores have been below satisfactory for the past 6 months with no sign of improvement.</textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">@Html.SmartLocalize("HR Comments (Optional)")</label>
                    <textarea class="form-control" id="modalHRComments" rows="3" placeholder="@Html.SmartLocalize("Add your comments here...")"></textarea>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Html.SmartLocalize("Close")</button>
                <button type="button" class="btn btn-warning me-2" data-bs-toggle="modal" data-bs-target="#final_settlement_modal" data-termination-id="">@Html.SmartLocalize("View Settlement Details")</button>
                <button type="button" class="btn btn-danger me-2" data-action="decline" data-termination-id="">@Html.SmartLocalize("Decline")</button>
                <button type="button" class="btn btn-success" data-action="approve" data-termination-id="">@Html.SmartLocalize("Approve")</button>
            </div>
        </div>
    </div>
</div>

<!-- Confirmation Modal -->
<div class="modal fade" id="confirmation_modal" tabindex="-1" aria-labelledby="confirmationModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="confirmationModalLabel">@Html.SmartLocalize("Confirm Action")</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p id="confirmation_message">@Html.SmartLocalize("Are you sure you want to") <span id="confirmation_action"></span> @Html.SmartLocalize("this termination request?")</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Html.SmartLocalize("Cancel")</button>
                <button type="button" class="btn btn-primary" id="confirm_action">@Html.SmartLocalize("Confirm")</button>
            </div>
        </div>
    </div>
</div>

<!-- Final Settlement Modal -->
<div class="modal fade" id="final_settlement_modal" tabindex="-1" aria-labelledby="finalSettlementModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="finalSettlementModalLabel">@Html.SmartLocalize("Final Settlement Details")</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-6">
                        <h6 class="mb-3 text-success">@Html.SmartLocalize("Payable Amount")</h6>
                        <div class="mb-2 d-flex justify-content-between">
                            <span>@Html.SmartLocalize("Remaining Salary"):</span>
                            <span>৳32,500</span>
                        </div>
                        <div class="mb-2 d-flex justify-content-between">
                            <span>@Html.SmartLocalize("Unused Leave"):</span>
                            <span>৳8,500</span>
                        </div>
                        <div class="mb-2 d-flex justify-content-between">
                            <span>@Html.SmartLocalize("Severance Pay"):</span>
                            <span>৳25,000</span>
                        </div>
                        <div class="mb-2 d-flex justify-content-between">
                            <span>@Html.SmartLocalize("Gratuity"):</span>
                            <span>৳45,000</span>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between fw-bold text-success">
                            <span>@Html.SmartLocalize("Total Payable"):</span>
                            <span>৳111,000</span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <h6 class="mb-3 text-danger">@Html.SmartLocalize("Deductible Amount")</h6>
                        <div class="mb-2 d-flex justify-content-between">
                            <span>@Html.SmartLocalize("Advance Salary"):</span>
                            <span>৳0</span>
                        </div>
                        <div class="mb-2 d-flex justify-content-between">
                            <span>@Html.SmartLocalize("Loan Outstanding"):</span>
                            <span>৳15,000</span>
                        </div>
                        <div class="mb-2 d-flex justify-content-between">
                            <span>@Html.SmartLocalize("Notice Period Shortage"):</span>
                            <span>৳0</span>
                        </div>
                        <div class="mb-2 d-flex justify-content-between">
                            <span>@Html.SmartLocalize("Other Deductions"):</span>
                            <span>৳3,000</span>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between fw-bold text-danger">
                            <span>@Html.SmartLocalize("Total Deductible"):</span>
                            <span>৳18,000</span>
                        </div>
                    </div>
                </div>
                <hr>
                <div class="row">
                    <div class="col-12">
                        <div class="d-flex justify-content-between align-items-center bg-light p-3 rounded">
                            <h5 class="mb-0">@Html.SmartLocalize("Net Settlement Amount"):</h5>
                            <h4 class="mb-0 text-primary">৳93,000</h4>
                        </div>
                    </div>
                </div>
                <div class="mt-3">
                    <label class="form-label">@Html.SmartLocalize("Settlement Notes")</label>
                    <textarea class="form-control" rows="3" placeholder="@Html.SmartLocalize("Add any additional notes regarding the settlement...")"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Html.SmartLocalize("Close")</button>
                <button type="button" class="btn btn-primary">@Html.SmartLocalize("Generate Settlement Letter")</button>
            </div>
        </div>
    </div>
</div>







