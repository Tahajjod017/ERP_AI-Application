    .avatar-wrapper {
        width: 40px;
        height: 40px;
        position: relative;
        overflow: hidden;
        display: inline-block;
        background-color: #007bff; /* Bootstrap primary */
        border-radius: 50%;
    }

    .avatar-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 50%;
        display: block;
    }

    .avatar-fallback {
        position: absolute;
        top: 0;
        left: 0;
        display: none;
        width: 100%;
        height: 100%;
        color: white;
        font-weight: bold;
        font-size: 1rem;
        align-items: center;
        justify-content: center;
        display: flex;
    }

</style>




