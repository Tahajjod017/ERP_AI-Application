<style>
    .view-toggle.active {
        background-color: #0d6efd !important;
        color: white !important;
        border-color: #0d6efd !important;
    }

    .view-content {
        transition: opacity 0.3s ease;
    }

    .view-content.hidden {
        display: none;
    }

    .view-content.visible {
        opacity: 1;
    }

    /* Force Bootstrap grid to work correctly */
    #boardView .row {
        display: flex !important;
        flex-wrap: wrap !important;
        margin-right: -15px !important;
        margin-left: -15px !important;
    }

    #boardView .col {
        flex: 1 0 0% !important;
        max-width: 100% !important;
        padding-right: 15px !important;
        padding-left: 15px !important;
    }

    /* Ensure cards take full width of their column */
    #boardView .card {
        width: 100% !important;
        box-sizing: border-box !important;
    }


    /*  table  */
    th.sort {
        cursor: pointer;
        position: relative;
        padding-right: 1.5rem !important; /* Space for arrow */
    }

    th.sort.sort-asc::after {
        content: '\f0de'; /* Font Awesome up arrow */
        font-family: 'Font Awesome 5 Free';
        font-weight: 900;
        position: absolute;
        right: 0.5rem;
        top: 50%;
        transform: translateY(-50%);
    }

    th.sort.sort-desc::after {
        content: '\f0dd'; /* Font Awesome down arrow */
        font-family: 'Font Awesome 5 Free';
        font-weight: 900;
        position: absolute;
        right: 0.5rem;
        top: 50%;
        transform: translateY(-50%);
    }

   

</style>



