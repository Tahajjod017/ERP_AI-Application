@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
	<script src="~/js/pages/employees/employeelist.js"></script>
	<script src="~/js/pages/employees/employeevalidator.js"></script>

    <script>
          document.addEventListener('DOMContentLoaded', function () {
          const listViewBtn = document.getElementById('listViewBtn');
          const boardViewBtn = document.getElementById('boardViewBtn');
          const listView = document.getElementById('listView');
          const boardView = document.getElementById('boardView');

          // Set initial state: boardView visible, listView hidden
          boardView.classList.remove('hidden');
          boardView.classList.add('visible');
          listView.classList.add('hidden');
          listView.classList.remove('visible');
          boardViewBtn.classList.add('active');
          listViewBtn.classList.remove('active');

          // List view button click
          listViewBtn.addEventListener('click', function (e) {
            e.preventDefault();
            boardView.classList.add('hidden');
            boardView.classList.remove('visible');
            listView.classList.remove('hidden');
            listView.classList.add('visible');
            boardViewBtn.classList.remove('active');
            listViewBtn.classList.add('active');
          });

          // Board view button click
          boardViewBtn.addEventListener('click', function (e) {
            e.preventDefault();
            listView.classList.add('hidden');
            listView.classList.remove('visible');
            boardView.classList.remove('hidden');
            boardView.classList.add('visible');
            listViewBtn.classList.remove('active');
            boardViewBtn.classList.add('active');
          });
        });
    </script>
}