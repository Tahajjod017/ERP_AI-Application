@model GCTL_App.ViewModels.MasterSetup.MaritalStatus.MaritalStatusPageVM

@{
    ViewData["Title"] = @Html.SmartLocalize("Add Marital Status");
}

<nav class="mb-3 crm-deals-breadcrumb" aria-label="breadcrumb">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item active">@ViewData["Title"]</li>
    </ol>
</nav>

<div class="row g-2">
    <div class="col-12 col-md-7 col-xl-5 col-xxl-5">
        <partial name="_Form" model="Model.Setup" />
    </div>

    <div class="col-12 col-md-7 col-xl-7 col-xxl-7">
        <partial name="_Table" />
    </div>
</div>

<partial name="_ConfirmDelete" />

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/js/pages/mastersetup/maritalStatus.js"></script>
    <script type="text/javascript">
        $(function () {
            var options = {
                baseUrl: '@Url.Action("", "MaritalStatus")'
            };
            options.load = () => {

            };

            $.maritalStatus(options);
        });
    </script>
}
