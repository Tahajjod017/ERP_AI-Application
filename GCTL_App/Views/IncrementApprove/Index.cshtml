<!-- Increment Approval Modal -->
<div class="modal fade" id="increment_approval_modal" tabindex="-1" aria-labelledby="incrementApprovalModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="incrementApprovalModalLabel">@Html.SmartLocalize("Review Increment Request")</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">@Html.SmartLocalize("Employee Name")</label>
                            <input type="text" class="form-control" value="Hasan Shikder" readonly>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">@Html.SmartLocalize("Department")</label>
                            <input type="text" class="form-control" value="Development" readonly>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">@Html.SmartLocalize("Increment Type")</label>
                            <input type="text" class="form-control" value="Annual Increment" readonly>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">@Html.SmartLocalize("Effective Date")</label>
                            <input type="text" class="form-control" value="01 Jan 2024" readonly>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">@Html.SmartLocalize("Current Salary")</label>
                            <input type="text" class="form-control" value="৳45,000" readonly>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">@Html.SmartLocalize("Proposed Salary")</label>
                            <input type="text" class="form-control" value="৳50,000" readonly>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">@Html.SmartLocalize("Increment Amount")</label>
                            <input type="text" class="form-control" value="৳5,000" readonly>
                        </div>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">@Html.SmartLocalize("Justification/Reason")</label>
                    <textarea class="form-control" rows="3" readonly>@Html.SmartLocalize("Annual performance review shows consistent excellent performance. Employee has exceeded targets and contributed significantly to project success.")</textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">@Html.SmartLocalize("Comments (Optional)")</label>
                    <textarea class="form-control" rows="3" placeholder="@Html.SmartLocalize("Add your comments here...")"></textarea>
                </div>
            </div>


            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Html.SmartLocalize("Close")</button>
                <button type="button" class="btn btn-danger me-2" data-action="decline" data-increment-id="">@Html.SmartLocalize("Decline")</button>
                <button type="button" class="btn btn-success" data-action="approve" data-increment-id="">@Html.SmartLocalize("Approve")</button>
            </div>

        </div>
    </div>
</div>

<!-- Confirmation Modal -->
<div class="modal fade" id="confirmation_modal" tabindex="-1" aria-labelledby="confirmationModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="confirmationModalLabel">@Html.SmartLocalize("Confirm Action")</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p id="confirmation_message">@Html.SmartLocalize("Are you sure you want to") <span id="confirmation_action"></span> @Html.SmartLocalize("this promotion?")</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Html.SmartLocalize("Cancel")</button>
                <button type="button" class="btn btn-primary" id="confirm_action">@Html.SmartLocalize("OK")</button>
            </div>
        </div>
    </div>
</div>


<script src="~/lib/jquery/dist/jquery.min.js"></script>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="~/js/pages/Employees/EmployeeStatus/Increment/IncrementApprove.js"></script>

}





