<!-- Increment Approval Modal -->
<div class="modal fade" id="increment_approval_modal" tabindex="-1" aria-labelledby="incrementApprovalModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="incrementApprovalModalLabel">Review Increment Request</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">Employee Name</label>
                            <input type="text" class="form-control" value="Hasan Shikder" readonly>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">Department</label>
                            <input type="text" class="form-control" value="Development" readonly>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">Increment Type</label>
                            <input type="text" class="form-control" value="Annual Increment" readonly>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">Effective Date</label>
                            <input type="text" class="form-control" value="01 Jan 2024" readonly>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Current Salary</label>
                            <input type="text" class="form-control" value="৳45,000" readonly>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Proposed Salary</label>
                            <input type="text" class="form-control" value="৳50,000" readonly>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Increment Amount</label>
                            <input type="text" class="form-control" value="৳5,000" readonly>
                        </div>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Justification/Reason</label>
                    <textarea class="form-control" rows="3" readonly>Annual performance review shows consistent excellent performance. Employee has exceeded targets and contributed significantly to project success.</textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Comments (Optional)</label>
                    <textarea class="form-control" rows="3" placeholder="Add your comments here..."></textarea>
                </div>
            </div>
           

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-danger me-2" data-action="decline" data-increment-id="">Decline</button>
                <button type="button" class="btn btn-success" data-action="approve" data-increment-id="">Approve</button>
            </div>

        </div>
    </div>
</div>


<script src="~/lib/jquery/dist/jquery.min.js"></script>
