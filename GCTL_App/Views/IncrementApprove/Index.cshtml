<!-- Waiting for Increment Approval Table -->
<div class="mb-4">
    <div class="card">
        <div class="card-header d-flex align-items-center justify-content-between flex-wrap row-gap-3 mb-1">
            <h4 class="mb-1">Waiting for Increment Approval</h4>
            <div class="d-flex my-xl-auto right-content align-items-center flex-wrap row-gap-3">
                <div class="dropdown me-3">
                    <div class="input-icon-end position-relative">
                        <input class="form-control datetimepicker flatpickr-input" id="timepicker2" type="text" placeholder="d/m/y to d/m/y" data-options='{"mode":"range","dateFormat":"d/m/y","disableMobile":true}' readonly="readonly">
                    </div>
                </div>

                <div class="dropdown me-3">
                    <select class="form-select" id="incrementType" data-choices="data-choices" size="1" required="required" name="incrementType" data-options='{"removeItemButton":true,"placeholder":true}'>
                        <option value="">Increment Type</option>
                        <option>Annual Increment</option>
                        <option>Performance Bonus</option>
                        <option>Promotion Increment</option>
                        <option>Special Increment</option>
                    </select>
                </div>

                <div class="dropdown me-3">
                    <select class="form-select" id="statusSelect" data-choices="data-choices" size="1" required="required" name="statusSelect" data-options='{"removeItemButton":true,"placeholder":true}'>
                        <option value="">Select Status</option>
                        <option>Approved</option>
                        <option>Declined</option>
                        <option>Pending</option>
                    </select>
                </div>

                <div class="dropdown">
                    <select class="form-select" id="sortBy" data-choices="data-choices" size="1" required="required" name="sortBy" data-options='{"removeItemButton":true,"placeholder":true}'>
                        <option value="">Sort by: Last 7 days</option>
                        <option>Recently Added</option>
                        <option>Ascending</option>
                        <option>Descending</option>
                        <option>Last Month</option>
                        <option>Last 7 days</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="border-translucent p-3">
            <div id="incrementApprovalTable" >
                <div class="table-responsive scrollbar mx-n1 px-1">
                    <table class="table table-sm fs-9 leads-table">
                        <thead>
                            <tr>
                                <th class="white-space-nowrap fs-9 align-middle ps-0" style="max-width:20px; width:18px;">
                                    <div class="form-check mb-0 fs-8">
                                        <input class="form-check-input" type="checkbox" data-bulk-select='{"body":"increment-approval-body"}' />
                                    </div>
                                </th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="employeeName">Employee Name</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="incrementType">Increment Type</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="currentSalary">Current Salary</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="proposedSalary">Proposed Salary</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="incrementAmount">Increment Amount</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="effectiveDate">Effective Date</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="decision">Decision</th>
                                <th class="sort text-end align-middle pe-0 ps-5" scope="col"></th>
                            </tr>
                        </thead>
                        <tbody class="list" id="increment-approval-body">
                          
                        </tbody>
                    </table>
                </div>

                <div class="row align-items-center justify-content-between pe-0 fs-9">
                    <div class="col-auto d-flex">
                        <p class="mb-0 d-none d-sm-block me-3 fw-semibold text-body" data-list-info="data-list-info"></p>
                        <a class="fw-semibold" href="#!" data-list-view="*">View all<span class="fas fa-angle-right ms-1" data-fa-transform="down-1"></span></a>
                        <a class="fw-semibold d-none" href="#!" data-list-view="less">View Less<span class="fas fa-angle-right ms-1" data-fa-transform="down-1"></span></a>
                    </div>
                    <div class="col-auto d-flex">
                        <button class="page-link" data-list-pagination="prev"><span class="fas fa-chevron-left"></span></button>
                        <ul class="mb-0 pagination"></ul>
                        <button class="page-link pe-0" data-list-pagination="next"><span class="fas fa-chevron-right"></span></button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>



