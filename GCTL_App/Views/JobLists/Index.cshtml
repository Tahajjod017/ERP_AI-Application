<style>
    .crm-card-header {
        font-size: 24px !important;
        font-weight: 600;
        color: #2c3e50;
        text-transform: none !important;
    }

    .job-status-badge {
        font-size: 0.8rem;
        padding: 0.35em 0.75em;
        border-radius: 50rem;
    }

    .table-crm tbody tr {
        transition: all 0.2s ease;
    }

        .table-crm tbody tr:hover {
            background-color: #f8f9fa !important;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
            transform: translateY(-1px);
        }

    .btn-crm-primary {
        background: #4361ee;
        border: none;
        border-radius: 8px;
        padding: 0.5rem 1rem;
        font-weight: 500;
    }

        .btn-crm-primary:hover {
            background: #3a56d4;
        }

    .btn-calendar-view {
        background: #f8f9fa;
        color: #4361ee;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
    }

        .btn-calendar-view:hover {
            background-color: #4361ee !important;
            color: white !important;
        }

    .search-box-modern .form-control {
        border-radius: 8px;
        border: 1px solid #e0e0e0;
        padding-left: 2.5rem;
    }

    .search-box-modern .search-box-icon {
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #6c757d;
    }

    .filter-btn {
        border-radius: 8px;
        padding: 0.5rem 1rem;
    }
</style>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-bottom d-flex align-items-center justify-content-between py-4">
        <h4 class="crm-card-header mb-0" id="card-title">0 Jobs</h4>
        <div class="d-flex gap-3">
            <a class="btn btn-crm-primary text-white d-flex align-items-center" asp-controller="CreateJobs">
                <span class="fas fa-plus me-2"></span> Create Job
            </a>
            <a class="btn btn-calendar-view d-flex align-items-center" id="calenderView" asp-controller="FieldCalender">
                <i class="fa-regular fa-calendar-days me-2"></i>
                Calendar View
            </a>
        </div>
    </div>

    <div class="card-body p-4">
        <!-- Filters & Search Row -->
        <div class="row g-3 justify-content-between mb-4">
            <div class="col-auto">
                <div class="search-box-modern position-relative">
                    <input class="form-control search-input search" type="search" placeholder="Search jobs by title, customer..." aria-label="Search" />
                    <span class="fas fa-search search-box-icon"></span>
                </div>
            </div>
            <div class="col-auto">
                <div class="d-flex gap-2 align-items-center">
                    <input class="form-control datetimepicker flatpickr-input" id="datepicker" type="text"
                           placeholder="Select date range" readonly="readonly" />
                    <button class="btn filter-btn btn-outline-secondary" type="button" data-bs-toggle="modal" data-bs-target="#filterModal">
                        <span class="fa-solid fa-filter me-2"></span> Filters
                    </button>
                </div>
            </div>
        </div>

        <!-- Table -->
        <div class="table-responsive">
            <table class="table table-hover table-crm align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4" style="width:50px">#</th>
                        <th class="ps-0">Job Title</th>
                        <th>Customer</th>
                        <th>Type</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Status</th>
                        <th>Location</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody id="leal-tables-body">
                    <!-- Rows loaded via AJAX -->
                </tbody>
            </table>

            <!-- Empty State -->
            <div class="text-center py-5 d-none" id="emptyState">
                <img src="~/assets/img/illustrations/no-data.png" alt="No jobs" class="mb-4" style="width: 200px; opacity: 0.5;" />
                <h5 class="text-muted">No jobs found</h5>
                <p class="text-muted">Try adjusting your filters or create a new job.</p>
            </div>
        </div>

        <!-- Pagination & Info -->
        <div class="row align-items-center mt-4">
            <div class="col">
                <p class="mb-0 text-body fs-9" id="totalApprove"></p>
            </div>
            <div class="col-auto">
                <ul class="pagination mb-0" id="pageNumber"></ul>
            </div>
        </div>
    </div>
</div>

<!-- Filter Modal (Keep your existing one or upgrade it similarly) -->