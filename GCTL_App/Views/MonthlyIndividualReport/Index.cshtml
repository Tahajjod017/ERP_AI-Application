@{
    var mainTab = "MonthlyReport";
    var subTab = "MonthlyReportForIndividual";
}

<partial name="~/Views/Shared/AttendenceReportNavs/_attendenceReportMenuTabs.cshtml" model="mainTab" />
<partial name="~/Views/Shared/AttendenceReportNavs/_AttendenceSubMenuReportMonthly.cshtml" model="subTab" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<!-- Include Month Select Plugin CSS (important to load for correct styling) -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/plugins/monthSelect/style.css">




    <div class="col-sm-12">
        <div class="card mb-3 border-0">
            <div class="card-body">

            <div class="border rounded">
                <div class="row gx-0">

                    <div class="col-md col-sm-4 border-end">
                        <div class="p-3">
                            <span class="fw-medium mb-1 d-block">Present</span>
                            <div class="d-flex align-items-center justify-content-between">
                                <h5>250</h5>
                                <span class="badge badge-phoenix badge-phoenix-success">
                                    <i class="ti ti-arrow-wave-right-down me-1"></i>
                                    78 %
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="col-md col-sm-4 border-end">
                        <div class="p-3">
                            <span class="fw-medium mb-1 d-block">Leave</span>
                            <div class="d-flex align-items-center justify-content-between">
                                <h5>5</h5>
                                <span class="badge badge-phoenix badge-phoenix-warning">
                                    <i class="ti ti-arrow-wave-right-down me-1"></i>
                                    2 %
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="col-md col-sm-4 border-end">
                        <div class="p-3">
                            <span class="fw-medium mb-1 d-block">Site Visit</span>
                            <div class="d-flex align-items-center justify-content-between">
                                <h5>10</h5>
                                <span class="badge badge-phoenix badge-phoenix-success">
                                    <i class="ti ti-arrow-wave-right-down me-1"></i>
                                    06 %
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="col-md col-sm-4">
                        <div class="p-3">
                            <span class="fw-medium mb-1 d-block">Absent</span>
                            <div class="d-flex align-items-center justify-content-between">
                                <h5>12</h5>
                                <span class="badge badge-phoenix badge-phoenix-danger">
                                    <i class="ti ti-arrow-wave-right-down me-1"></i>
                                    08 %
                                </span>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
                <!-- Data searching -->
                <div class="card-header d-flex justify-content-between flex-wrap row-gap-3 mb-4">

                    <h4 class="mb-1">Employee Name (Designation)</h4>
                    <div class="d-flex my-xl-auto right-content align-items-center flex-wrap row-gap-3">

                        <div class="dropdown me-3">
                            <select class="form-select" id="organizerSingle3" data-choices="data-choices" size="1" required="required" name="organizerSingle" data-options='{"removeItemButton":true,"placeholder":true}'>
                                <option value="">Select Company</option>
                                <option value="">GCTL</option>
                                <option value="">CSL Computer</option>
                            </select>
                        </div>

                        <div class="dropdown me-3">
                            <select class="form-select" id="organizerSingle3" data-choices="data-choices" size="1" required="required" name="organizerSingle" data-options='{"removeItemButton":true,"placeholder":true}'>
                                <option value="">Department</option>
                                <option>Finance</option>
                                <option>UI/UX</option>
                                <option>IT Manager</option>
                            </select>
                        </div>

                        <div class="dropdown me-3">
                            <select class="form-select" id="organizerSingle3" data-choices="data-choices" size="1" required="required" name="organizerSingle" data-options='{"removeItemButton":true,"placeholder":true}'>
                                <option value="">Employee Name</option>
                                <option>Abdullah</option>
                                <option>Juel Rana</option>
                                <option>Hasan</option>
                                <option>Nozib-ullah</option>
                            </select>
                        </div>
                        <div class="">
                        <input type="text" id="year-month-picker" class="form-control" />

                        </div>
                        <div class="dropdown me-3">
                            <select class="form-select" id="organizerSingle3" data-choices="data-choices" size="1" required="required" name="organizerSingle" data-options='{"removeItemButton":true,"placeholder":true}'>
                                <option value="">Select Month</option>
                                <option>January</option>
                                <option>February</option>
                                <option>March</option>
                                <option>April</option>
                                <option>May</option>
                                <option>June</option>
                                <option>July</option>
                                <option>August</option>
                                <option>September</option>
                                <option>October</option>
                                <option>November</option>
                                <option>December</option>
                            </select>
                        </div>

                    </div>
                </div>

                <!-- All Employee monthly attendance Table-->
            <div id="individualEmployeemonthlyAttendanceTable">
                <div class="table-responsive">
                    <table class="table-bordered text-center p-2">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <!-- The month headers will be dynamically added here -->
                            </tr>
                        </thead>
                        <tbody>
                            <!-- The attendance data rows will be dynamically added here -->
                        </tbody>
                    </table>
                </div>
            </div>


