@model GCTL.Core.ViewModels.AttendanceManagement.AttendenceReportAlls.AttendanceEmployeeReportVM
@{
    var departments = ViewBag.DepartmentDD as List<GCTL.Core.ViewModels.CommonSelectVM>;
    var employees = ViewBag.EmployeeList as List<GCTL.Core.ViewModels.CommonSelectVM>;

}
@{
}

@{
    var mainTab = "MonthlyReport";
    var subTab = "MonthlyReportForIndividual";
}

<partial name="~/Views/Shared/AttendenceReportNavs/_attendenceReportMenuTabs.cshtml" model="mainTab" />
<partial name="~/Views/Shared/AttendenceReportNavs/_AttendenceSubMenuReportMonthly.cshtml" model="subTab" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<!-- Include Month Select Plugin CSS (important to load for correct styling) -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/plugins/monthSelect/style.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/themes/dark.css">

<style>
    
    .flatpickr-monthSelect-months {
        display: grid;
        grid-template-columns: repeat(3, 1fr); /* 3 equal columns */
        gap: 10px; /* Space between months */
        margin: 10px 1px 3px 1px;
    }

    /* Styling for individual months */
    .flatpickr-monthSelect-month {
        background: none;
        border: 1px solid transparent;
        border-radius: 4px;
        box-sizing: border-box;
        color: #393939;
        cursor: pointer;
        display: flex; /* Use flexbox to center the text inside the month */
        justify-content: center;
        padding: 10px;
        position: relative;
        text-align: center;
        width: 100%; /* Make sure it takes full width of the column */
    }

        /* Disabled month styling */
        .flatpickr-monthSelect-month.flatpickr-disabled {
            color: #eee;
        }

            .flatpickr-monthSelect-month.flatpickr-disabled:hover,
            .flatpickr-monthSelect-month.flatpickr-disabled:focus {
                cursor: not-allowed;
                background: none !important;
            }

    /* Dark theme adjustments */
    .flatpickr-monthSelect-theme-dark {
        background: #3f4458;
    }

        .flatpickr-monthSelect-theme-dark .flatpickr-monthSelect-month {
            color: rgba(255, 255, 255, 0.95);
        }

            .flatpickr-monthSelect-theme-dark .flatpickr-monthSelect-month.selected {
                background-color: #80cbc4;
                color: #fff;
                border-color: #80cbc4;
            }

    /* Styling for today’s month */
    .flatpickr-monthSelect-month.today {
        border-color: #959ea9;
    }

    .flatpickr-monthSelect-month.selected,
    .flatpickr-monthSelect-month.startRange,
    .flatpickr-monthSelect-month.endRange {
        background-color: #569ff7;
        box-shadow: none;
        color: #fff;
        border-color: #569ff7;
    }

    /* Range selection */
    .flatpickr-monthSelect-month.startRange {
        border-radius: 50px 0 0 50px;
    }

    .flatpickr-monthSelect-month.endRange {
        border-radius: 0 50px 50px 0;
    }

    .flatpickr-monthSelect-month.inRange {
        border-radius: 0;
        box-shadow: -5px 0 0 #e6e6e6, 5px 0 0 #e6e6e6;
    }


    /* ===== Responsive Full Width Fix ===== */
    .table-responsive {
        width: 100%;
        overflow-x: auto;
    }

    table.table-bordered {
        width: 100%;
        min-width: 1500px; /* আপনার কলাম যত বেশি, তত বড় রাখুন */
        border-collapse: collapse;
    }

        table.table-bordered th,
        table.table-bordered td {
            padding: 6px 10px;
            font-size: 13px;
            text-align: center;
            vertical-align: middle;
            white-space: nowrap;
        }

        table.table-bordered th {
            background-color: #f9fafb;
            font-weight: 600;
        }

        table.table-bordered tr th:first-child {
            position: sticky;
            left: 0;
            background-color: #fff;
            z-index: 2;
        }


</style>

    <div class="col-sm-12">
        <div class="card mb-3 border-0">
            <div class="card-body">

            <div class="border rounded">
                <div class="row gx-0">

                    <div class="col-md col-sm-4 border-end">
                        <div class="p-3">
                            <span class="fw-medium mb-1 d-block">Total Present</span>
                            <div class="d-flex align-items-center justify-content-between">
                                <h5>00</h5>
                                <span class="badge badge-phoenix badge-phoenix-success">
                                    <i class="ti ti-arrow-wave-right-down me-1"></i>
                                    00 %
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="col-md col-sm-4 border-end">
                        <div class="p-3">
                            <span class="fw-medium mb-1 d-block">Total Leave</span>
                            <div class="d-flex align-items-center justify-content-between">
                                <h5>00</h5>
                                <span class="badge badge-phoenix badge-phoenix-warning">
                                    <i class="ti ti-arrow-wave-right-down me-1"></i>
                                    00 %
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="col-md col-sm-4 border-end">
                        <div class="p-3">
                            <span class="fw-medium mb-1 d-block">Total Late</span>
                            <div class="d-flex align-items-center justify-content-between">
                                <h5>00</h5>
                                <span class="badge badge-phoenix badge-phoenix-success">
                                    <i class="ti ti-arrow-wave-right-down me-1"></i>
                                    00 %
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="col-md col-sm-4">
                        <div class="p-3">
                            <span class="fw-medium mb-1 d-block">Total Absent</span>
                            <div class="d-flex align-items-center justify-content-between">
                                <h5>00</h5>
                                <span class="badge badge-phoenix badge-phoenix-danger">
                                    <i class="ti ti-arrow-wave-right-down me-1"></i>
                                    00 %
                                </span>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
                <!-- Data searching -->
                <div class="card-header d-flex justify-content-between flex-wrap row-gap-3 mb-4">

                    <h4 class="mb-1"></h4>
                    <div class="d-flex my-xl-auto right-content align-items-center flex-wrap row-gap-3">

                    <div class="dropdown me-3">
                        <select class="form-select choiceDD" asp-items="@ViewBag.OrganizationDD as SelectList" id="organizationid" name="OrganizationID">
                            <option value="">Select Company</option>
                        </select>
                    </div>
                    <div class="dropdown me-2">
                        <select class="form-multi-select" asp-for="DepartmentID"
                                id="DepartmentIDsSelect"
                                data-coreui-selection-type="counter"
                                data-coreui-placeholder="@Html.SmartLocalize("Select Department")..."
                                data-coreui-search="true"
                                data-coreui-multiple="false">
                            @foreach (var group in departments.GroupBy(e => e.GroupName))
                            {
                                <optgroup label="@group.Key">
                                    @foreach (var emp in group)
                                    {
                                        <option value="@emp.Id">@emp.Name</option>
                                    }
                                </optgroup>
                            }
                        </select>
                    </div>


                    <div class="dropdown me-2">
                        <select class="form-multi-select" asp-for="EmployeeID"
                                id="EmployeeIDsSelect"
                                data-coreui-selection-type="counter"
                                data-coreui-multiple="false"
                                data-coreui-placeholder="@Html.SmartLocalize("Select Employee")..."
                                data-coreui-search="true">
                            @foreach (var group in employees.GroupBy(e => e.GroupName))
                            {
                                <optgroup label="@group.Key">
                                    @foreach (var emp in group)
                                    {
                                        <option value="@emp.Id">@emp.Name</option>
                                    }
                                </optgroup>
                            }
                        </select>
                    </div>
                        
                    <div class="flatpickr-input-container me-3">
                        <input class="form-control ps-6 flatpickr-input" id="year-month-picker-1" type="text" readonly="readonly" placeholder="Select Month">
                        <span class="uil uil-calendar-alt flatpickr-icon text-body-tertiary"></span>
                    </div>
                    <div class="dropdown">
                        <button class="btn btn-phoenix-secondary rounded-3 me-1 mb-1"
                                type="button"
                                id="btnPrintJobCard">
                            <span class="fas fa-print me-2" data-fa-transform="shrink-3"></span>Print
                        </button>

                    </div>

                    </div>
                </div>

