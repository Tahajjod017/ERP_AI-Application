@using GCTL.Core.ViewModels.POS.Sales.SalesOrders
@model SalesOrderSidebarDetailsViewModel

<div class="col-md-3 mb-4">
    <div class="card mb-3" style="min-height: 1000px;">
        <div class="card-body">
            <div class="invoice-card">
                <div class="accordion" id="accordionExample">
                    <!-- Create Section -->
                    <div class="accordion-item border-top">
                        <h2 class="accordion-header" id="headingCreate">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseCreate" aria-expanded="true" aria-controls="collapseCreate">
                                @Html.SmartLocalize("Create")
                            </button>
                        </h2>
                        <div class="accordion-collapse collapse show" id="collapseCreate" aria-labelledby="headingCreate" data-bs-parent="#accordionExample">
                            <div class="accordion-body pt-0">
                                <p class="fs-9" id="createPerson">
                                    <strong>@Html.SmartLocalize("Created By:")</strong> @Model.CreatedByName <br />
                                    <strong>@Html.SmartLocalize("Created At:")</strong> @Model.CreatedAt?.ToString("MMM dd, yyyy hh:mm tt")
                                    @if (!string.IsNullOrEmpty(Model.UpdatedByName))
                                    {
                                        <br />
                                        <strong>@Html.SmartLocalize("Updated By:")</strong> @Model.UpdatedByName <br />
                                        <strong>@Html.SmartLocalize("Updated At:")</strong> @Model.UpdatedAt?.ToString("MMM dd, yyyy hh:mm tt")
                                    }
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Edit Section -->
                    <div class="accordion-item border-top">
                        <h2 class="accordion-header" id="headingEdit">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseEdit" aria-expanded="true" aria-controls="collapseEdit">
                                @Html.SmartLocalize("Edit")
                            </button>
                        </h2>
                        <div class="accordion-collapse collapse show" id="collapseEdit" aria-labelledby="headingEdit" data-bs-parent="#accordionExample">
                            <div class="accordion-body pt-0">
                                <p class="fs-9">
                                    @Html.SmartLocalize("Sales Order Number:") @Model.SalesOrderNumber <br>
                                    @if (Model.CanEdit)
                                    {
                                        @foreach (var item in Model.SalesOrderIdList)
                                        {
                                            if (item.current == "current")
                                            {
                                                <a href="#" style="color: black;text-decoration: none;">@Html.SmartLocalize("Version") @item.version</a> @item.draftSign @item.finalSign <br>
                                            }
                                            else
                                            {
                                                <a href="@Url.Action("Index", "SalesOrderDetails", new { id = item.id })">@Html.SmartLocalize("Version") @item.version</a> @item.draftSign @item.finalSign <br>
                                            }
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">@Html.SmartLocalize("Cannot edit")</span>
                                    }
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Duplicate Section -->
                    <div class="accordion-item border-top">
                        <h2 class="accordion-header" id="headingDuplicate">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseDuplicate" aria-expanded="true" aria-controls="collapseDuplicate">
                                @Html.SmartLocalize("Duplicate")
                            </button>
                        </h2>
                        <div class="accordion-collapse collapse show" id="collapseDuplicate" aria-labelledby="headingDuplicate" data-bs-parent="#accordionExample">
                            <div class="accordion-body pt-0">
                                <p class="fs-9">
                                    @Html.SmartLocalize("Sales Order Number:") @Model.SalesOrderNumber <br>
                                    <a href="javascript:void(0)" onclick="duplicateSalesOrder(@Model.SalesOrderId)">@Html.SmartLocalize("Create Duplicate")</a>
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Source Quotation Section -->
                    @if (!string.IsNullOrEmpty(Model.QuotationNumber))
                    {
                        <div class="accordion-item border-top">
                            <h2 class="accordion-header" id="headingQuotation">
                                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseQuotation" aria-expanded="true" aria-controls="collapseQuotation">
                                    @Html.SmartLocalize("Source Quotation")
                                </button>
                            </h2>
                            <div class="accordion-collapse collapse show" id="collapseQuotation" aria-labelledby="headingQuotation" data-bs-parent="#accordionExample">
                                <div class="accordion-body pt-0">
                                    <p class="fs-9">
                                        @Html.SmartLocalize("Quotation Number:") @Model.QuotationNumber
                                    </p>
                                </div>
                            </div>
                        </div>
                    }



                    <!-- ADD THIS SECTION HERE -->
                    <!-- Create Shipment Section -->
                    <div class="accordion-item border-top">
                        <h2 class="accordion-header" id="headingShipment">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseShipment" aria-expanded="true" aria-controls="collapseShipment">
                                @Html.SmartLocalize("Shipment")
                            </button>
                        </h2>
                        <div class="accordion-collapse collapse show" id="collapseShipment" aria-labelledby="headingShipment" data-bs-parent="#accordionExample">
                            <div class="accordion-body pt-0">
                                @if (Model.CanCreateShipment)
                                {
                                    <p class="fs-9">
                                        <a href="/Shipment/Index?salesOrderId=@Model.SalesOrderId" class="btn btn-sm btn-phoenix-primary w-100">
                                            <i class="fas fa-shipping-fast me-2"></i>
                                            @Html.SmartLocalize("Create Shipment")
                                        </a>
                                    </p>
                                }

                                @if (Model.HasShipments && Model.Shipments != null && Model.Shipments.Any())
                                {
                                    <hr class="my-2" />
                                    <p class="fs-9 fw-bold mb-2">@Html.SmartLocalize("Existing Shipments:")</p>
                                    @foreach (var shipment in Model.Shipments)
                                    {
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <a href="/ShipmentDetails/Index/@shipment.ShipmentId" class="fs-9 text-decoration-none">
                                                @shipment.ShipmentNumber
                                            </a>
                                            <span class="badge badge-phoenix-@shipment.StatusClass fs-10">
                                                @shipment.Status
                                            </span>
                                        </div>
                                    }
                                }
                                else if (!Model.CanCreateShipment)
                                {
                                    <p class="fs-9 text-muted">@Html.SmartLocalize("No shipments available")</p>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Send Email Section starts here (existing code) -->
                    <!-- Send Email Section -->
                    <div class="accordion-item">
                        <h2 class="accordion-header" id="headingEmail">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseEmail" aria-expanded="true" aria-controls="collapseEmail">
                                @Html.SmartLocalize("Send Email")
                            </button>
                        </h2>
                        <div class="accordion-collapse collapse show" id="collapseEmail" aria-labelledby="headingEmail" data-bs-parent="#accordionExample">
                            <div class="accordion-body pt-0">
                                @if (Model.CanSendEmail)
                                {
                                    <a class="btn btn-subtle-primary me-1 mb-1" type="button" data-bs-toggle="modal" data-bs-target="#showSendModal">
                                        <i class="far fa-envelope" aria-hidden="true"></i>
                                    </a>
                                    <a class="btn btn-subtle-primary me-1 mb-1" type="button" onclick="printSalesOrder(@Model.SalesOrderId)">
                                        <i class="fa fa-print" aria-hidden="true"></i>
                                    </a>
                                }
                            </div>
                        </div>
                    </div>


                    <!-- Status Actions -->
                    @if (Model.CanMakeFinal == true && !Model.HasShipments)
                    {
                        <div class="accordion-item border-top">
                            <h2 class="accordion-header" id="headingStatus">
                                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseStatus" aria-expanded="true" aria-controls="collapseStatus">
                                    @Html.SmartLocalize("Status Actions")
                                </button>
                            </h2>
                            <div class="accordion-collapse collapse show" id="collapseStatus" aria-labelledby="headingStatus" data-bs-parent="#accordionExample">
                                <div class="accordion-body pt-0">
                                    <p class="fs-9">
                                        <a href="javascript:void(0)" onclick="markAsApproved(@Model.SalesOrderId)">@Html.SmartLocalize("Mark as Approved")</a>
                                    </p>
                                </div>
                            </div>
                        </div>
                    }


                </div>
            </div>
        </div>
    </div>
</div>

<!-- Send Email Modal -->
<div class="modal fade" id="showSendModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@Html.SmartLocalize("Send Sales Order via Email")</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">@Html.SmartLocalize("Recipient Email")</label>
                    <input type="email" class="form-control" id="recipientEmail" placeholder="@Html.SmartLocalize("customer@example.com")">
                </div>
                <div class="mb-3">
                    <label class="form-label">@Html.SmartLocalize("Subject")</label>
                    <input type="text" class="form-control" id="emailSubject" value="@Html.SmartLocalize("Sales Order -") @Model.SalesOrderNumber">
                </div>
                <div class="mb-3">
                    <label class="form-label">@Html.SmartLocalize("Message")</label>
                    <textarea class="form-control" id="emailMessage" rows="5">@Html.SmartLocalize("Dear Customer,\nPlease find attached the sales order for your review.\nBest regards")</textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Html.SmartLocalize("Close")</button>
                <button type="button" class="btn btn-primary" onclick="sendEmailNow(@Model.SalesOrderId)">@Html.SmartLocalize("Send Email")</button>
            </div>
        </div>
    </div>
</div>

<script>
function duplicateSalesOrder(salesOrderId) {
    if (confirm('@Html.SmartLocalize("Are you sure you want to duplicate this sales order?")')) {
        $.ajax({
            url: '/SalesOrderDetails/Duplicate',
            method: 'POST',
            data: { id: salesOrderId },
            success: function (response) {
                if (response.success) {
                    toastr.success('@Html.SmartLocalize("Sales Order duplicated successfully!")');
                    window.location.href = '/SalesOrderDetails/Index/' + response.newSalesOrderId;
                } else {
                    toastr.error('@Html.SmartLocalize("Failed to duplicate:") ' + response.message);
                }
            },
            error: function () {
                toastr.error('@Html.SmartLocalize("Failed to duplicate sales order.")');
            }
        });
    }
}


    function markAsApproved(salesOrderId) {
        if (confirm('Mark this Sales Order as Approved?')) {
            $.ajax({
                url: '/SalesOrderDetails/UpdateStatus',
                method: 'POST',
                data: {
                    id: salesOrderId,
                    status: 3 // QuotationStatus.Approved
                },
                success: function (response) {
                    if (response.success) {
                        toastr.success('Quotation marked as Approved!');
                        location.reload();
                    } else {
                        toastr.warning('Failed to update status: ' + response.message);
                    }
                },
                error: function () {
                    toastr.error('Failed to update status. Please try again.');
                }
            });
        }
    }


function sendEmailNow(salesOrderId) {
    const recipient = $('#recipientEmail').val();
    const subject = $('#emailSubject').val();
    const message = $('#emailMessage').val();
    if (!recipient) {
        toastr.warning('@Html.SmartLocalize("Please enter recipient email address")');
        return;
    }
    $.ajax({
        url: '/SalesOrderDetails/SendEmail',
        method: 'POST',
        data: {
            id: salesOrderId,
            recipientEmail: recipient,
            subject: subject,
            message: message
        },
        success: function (response) {
            if (response.success) {
                toastr.success('@Html.SmartLocalize("Email sent successfully!")');
                $('#showSendModal').modal('hide');
            } else {
                toastr.error('@Html.SmartLocalize("Failed to send email:") ' + response.message);
            }
        },
        error: function () {
            toastr.error('@Html.SmartLocalize("Failed to send email.")');
        }
    });
}

function printSalesOrder(salesOrderId) {
    window.open('/SalesOrderDetails/PrintPDF/' + salesOrderId, '_blank');
}
</script>