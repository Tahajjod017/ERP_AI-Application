                    <!-- Invoice Section -->
                    @if (Model.HasShipmentsStarted)
                    {
                        <div class="accordion-item border-top">
                            <h2 class="accordion-header" id="headingInvoice">
                                <button class="accordion-button" type="button" data-bs-toggle="collapse"
                                        data-bs-target="#collapseInvoice" aria-expanded="true"
                                        aria-controls="collapseInvoice">
                                    @Html.SmartLocalize("Invoice")
                                    @if (Model.HasInvoices)
                                    {
                                        <span class="badge bg-primary ms-2">@Model.Invoices.Count</span>
                                    }
                                </button>
                            </h2>
                            <div class="accordion-collapse collapse show" id="collapseInvoice"
                                 aria-labelledby="headingInvoice" data-bs-parent="#accordionExample">
                                <div class="accordion-body pt-0">

                                    <!-- Create Invoice Buttons -->
                                    <div class="mb-3">
                                        @if (Model.CanCreatePartialInvoice)
                                        {
                                            <div class="mb-2">
                                                <a href="/Invoice/CreatePartial?salesOrderId=@Model.SalesOrderId"
                                                   class="btn btn-sm btn-warning w-100">
                                                    <i class="fas fa-file-invoice me-2"></i>
                                                    @Html.SmartLocalize("Create Partial Invoice")
                                                </a>
                                                <small class="text-muted d-block mt-1 text-center">
                                                    For shipped items only
                                                </small>
                                            </div>
                                        }

                                        @if (Model.IsFullyShipped && Model.CanCreateInvoice && !Model.HasFinalInvoice)
                                        {
                                            <div class="mb-2">
                                                <a href="/Invoice/CreateFinal?salesOrderId=@Model.SalesOrderId"
                                                   class="btn btn-sm btn-success w-100">
                                                    <i class="fas fa-file-invoice-dollar me-2"></i>
                                                    @Html.SmartLocalize("Create Final Invoice")
                                                </a>
                                                <small class="text-muted d-block mt-1 text-center">
                                                    For all items (fully shipped)
                                                </small>
                                            </div>
                                        }

                                        @if (!Model.IsFullyShipped && Model.CanCreateInvoice && !Model.HasFinalInvoice)
                                        {
                                            @*<div class="mb-2">
                                                <a href="/Invoice/CreateDraft?salesOrderId=@Model.SalesOrderId"
                                                   class="btn btn-sm btn-info w-100">
                                                    <i class="fas fa-file-edit me-2"></i>
                                                    @Html.SmartLocalize("Create Draft Invoice")
                                                </a>
                                                <small class="text-muted d-block mt-1 text-center">
                                                    Draft invoice for current shipped items
                                                </small>
                                            </div>*@
                                        }
                                    </div>

                                    <!-- Invoice List -->
                                    @if (Model.HasInvoices)
                                    {
                                        <hr class="my-2" />
                                        <p class="fs-9 fw-bold mb-2">@Html.SmartLocalize("Invoices:")</p>

                                        @foreach (var invoice in Model.Invoices)
                                        {
                                            <div class="invoice-item mb-3 p-2 border rounded">
                                                <!-- Invoice Header -->
                                                <div class="d-flex justify-content-between align-items-start mb-1">
                                                    <div>
                                                        <a href="/InvoiceDetails/Index/@invoice.InvoiceId"
                                                           class="fs-9 fw-bold text-decoration-none">
                                                            <i class="fas fa-file-invoice me-1"></i>
                                                            @invoice.InvoiceNumber
                                                        </a>
                                                        @if (invoice.IsPartial && !string.IsNullOrEmpty(invoice.PartialForInvoiceNumber))
                                                        {
                                                            <small class="text-muted ms-2">
                                                                <i class="fas fa-link"></i> Partial of @invoice.PartialForInvoiceNumber
                                                            </small>
                                                        }
                                                    </div>
                                                    <div class="text-end">
                                                        @if (!string.IsNullOrEmpty(invoice.StatusName))
                                                        {
                                                            <span class="badge bg-@invoice.StatusClass fs-10">
                                                                @invoice.StatusName
                                                            </span>
                                                        }
                                                    </div>
                                                </div>

                                                <!-- Invoice Details -->
                                                <div class="row">
                                                    <div class="col-8">
                                                        <small class="text-muted d-block">
                                                            <i class="far fa-calendar me-1"></i>
                                                            @invoice.InvoiceDate?.ToString("MMM dd, yyyy")
                                                        </small>
                                                        <small class="d-block">
                                                            @if (invoice.IsDraft)
                                                            {
                                                                <span class="badge bg-warning">Draft</span>
                                                            }
                                                            @if (invoice.IsPartial)
                                                            {
                                                                <span class="badge bg-info">Partial</span>
                                                            }
                                                            @if (invoice.IsFinal)
                                                            {
                                                                <span class="badge bg-success">Final</span>
                                                            }
                                                        </small>
                                                    </div>
                                                    <div class="col-4 text-end">
                                                        <small class="fw-bold d-block">@invoice.GrandTotal.ToString("C")</small>
                                                        @if (invoice.PaidAmount > 0)
                                                        {
                                                            <small class="@(invoice.PaidAmount >= invoice.GrandTotal ? "text-success" : "text-warning")">
                                                                @if (invoice.PaidAmount >= invoice.GrandTotal)
                                                                {
                                                                    <i class="fas fa-check-circle"></i> 
                                                                 }
                                                                else
                                                                {
                                                                    <i class="fas fa-exclamation-circle"></i>
                                                                 }
                                                            </small>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="text-center py-3">
                                            <i class="fas fa-file-invoice fa-2x text-muted mb-2"></i>
                                            <p class="text-muted fs-9 mb-0">@Html.SmartLocalize("No invoices created yet")</p>
                                            @if (!Model.HasShipmentsStarted)
                                            {
                                                <small class="text-muted">Create shipments first</small>
                                            }
                                        </div>
                                    }

                                    <!-- Invoice Summary -->
                                    @if (Model.HasInvoices)
                                    {
                                        <div class="mt-3 pt-3 border-top">
                                            <div class="row fs-9">
                                                <div class="col-6">
                                                    <small class="text-muted">Total Invoices:</small>
                                                </div>
                                                <div class="col-6 text-end fw-bold">
                                                    @Model.Invoices.Count
                                                </div>

                                                <div class="col-6">
                                                    <small class="text-muted">Total Amount:</small>
                                                </div>
                                                <div class="col-6 text-end fw-bold">
                                                    @Model.Invoices.Sum(i => i.GrandTotal).ToString("C")
                                                </div>

                                                @{
                                                    var totalPaid = Model.Invoices.Sum(i => i.PaidAmount);
                                                    var totalDue = Model.Invoices.Sum(i => i.GrandTotal - i.PaidAmount);
                                                }

                                                <div class="col-6">
                                                    <small class="text-muted">Total Paid:</small>
                                                </div>
                                                <div class="col-6 text-end fw-bold text-success">
                                                    @totalPaid.ToString("C")
                                                </div>

                                                <div class="col-6">
                                                    <small class="text-muted">Total Due:</small>
                                                </div>
                                                <div class="col-6 text-end fw-bold text-danger">
                                                    @totalDue.ToString("C")
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }



                    <!-- Send Email Section starts here (existing code) -->
                    <!-- Send Email Section -->
                    <div class="accordion-item">
                        <h2 class="accordion-header" id="headingEmail">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseEmail" aria-expanded="true" aria-controls="collapseEmail">
                                @Html.SmartLocalize("Send Email")
                            </button>
                        </h2>
                        <div class="accordion-collapse collapse show" id="collapseEmail" aria-labelledby="headingEmail" data-bs-parent="#accordionExample">
                            <div class="accordion-body pt-0">
                                @if (Model.CanSendEmail)
                                {
                                    <a class="btn btn-subtle-primary me-1 mb-1" type="button" data-bs-toggle="modal" data-bs-target="#showSendModal">
                                        <i class="far fa-envelope" aria-hidden="true"></i>
                                    </a>
                                    <a class="btn btn-subtle-primary me-1 mb-1" type="button" onclick="printSalesOrder(@Model.SalesOrderId)">
                                        <i class="fa fa-print" aria-hidden="true"></i>
                                    </a>
                                }
                            </div>
                        </div>
                    </div>


                    <!-- Status Actions -->
                    @if (Model.CanMakeFinal == true && !Model.HasShipments)
                    {
                        <div class="accordion-item border-top">
                            <h2 class="accordion-header" id="headingStatus">
                                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseStatus" aria-expanded="true" aria-controls="collapseStatus">
                                    @Html.SmartLocalize("Status Actions")
                                </button>
                            </h2>
                            <div class="accordion-collapse collapse show" id="collapseStatus" aria-labelledby="headingStatus" data-bs-parent="#accordionExample">
                                <div class="accordion-body pt-0">
                                    <p class="fs-9">
                                        <a href="javascript:void(0)" onclick="markAsApproved(@Model.SalesOrderId)">@Html.SmartLocalize("Mark as Approved")</a>
                                    </p>
                                </div>
                            </div>
                        </div>
                    }


                </div>
            </div>
        </div>
    </div>
</div>

<!-- Send Email Modal -->
<div class="modal fade" id="showSendModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@Html.SmartLocalize("Send Sales Order via Email")</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">@Html.SmartLocalize("Recipient Email")</label>
                    <input type="email" class="form-control" id="recipientEmail" placeholder="@Html.SmartLocalize("customer@example.com")">
                </div>
                <div class="mb-3">
                    <label class="form-label">@Html.SmartLocalize("Subject")</label>
                    <input type="text" class="form-control" id="emailSubject" value="@Html.SmartLocalize("Sales Order -") @Model.SalesOrderNumber">
                </div>
                <div class="mb-3">
                    <label class="form-label">@Html.SmartLocalize("Message")</label>
                    <textarea class="form-control" id="emailMessage" rows="5">@Html.SmartLocalize("Dear Customer,\nPlease find attached the sales order for your review.\nBest regards")</textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Html.SmartLocalize("Close")</button>
                <button type="button" class="btn btn-primary" onclick="sendEmailNow(@Model.SalesOrderId)">@Html.SmartLocalize("Send Email")</button>
            </div>
        </div>
    </div>
</div>

<script>
    function createPartialInvoice(salesOrderId) {
        if (confirm('Create partial invoice for shipped items?')) {
            window.location.href = '/Invoice/CreatePartial?salesOrderId=' + salesOrderId;
        }
    }

    // Create final invoice
    function createFinalInvoice(salesOrderId) {
        if (confirm('Create final invoice for all items? This can only be done once.')) {
            window.location.href = '/Invoice/Create?salesOrderId=' + salesOrderId;
        }
    }

//    function createInvoice(salesOrderId, isPartial) {

//        showDev(salesOrderId + " " + isPartial, 'salesOrderId + isPartial')
//    // Your invoice creation logic
//}



function duplicateSalesOrder(salesOrderId) {
    if (confirm('@Html.SmartLocalize("Are you sure you want to duplicate this sales order?")')) {
        $.ajax({
            url: '/SalesOrderDetails/Duplicate',
            method: 'POST',
            data: { id: salesOrderId },
            success: function (response) {
                if (response.success) {
                    toastr.success('@Html.SmartLocalize("Sales Order duplicated successfully!")');
                    window.location.href = '/SalesOrderDetails/Index/' + response.newSalesOrderId;
                } else {
                    toastr.error('@Html.SmartLocalize("Failed to duplicate:") ' + response.message);
                }
            },
            error: function () {
                toastr.error('@Html.SmartLocalize("Failed to duplicate sales order.")');
            }
        });
    }
}


    function markAsApproved(salesOrderId) {
        if (confirm('Mark this Sales Order as Approved?')) {
            $.ajax({
                url: '/SalesOrderDetails/UpdateStatus',
                method: 'POST',
                data: {
                    id: salesOrderId,
                    status: 3 // QuotationStatus.Approved
                },
                success: function (response) {
                    if (response.success) {
                        toastr.success('Quotation marked as Approved!');
                        location.reload();
                    } else {
                        toastr.warning('Failed to update status: ' + response.message);
                    }
                },
                error: function () {
                    toastr.error('Failed to update status. Please try again.');
                }
            });
        }
    }


function sendEmailNow(salesOrderId) {
    const recipient = $('#recipientEmail').val();
    const subject = $('#emailSubject').val();
    const message = $('#emailMessage').val();
    if (!recipient) {
        toastr.warning('@Html.SmartLocalize("Please enter recipient email address")');
        return;
    }
    $.ajax({
        url: '/SalesOrderDetails/SendEmail',
        method: 'POST',
        data: {
            id: salesOrderId,
            recipientEmail: recipient,
            subject: subject,
            message: message
        },
        success: function (response) {
            if (response.success) {
                toastr.success('@Html.SmartLocalize("Email sent successfully!")');
                $('#showSendModal').modal('hide');
            } else {
                toastr.error('@Html.SmartLocalize("Failed to send email:") ' + response.message);
            }
        },
        error: function () {
            toastr.error('@Html.SmartLocalize("Failed to send email.")');
        }
    });
}

function printSalesOrder(salesOrderId) {
    window.open('/SalesOrderDetails/PrintPDF/' + salesOrderId, '_blank');
}
</script>