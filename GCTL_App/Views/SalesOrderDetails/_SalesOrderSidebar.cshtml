@using GCTL.Core.ViewModels.POS.Sales.SalesOrders
@model SalesOrderSidebarDetailsViewModel

<div class="col-md-3 mb-4">
    <div class="card mb-3" style="min-height: 1000px;">
        <div class="card-body">
            <div class="invoice-card">
                <div class="accordion" id="accordionExample">
                    <!-- Create Section -->
                    <div class="accordion-item border-top">
                        <h2 class="accordion-header" id="headingCreate">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseCreate" aria-expanded="true" aria-controls="collapseCreate">
                                @Html.SmartLocalize("Create")
                            </button>
                        </h2>
                        <div class="accordion-collapse collapse show" id="collapseCreate" aria-labelledby="headingCreate" data-bs-parent="#accordionExample">
                            <div class="accordion-body pt-0">
                                <p class="fs-9" id="createPerson">
                                    <strong>@Html.SmartLocalize("Created By:")</strong> @Model.CreatedByName <br />
                                    <strong>@Html.SmartLocalize("Created At:")</strong> @Model.CreatedAt?.ToString("MMM dd, yyyy hh:mm tt")
                                    @if (!string.IsNullOrEmpty(Model.UpdatedByName))
                                    {
                                        <br />
                                        <strong>@Html.SmartLocalize("Updated By:")</strong> @Model.UpdatedByName <br />
                                        <strong>@Html.SmartLocalize("Updated At:")</strong> @Model.UpdatedAt?.ToString("MMM dd, yyyy hh:mm tt")
                                    }
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Edit Section -->
                    <div class="accordion-item border-top">
                        <h2 class="accordion-header" id="headingEdit">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseEdit" aria-expanded="true" aria-controls="collapseEdit">
                                @Html.SmartLocalize("Edit")
                            </button>
                        </h2>
                        <div class="accordion-collapse collapse show" id="collapseEdit" aria-labelledby="headingEdit" data-bs-parent="#accordionExample">
                            <div class="accordion-body pt-0">
                                <p class="fs-9">
                                    @Html.SmartLocalize("Sales Order Number:") @Model.SalesOrderNumber <br>
                                    @if (Model.CanEdit)
                                    {
                                        @foreach (var item in Model.SalesOrderIdList)
                                        {
                                            if (item.current == "current")
                                            {
                                                <a href="#" style="color: black;text-decoration: none;">@Html.SmartLocalize("Version") @item.version</a> @item.draftSign @item.finalSign <br>
                                            }
                                            else
                                            {
                                                <a href="@Url.Action("Index", "SalesOrderDetails", new { id = item.id })">@Html.SmartLocalize("Version") @item.version</a> @item.draftSign @item.finalSign <br>
                                            }
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">@Html.SmartLocalize("Cannot edit")</span>
                                    }
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Duplicate Section -->
                    <div class="accordion-item border-top">
                        <h2 class="accordion-header" id="headingDuplicate">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseDuplicate" aria-expanded="true" aria-controls="collapseDuplicate">
                                @Html.SmartLocalize("Duplicate")
                            </button>
                        </h2>
                        <div class="accordion-collapse collapse show" id="collapseDuplicate" aria-labelledby="headingDuplicate" data-bs-parent="#accordionExample">
                            <div class="accordion-body pt-0">
                                <p class="fs-9">
                                    @Html.SmartLocalize("Sales Order Number:") @Model.SalesOrderNumber <br>
                                    <a href="javascript:void(0)" onclick="duplicateSalesOrder(@Model.SalesOrderId)">@Html.SmartLocalize("Create Duplicate")</a>
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Source Quotation Section -->
                    @if (!string.IsNullOrEmpty(Model.QuotationNumber))
                    {
                        <div class="accordion-item border-top">
                            <h2 class="accordion-header" id="headingQuotation">
                                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseQuotation" aria-expanded="true" aria-controls="collapseQuotation">
                                    @Html.SmartLocalize("Source Quotation")
                                </button>
                            </h2>
                            <div class="accordion-collapse collapse show" id="collapseQuotation" aria-labelledby="headingQuotation" data-bs-parent="#accordionExample">
                                <div class="accordion-body pt-0">
                                    <p class="fs-9">
                                        @Html.SmartLocalize("Quotation Number:") @Model.QuotationNumber
                                    </p>
                                </div>
                            </div>
                        </div>
                    }



                    <!-- ADD THIS SECTION HERE -->
                    <!-- Create Shipment Section -->
                    <div class="accordion-item border-top">
                        <h2 class="accordion-header" id="headingShipment">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseShipment" aria-expanded="true" aria-controls="collapseShipment">
                                @Html.SmartLocalize("Shipment")
                            </button>
                        </h2>
                        <div class="accordion-collapse collapse show" id="collapseShipment" aria-labelledby="headingShipment" data-bs-parent="#accordionExample">
                            <div class="accordion-body pt-0">
                                @if (Model.CanCreateShipment)
                                {
                                    <p class="fs-9">
                                        <a href="/Shipment/Index?salesOrderId=@Model.SalesOrderId" class="btn btn-sm btn-phoenix-primary w-100">
                                            <i class="fas fa-shipping-fast me-2"></i>
                                            @Html.SmartLocalize("Create Shipment")
                                        </a>
                                    </p>
                                }


                                @if (Model.IsFullyShipped)
                                {
                                    <div class="alert alert-success fs-9 py-2 mb-2">
                                        <i class="fas fa-check-circle me-2"></i>
                                        @Html.SmartLocalize("Fully Shipped")
                                    </div>
                                }
                                else if (Model.HasShipmentsStarted)
                                {
                                    <div class="alert alert-info fs-9 py-2 mb-2">
                                        <i class="fas fa-shipping-fast me-2"></i>
                                        @Html.SmartLocalize("Partially Shipped")
                                    </div>
                                }


                                @if (Model.HasShipments && Model.Shipments != null && Model.Shipments.Any())
                                {
                                    <hr class="my-2" />
                                    <p class="fs-9 fw-bold mb-2">@Html.SmartLocalize("Existing Shipments:")</p>
                                    @foreach (var shipment in Model.Shipments)
                                    {
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <a href="/ShipmentDetails/Index/@shipment.ShipmentId" class="fs-9 text-decoration-none">
                                                @shipment.ShipmentNumber
                                            </a>
                                            <span class="badge badge-phoenix-@shipment.StatusClass fs-10">
                                                @shipment.Status
                                            </span>
                                        </div>
                                    }
                                }
                                else if (!Model.CanCreateShipment)
                                {
                                    <p class="fs-9 text-muted">@Html.SmartLocalize("No shipments available")</p>
                                }
                            </div>
                        </div>
                    </div>


                    <!-- Invoice Section -->
