@using GCTL.Core.ViewModels.POS.Sales.SalesOrders
@model SalesOrderDetailsViewModel
@{
    var sidebarData = ViewBag.SidebarData as SalesOrderSidebarDetailsViewModel;
    var isEditMode = ViewBag.IsEditMode ?? false;
    ViewData["Title"] = Html.SmartLocalize("Sales Order");
}

<div class="row">
    <div class="row col-xl-12 border-2">
        <div class="d-flex justify-content-between align-items-center">
            <p class="mb-1 fw-lighter fs-5">@Html.SmartLocalize("Sales Order")</p>
        </div>
    </div>
</div>

<div class="">
    @if (isEditMode)
    {
        <!-- EDIT MODE -->
        <form asp-action="Save" method="post" id="salesOrderForm">
            <input asp-for="Id" type="hidden" />
            <div class="row mb-4">
                <div class="col-xl-9">
                    <div class="card pt-4 p-5 mb-3" style="min-height: 1000px;">
                        <div class="row col-xl-12">
                            <p class="mb-1 fw-bold fs-7">@Html.SmartLocalize("Sales Order")</p>
                            <p class="mb-2 fw-lighter fs-9">
                                @Html.SmartLocalize("Edit sales order details.")
                            </p>
                            <div class="border-bottom border-2"></div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-12">
                                <div class="row justify-content-between">
                                    <!-- Customer Info -->
                                    <div class="col-xl-5">
                                        <div class="col-md-12">
                                            <input asp-for="SelectedCustomerId" type="hidden" id="selectedCustomerId" />
                                            <button type="button" class="btn border border-github py-5 px-10 mt-4" id="showUserDropdownBtn">
                                                <i class="fa fa-user fs-3 mb-2"></i>
                                                <p>@Html.SmartLocalize("Add Customer")</p>
                                            </button>
                                            <div id="userDropdownContainer" style="display:none;">
                                                <label class="form-label">@Html.SmartLocalize("Select Customer")</label>
                                                <select id="customerDropdown" class="form-select">
                                                    <option value="">@Html.SmartLocalize("-- Select Customer --")</option>
                                                </select>
                                            </div>
                                            <script type="application/json" id="customersData">
                                                @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Customers))
                                            </script>
                                            <input type="hidden" id="preSelectedCustomerId" value="@(Model.SelectedCustomerId?.ToString() ?? "")" />
                                            <div id="userInfo" class="card mb-3 mt-3" style="display:none;">
                                                <div class="card-body">
                                                    <h5 class="card-title mb-2">@Html.SmartLocalize("Billing Information")</h5>
                                                    <div class="d-flex">
                                                        <div class="me-auto">
                                                            <p class="mb-1 fs-9 info-company"></p>
                                                            <p class="mb-1 fs-9 info-addr1"></p>
                                                            <p class="mb-1 fs-9 info-addr2"></p>
                                                        </div>
                                                        <div class="mx-auto">
                                                            <p class="mb-1 fs-9 info-tax"></p>
                                                            <p class="mb-1 fs-9 info-phone"></p>
                                                            <p class="mb-1 fs-9 info-email"></p>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Order Details -->
                                    <div class="col-xl-7">
                                        <div class="row mt-3">
                                            <div class="col-xl-12">
                                                <div class="mb-3">
                                                    <label class="form-label">@Html.SmartLocalize("Sales Order Number")</label>
                                                    <input asp-for="OrderNumber" class="form-control" readonly />
                                                </div>
                                            </div>
                                            <div class="col-xl-6">
                                                <div class="mb-3">
                                                    <label class="form-label">@Html.SmartLocalize("Order Date")</label>
                                                    <input asp-for="OrderDate" class="form-control" type="date" />
                                                </div>
                                            </div>
                                            @if (!string.IsNullOrEmpty(Model.QuotationNumber))
                                            {
                                                <div class="col-xl-6">
                                                    <div class="mb-3">
                                                        <label class="form-label">@Html.SmartLocalize("Linked Quotation")</label>
                                                        <input value="@Model.QuotationNumber" class="form-control" readonly />
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Items Table (Editable) -->
                        <div class="col-xl-12 mt-3">
                            <table class="table" id="itemsTable" style="border-bottom: 0px solid #ffffff00;">
                                <thead>
                                    <tr>
                                        <th style="width: 50px;">@Html.SmartLocalize("SL")</th>
                                        <th class="text-center">@Html.SmartLocalize("Description")</th>
                                        <th class="text-center">@Html.SmartLocalize("Unit")</th>
                                        <th class="text-center">@Html.SmartLocalize("Area")</th>
                                        <th class="text-center">@Html.SmartLocalize("Rate")</th>
                                        <th class="text-center">@Html.SmartLocalize("Qty")</th>
                                        <th class="text-center">@Html.SmartLocalize("Amount")</th>
                                        <th style="width: 50px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < Model.Items.Count; i++)
                                    {
                                        <tr data-index="@i">
                                            <td class="fs-8 text-center align-middle">@(i + 1)</td>
                                            <td><input asp-for="Items[i].Description" class="form-control" /></td>
                                            <td>
                                                <select asp-for="Items[i].Unit" class="form-select unitDD searchableSelect" asp-items="ViewBag.Unit">
                                                    <option value="">@Html.SmartLocalize("-- Select Unit --")</option>
                                                </select>
                                            </td>
                                            <td><input asp-for="Items[i].Area" class="form-control calc" type="number" step="any" /></td>
                                            <td><input asp-for="Items[i].Rate" class="form-control calc" type="number" step="any" /></td>
                                            <td><input asp-for="Items[i].Quantity" class="form-control calc-qty" type="number" step="any" /></td>
                                            <td class="amount text-end align-middle">@Model.Items[i].Amount.ToString("N2")</td>
                                            <td class="text-center align-middle">
                                                <button type="button" class="btn btn-sm btn-outline-danger mx-2 remove-item">
                                                    <i class="far fa-trash-alt text-black"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                    <tr>
                                        <td colspan="10" class="text-center">
                                            <a id="add-item-btn" class="text-primary py-2" role="button" style="cursor:pointer;">
                                                @Html.SmartLocalize("Add an Item")
                                            </a>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td colspan="6" class="text-end fs-9 fw-bold">@Html.SmartLocalize("Sub Total Taka")</td>
                                        <td colspan="2" class="text-center fs-9 fw-bold" id="subTotal">@Model.SubTotal.ToString("N2")</td>
                                    </tr>
                                    <tr>
                                        <td colspan="6" class="text-end fs-9 py-2">
                                            <div class="d-flex justify-content-end">
                                                <div class="mx-2 mt-2">@Html.SmartLocalize("VAT/Deduction (%)")</div>
                                                <div><input asp-for="VatPercent" id="vatPercent" class="form-control" type="number" step="any" /></div>
                                            </div>
                                        </td>
                                        <td colspan="2" class="text-center fs-9" id="vatAmount">@Model.VatAmount.ToString("N2")</td>
                                    </tr>
                                    <tr>
                                        <td colspan="6" class="text-end h5">@Html.SmartLocalize("Grand Total Taka")</td>
                                        <td colspan="2" class="text-center h5" id="grandTotal">@Model.GrandTotal.ToString("N2")</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <!-- Note -->
                        <div class="col-xl-12 mb-3">
                            <p class="mb-1 fw-bold fs-8">@Html.SmartLocalize("Note")</p>
                            <div class="">
                                <textarea asp-for="Note" class="form-control" rows="3" placeholder="@Html.SmartLocalize("Add any additional notes here...")"></textarea>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="col-xl-12 mb-3">
                            <div class="d-flex justify-content-end">
                                <a href="@Url.Action("Index", "SalesOrderDetails", new { id = Model.Id })" class="btn btn-secondary me-2">@Html.SmartLocalize("Cancel")</a>
                                <button type="submit" class="btn btn-primary">@Html.SmartLocalize("Save Sales Order")</button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Sidebar -->
                @if (sidebarData != null)
                {
                    <partial name="_SalesOrderSidebar" model="sidebarData" />
                }
            </div>
        </form>
    }
    else
    {
        <!-- READ-ONLY MODE -->
        <div class="row mb-4">
            <div class="col-xl-9">
                <div class="card pt-4 p-5 mb-3" style="min-height: 1000px;">
                    <div class="row col-xl-12">
                        <p class="mb-1 fw-bold fs-7">@Html.SmartLocalize("Sales Order Details")</p>
                        <div class="border-bottom border-2"></div>
                    </div>

                    <div class="row mb-3 mt-3">
                        <div class="col-md-12">
                            <div class="row">
                                <!-- Customer Info -->
                                <div class="col-xl-6">
                                    <div class="card mb-3" style="min-height: 165px;">
                                        <div class="card-body">
                                            <h5 class="card-title mb-2">@Html.SmartLocalize("Customer Information")</h5>
                                            <p class="mb-1 fs-9"><strong>@Html.SmartLocalize("Company:")</strong> @Model.CustomerData.CompanyName</p>
                                            <p class="mb-1 fs-9"><strong>@Html.SmartLocalize("Address:")</strong> @Model.CustomerData.AddressLine1</p>
                                            <p class="mb-1 fs-9"><strong>@Html.SmartLocalize("Phone:")</strong> @Model.CustomerData.Phone</p>
                                            <p class="mb-1 fs-9"><strong>@Html.SmartLocalize("Email:")</strong> @Model.CustomerData.Email</p>
                                        </div>
                                    </div>
                                </div>

                                <!-- Order Info -->
                                <div class="col-xl-6">
                                    <div class="card pb-1 ps-2 p-3 mb-3" style="min-height: 165px;">
                                        <div class="row">
                                            <div class="col-6">
                                                <label class="form-label fw-bold">@Html.SmartLocalize("Order Number")</label>
                                                <p class="fs-8 ms-3">@Model.OrderNumber</p>
                                            </div>
                                            <div class="col-6">
                                                <label class="form-label fw-bold">@Html.SmartLocalize("Order Date")</label>
                                                <p class="fs-8 ms-3">@Model.OrderDate.ToString("MMM dd, yyyy")</p>
                                            </div>
                                            @if (!string.IsNullOrEmpty(Model.QuotationNumber))
                                            {
                                                <div class="col-12">
                                                    <label class="form-label fw-bold">@Html.SmartLocalize("Linked Quotation")</label>
                                                    <p class="fs-8 ms-3">@Model.QuotationNumber</p>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Items Table (Read-only) -->
                    <div class="col-xl-12 mt-3">
                        <table class="table" style="border-bottom: 0px solid #ffffff00;">
                            <thead>
                                <tr>
                                    <th style="width: 50px;">@Html.SmartLocalize("SL")</th>
                                    <th>@Html.SmartLocalize("Description")</th>
                                    <th class="text-center">@Html.SmartLocalize("Unit")</th>
                                    <th class="text-center">@Html.SmartLocalize("Area")</th>
                                    <th class="text-center">@Html.SmartLocalize("Rate")</th>
                                    <th class="text-center">@Html.SmartLocalize("Qty")</th>
                                    <th class="text-center">@Html.SmartLocalize("Amount")</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.Items.Count; i++)
                                {
                                    <tr>
                                        <td class="fs-8 text-center align-middle">@(i + 1)</td>
                                        <td>@Model.Items[i].Description</td>
                                        <td class="text-center">@Model.Items[i].UnitName</td>
                                        <td class="text-center">@Model.Items[i].Area.ToString("N2")</td>
                                        <td class="text-center">@Model.Items[i].Rate.ToString("N2")</td>
                                        <td class="text-center">@Model.Items[i].Quantity.ToString("N2")</td>
                                        <td class="text-end">@Model.Items[i].Amount.ToString("N2")</td>
                                    </tr>
                                }
                                <tr>
                                    <td colspan="6" class="text-end fs-9 fw-bold">@Html.SmartLocalize("Sub Total Taka")</td>
                                    <td class="text-end fs-9 fw-bold">@Model.SubTotal.ToString("N2")</td>
                                </tr>
                                <tr>
                                    <td colspan="6" class="text-end fs-9">@Html.SmartLocalize("VAT/Deduction") - @Model.VatPercent%</td>
                                    <td class="text-end fs-9">@Model.VatAmount.ToString("N2")</td>
                                </tr>
                                <tr>
                                    <td colspan="6" class="text-end h5">@Html.SmartLocalize("Grand Total Taka")</td>
                                    <td class="text-end h5">@Model.GrandTotal.ToString("N2")</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- Note (Read-only) -->
                    @if (!string.IsNullOrEmpty(Model.Note))
                    {
                        <div class="col-xl-12 mb-3">
                            <p class="mb-1 fw-bold fs-8">@Html.SmartLocalize("Note")</p>
                            <div class="">
                                <p class="fs-9">@Model.Note</p>
                            </div>
                        </div>
                    }

                    <div class="d-flex justify-content-end gap-2 align-items-center">
                        @if (!isEditMode && sidebarData != null && sidebarData.CanEdit)
                        {
                            <a href="@Url.Action("Edit", "SalesOrderDetails", new { id = Model.Id })" class="btn btn-primary">
                                <i class="fa fa-edit me-1"></i> @Html.SmartLocalize("Edit Sales Order")
                            </a>
                        }
                    </div>
                </div>
            </div>

            <!-- Sidebar -->
            @if (sidebarData != null)
            {
                <partial name="_SalesOrderSidebar" model="sidebarData" />
            }
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/pages/Sales/SalesOrderDetails.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
}