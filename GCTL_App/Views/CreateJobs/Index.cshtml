<style>
    .card-header {
        font-size: 22px!important;
        text-transform: uppercase !important;
    }
    label {
        font-size: 12px!important;
        font-weight: bold!important;
        text-transform: uppercase!important;
    }
</style>
<div class="card">
    <h5 class="card-header">Create A New Job</h5>
    <div class="row col-md-12 m-0 pb-3">
        <form action="shift-roster-ui.html">
            <div class="modal-body pb-0">
                <div class="row mt-3">

                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label" for="exampleFormControlInput">Customer Name <a class="ms-4" data-bs-toggle="modal" data-bs-target="#addCompanyModal">+add Customer</a></label>
                            <select class="form-select" id="" data-choices="data-choices" size="1" required="required" name="organizerSingle" data-options='{"removeItemButton":true,"placeholder":true}'>

                                <option>Mahamudul Hasan</option>
                                <option>Mashum Billah</option>
                                <option>Abdul Motin</option>
                            </select>
                        </div>
                    </div>


                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label" for="exampleFormControlInput">Job Title</label>
                            <input class="form-control" id="" type="text" />
                        </div>
                    </div>


                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label" for="organizerMultiple">Job Type</label>
                            <select class="form-select" id="" data-choices="data-choices" size="1" required="required" name="organizerSingle" data-options='{"removeItemButton":true,"placeholder":true}'>
                                <option value="">Sales</option>
                                <option>Services</option>
                            </select>
                        </div>
                    </div>


                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label" for="exampleFormControlInput">Team Members</label>
                            <select class="form-select" id="organizerMultiple" data-choices="data-choices" multiple="multiple" data-options='{"removeItemButton":true,"placeholder":true}'>
                                <option>Juewal Rana</option>
                                <option>Nozib Ullah</option>
                                <option>Korim Shekh</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label" for="organizerMultiple">Start Date Time</label>
                            <input class="form-control datetimepicker" id="" type="text" placeholder="dd/mm/yyyy hour : minute" data-options='{"enableTime":true,"dateFormat":"d/m/y H:i","disableMobile":true}' />
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label" for="organizerMultiple">End Date Time</label>
                            <input class="form-control datetimepicker" id="" type="text" placeholder="dd/mm/yyyy hour : minute" data-options='{"enableTime":true,"dateFormat":"d/m/y H:i","disableMobile":true}' />
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label" for="organizerMultiple">Status</label>
                            <select class="form-select" id="" data-choices="data-choices" size="1" required="required" name="organizerSingle" data-options='{"removeItemButton":true,"placeholder":true}'>
                                <option value="">New</option>
                                <option>Close</option>
                                <option>Done</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" id="flexSwitchCheckDefault" type="checkbox" />
                                <label class="form-check-label" for="flexSwitchCheckDefault">Job Location Same as Customer Location</label>
                            </div>
                            <input class="form-control" id="" type="text" />
                        </div>
                    </div>

                    <div class="col-md-6 ">
                        <div class="mb-3">
                            <label class="form-label" for="exampleFormControlInput">Note</label>
                            <textarea class="form-control border-translucent" id="" rows="6"></textarea>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label" for="exampleFormControlInput">File Upload</label>
                            <div class="dropzone dropzone-multiple p-0" id="dropzone" data-dropzone="data-dropzone" data-options='{"url":"valid/url","maxFiles":1,"dictDefaultMessage":"Choose or Drop a file here"}'>
                                <div class="fallback">
                                    <input type="file" name="file" />
                                </div>
                                <div class="dz-message" data-dz-message="data-dz-message">
                                    <div class="dz-message-text"><img class="me-2" src="../../../assets/img/icons/cloud-upload.svg" width="25" alt="" />Drop your file here</div>
                                </div>
                                <div class="dz-preview dz-preview-multiple m-0 d-flex flex-column">
                                    <div class="d-flex pb-3 border-bottom border-translucent media px-2">
                                        <div class="border p-2 rounded-2 me-2"><img class="rounded-2 dz-image" src="../../../assets/img/icons/file.png" alt="..." data-dz-thumbnail="data-dz-thumbnail" /></div>
                                        <div class="flex-1 d-flex flex-between-center">
                                            <div>
                                                <h6 data-dz-name="data-dz-name"></h6>
                                                <div class="d-flex align-items-center">
                                                    <p class="mb-0 fs-9 text-body-quaternary lh-1" data-dz-size="data-dz-size"></p>
                                                    <div class="dz-progress"><span class="dz-upload" data-dz-uploadprogress=""></span></div>
                                                </div><span class="fs-10 text-danger" data-dz-errormessage="data-dz-errormessage"></span>
                                            </div>
                                            <div class="dropdown">
                                                <button class="btn btn-link text-body-quaternary btn-sm dropdown-toggle btn-reveal dropdown-caret-none" type="button" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false"><span class="fas fa-ellipsis-h"></span></button>
                                                <div class="dropdown-menu dropdown-menu-end border border-translucent py-2"><a class="dropdown-item" href="#!" data-dz-remove="data-dz-remove">Remove File</a></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>



                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light me-2" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>

</div>
