@model GCTL.Core.ViewModels.AdminSettingsVM.ApprovalSettingsVM
@{
    var mainTab = "CompanySetting";
    var subTab = "ApprovalSettings";
}

<partial name="~/Views/Shared/AdminsettingsNavs/CompanySettingsNavs/_MainSettingsTabPartial.cshtml" model="mainTab" />
<partial name="~/Views/Shared/AdminsettingsNavs/CompanySettingsNavs/_NavCompanySettingsPartial.cshtml" model="subTab" />
<style>
    .custom-padding-left {
        padding-left: 4.5em;
        margin-bottom: -0.656rem;
        padding-top: 1rem;
    }
</style>

<div class="col-xl-12 mt-3">
    <div class="card mb-4">
        <div class="card-body">


            <div class="border-bottom d-flex align-items-center justify-content-between pb-3 mb-3">
                <h4 class="mb-0">Approval Settings</h4>
                <button class="btn " title="User Manual(info of this page)" data-bs-toggle="modal" data-bs-target="#manualModal">
                    <i class="fas fa-info-circle"></i>
                </button>
            </div>




            <!-- Start Approval Settings Form -->
            <form id="aprovalSettingsForm" asp-controller="ApprovalSettings" asp-action="Create" method="post">
                <div class="border-bottom mb-3">
                    <div class="row">
                        <div class="col-md-12 d-flex">
                            <div class="flex-fill">
                                <div class="row">
                                    <!-- Company and Approval Type -->
                                    <div class="col-md-6">
                                        <div class="mb-3 mt-1">
                                            <label class="form-label">Organization Name</label>
                                            <select class="form-select choiceDD" id="OrganizationID" name="OrganizationID" required>
                                                <option value="">Select Organization</option>
                                                @foreach (var org in ViewBag.Organizations)
                                                {
                                                    var isSelected = org.Selected ? "selected" : "";


                                                    <option value="@org.Value" selected="@isSelected">@org.Text</option>
                                                }
                                            </select>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="mb-3 mt-1">
                                            <label class="form-label">Approval Type</label>
                                            <select class="form-select choiceDD" id="ApprovalTypeID" name="ApprovalTypeID" required>
                                                <option value="">Select Approval Type</option>
                                                @foreach (var status in ViewBag.ApprovalTypes)
                                                {
                                                    <option value="@status.Value">@status.Text</option>
                                                }
                                            </select>
                                        </div>
                                    </div>


                                    <!-- Approver Sections (First, Second, Third Approver) -->
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <div class="row">
                                                <!-- First Approvers Checkbox -->
                                                <div class="form-check form-switch col-12 custom-padding-left">
                                                    <input class="form-check-input" id="chkFirst" type="checkbox" required />
                                                    <label class="form-check-label" for="chkFirst">First Approver</label>
                                                </div>
                                            </div>

                                            <!-- Select Dropdown (Below Checkbox) -->
                                            <div class="mt-3">
                                                <select class="form-select choiceDD" id="selFirst" name="FirstApprovalID" required></select>

                                            </div>
                                        </div>
                                    </div>

                                    <!-- Second Approvers Section -->
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <div class="row">
                                                <!-- Second Approvers Checkbox -->
                                                <div class="form-check form-switch col-12 custom-padding-left">
                                                    <input class="form-check-input" id="chkSecond" type="checkbox" name="IsEnableSecondApproval" />
                                                    <label class="form-check-label" for="chkSecond">Second Approver</label>
                                                </div>
                                            </div>

                                            <!-- Select Dropdown (Below Checkbox) -->
                                            <div class="mt-3">
                                                <select class="form-select choiceDD" id="selSecond" name="SecondApprovalID"></select>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Third Approvers Section -->
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <div class="row">
                                                <!-- Third Approvers Checkbox -->
                                                <div class="form-check form-switch col-12 custom-padding-left">
                                                    <input class="form-check-input" id="chkThird" type="checkbox" name="IsEnableThirdApproval" />
                                                    <label class="form-check-label" for="chkThird">Third Approver</label>
                                                </div>
                                            </div>

                                            <!-- Select Dropdown (Below Checkbox) -->
                                            <div class="mt-3">
                                                <select class="form-select choiceDD" id="selThird" name="ThirdApprovalID"></select>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- 
                                    <div class="col-md-4" id="selfApprovalSection">

                                        <div class="mb-3">
                                            <div class="row">
                                                <div class="form-check form-switch col-12 custom-padding-left">
                                                    <input class="form-check-input" type="checkbox" id="chkSelfApproval" name="AllowSelfApproval" />
                                                    <label class="form-check-label" for="chkSelfApproval">Self-Approval</label>
                                                </div>
                                            </div>

                                           
                                            @* <div class="mt-3">
                                                    <select class="form-select choiceDD" id="selSelfApproval" name="SelfExceptionApprovalID" required>
                                                        <option value="">Select Self Approver</option>
                                                        <!-- Options will be populated dynamically -->
                                                    </select>
                                                </div> *@
                                            <div class="mt-3">
                                                <select class="form-select choiceDD"
                                                        id="selSelfApproval"
                                                        name="SelfExceptionApprovalID">
                                                    <option value="">
                                                        Select Higher authority in case of Self approval
                                                    </option>
                                                </select>
                                            </div>

                                        </div>
                                    </div>
                                     -->
                                   
                                    <div class="col-md-4" id="selfApprovalSection">
                                        <div class="mb-3">
                                            <div class="row">
                                                <div class="col-12  d-flex align-items-center" style="margin-bottom: -0.656rem;padding-top: 1rem;">
                                                    <div class="form-check me-3">
                                                        <input class="form-check-input" type="radio" name="AllowSelfApproval" id="enableSelfApproval" value="true" checked />
                                                        <label class="form-check-label" for="enableSelfApproval">Enable Self Approval</label>
                                                    </div>
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="radio" name="AllowSelfApproval" id="disableSelfApproval" value="false" />
                                                        <label class="form-check-label" for="disableSelfApproval">Disable Self Approval</label>
                                                    </div>
                                                </div>
                                            </div>
                                            <!-- Select Dropdown (Below Radio Buttons) -->
                                            <div class="mt-3">
                                                <select class="form-select choiceDD" id="selSelfApproval" name="SelfExceptionApprovalID" disabled>
                                                    <option value="">Select Higher authority incase of Self-approval</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>




                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Form Buttons -->
                <div class="d-flex align-items-center justify-content-end">
                    <button type="reset" class="btn btn-outline-secondary me-2">Reset</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>


            <!-- End Approval Settings Form -->

        </div>
    </div>








    <partial name="_ApprovalSettingsTable" />
    <partial name="_editApprovalSettings" />
    <partial name="_ConfirmDelete" />
</div>



<style>
    .modal-header {
         /* background: #2c7be5; */
    }

    .step-box {
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 15px;
    }

    .step-number {
        background: #2c7be5;
        color: white;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-right: 15px;
        font-weight: bold;
    }

    .alert-simple {
        padding: 15px;
        border-radius: 8px;
        margin: 15px 0;
    }

    .alert-blue {
        background: #e3f2fd;
        border-left: 4px solid #2c7be5;
        color: #1976d2;
    }

    .alert-yellow {
        background: #fff8e1;
        border-left: 4px solid #ff9800;
        color: #f57c00;
    }

    .simple-card {
        background: white;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 15px;
    }

    .flow-step {
        text-align: center;
        padding: 15px;
        background: white;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        margin: 10px;
    }
</style>



<div class="modal fade" id="manualModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header text-white">
                <h5 class="modal-title">
                    <i class="fas fa-book me-2"></i>@Html.SmartLocalize("Approval Settings Help")
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">

                <!-- What is this? -->
                <div class="simple-card">
                    <h5><i class="fas fa-question-circle text-primary me-2"></i>@Html.SmartLocalize("What is this?")</h5>
                    <p>@Html.SmartLocalize("Here you can configure approval settings for various types of requests such as leave, purchase, etc.")</p>
                </div>

                <!-- How to setup -->
                <h5 class="mb-3">@Html.SmartLocalize("How to Set Up:")</h5>

                <div class="step-box">
                    <div class="d-flex align-items-start">
                        <span class="step-number">1</span>
                        <div>
                            <h6>@Html.SmartLocalize("Select Organization")</h6>
                            <p class="mb-0">@Html.SmartLocalize("First, choose your organization from the Organization Name dropdown.")</p>
                        </div>
                    </div>
                </div>

                <div class="step-box">
                    <div class="d-flex align-items-start">
                        <span class="step-number">2</span>
                        <div>
                            <h6>@Html.SmartLocalize("Select Approval Type")</h6>
                            <p class="mb-0">@Html.SmartLocalize("Select the type of request you want to configure approval for (e.g., Leave, Purchase).")</p>
                        </div>
                    </div>
                </div>

                <div class="step-box">
                    <div class="d-flex align-items-start">
                        <span class="step-number">3</span>
                        <div>
                            <h6>@Html.SmartLocalize("Set First Approver (Required)")</h6>
                            <p class="mb-0">@Html.SmartLocalize("Check the First Approver box and select who will approve the request. This step is mandatory.")</p>
                        </div>
                    </div>
                </div>

                <div class="step-box">
                    <div class="d-flex align-items-start">
                        <span class="step-number">4</span>
                        <div>
                            <h6>@Html.SmartLocalize("Second/Third Approver (If Needed)")</h6>
                            <p class="mb-0">@Html.SmartLocalize("If multiple approval levels are required, enable and select Second or Third Approver.")</p>
                        </div>
                    </div>
                </div>

                <div class="step-box">
                    <div class="d-flex align-items-start">
                        <span class="step-number">5</span>
                        <div>
                            <h6>@Html.SmartLocalize("Self-Approval (Optional)")</h6>
                            <p class="mb-0">
                                @Html.SmartLocalize("If the user is the Final Approver and Self-Approval is enabled, the system will auto-approve the request.")
                                <br>
                                @Html.SmartLocalize("If Self-Approval is not enabled, the request will go to the assigned Approver.")
                            </p>
                        </div>
                    </div>
                </div>

                
              @*    <h5 class="mt-4 mb-3">@Html.SmartLocalize("How the Approval Flow Works:")</h5>

                 <div class="row">
                     <div class="col-md-2">
                         <div class="flow-step">
                             <i class="fas fa-file-alt fa-2x text-primary mb-2"></i>
                             <p class="mb-0"><small>@Html.SmartLocalize("Request Submit")</small></p>
                         </div>
                     </div>
