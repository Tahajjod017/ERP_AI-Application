                         </div>
                     </div>
                     <div class="col-md-1 d-flex align-items-center justify-content-center">
                         <i class="fas fa-arrow-right text-muted"></i>
                     </div>
                     <div class="col-md-2">
                         <div class="flow-step">
                             <i class="fas fa-user-cog fa-2x text-warning mb-2"></i>
                             <p class="mb-0"><small>@Html.SmartLocalize("Second Approver (optional)")</small></p>
                         </div>
                     </div>
                     <div class="col-md-1 d-flex align-items-center justify-content-center">
                         <i class="fas fa-arrow-right text-muted"></i>
                     </div>
                     <div class="col-md-2">
                         <div class="flow-step">
                             <i class="fas fa-check-circle fa-2x text-success mb-2"></i>
                             <p class="mb-0"><small>@Html.SmartLocalize("Approved")</small></p>
                         </div>
                     </div>
                 </div> *@


                <!-- Approval Flow -->
                <h5 class="mt-4 mb-3 text-center">@Html.SmartLocalize("How the Approval Flow Works:")</h5>

                <div class="container-fluid">
                    <div class="d-flex justify-content-center">
                        <div class="d-flex flex-nowrap align-items-center text-center">

                            <div class="px-3 py-2 border rounded me-2">
                                <i class="fas fa-file-alt fa-2x text-primary mb-2"></i>
                                <p class="mb-0"><small>@Html.SmartLocalize("Request Submit")</small></p>
                            </div>

                            <i class="fas fa-arrow-right text-muted me-2"></i>

                            <div class="px-3 py-2 border rounded me-2">
                                <i class="fas fa-user-tie fa-2x text-success mb-2"></i>
                                <p class="mb-0"><small>@Html.SmartLocalize("First Approver")</small></p>
                            </div>

                            <i class="fas fa-arrow-right text-muted me-2"></i>

                            <div class="px-3 py-2 border rounded me-2">
                                <i class="fas fa-user-cog fa-2x text-warning mb-2"></i>
                                <p class="mb-0"><small>@Html.SmartLocalize("Second Approver (optional)")</small></p>
                            </div>

                            <i class="fas fa-arrow-right text-muted me-2"></i>

                            <div class="px-3 py-2 border rounded">
                                <i class="fas fa-check-circle fa-2x text-success mb-2"></i>
                                <p class="mb-0"><small>@Html.SmartLocalize("Approved")</small></p>
                            </div>

                        </div>
                    </div>
                </div>



                <!-- Self Approval Explanation -->
                <div class="alert-blue alert-simple mt-4">
                    <h6><i class="fas fa-user-check me-2"></i>@Html.SmartLocalize("What is Self-Approval?")</h6>
                    <p>@Html.SmartLocalize("If the user is the Final Approver and Self-Approval is enabled, the system will auto approve the request.")</p>
                    <p class="mb-0">@Html.SmartLocalize("If Self-Approval is not enabled, the request will go to the selected Approver instead.")</p>
                </div>

                <!-- Examples -->
                <h5 class="mt-4 mb-3">@Html.SmartLocalize("Examples:")</h5>

                <div class="simple-card">
                    <h6>@Html.SmartLocalize("Leave Application:")</h6>
                    <p class="mb-0">@Html.SmartLocalize("If only manager approval is needed → select the manager as First Approver.")</p>
                </div>

                <div class="simple-card">
                    <h6>@Html.SmartLocalize("Purchase Request:")</h6>
                    <p class="mb-0">@Html.SmartLocalize("Department Head → Finance Manager → CEO → Enable and select all three levels.")</p>
                </div>

                <div class="simple-card">
                    <h6>@Html.SmartLocalize("Team Lead Timesheet:")</h6>
                    <p class="mb-0">
                        @Html.SmartLocalize("If the Team Lead is the final approver and Self-Approval is enabled → system will auto approve.")
                        <br>
                        @Html.SmartLocalize("If Self-Approval is not enabled → the request will go to the Correspondent Approver (e.g., Department Head).")
                    </p>
                </div>

                <!-- Important Notes -->
                <div class="alert-yellow alert-simple">
                    <h6><i class="fas fa-exclamation-triangle me-2"></i>@Html.SmartLocalize("Important Notes:")</h6>
                    <ul class="mb-0">
                        <li>@Html.SmartLocalize("First Approver is mandatory")</li>
                        <li>@Html.SmartLocalize("If Self-Approval is enabled, system auto approves")</li>
                        <li>@Html.SmartLocalize("If Self-Approval is disabled, an Approver must be selected")</li>
                        <li>@Html.SmartLocalize("Don’t forget to click the Save button after setup")</li>
                    </ul>
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Html.SmartLocalize("Close")</button>
            </div>
        </div>
    </div>
</div>

