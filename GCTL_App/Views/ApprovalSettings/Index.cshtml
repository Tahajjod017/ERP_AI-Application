@{
    var mainTab = "CompanySetting";
    var subTab = "ApprovalSettings";
}

<partial name="~/Views/Shared/AdminsettingsNavs/CompanySettingsNavs/_MainSettingsTabPartial.cshtml" model="mainTab" />
<partial name="~/Views/Shared/AdminsettingsNavs/CompanySettingsNavs/_NavCompanySettingsPartial.cshtml" model="subTab" />
<style>
    .custom-padding-left {
        padding-left: 4.5em;
        margin-bottom: -0.656rem;
        padding-top:1rem;
    }
</style>

<div class="col-xl-12 mt-3">
    <div class="card mb-4">
        <div class="card-body">
            <div class="border-bottom d-flex align-items-center pb-3 mb-3">
                <h4>Approval Settings</h4>
            </div>

            <!-- Start Approval Settings Form -->
            <form action="approval-settings.html">
                <div class="border-bottom mb-3">
                    <div class="row">
                        <div class="col-md-12 d-flex">
                            <div class="flex-fill">
                                <div class="row">
                                    <!-- Company and Approval Type -->
                                    <div class="col-md-6">
                                        <div class="mb-3 mt-1">
                                            <label class="form-label">Company Name</label>
                                            <select class="form-multi-select" multiple data-coreui-search="true">
                                                <option value="1">CSL</option>
                                                <option value="2">GCTL</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="mb-3 mt-1">
                                            <label class="form-label">Approval Type</label>
                                            <select class="form-select" id="approval" data-choices data-options='{"removeItemButton":true,"placeholder":true}'>
                                                <option>Leave Approval</option>
                                                <option>Purchase Approval</option>
                                                <option>Loan Approval</option>
                                            </select>
                                        </div>
                                    </div>

                                    <!-- Approver Sections (First, Second, Third Approver) -->
                                    <script>
                                        const approvers = [
                                            { label: "First", checkboxId: "chkFirst", selectId: "selFirst", toggleId: "toggleFirst" },
                                            { label: "Second", checkboxId: "chkSecond", selectId: "selSecond", toggleId: "toggleSecond" },
                                            { label: "Third", checkboxId: "chkThird", selectId: "selThird", toggleId: "toggleThird" }
                                        ];

                                        const employees = ["CEO", "Manager", "Team Lead"];
                                        const designations = ["Executive", "Supervisor", "Director"];

                                        document.addEventListener('DOMContentLoaded', function () {
                                            approvers.forEach(ap => {
                                                const checkbox = document.getElementById(ap.checkboxId);
                                                const select = document.getElementById(ap.selectId);
                                                const toggle = document.getElementById(ap.toggleId);

                                                checkbox.addEventListener('change', function () {
                                                    select.disabled = !this.checked;
                                                    toggle.disabled = !this.checked;
                                                });

                                                toggle.addEventListener('change', function () {
                                                    populateOptions(select, this.checked ? employees : designations);
                                                });

                                                // Initialize
                                                select.disabled = true;
                                                toggle.disabled = true;
                                                populateOptions(select, designations); // default
                                            });

                                            function populateOptions(selectEl, items) {
                                                selectEl.innerHTML = '<option value="">Select</option>';
                                                items.forEach(item => {
                                                    const opt = document.createElement('option');
                                                    opt.value = item.toLowerCase().replace(/\s+/g, '-');
                                                    opt.text = item;
                                                    selectEl.appendChild(opt);
                                                });
                                            }
                                        });
                                    </script>

                                    <!-- Approver Fields -->
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <div class="row">
                                                <!-- First Approvers Checkbox (Left Half) -->
                                                <div class="form-check form-switch col-6 custom-padding-left">
                                                    <input class="form-check-input" id="chkFirst" type="checkbox" />
                                                    <label class="form-check-label" for="chkFirst">First Approvers</label>
                                                </div>

                                                <!-- Use Employee Checkbox (Right Half) -->
                                                <div class="form-check form-switch col-6 custom-padding-left">
                                                    <input class="form-check-input" id="toggleFirst" type="checkbox" />
                                                    <label class="form-check-label" for="toggleFirst">Use Employee</label>
                                                </div>
                                            </div>

                                            <!-- Select Dropdown (Below Checkboxes) -->
                                            <div class="mt-3">
                                                <select class="form-select " id="selFirst" disabled>
                                                    <option value="">Select</option>
                                                    <option value="ceo">CEO</option>
                                                    <option value="manager">Manager</option>
                                                    <option value="teamlead">Team Lead</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Second Approvers Section -->
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <div class="row">
                                                <!-- Second Approvers Checkbox (Left Half) -->
                                                <div class="form-check form-switch col-6 custom-padding-left">
                                                    <input class="form-check-input" id="chkSecond" type="checkbox" />
                                                    <label class="form-check-label" for="chkSecond">Second Approvers</label>
                                                </div>

                                                <!-- Use Employee Checkbox (Right Half) -->
                                                <div class="form-check form-switch col-6 custom-padding-left">
                                                    <input class="form-check-input" id="toggleSecond" type="checkbox" />
                                                    <label class="form-check-label" for="toggleSecond">Use Employee</label>
                                                </div>
                                            </div>

                                            <!-- Select Dropdown (Below Checkboxes) -->
                                            <div class="mt-3">
                                                <select class="form-select" id="selSecond" disabled>
                                                    <option value="">Select</option>
                                                    <option value="ceo">CEO</option>
                                                    <option value="manager">Manager</option>
                                                    <option value="teamlead">Team Lead</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Third Approvers Section -->
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <div class="row">
                                                <!-- Third Approvers Checkbox (Left Half) -->
                                                <div class="form-check form-switch col-6 custom-padding-left">
                                                    <input class="form-check-input" id="chkThird" type="checkbox" />
                                                    <label class="form-check-label" for="chkThird">Third Approvers</label>
                                                </div>

                                                <!-- Use Employee Checkbox (Right Half) -->
                                                <div class="form-check form-switch col-6">
                                                    <input class="form-check-input" id="toggleThird" type="checkbox" />
                                                    <label class="form-check-label" for="toggleThird">Use Employee</label>
                                                </div>
                                            </div>

                                            <!-- Select Dropdown (Below Checkboxes) -->
                                            <div class="mt-3">
                                                <select class="form-select" id="selThird" disabled>
                                                    <option value="">Select</option>
                                                    <option value="ceo">CEO</option>
                                                    <option value="manager">Manager</option>
                                                    <option value="teamlead">Team Lead</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- END Approval Block -->
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Form Buttons -->
                <div class="d-flex align-items-center justify-content-end">
                    <button type="button" class="btn btn-outline-light border me-3">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Start Approval Settings Form -->
    


