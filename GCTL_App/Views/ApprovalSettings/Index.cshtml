@{
    var mainTab = "CompanySetting";
    var subTab = "ApprovalSettings";
}

<partial name="~/Views/Shared/AdminsettingsNavs/CompanySettingsNavs/_MainSettingsTabPartial.cshtml" model="mainTab" />
<partial name="~/Views/Shared/AdminsettingsNavs/CompanySettingsNavs/_NavCompanySettingsPartial.cshtml" model="subTab" />
<style>
    .custom-padding-left {
        padding-left: 4.5em;
        margin-bottom: -0.656rem;
        padding-top:1rem;
    }
</style>

<div class="col-xl-12 mt-3">
    <div class="card mb-4">
        <div class="card-body">
            <div class="border-bottom d-flex align-items-center pb-3 mb-3">
                <h4>Approval Settings</h4>
            </div>

            <!-- Start Approval Settings Form -->
            <form id="aprovalSettingsForm" asp-controller="ApprovalSettings" asp-action="Create" method="post">
                <div class="border-bottom mb-3">
                    <div class="row">
                        <div class="col-md-12 d-flex">
                            <div class="flex-fill">
                                <div class="row">
                                    <!-- Company and Approval Type -->
                                    <div class="col-md-6">
                                        <div class="mb-3 mt-1">
                                            <label class="form-label">Organization Name</label>
                                            <select class="form-select choiceDD" id="OrganizationID" name="OrganizationID">
                                                <option value="">Select Organization</option>
                                                @foreach (var org in ViewBag.Organizations)
                                                {
                                                    <option value="@org.Value">@org.Text</option>
                                                }
                                            </select>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="mb-3 mt-1">
                                            <label class="form-label">Approval Type</label>
                                            <select class="form-select choiceDD" id="ApprovalTypeID" name="ApprovalTypeID">
                                                <option value="">Select Approval Type</option>
                                                @foreach (var status in ViewBag.ApprovalTypes)
                                                {
                                                    <option value="@status.Value">@status.Text</option>
                                                }
                                            </select>
                                        </div>
                                    </div>

                                    <!-- Approver Sections (First, Second, Third Approver) -->
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <div class="row">
                                                <!-- First Approvers Checkbox -->
                                                <div class="form-check form-switch col-6 custom-padding-left">
                                                    <input class="form-check-input" id="chkFirst" type="checkbox" />
                                                    <label class="form-check-label" for="chkFirst">First Approver</label>
                                                </div>

                                                <!-- Use Employee Checkbox (Right Half) -->
                                                <div class="form-check form-switch col-6 custom-padding-left">
                                                    <input class="form-check-input" id="toggleFirst" type="checkbox" name="IsDesignationOrEmpFirstApprovalID" />
                                                    <label class="form-check-label" for="toggleFirst">Use Employee</label>
                                                </div>
                                            </div>

                                            <!-- Select Dropdown (Below Checkboxes) -->
                                            <div class="mt-3">
                                                <select class="form-select " id="selFirst" disabled name="FirstApprovalID">
                                                    <!-- Options will be populated dynamically -->
                                                </select>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Second Approvers Section -->
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <div class="row">
                                                <!-- Second Approvers Checkbox -->
                                                <div class="form-check form-switch col-6 custom-padding-left">
                                                    <input class="form-check-input" id="chkSecond" type="checkbox" name="IsEnableSecondApproval" />
                                                    <label class="form-check-label" for="chkSecond">Second Approver</label>
                                                </div>

                                                <!-- Use Employee Checkbox (Right Half) -->
                                                <div class="form-check form-switch col-6 custom-padding-left">
                                                    <input class="form-check-input" id="toggleSecond" type="checkbox" name="IsDesignationOrEmpSecondApprovalID" />

                                                    <label class="form-check-label" for="toggleSecond">Use Employee</label>
                                                </div>
                                            </div>

                                            <!-- Select Dropdown (Below Checkboxes) -->
                                            <div class="mt-3">
                                                <select class="form-select " id="selSecond" disabled name="SecondApprovalID">
                                                    <!-- Options will be populated dynamically -->
                                                </select>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Third Approvers Section -->
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <div class="row">
                                                <!-- Third Approvers Checkbox -->
                                                <div class="form-check form-switch col-6 custom-padding-left">
                                                    <input class="form-check-input" id="chkThird" type="checkbox" name="IsEnableThirdApproval" />
                                                    <label class="form-check-label" for="chkThird">Third Approver</label>
                                                </div>

                                                <!-- Use Employee Checkbox (Right Half) -->
                                                <div class="form-check form-switch col-6 custom-padding-left">
                                                    <input class="form-check-input" id="toggleThird" type="checkbox" name="IsDesignationOrEmpThirdApprovalID" />
                                                    <label class="form-check-label" for="toggleThird">Use Employee</label>
                                                </div>
                                            </div>

                                            <!-- Select Dropdown (Below Checkboxes) -->
                                            <div class="mt-3">
                                                <select class="form-select" id="selThird" disabled name="ThirdApprovalID">
                                                    <!-- Options will be populated dynamically -->
                                                </select>
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Form Buttons -->
                <div class="d-flex align-items-center justify-content-end">
                    <button type="reset" class="btn btn-outline-secondary me-2">Reset</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>

           
            <!-- End Approval Settings Form -->

        </div>
    </div>


    


 
   

    <partial name="_ApprovalSettingsTable"/>
    <partial name="_editApprovalSettings" />
    <partial name="_ConfirmDelete" />
</div>

@section Scripts {
    <script src="~/js/pages/adminsettings/organizationsettings/approvalsettings.js"></script>
}