<div class="modal fade" id="edit_approval_setting">
    <div class="modal-dialog modal-dialog-centered modal-md">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">Edit Approval</h4>
                <button type="button" class="btn-close custom-btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="approval-settings.html" class="p-3">

                <div class="border-bottom mb-3">
                    <div class="row">
                        <div class="col-md-12 d-flex">
                            <div class="flex-fill">


                                <div class="row">

                                    <div class="col-md-6">
                                        <div class="mb-3 mt-1">
                                            <label class="form-label" for="exampleFormControlInput">Company Name</label>
                                            <select class="form-multi-select" multiple data-coreui-search="true">
                                                <option value="1">CSL</option>
                                                <option value="2">GCTL</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="mb-3 mt-1">
                                            <label class="form-label" for="exampleFormControlInput">Approval Type</label>
                                            <select class="form-select" id="approval" data-choices="data-choices" data-options='{"removeItemButton":true,"placeholder":true}'>
                                                <option selected>Leave Approval</option>
                                                <option>Purchage Approval</option>
                                                <option>Loan Approval</option>
                                            </select>
                                        </div>
                                    </div>


                                    <!-- Second Div -->
                                    <div class="col-md-4">
                                        <div class="mb-3 mt-1">
                                            <label class="form-label" for="exampleFormControlInput">First Approvers</label>
                                            <select class="form-select" id="organizerSingle" data-choices="data-choices" data-options='{"removeItemButton":true,"placeholder":true}'>
                                                <option>Select</option>
                                                <option selected>CEO</option>A
                                                <option>Manager</option>
                                                <option>Team Lead</option>
                                            </select>
                                        </div>
                                    </div>

                                    <!-- First Div -->
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" id="flexSwitchCheckDefault1" type="checkbox" />
                                                <label class="form-check-label" for="flexSwitchCheckDefault1">Second Approvers</label>
                                            </div>
                                            <select class="form-select" id="organizerSingle1" disabled>
                                                <option value="">Select</option>
                                                <option value="ceo">CEO</option>
                                                <option value="manager">Manager</option>
                                                <option value="teamlead">Team Lead</option>
                                            </select>
                                        </div>
                                    </div>

                                    <!-- Second Div -->
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" id="flexSwitchCheckDefault2" type="checkbox" />
                                                <label class="form-check-label" for="flexSwitchCheckDefault2">Third Approvers</label>
                                            </div>
                                            <select class="form-select" id="organizerSingle2" disabled>
                                                <option value="">Select</option>
                                                <option value="ceo">CEO</option>
                                                <option value="manager">Manager</option>
                                                <option value="teamlead">Team Lead</option>
                                            </select>
                                        </div>
                                    </div>


                                    <!-- JavaScript Logic -->
                                    <script>
                                        document.addEventListener('DOMContentLoaded', function () {
                                          const firstCheckbox = document.getElementById('flexSwitchCheckDefault1');
                                          const secondCheckbox = document.getElementById('flexSwitchCheckDefault2');
                                          const firstSelect = document.getElementById('organizerSingle1');
                                          const secondSelect = document.getElementById('organizerSingle2');

                                          // Task 1: Enable first select when first checkbox is checked
                                          firstCheckbox.addEventListener('change', function () {
                                            firstSelect.disabled = !this.checked;
                                          });

                                          // Task 2: Enable second select only if first checkbox is checked
                                          secondCheckbox.addEventListener('change', function () {
                                            if (firstCheckbox.checked) {
                                              secondSelect.disabled = !this.checked;
                                            } else {
                                              alert('Please check the "Second Leave Approvers" first.');
                                              this.checked = false; // Prevent checking if first is not checked
                                            }
                                          });
                                        });
                                    </script>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex align-items-center justify-content-end">
                    <button type="reset" class="btn btn-outline-secondary  me-3">Reset</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>
