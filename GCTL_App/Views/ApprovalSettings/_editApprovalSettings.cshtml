<div class="modal fade" id="edit_approval_setting">
    <div class="modal-dialog modal-dialog-centered modal-md">
        <div class="modal-content p-3">
            <div class="modal-header">
                <h4 class="modal-title">Edit Approval</h4>
                <button type="button" class="btn-close custom-btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="aprovalSettingsFormEdit" asp-controller="ApprovalSettings" asp-action="Updates" method="post">
                <div class="border-bottom mb-3">
                    <div class="row">
                        <div class="col-md-12 d-flex">
                            <div class="flex-fill">
                                <div class="row">
                                    <!-- Company and Approval Type -->
                                    <div class="col-md-6">
                                        <div class="mb-3 mt-1">
                                            <label class="form-label">Organization Name</label>
                                            <select class="form-select choiceDD" id="OrganizationeEditID" name="OrganizationID" required>
                                                <option value="">Select Organization</option>
                                                @foreach (var org in ViewBag.Organizations)
                                                {
                                                    var isSelected = org.Selected ? "selected" : "";
                                                    <option value="@org.Value" selected="@isSelected">@org.Text</option>
                                                }
                                            </select>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="mb-3 mt-1">
                                            <label class="form-label">Approval Type</label>
                                            <select class="form-select choiceDD" id="ApprovalTypeEditID" name="ApprovalTypeID" required>
                                                <option value="">Select Approval Type</option>
                                                @foreach (var status in ViewBag.ApprovalTypes)
                                                {
                                                    <option value="@status.Value">@status.Text</option>
                                                }
                                            </select>
                                        </div>
                                    </div>


                                    <!-- Approver Sections (First, Second, Third Approver) -->
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <div class="row">
                                                <!-- First Approvers Checkbox -->
                                                <div class="form-check form-switch col-12 custom-padding-left">
                                                    <input class="form-check-input" id="chkFirstEdit" type="checkbox" required />
                                                    <label class="form-check-label" for="chkFirstEdit">First Approver</label>
                                                </div>
                                            </div>

                                            <!-- Select Dropdown (Below Checkbox) -->
                                            <div class="mt-3">
                                                <select class="form-select choiceDD" id="selFirstEdit" name="FirstApprovalID" required></select>

                                            </div>
                                        </div>
                                    </div>

                                    <!-- Second Approvers Section -->
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <div class="row">
                                                <!-- Second Approvers Checkbox -->
                                                <div class="form-check form-switch col-12 custom-padding-left">
                                                    <input class="form-check-input" id="chkSecondEdit" type="checkbox" name="IsEnableSecondApproval" />
                                                    <label class="form-check-label" for="chkSecondEdit">Second Approver</label>
                                                </div>
                                            </div>

                                            <!-- Select Dropdown (Below Checkbox) -->
                                            <div class="mt-3">
                                                <select class="form-select choiceDD" id="selSecondEdit" name="SecondApprovalID"></select>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Third Approvers Section -->
                                    <div class="col-md-4">
                                        <div class="mb-3">
                                            <div class="row">
                                                <!-- Third Approvers Checkbox -->
                                                <div class="form-check form-switch col-12 custom-padding-left">
                                                    <input class="form-check-input" id="chkThirdEdit" type="checkbox" name="IsEnableThirdApproval" />
                                                    <label class="form-check-label" for="chkThirdEdit">Third Approver</label>
                                                </div>
                                            </div>

                                            <!-- Select Dropdown (Below Checkbox) -->
                                            <div class="mt-3">
                                                <select class="form-select choiceDD" id="selThirdEdit" name="ThirdApprovalID"></select>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Checkbox for AllowSelfApproval (Initially hidden) -->
                                    <div class="col-md-4" id="selfApprovalEditSection">
                                        <div class="mb-3">
                                            <div class="row">
                                                <div class="form-check form-switch col-12 custom-padding-left">
                                                    <input class="form-check-input" type="checkbox" id="chkSelfApprovalEdit" name="AllowSelfApproval" />
                                                    <label class="form-check-label" for="chkSelfApprovalEdit">Allow Self-Approval</label>
                                                </div>
                                            </div>

                                            <!-- Select Dropdown (Below Checkbox) -->
                                            <div class="mt-3">
                                                <select class="form-select choiceDD"
                                                        id="selSelfApprovalEdit"
                                                        name="SelfExceptionApprovalID">
                                                    <option value="">Select Self Approver</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Form Buttons -->
                <div class="d-flex align-items-center justify-content-end">
                    <button type="reset" class="btn btn-outline-secondary me-2">Reset</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

