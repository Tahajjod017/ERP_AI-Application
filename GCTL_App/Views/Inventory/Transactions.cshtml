<div class="d-flex mb-3 pb-3">
    <span class="fa-stack me-2 ms-n1">
        <i class="fas fa-circle fa-stack-2x text-primary"></i>
        <i class="fa-inverse fa-stack-1x text-primary-subtle fas fa-exchange-alt" data-fa-transform="shrink-4"></i>
    </span>
    <div class="col">
        <h3 class="mb-0 text-primary position-relative fw-bold">
            <span class="bg-body pe-2">Transaction History</span>
            <span class="border border-primary position-absolute top-50 translate-middle-y w-100 start-0 z-n1"></span>
        </h3>
    </div>
</div>

<div class="px-4 px-lg-6 bg-body-emphasis rounded">
    <div class="mb-4">
        <div class="row g-3 justify-content-between align-items-end mb-4 mt-3">
            <div class="col-12 col-sm-auto">
                <div class="d-flex align-items-center flex-wrap">
                    <div class="me-3">
                        <select class="form-select choiceDD" id="locationFilter" asp-items="@ViewBag.Locations as SelectList">
                            <option value="">All Locations</option>
                        </select>
                    </div>
                    <div class="me-3">
                        <select class="form-select choiceDD" id="productFilter" asp-items="@ViewBag.Products as SelectList">
                            <option value="">All Products</option>
                        </select>
                    </div>
                    <div class="me-3">
                        <select class="form-select choiceDD" id="typeFilter">
                            <option value="">All Types</option>
                            <option value="IN">IN (Receive)</option>
                            <option value="OUT">OUT (Issue)</option>
                        </select>
                    </div>
                    <div class="me-3">
                        <input type="date" class="form-control" id="fromDate" placeholder="From Date">
                    </div>
                    <div class="me-3">
                        <input type="date" class="form-control" id="toDate" placeholder="To Date">
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-auto">
                <div class="d-flex align-items-center">
                    <div class="me-3">
                        <input class="form-control" id="searchInput" type="text" placeholder="Search">
                    </div>
                    <div class="dropdown me-3">
                        <div class="input-group">
                            <span class="input-group-text">Showing</span>
                            <select class="form-select" id="pageSizeSelect">
                                <option value="10">10</option>
                                <option value="25">25</option>
                                <option value="50">50</option>
                                <option value="100">100</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="table-responsive ms-n1 ps-1 scrollbar">
            <table class="table mb-0 table-borderless table-hover dyn-tableDrag InventoryTransactions" id="InventoryTransactions">
                <thead>
                    <tr>
                        <th class="sort white-space-nowrap align-middle" data-sort="TransactionDate">Date</th>
                        <th class="sort white-space-nowrap align-middle" data-sort="TransactionType">Type</th>
                        <th class="sort white-space-nowrap align-middle" data-sort="ProductName">Product</th>
                        <th class="sort white-space-nowrap align-middle" data-sort="LocationName">Location</th>
                        <th class="sort white-space-nowrap align-middle text-end" data-sort="Quantity">Qty</th>
                        <th class="sort white-space-nowrap align-middle text-end" data-sort="UnitCost">Unit Cost</th>
                        <th class="sort white-space-nowrap align-middle text-end" data-sort="BalanceAfter">Balance After</th>
                        <th class="sort white-space-nowrap align-middle" data-sort="ReferenceType">Reference</th>
                        <th class="sort white-space-nowrap align-middle">Note</th>
                        <th class="sort white-space-nowrap align-middle" data-sort="CreatedByName">By</th>
                    </tr>
                </thead>
                <tbody class="list" id="transactions-table-body"></tbody>
            </table>
        </div>

        <div class="d-flex flex-wrap align-items-center justify-content-between py-3 pe-0 fs-9">
            <p class="mb-0" data-list-info="list-info"></p>
            <div class="d-flex">
                <button class="page-link" id="prevBtn"><span class="fas fa-chevron-left"></span></button>
                <ul class="mb-0 pagination" id="pagination"></ul>
                <button class="page-link pe-0" id="nextBtn"><span class="fas fa-chevron-right"></span></button>
            </div>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
@section Scripts {
    <script src="~/js/pages/POS/Inventory/inventoryTransactions.js"></script>
}