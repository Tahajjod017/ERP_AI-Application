<div class="d-flex mb-3 pb-3">
    <span class="fa-stack me-2 ms-n1">
        <i class="fas fa-circle fa-stack-2x text-primary"></i>
        <i class="fa-inverse fa-stack-1x text-primary-subtle fas fa-warehouse" data-fa-transform="shrink-4"></i>
    </span>
    <div class="col">
        <h3 class="mb-0 text-primary position-relative fw-bold">
            <span class="bg-body pe-2">Inventory Stock</span>
            <span class="border border-primary position-absolute top-50 translate-middle-y w-100 start-0 z-n1"></span>
        </h3>
    </div>

    <div class="justify-content-end">
        <a href="/Inventory/Adjustment" class="btn btn-phoenix-primary">
            @Html.SmartLocalize("Stock Adjustment")
        </a>
    </div>

</div>

<div class="px-4 px-lg-6 bg-body-emphasis rounded">
    <div class="mb-4">
        <div class="row g-3 justify-content-between align-items-end mb-4 mt-3">
            <div class="col-12 col-sm-auto">
                <div class="d-flex align-items-center">
                    <div class="me-3">
                        <div class="columnDrag InventoryStock"></div>
                    </div>
                    <div class="dropdown me-3">
                        <select class="form-select choiceDD" id="locationFilter" asp-items="@ViewBag.Locations as SelectList">
                            <option value="">All Locations</option>
                        </select>
                    </div>
                    <div class="dropdown me-3">
                        <select class="form-select choiceDD" id="productTypeFilter" asp-items="@ViewBag.ProductTypes as SelectList">
                            <option value="">All Product Types</option>
                        </select>
                    </div>
                    <div class="form-check me-3">
                        <input class="form-check-input" type="checkbox" id="lowStockOnlyFilter" />
                        <label class="form-check-label" for="lowStockOnlyFilter">
                            Low Stock Only
                        </label>
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-auto">
                <div class="d-flex align-items-center">
                    <div class="me-3">
                        <input class="form-control" id="searchInput" type="text" placeholder="Search">
                    </div>
                    <div class="dropdown me-3">
                        <div class="input-group">
                            <span class="input-group-text">Showing</span>
                            <select class="form-select" id="pageSizeSelect">
                                <option value="10">10</option>
                                <option value="25">25</option>
                                <option value="50">50</option>
                                <option value="100">100</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="table-responsive ms-n1 ps-1 scrollbar">
            <table class="table mb-0 table-borderless table-hover dyn-tableDrag InventoryStock" id="InventoryStock">
                <thead>
                    <tr>
                        <th class="sort white-space-nowrap align-middle ps-0" data-sort="ProductName">Product</th>
                        <th class="sort white-space-nowrap align-middle ps-2" data-sort="ProductType">Type</th>
                        <th class="sort white-space-nowrap align-middle ps-2" data-sort="Brand">Brand</th>
                        <th class="sort white-space-nowrap align-middle ps-2" data-sort="LocationName">Location</th>
                        <th class="sort white-space-nowrap align-middle ps-2" data-sort="Quantity">Quantity</th>
                        <th class="sort white-space-nowrap align-middle ps-2" data-sort="ReservedQuantity">Reserved</th>
                        <th class="sort white-space-nowrap align-middle ps-2" data-sort="AvailableQuantity">Available</th>
                        <th class="sort white-space-nowrap align-middle ps-2" data-sort="MinimumQuantity">Min</th>
                        <th class="sort white-space-nowrap align-middle ps-2" data-sort="TotalValue">Value</th>
                        <th class="align-middle text-end" style="width:100px;">Action</th>
                    </tr>
                </thead>
                <tbody class="list" id="inventory-stock-table"></tbody>
            </table>
        </div>

        <div class="d-flex flex-wrap align-items-center justify-content-between py-3 pe-0 fs-9">
            <p class="mb-0" data-list-info="list-info"></p>
            <div class="d-flex">
                <button class="page-link" id="prevBtn"><span class="fas fa-chevron-left"></span></button>
                <ul class="mb-0 pagination" id="pagination"></ul>
                <button class="page-link pe-0" id="nextBtn"><span class="fas fa-chevron-right"></span></button>
            </div>
        </div>
    </div>
</div>

<!-- View Product Stock Modal -->
<div class="modal fade" id="viewStockModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header  border-0">
                <h5 class="modal-title">Product Stock by Location</h5>
                <button class="btn btn-close p-1" type="button" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <h6 class="mb-3" id="modal_ProductName"></h6>
                <div class="table-responsive">
                    <table class="table table-borderless table-hover table-sm">
                        <thead>
                            <tr>
                                <th>Location</th>
                                <th>Quantity</th>
                                <th>Reserved</th>
                                <th>Available</th>
                            </tr>
                        </thead>
                        <tbody id="modal_LocationsTable"></tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer  border-0">
                <button class="btn btn-outline-primary" type="button" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
@section Scripts {
   
    <script src="~/js/pages/POS/Inventory/inventoryStock.js"></script>
}
