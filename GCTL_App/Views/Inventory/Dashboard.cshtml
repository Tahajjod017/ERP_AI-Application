@model GCTL.Core.ViewModels.POS.Inventory.InventoryDashboardViewModel

<div class="d-flex mb-3 pb-3">
    <span class="fa-stack me-2 ms-n1">
        <i class="fas fa-circle fa-stack-2x text-primary"></i>
        <i class="fa-inverse fa-stack-1x text-primary-subtle fas fa-chart-line" data-fa-transform="shrink-4"></i>
    </span>
    <div class="col">
        <h3 class="mb-0 text-primary position-relative fw-bold">
            <span class="bg-body pe-2">Inventory Dashboard</span>
            <span class="border border-primary position-absolute top-50 translate-middle-y w-100 start-0 z-n1"></span>
        </h3>
    </div>
</div>

<!-- Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="card h-100 bg-primary-subtle border-0">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="text-muted mb-2">Total Stock Value</h6>
                        <h2 class="mb-0 text-primary">৳<span id="totalStockValue">@Model.TotalStockValue.ToString("N2")</span></h2>
                    </div>
                    <div class="fs-3 text-primary">
                        <i class="fas fa-dollar-sign"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card h-100 bg-info-subtle border-0">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="text-muted mb-2">Total Products</h6>
                        <h2 class="mb-0 text-info"><span id="totalProducts">@Model.TotalProducts</span></h2>
                    </div>
                    <div class="fs-3 text-info">
                        <i class="fas fa-boxes"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card h-100 bg-warning-subtle border-0">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="text-muted mb-2">Low Stock Items</h6>
                        <h2 class="mb-0 text-warning"><span id="lowStockItems">@Model.LowStockItems</span></h2>
                    </div>
                    <div class="fs-3 text-warning">
                        <i class="fas fa-exclamation-triangle"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card h-100 bg-danger-subtle border-0">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="text-muted mb-2">Out of Stock</h6>
                        <h2 class="mb-0 text-danger"><span id="outOfStockItems">@Model.OutOfStockItems</span></h2>
                    </div>
                    <div class="fs-3 text-danger">
                        <i class="fas fa-times-circle"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Charts and Tables -->
<div class="row g-3 mb-4">
    <!-- Stock by Location Chart -->
    <div class="col-xl-6">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="mb-0">Stock by Location</h5>
            </div>
            <div class="card-body">
                <canvas id="stockByLocationChart" height="300"></canvas>
            </div>
        </div>
    </div>

    <!-- Recent Transactions -->
    <div class="col-xl-6">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Recent Transactions</h5>
                <a href="/Inventory/Transactions" class="btn btn-sm btn-phoenix-primary">View All</a>
            </div>
            <div class="card-body">
                <div class="table-responsive" style="max-height: 300px; overflow-y: auto;">
                    <table class="table table-borderless table-hover table-sm">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Type</th>
                                <th>Product</th>
                                <th>Qty</th>
                            </tr>
                        </thead>
                        <tbody id="recentTransactionsBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Low Stock Alerts and Top Products -->
<div class="row g-3">
    <!-- Low Stock Alerts -->
    <div class="col-xl-6">
        <div class="card">
            <div class="card-header bg-warning-subtle">
                <h5 class="mb-0 text-warning">
                    <i class="fas fa-exclamation-triangle me-2"></i>Low Stock Alerts
                </h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-borderless table-hover table-sm">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Location</th>
                                <th>Current</th>
                                <th>Min</th>
                                <th>Shortage</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.LowStockAlerts != null && Model.LowStockAlerts.Any())
                            {
                                @foreach (var item in Model.LowStockAlerts)
                                {
                                    <tr>
                                        <td>@item.ProductName</td>
                                        <td>@item.LocationName</td>
                                        <td class="text-danger fw-bold">@item.CurrentQuantity</td>
                                        <td>@item.MinimumQuantity</td>
                                        <td class="text-danger">@item.Shortage</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted">No low stock items</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Top Products by Value -->
    <div class="col-xl-6">
        <div class="card">
            <div class="card-header bg-success-subtle">
                <h5 class="mb-0 text-success">
                    <i class="fas fa-trophy me-2"></i>Top Products by Value
                </h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-borderless table-hover table-sm">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Quantity</th>
                                <th>Value</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.TopProductsByValue != null && Model.TopProductsByValue.Any())
                            {
                                @foreach (var item in Model.TopProductsByValue)
                                {
                                    <tr>
                                        <td>@item.ProductName</td>
                                        <td>@item.Quantity</td>
                                        <td class="fw-bold">৳@item.Value.ToString("N2")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="3" class="text-center text-muted">No data available</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
@section Scripts {
    
    <script src="~/js/pages/POS/Inventory/inventoryDashboard.js"></script>
}
