<div class="modal fade" id="new_resignation">
    <div class="modal-dialog modal-dialog-centered modal-md">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">Add Resignation</h4>
                <button type="button" class="btn-close custom-btn-close" data-bs-dismiss="modal" aria-label="Close">
                </button>
            </div>
            <form action="resignation.html">
                <div class="modal-body pb-0">
                    <div class="row">

                        <div class="col-md-12">
                            <div class="mb-3">
                                <label class="form-label" for="organizerSingleCompany">Company</label>
                                <select class="form-select choiceDD" id="company" asp-items="@ViewBag.OrganizationDD">
                                </select>
                            </div>
                        </div>

                        <div class="col-md-12">
                            <div class="mb-3">
                                <label class="form-label">Resigning Employee</label>
                                <select class="form-select choiceDD" id="employeeId" asp-items="@ViewBag.EmployeeDD">
                                </select>
                            </div>
                        </div>


                        <div class="col-md-12">
                            <div class="mb-3 position-relative">
                                <div class="content-head d-flex justify-content-between align-items-center">
                                    <label class="form-label">@Html.SmartLocalize("Notice Date")</label>
                                    <div class="form-check form-switch">
                                    </div>
                                </div>
                                <div class="position-relative">
                                    <input class="form-control datetimepicker" id="noticeDate" type="text" placeholder="dd/mm/yyyy"
                                           data-options='{"disableMobile":true,"dateFormat":"d/m/Y"}' style="padding-left: 30px;" />
                                    <span class="uil uil-calendar-alt flatpickr-icon text-body-tertiary position-absolute"
                                          style="top: 50%; left: 10px; transform: translateY(-50%); cursor: pointer;"></span>
                                </div>
                            </div>
                        </div>



                        <div class="col-md-12">
                            <div class="mb-3 position-relative">
                                <div class="content-head d-flex justify-content-between align-items-center">
                                    <label class="form-label">@Html.SmartLocalize("Resignation Date")</label>
                                    <div class="form-check form-switch">
                                    </div>
                                </div>
                                <div class="position-relative">
                                    <input class="form-control datetimepicker" id="resignationDate" type="text" placeholder="dd/mm/yyyy"
                                           data-options='{"disableMobile":true,"dateFormat":"d/m/Y"}' style="padding-left: 30px;" />
                                    <span class="uil uil-calendar-alt flatpickr-icon text-body-tertiary position-absolute" style="top: 50%; left: 10px; transform: translateY(-50%); cursor: pointer;"></span>
                                </div>
                            </div>
                        </div>



                        <div class="col-md-12">
                            <div class="mb-3">
                                <label class="form-label">Reason</label>
                                <textarea class="form-control" rows="3"></textarea>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-white border me-2" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Add Resignation</button>
                </div>
            </form>
        </div>
    </div>
</div>





