@model GCTL_App.ViewModels.AttendanceManagement.ScheduleManagement.AssignSpiralPattern.AssignSpiralPatternPageVM

@section Styles {
    <style>

        #hiddenDiv {
            display: none; /* Initially hidden */
        }

        #div2 {
            display: none;
        }

        .disabled {
            pointer-events: none;
            opacity: 0.5;
        }

        .shift-cell {
            position: relative;
        }

        .day-block {
            background: repeating-linear-gradient( 135deg, #e5e5e5, #e5e5e5 10px, #f7f7f7 10px, #f7f7f7 20px );
            border-radius: .4rem;
            padding: 5px 0 5px 0;
        }

        .add-shift-btn {
            display: none;
            align-items: center;
        }

        .shift-cell:hover .add-shift-btn {
            display: block;
            background-color: white;
            color: black;
            margin: 5px auto;
        }

        .add-shift-btn2 {
            display: none;
            align-items: center;
        }

        .startTime:hover .add-shift-btn2 {
            display: block;
            background-color: white;
            color: black;
            margin: 5px;
        }

        .table-container {
            display: none; /* Hide all tables by default */
        }

    </style>
}

<partial name="_Form" model="Model.Create" />
<partial name="_Table" />
<partial name="_EditSpiralPattern" model="Model.Edit" />
<partial name="_SpiralPatternDetails" />
<partial name="_ConfirmDelete" />

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
	<script src="~/js/pages/attendancemanagement/schedulemanagement/assignspiralpattern.js"></script>
    <script>
        $(function () {
            var options = {
                baseUrl: '@Url.Action("", "AssignSpiralPattern")'
            };
            options.load = () => { };
            $.assignSpiralPattern(options);
        });
    </script>
}