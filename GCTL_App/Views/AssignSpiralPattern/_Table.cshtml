@{
    var tblDepartments = ViewBag.DepartmentDD as List<GCTL.Core.ViewModels.CommonSelectVM>;
    var tblEmployees = ViewBag.EmployeeList as List<GCTL.Core.ViewModels.CommonSelectVM>;
    var tblSpiralPatterns = ViewBag.SpiralPatternDD as List<GCTL.Core.ViewModels.CommonSelectVM>;
}

<div class="mb-5 mt-3">
    <div class="card">
        <div class="card-header row-gap-3">
            <h4 class="mb-2">Assigned Employee Spiral Pattern List</h4>
            
            <div class="row">
                <div class="col">
                    <select class="form-select" id="TblOrganizationID" asp-items="@ViewBag.OrganizationDD as SelectList" data-choices="data-choices" data-options='{"removeItemButton":true,"placeholder":true}'>
                        <option value="">@Html.SmartLocalize("Select Organization")...</option>
                    </select>
                </div>

                <div class="col">
                    <select class="form-multi-select" id="TblDepartmentID" 
                        multiple data-coreui-selection-type="counter" 
                        data-coreui-placeholder="@Html.SmartLocalize("Select Department")..."
                        data-coreui-search="true">
                        @foreach (var group in tblDepartments.GroupBy(e => e.GroupName))
                        {
                            <optgroup label="@group.Key">
                                @foreach (var emp in group)
                                {
                                    <option value="@emp.Id">@emp.Name</option>
                                }
                            </optgroup>
                        }
                    </select>
                </div>

                <div class="col">
                    <select class="form-multi-select" id="EmployeeID" 
                        multiple data-coreui-selection-type="counter" 
                        data-coreui-placeholder="@Html.SmartLocalize("Select Employee")..."
                        data-coreui-search="true">
                        @foreach (var group in tblEmployees.GroupBy(e => e.GroupName))
                        {
                            <optgroup label="@group.Key">
                                @foreach (var emp in group)
                                {
                                    <option value="@emp.Id">@emp.Name</option>
                                }
                            </optgroup>
                        }
                    </select>
                </div>

                <div class="col">
                    <select class="form-select" id="TblSpiralPatternTypeID" asp-items="@ViewBag.SpiralPatternTypeDD" data-choices="data-choices" data-options='{"removeItemButton":true,"placeholder":true}'>
                        <option value="">@Html.SmartLocalize("Select Spiral Patern Type")...</option>
                    </select>
                </div>

                <div class="col">
                    <select class="form-select" id="TblSpiralPatternID" data-choices="data-choices" data-options='{"removeItemButton":true,"placeholder":true}'>
                        <option value="">@Html.SmartLocalize("Select Spiral Patern")...</option>
                        @foreach (var group in tblSpiralPatterns.GroupBy(e => e.GroupName))
                        {
                            <optgroup label="@group.Key">
                                @foreach (var emp in group)
                                {
                                    <option value="@emp.Id">@emp.Name</option>
                                }
                            </optgroup>
                        }
                    </select>
                </div>
            </div>
        </div>

        <div class="border-translucent p-3">
            <div class="row g-3 justify-content-between align-items-end mb-4">
                <div class="col-12 col-sm-auto">
                    <div class="d-flex align-items-center me-3" style="width: auto;">
                        <span class="ms-2">@Html.SmartLocalize("Showing"):</span> &nbsp;
                        <div style="width: 100%;">
                            <select id="assignSpiralPattern-pageSizeSelect" class="form-select form-select-sm" tabindex="10">
                                <option class="dropdown-item" value="5">@Html.SmartLocalize("5")</option>
                                <option class="dropdown-item" value="10">@Html.SmartLocalize("10")</option>
                                <option class="dropdown-item" value="25">@Html.SmartLocalize("25")</option>
                                <option class="dropdown-item" value="50">@Html.SmartLocalize("50")</option>
                                <option class="dropdown-item" value="100">@Html.SmartLocalize("100")</option>
                                <option class="dropdown-item" value="0">@Html.SmartLocalize("All")</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-sm-auto">
                    <div class="d-flex align-items-center">
                        <div class="d-none me-3" id="assignSpiralPattern-bulkSelectActions">
                            <div class="position-relative">
                                <button type="button" class="btn btn-phoenix-danger btn-sm ms-2" id="assignSpiralPattern-delSel">@Html.SmartLocalize("Delete")</button>
                            </div>
                        </div>

                        <div class="search-box me-3" id="assignSpiralPattern-searchBox">
                            <form class="position-relative" id="assignSpiralPattern-searchForm">
                                <input class="form-control search-input search" id="assignSpiralPattern-searchInput" type="search" placeholder="@Html.SmartLocalize("Search here")" aria-label="Search" />
                                <span class="fas fa-search search-box-icon"></span>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <div class="table-responsive scrollbar mx-n1 px-1">
                <table class="table table-bordered table-sm fs-9 leads-table">
                    <thead>
                        <tr>
                            <th class="sort align-middle ps-3 text-uppercase text-nowrap" data-sort="OrganizationName">@Html.SmartLocalize("Organization Name")</th>
                            <th class="sort align-middle ps-3 text-uppercase text-nowrap" data-sort="ShiftName">@Html.SmartLocalize("Department Name")</th>
                            <th class="sort align-middle ps-3 text-uppercase text-nowrap" data-sort="EmployeeName">@Html.SmartLocalize("Employee Name")</th>
                            <th class="sort align-middle ps-3 text-uppercase text-nowrap" data-sort="SpiralPatternTypeName">@Html.SmartLocalize("Spiral Pattern Type")</th>
                            <th class="sort align-middle ps-3 text-uppercase text-nowrap" data-sort="SpiralPatternName">@Html.SmartLocalize("Spiral Pattern Name")</th>
                            <th class="sort align-middle ps-3 text-uppercase text-nowrap" data-sort="StartDate">@Html.SmartLocalize("Start Date")</th>
                            <th class="sort align-middle ps-3 text-uppercase text-nowrap" data-sort="EndDate">@Html.SmartLocalize("End Date")</th>
                            <th class="align-middle ps-3 text-uppercase text-nowrap">@Html.SmartLocalize("Action")</th>
                        </tr>
                    </thead>
                    <tbody id="assignSpiralPattern-tBody">
                        @* <tr class="hover-actions-trigger btn-reveal-trigger position-static">

                            <td class="compName align-middle white-space-nowrap fw-semibold text-body py-2 ps-3">
                                <h5>GCTL</h5>
                            </td>
                            <td class="deptName align-middle white-space-nowrap fw-semibold text-body py-2 ps-3">
                                <h5>Developer</h5>
                            </td>
                            <td class="empName align-middle white-space-nowrap fw-semibold text-body py-2 ps-3">
                                <h5>Md. Hasan</h5>
                            </td>
                            <td class="rosterName align-middle white-space-nowrap  fw-semibold text-body py-1 ps-3">
                                <span>Weekly</span>
                            </td>
                            <td class="rosterName align-middle white-space-nowrap  fw-semibold text-body py-1 ps-3">
                                <a href="#" class="nav-item mx-2 text-decoration-none" data-bs-toggle="modal" data-bs-target="#spiral_pattern_details">
                                    <span>Spiral Pattern 1</span>
                                </a>
                            </td>

                            <td class="endDate py-1 ps-3">01 jan 2025</td>
                            <td class="endDate py-1 ps-3">01 jan 2026</td>

                            <td class="align-middle white-space-nowrap text-end pe-0 ps-3">
                                <div class="btn-reveal-trigger position-static">
                                    <a href="#" class="text-decoration-none nav-item mx-2" data-bs-toggle="modal" data-bs-target="#edit_spiral_pattern">
                                        <i class="fas fa-edit text-success"></i>
                                    </a>
                                    <a href="#" class="text-decoration-none nav-item mx-2" data-bs-toggle="modal" data-bs-target="#cancel_modal">
                                        <i class="fas fa-x text-danger"></i>
                                    </a>
                                </div>
                            </td>
                        </tr> *@
                    </tbody>
                </table>
            </div>

            <div class="d-flex flex-wrap align-items-center justify-content-between py-3 pe-0 fs-9 border-bottom border-translucent">
                <div class="d-flex">
                    <p class="mb-0 d-none d-sm-block me-3 fw-semibold text-body" id="assignSpiralPattern-paginationInfo">
                        @Html.SmartLocalize("Showing") <span id="startItem"></span>
                        @Html.SmartLocalize("to") <span id="endItem"></span>
                        @Html.SmartLocalize("Items of") <span id="totalItems"></span>
                    </p>

                    <p class="mb-0 d-none d-sm-block me-3 fw-semibold text-body" data-list-info="data-list-info"></p>
                </div>
                <div class="d-flex">
                    <button class="page-link" data-list-pagination="prev" id="assignSpiralPattern-prevPageBtn"><span class="fas fa-chevron-left"></span></button>
                    <ul class="mb-0 pagination" id="assignSpiralPattern-paginationLinks"></ul>
                    <button class="page-link pe-0" data-list-pagination="next" id="assignSpiralPattern-nextPageBtn"><span class="fas fa-chevron-right"></span></button>
                </div>
            </div>
        </div>
    </div>
</div>