@{
    var employeeId = ViewBag.EmployeeId;
    DateTime date = DateTime.Now;
}
<div class="mb-9 mt-1">
    @* <button type="button" id="PaySlipSave" class="btn-outline-info">Pay Slip Save</button> *@
    <div class="card p-4">
        <div class="invoice-wrapper">
            <div class="d-flex justify-content-center">
                <span class="h4">Payslip for the month of @date.ToString("MMMM yyyy")</span>
            </div>
            <input id="EmployeeID"  type="hidden" />
            <div class="payment-info">
                <div class="row border-bottom">
                    <div class="col-sm-6 mb-3">
                        <span>Payslip No.</span><strong id="paySlipNo">0001</strong>
                    </div>
                    <div class="col-sm-6 text-end">
                        <span>Payment Date</span>
                        <strong id="paymentDateTime"></strong>
                       @*  <strong>@date.ToString("MMM dd, yyyy - hh:mm tt")</strong> *@
                    </div>
                </div>
            </div>
            <div class="payment-details mt-3">
                <div class="row">
                    <div class="col-sm-6">
                        <img id="orgLogo" class="mb-2" width="26px">
                        <strong id="OrganizationName"> </strong>
                        <p id="OrganizationAddress">
                        </p>
                    </div>
                    <div class="col-sm-6 text-end">
                        <span>Payment To</span>
                        <strong id="empName"></strong>
                        <p id="empAddress">

                        </p>
                    </div>
                </div>
            </div>
            <div class="line-items">
                <div class="row">
                    <div class="col-sm-6">
                        <div>
                            <p class="extra-notes"><strong>Earnings</strong></p>
                            <table class="table table-bordered">
                                <tbody class="">
                                    <tr>
                                        <td>
                                            <strong class="ms-2">Basic</strong>
                                            <span class=" me-2 float-end" id="BasicSalary"></span>
                                        </td>
                                    </tr>

                                <tbody id="allowanceTable"></tbody>

                                <tbody id="benefitTable"></tbody>
                                <tr>
                                    <td>
                                        <strong class="ms-2">Total Earnings</strong><span class="me-2 float-end"><strong id="TotalSalary"></strong></span>
                                    </td>
                                </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="col-sm-6">
                        <div>
                            <p class="extra-notes"><strong>Deductions</strong></p>
                            <table class="table table-bordered ">
                                <tbody class="me-2">
                                    <tr>
                                        <td>
                                            <strong class="ms-2">Provident Fund</strong><span class="me-2 float-end">0.00</span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <strong class="ms-2">Professional Tax</strong><span class="me-2 float-end" id="ProfessionalTax">0.00</span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <strong class="ms-2">ESI</strong><span class="me-2 float-end">0.00</span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <strong class="ms-2">Home Loan</strong><span class="me-2 float-end">0.00</span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <strong class="ms-2">TDS</strong><span class="me-2 float-end">0.00</span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <strong class="ms-2">Total Deductions</strong><span class="me-2 float-end"><strong id="TotalDeductions">0.00</strong></span>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="col-sm-12">
                        <div class="col-sm-12">
                            <span class="fw-bold" id="NetPay">Net Pay :</span><br><br><span id="SalaryInWords">Eight Thousand Five Hundred Fifty Two Only</span>
                        </div>
                    </div>
                </div>
                <div class="d-flex justify-content-end">
                    <div class="d-flex flex-column mt-2">
                        <span class="fw-bolder">For Priya Jain</span><span class="mt-4">Authorised Signatory</span>
                    </div>
                </div>
                <div class="print">
                    <a href="#"><i class="fa fa-print"></i> Print this receipt</a>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="~/js/pages/payrollmanagements/PayRollPolicy/PaySlipForEmp.js"></script>

}