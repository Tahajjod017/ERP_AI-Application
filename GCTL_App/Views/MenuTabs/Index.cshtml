@model GCTL_App.ViewModels.MenuTab.MenuTabPageVM

@{
    ViewData["Title"] = "Menu Tab";
}

<nav class="mb-3 crm-deals-breadcrumb" aria-label="breadcrumb">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item active"><h3 class="text-body-emphasis">@ViewData["Title"]</h3></li>
    </ol>
</nav>

<div class="row">
    <div class="col-12">
        <div class="mx-n4 px-4 mx-lg-n6 px-lg-6 bg-body-emphasis border-top">

        </div>
    </div>
</div>

<div class="mt-4 mx-lg-n4">
    <div class="row g-4">
        <div class="col-12 col-md-7 col-xl-5 col-xxl-5">
            <partial name="_Form" model="Model.Setup" />
        </div>

        <div class="col-12 col-md-7 col-xl-7 col-xxl-7">
            @* <partial name="_Table" model="Model.List" /> *@
            <partial name="_Table" model="Model.List" />
        </div>

    </div>
</div>

<partial name="_ConfirmDelete" />


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/js/pages/menutab/menutabs.js"></script>
    <script type="text/javascript">
        $(function () {
            var options = {
                baseUrl: '@Url.Action("", "MenuTabs")'
            };
            options.load = () => {

            };

            $.menutabs(options);
        });
    </script>
}