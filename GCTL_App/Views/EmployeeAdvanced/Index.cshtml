@model GCTL.Core.ViewModels.FieldServices.EmployeeAdvancedVM

@{
	ViewData["Title"] = "Employee Advanced";
}

<div class="card">
	<div class="card-header">
		<h3>Employee  Advanced</h3>
	</div>
	<div class="card-body">
		<div class="row col-md-12">
			
			<form asp-controller="EmployeeAdvanced" id="formClear" asp-action="Create">
				<input hidden asp-for="EmployeeAdvanceID"value=0 />
				<div class="modal-body pb-0">
					<div class="row mt-3">

						<div class="col-md-6">
							<div class="mb-3">
								<label class="form-label req" asp-for="CustomerID2">Client Name</label>
								<select asp-for="CustomerID2"></select>
								<span asp-validation-for="CustomerID2" class="text-danger"></span>
							</div>
						</div>

						<div class="col-md-3 ">
							<div class="mb-3">
								<label class="form-label req" asp-for="JobID">Job Name</label>
								<select asp-for="JobID" class="form-select" asp-items="ViewBag.JobTypesDD" desable>
								</select>
								<span asp-validation-for="JobID" class="text-danger"></span>
							</div>
						</div>
						<div class="col-md-3">
							<div class="mb-3">
								<label class="form-label" for="organizerMultiple">Job Type</label>
								<select asp-for="RequestedByUserID" class="form-select"multiple="multiple" asp-items="ViewBag.JobTypesDDD"></select>
								<span asp-validation-for="RequestedByUserID" class="text-danger"></span>
							</div>
						</div>

						<div class="col-md-6">
							<div class="mb-3">
								<label class="form-label form-switch req" for="exampleFormControlInput">
									Advanced Received By
									<label class="form-check-label ms-5" for="flexSwitchCheckDefault">Self</label>
									<input class="form-check-input ms-2" id="toggleCheckbox" type="checkbox" />
									<label class="form-check-label ms-2" for="flexSwitchCheckDefault">Group</label>

								</label>

								<select asp-for="ApprovedByUserID" class="form-select  approvedBySelect initSelectEmpAD"
										asp-items="ViewBag.EmployeeDD">
									<!--Advanced Recieved by-->
									<span asp-validation-for="ApprovedByUserID"></span>
								</select>
							</div>
						</div>

						<div class="col-md-6" id="hiddenDiv2">
							<div class="mb-3">
								<label class="form-label" for="exampleFormControlInput">Other Employees Name</label>
								<select asp-for="GroupEmployeeID" class="form-select initSelectEmpAD" multiple="multiple" asp-items="ViewBag.EmployeeDD">
								</select>
							</div>
						</div>


						@* <div id="dateSection" style="display:none;"> *@
						<div class="col-md-6">
							<div class="mb-3">
								<label class="form-label" asp-for="StartDate">From Date</label>
								<input class="form-control" asp-for="StartDate" type="date" />
							</div>
						</div>
						@* </div> *@
						<div class="col-md-6">
							<div class="mb-3">
								<label class="form-label" asp-for="EndDate">To Date</label>
								<input class="form-control" asp-for="EndDate" type="date" />
							</div>
						</div>

						<div class="col-md-6">
							<div class="mb-3">
								<label class="form-label" asp-for="AmountRequested">Amount</label>
								<input class="form-control" asp-for="AmountRequested" type="number" />
							</div>
						</div>
					</div>
				</div>
				<div class="modal-footer">
					<button type="button" id="cancleBtn" class="btn btn-light me-2" data-bs-dismiss="modal">Cancel</button>
					<button type="submit" id="saveBtn" class="btn btn-primary">Send for Approval</button>
				</div>
			</form>
		</div>
	</div>
</div>

<div class="card mt-4">
	<div class="card-header mb-4">
		<div class="d-flex justify-content-between mb-3">
			<h4 class="mb-1">Advance Payment List</h4>
		</div>

		<div class="d-flex my-xl-auto right-content align-items-center flex-wrap row-gap-3">

			<div class="dropdown me-2">
				<select class="form-select" id="organizerSingle">
					<option value="">Select Company...</option>
					
				</select>
			</div>

			@* <div class="dropdown me-2">
                <select asp-for="ApprovalSettingID" class="form-select"
                        asp-items="ViewBag.ApprovalStatus">

                </select>
            </div> *@

			<div class="dropdown me-2">
				<select class="form-select">
					<option value="">Select Project</option>
					
				</select>
			</div>
		</div>
	</div>

	<div class="border-translucent p-3">
		<div class="row g-3 justify-content-between align-items-end mb-4">
			<div class="col-12 col-sm-auto">
				<div class="d-flex align-items-center me-3" style="width: auto;">
					<span class="ms-2">@Html.SmartLocalize("Showing"):</span> &nbsp;
					<div style="width: 100%;">
						<select id="empAdvanced-pageSizeSelect" class="form-select form-select-sm" tabindex="10">
							<option class="dropdown-item" value="5">@Html.SmartLocalize("5")</option>
							<option class="dropdown-item" value="10">@Html.SmartLocalize("10")</option>
							<option class="dropdown-item" value="25">@Html.SmartLocalize("25")</option>
							<option class="dropdown-item" value="50">@Html.SmartLocalize("50")</option>
							<option class="dropdown-item" value="100">@Html.SmartLocalize("100")</option>
						</select>
					</div>
				</div>
			</div>

			<div class="col-12 col-sm-auto">
				<div class="d-flex align-items-center">
					<div class="d-none me-3" id="empAdvanced-bulkSelectActions">
						<div class="position-relative">
							<button type="button" class="btn btn-phoenix-danger btn-sm ms-2" id="empAdvanced-bulkDelBtn">@Html.SmartLocalize("Delete")</button>
						</div>
					</div>

					<div class="search-box me-3" id="empAdvanced-searchBox">
						<form class="position-relative" id="empAdvanced-searchForm">
							<input class="form-control search-input search" id="empAdvanced-searchInput" type="search" placeholder="@Html.SmartLocalize("Search here")" aria-label="Search" />
							<span class="fas fa-search search-box-icon"></span>
						</form>
					</div>
				</div>
			</div>
		</div>

		<div class="table-responsive scrollbar mx-n1 px-1">
			<table class="table table-sm fs-9 leads-table">
				<thead>
					<tr>
						<th class="pe-5 align-start" scope="col" style="width: 5%;">
							<input type="checkbox" class="form-check-input addEmpCheck-selectedItem" id="empAdvanced-check-all" />
						</th>
						<th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="empId">Receiving Employee</th>
						<th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="empName">Client Name</th>
						<th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="empDept">Project Name</th>
						<th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="empDept">Project Type</th>
						<th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="empSalary">Advanced <br> Ammount</th>
						<th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="empBonus">Other Members</th>
						<th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="empDeduction">Status</th>
						<th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="netSalary">Approved <br> Person</th>
						<th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="paySlip">Date</th>
						<th class="align-middle white-space-nowrap ps-0 text-uppercase" scope="col" style="width: 5%;">@Html.SmartLocalize("Action")</th>
					</tr>
				</thead>
				<tbody id="empAdvanced-tBody">
					
				</tbody>
			</table>
		</div>

		<div class="d-flex flex-wrap align-items-center justify-content-between py-3 pe-0 fs-9 border-bottom border-translucent">
			<div class="d-flex">
				<p class="mb-0 d-none d-sm-block me-3 fw-semibold text-body" id="empAdvanced-paginationInfo"></p>

				<p class="mb-0 d-none d-sm-block me-3 fw-semibold text-body" data-list-info="data-list-info"></p>
			</div>
			<div class="d-flex">
				<button class="page-link" data-list-pagination="prev" id="empAdvanced-prevPageBtn"><span class="fas fa-chevron-left"></span></button>
				<ul class="mb-0 pagination" id="empAdvanced-paginationLinks"></ul>
				<button class="page-link pe-0" data-list-pagination="next" id="empAdvanced-nextPageBtn"><span class="fas fa-chevron-right"></span></button>
			</div>
		</div>
	</div>

</div>

<!-- FIRST MODAL -->
<div class="modal fade" id="createCustomerModalToggle" tabindex="-1" aria-hidden="true">
	<div class="modal-dialog modal-xl modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header">
				<h5 class="modal-title">Create Customer</h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
			</div>
			<div class="create-lead-modal-body"></div>
		</div>
	</div>
</div>

<!--SECOND MODAL-->
<div class="modal fade" id="createJobModalToggle" tabindex="-1" aria-hidden="true">
	<div class="modal-dialog modal-xl modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header">
				<h5 class="modal-title">Create Job</h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
			</div>
			<div class="create-job-modal-body"></div>
		</div>
	</div>
</div>

<partial name="_ConfirmDelete" />

@section Scripts {
	<script src="~/js/pages/fieldservices/employeeadvanced.js"></script>
}

