@using GCTL.Core.ViewModels.PayrollManagements.PayrollPolicy.PayRollEmpAllowance
@model GCTL.Core.ViewModels.PayrollManagements.PayrollPolicy.PayRollEmpAllowance.PayRollEmpAllowanceSaveVM
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<!-- Include Month Select Plugin CSS (important to load for correct styling) -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/plugins/monthSelect/style.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/themes/dark.css">
@{
    List<AllowanceTypeNameVM> list = ViewBag.LIsttt;
}
<style>
    .flatpickr-monthSelect-months {
        display: grid;
        grid-template-columns: repeat(3, 1fr); /* 3 equal columns */
        gap: 10px; /* Space between months */
        margin: 10px 1px 3px 1px;
    }

    /* Styling for individual months */
    .flatpickr-monthSelect-month {
        background: none;
        border: 1px solid transparent;
        border-radius: 4px;
        box-sizing: border-box;
        color: #393939;
        cursor: pointer;
        display: flex; /* Use flexbox to center the text inside the month */
        justify-content: center;
        padding: 10px;
        position: relative;
        text-align: center;
        width: 100%; /* Make sure it takes full width of the column */
    }

        /* Disabled month styling */
        .flatpickr-monthSelect-month.flatpickr-disabled {
            color: #eee;
        }

            .flatpickr-monthSelect-month.flatpickr-disabled:hover,
            .flatpickr-monthSelect-month.flatpickr-disabled:focus {
                cursor: not-allowed;
                background: none !important;
            }

    /* Dark theme adjustments */
    .flatpickr-monthSelect-theme-dark {
        background: #3f4458;
    }

        .flatpickr-monthSelect-theme-dark .flatpickr-monthSelect-month {
            color: rgba(255, 255, 255, 0.95);
        }

            .flatpickr-monthSelect-theme-dark .flatpickr-monthSelect-month.selected {
                background-color: #80cbc4;
                color: #fff;
                border-color: #80cbc4;
            }

    /* Styling for today’s month */
    .flatpickr-monthSelect-month.today {
        border-color: #959ea9;
    }

    .flatpickr-monthSelect-month.selected,
    .flatpickr-monthSelect-month.startRange,
    .flatpickr-monthSelect-month.endRange {
        background-color: #569ff7;
        box-shadow: none;
        color: #fff;
        border-color: #569ff7;
    }

    /* Range selection */
    .flatpickr-monthSelect-month.startRange {
        border-radius: 50px 0 0 50px;
    }

    .flatpickr-monthSelect-month.endRange {
        border-radius: 0 50px 50px 0;
    }

    .flatpickr-monthSelect-month.inRange {
        border-radius: 0;
        box-shadow: -5px 0 0 #e6e6e6, 5px 0 0 #e6e6e6;
    }
</style>

<form id="payrollEmpAllowanceForm" class="row g-3">

    <div class="col-md-6">

        <div class="mb-3">
            <div class="content-head d-flex justify-content-between align-items-center">
                <label class="form-label" for="organizerSingle">Company Name</label>
                <div class="form-check form-switch">
                </div>
            </div>
            <select class="form-multi-select" multiple asp-for="OrganizationID" asp-items="@ViewBag.OrganizationDD"
                    data-coreui-selection-type="tags" data-coreui-search="true">
                <option value="">Select Company</option>

            </select>
            <span id="OrganizationID-error" class="text-danger"></span>
        </div>
    </div>

    @for (int i = 0; i < list.Count; i++)
    {
        var item = list[i]; 

        <div class="col-md-12">
            <div class="mb-0">
                <div class="content-head d-flex justify-content-between align-items-center">

                    <h5>@item.EmployeeAllowanceTypeName</h5>
                    <input asp-for="EmployeeAllowanceTypeID" type="hidden" value="@item.EmployeeAllowanceTypeID" />
                    <!-- Effective Date -->
                    <div class="col-lg-4 col-md-4 col-sm-12">
                        <label class="form-label" for="year-month-picker-@i">Effective Date</label>
                        <div class="input-icon-end position-relative">
                            <input class="form-control ps-6 flatpickr-input"
                                   id="year-month-picker-@i"
                                   type="text"
                                   readonly="readonly"
                                   placeholder="Select Month">
                            <span class="uil uil-calendar-alt position-absolute top-50 end-0 translate-middle-y me-3 text-body-tertiary"></span>
                        </div>
                    </div>
                   
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" asp-for="IsActive">
                    </div>

                </div>
            </div>
        </div>

        <div id="houseRentContainer11">
            <div class="card shadow-sm rounded-3 mb-3 houseRentRow">
                <div class="card-body" id="houseRentContainer">
                    <div class="row g-3">
                        <!-- Min Salary -->
                        <div class="col-lg-3 col-md-6 col-sm-12">
                            <label class="form-label" for="MinSalary">Min Salary</label>
                            <input type="text" asp-for="HouseRentAllowances[0].SalaryMin" class="form-control" placeholder="Enter Min Salary" />
                        </div>
                        <!-- Max Salary -->
                        <div class="col-lg-3 col-md-6 col-sm-12">
                            <label class="form-label" for="MaxSalary">Max Salary</label>
                            <input type="text" asp-for="HouseRentAllowances[0].SalaryMax" class="form-control" placeholder="Enter Max Salary" />
                        </div>
                        <div class="col-lg-5 col-md-5 col-sm-12  d-flex align-items-center gap-3">
                            <div class="input-group mb-3">

                                <select class="form-select mt-4" id="fixedPercentage" style="max-width: 125px;height:37px;" asp-items="@ViewBag.CalculationTypeDD as SelectList">

                                    <option value="">Select One</option>
                                    <option value="Fixed">Fixed</option>
                                    <option value="Percentage">Percentage</option>
                                </select>

                                <div id="percentRate" style="display: none;">
                                    <label class="form-label" for="percentRate11">Percentage(%)</label>

                                    <select class="form-select choiceDD" id="percentRate11" asp-items="@ViewBag.PercenatageDD as SelectList" style="max-width:1850px;">
                                        <option value="">Select %</option>

                                    </select>
                                </div>
                                <!-- Fixed Rate Input -->
                                <div id="fixedRate" style="display: none;">
                                    <label class="form-label" for="percentRate11">Fixed</label>

                                    <input type="text" class="form-control" asp-for="Value" placeholder="Enter Fixed Rate" style=" max-width: 185px;">
                                </div>
                            </div>

                        </div>
                        <div class="col-lg-1 px-0 col-md-1 col-sm-1">
                            <button type="button" id="addDetails" class="btn btn-primary px-3 mt-4 addRow">
                                <i class="bi bi-plus-circle"></i>+
                            </button>
                        </div>

                    </div>
                </div>
            </div>

        </div>
    }
    <div class="col-12">
        <div class="row g-3 justify-content-end">
            <div class="col-auto">
                <button class="btn btn-phoenix-primary px-5" id="ResetButton">Cancel</button>
            </div>
            <div class="col-auto">
                <button class="btn btn-primary px-5 px-sm-15" id="PayRollEmpAllowanceSave">Save</button>
            </div>
        </div>
    </div>
</form>






