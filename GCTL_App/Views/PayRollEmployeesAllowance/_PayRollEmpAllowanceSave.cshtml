                                                        </div>
                                                    </div>
                                            
                                                </div>
                                                <div class="row g-3 justify-content-end">

                                                    <div class="col-auto">
                                                        <button class="btn btn-primary px-5 PayRollEmpAllowanceSave"  style="margin-right: 2.5rem !important;">Save</button>
                                                    </div>
                                                </div>

                                            </div>

                                        </div>
                                    
                                
                                
                            </form>
                        </div>
                    </div>
                   
                </div>
                
            }
        </div>

        
    }
    else
    {
        <p>No allowance types available.</p>
    } 

  

</form>


