                <option value="">Select Company</option>
            </select>
            <span id="OrganizationID-error" class="text-danger"></span>
        </div>
    </div>
     @if (list.Any())
    {
        <div class="accordion" id="accordionPanelsStayOpenExample">
            @for (int i = 0; i < list.Count; i++)
            {
                var item = list[i];
                var collapseId = $"collapse-{i}";
                var headingId = $"heading-{i}";
                var yearMonthPickerId = $"year-month-picker-{i}";
                var percentRateId = $"percentRate-{i}";
                var fixedRateId = $"fixedRate-{i}";
                var isFirst = i == 0;

                var buttonClass = isFirst ? "accordion-button" : "accordion-button collapsed";
                var collapseClass = isFirst ? "accordion-collapse collapse show" : "accordion-collapse collapse";
                var ariaExpanded = isFirst.ToString().ToLower();
                
                <div class="accordion-item">
                    <h2 class="accordion-header" id="@headingId">
                        <button class="@buttonClass" type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#@collapseId"
                                aria-expanded="@ariaExpanded"
                                aria-controls="@collapseId">
                            @item.EmployeeAllowanceTypeName
                        </button>
                    </h2>
                    <div id="@collapseId" class="@collapseClass" aria-labelledby="@headingId">
                        <div class="accordion-body">
                            <!-- Start of first row -->
                            <form id="payrollEmpAllowanceForm" class="row g-3">

                                        <div class="card shadow-sm rounded-3 mb-1 houseRentRow">
                                            <div class="card-body">
                                                <div class="houseRentContainer">
                                                    <div class="row">

                                                        <div class="col-lg-4 col-md-6 col-sm-12 mb-3">
                                                    <input type="hidden" asp-for="HouseRentAllowances[@i].EmployeeAllowanceTypeID" value="@item.EmployeeAllowanceTypeID" />
                                                            <label class="form-label" for="year-month-picker-@i">Effective Date</label>
                                                            <div class="input-icon-end position-relative">
                                                                <input class="form-control ps-6 flatpickr-input"
                                                                       id="year-month-picker-@i"
                                                                       type="text"
                                                                       readonly="readonly"
                                                                       asp-for="EffectiveDate"
                                                                       placeholder="Select Month">
                                                                <span class="uil uil-calendar-alt position-absolute top-50 end-0 translate-middle-y me-3 text-body-tertiary"></span>
                                                            </div>
                                                        </div>
                                                <div class="col-lg-4 col-md-6 col-sm-12 mb-3">
                                                    <div class="form-check form-switch mt-4" style="margin-left: 16.5rem !important;">
                                                                <input class="form-check-input" type="checkbox" asp-for="IsActive">
                                                                <label class="form-check-label ms-2">Active</label>
                                                            </div>
                                                        </div>
                                                    </div>


                                            <div class="row g-3 houseRentRow">
                                                        <div class="col-lg-4 col-md-6 col-sm-12">
                                                            <label class="form-label" for="MinSalary">Min Salary</label>
                                                            <input type="text" asp-for="HouseRentAllowances[@i].SalaryMin" class="form-control" placeholder="Enter Min Salary" />
                                                        </div>
                                                        <div class="col-lg-4 col-md-6 col-sm-12">
                                                            <label class="form-label" for="MaxSalary">Max Salary</label>
                                                            <input type="text" asp-for="HouseRentAllowances[@i].SalaryMax" class="form-control" placeholder="Enter Max Salary" />
                                                        </div>
                                                        <div class="col-lg-3 col-md-3 col-sm-12 d-flex align-items-center gap-3">
                                                            <div class="input-group mb-3">
                                                                <select class="form-select mt-4 fixedPercentageSelect" style="max-width: 125px;height:37px;">
                                                                    <option value="">Select One</option>
                                                                    <option value="Fixed">Fixed</option>
                                                                    <option value="Percentage">Percentage</option>
                                                                </select>
                                                                <div class="percentRate" style="display: none;">
                                                                    <label class="form-label" for="percentRate-@i">Percentage(%)</label>
                                                                    <select class="form-select choiceDD" id="percentRate-@i" asp-items="@ViewBag.PercenatageDD as SelectList" style="max-width:185px;">
                                                                        <option value="">Select %</option>
                                                                    </select>
                                                                </div>
                                                                <div class="fixedRate" style="display: none;">
