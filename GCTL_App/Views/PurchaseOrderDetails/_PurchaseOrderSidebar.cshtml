@using GCTL.Core.ViewModels.POS.Purchase.PurchaseOrderDetails
@model PurchaseOrderSidebarDetailsViewModel

<div class="col-md-3 mb-4">
    <div class="card mb-3" style="min-height: 1000px;">
        <div class="card-body">
            <div class="invoice-card">
                <div>
                    @if (Model.Status == GCTL.Core.Enums.PurchaseOrderStatus.Draft)
                    {
                        <div class="alert alert-subtle-warning" role="alert">
                            @Html.SmartLocalize("Purchase Order in draft mode. Click")
                            <a class="text-decoration-none" href="javascript:void(0)" onclick="savePurchaseOrder()">@Html.SmartLocalize("Save")</a>
                            @Html.SmartLocalize("to Confirm")
                        </div>
                    }
                    else if (Model.Status == GCTL.Core.Enums.PurchaseOrderStatus.Pending)
                    {
                        <div class="alert alert-subtle-primary" role="alert">
                            @Html.SmartLocalize("Purchase Order pending approval.")
                        </div>
                    }
                    else if (Model.Status == GCTL.Core.Enums.PurchaseOrderStatus.Approved)
                    {
                        <div class="alert alert-subtle-success" role="alert">
                            @Html.SmartLocalize("Purchase Order approved. Ready to receive.")
                        </div>
                    }
                    else if (Model.Status == GCTL.Core.Enums.PurchaseOrderStatus.Received)
                    {
                        <div class="alert alert-subtle-info" role="alert">
                            @Html.SmartLocalize("Purchase Order received.")
                        </div>
                    }
                    else if (Model.Status == GCTL.Core.Enums.PurchaseOrderStatus.Cancelled)
                    {
                        <div class="alert alert-subtle-danger" role="alert">
                            @Html.SmartLocalize("Purchase Order cancelled.")
                        </div>
                    }
                </div>

                <div class="accordion" id="accordionExample">
                    <!-- Create Section -->
                    <div class="accordion-item border-top">
                        <h2 class="accordion-header" id="headingCreate">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseCreate" aria-expanded="true" aria-controls="collapseCreate">
                                @Html.SmartLocalize("Create")
                            </button>
                        </h2>
                        <div class="accordion-collapse collapse show" id="collapseCreate" aria-labelledby="headingCreate" data-bs-parent="#accordionExample">
                            <div class="accordion-body pt-0">
                                <p class="fs-9" id="createPerson">
                                    <strong>@Html.SmartLocalize("Created By:")</strong> @Model.CreatedByName <br />
                                    <strong>@Html.SmartLocalize("Created At:")</strong> @Model.CreatedAt?.ToString("MMM dd, yyyy hh:mm tt")
                                    @if (!string.IsNullOrEmpty(Model.UpdatedByName))
                                    {
                                        <br />
                                        <strong>@Html.SmartLocalize("Updated By:")</strong> @Model.UpdatedByName <br />
                                        <strong>@Html.SmartLocalize("Updated At:")</strong> @Model.UpdatedAt?.ToString("MMM dd, yyyy hh:mm tt")
                                    }
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Edit Section -->
                    <div class="accordion-item border-top">
                        <h2 class="accordion-header" id="headingEdit">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseEdit" aria-expanded="true" aria-controls="collapseEdit">
                                @Html.SmartLocalize("Edit")
                            </button>
                        </h2>
                        <div class="accordion-collapse collapse show" id="collapseEdit" aria-labelledby="headingEdit" data-bs-parent="#accordionExample">
                            <div class="accordion-body pt-0">
                                <p class="fs-9">
                                    @Html.SmartLocalize("Purchase Order Number:") @Model.PurchaseOrderNumber <br>
                                    @if (Model.CanEdit)
                                    {
                                        @foreach (var item in Model.PurchaseOrderIdList)
                                        {
                                            if (item.current == "current")
                                            {
                                                <a href="#" style="color: black;text-decoration: none;">@Html.SmartLocalize("Version") @item.version</a> @item.draftSign @item.finalSign <br>
                                            }
                                            else
                                            {
                                                <a href="@Url.Action("Index", "PurchaseOrderDetails", new { id = item.id })">@Html.SmartLocalize("Version") @item.version</a> @item.draftSign @item.finalSign <br>
                                            }
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">@Html.SmartLocalize("Cannot edit (Status:") @Model.StatusDisplay)</span>
                                    }
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Duplicate Section -->
                    <div class="accordion-item border-top">
                        <h2 class="accordion-header" id="headingDuplicate">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseDuplicate" aria-expanded="true" aria-controls="collapseDuplicate">
                                @Html.SmartLocalize("Duplicate")
                            </button>
                        </h2>
                        <div class="accordion-collapse collapse show" id="collapseDuplicate" aria-labelledby="headingDuplicate" data-bs-parent="#accordionExample">
                            <div class="accordion-body pt-0">
                                <p class="fs-9">
                                    @Html.SmartLocalize("Purchase Order Number:") @Model.PurchaseOrderNumber <br>
                                    <a href="javascript:void(0)" onclick="duplicatePurchaseOrder(@Model.PurchaseOrderId)">@Html.SmartLocalize("Create Duplicate")</a>
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Receive Section -->
                    @if (Model.HasReceive)
                    {
                        <div class="accordion-item border-top">
                            <h2 class="accordion-header" id="headingReceive">
                                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseReceive" aria-expanded="true" aria-controls="collapseReceive">
                                    @Html.SmartLocalize("Purchase Receive")
                                </button>
                            </h2>
                            <div class="accordion-collapse collapse show" id="collapseReceive" aria-labelledby="headingReceive" data-bs-parent="#accordionExample">
                                <div class="accordion-body pt-0">
                                    <span class="fs-9">@Html.SmartLocalize("Receive Number:") <a href="@Url.Action("Index", "PurchaseReceive", new { id = Model.ReceiveId })">@Model.ReceiveNumber</a></span><br>
                                    <span class="fs-9">@Html.SmartLocalize("Status: Received")</span>
                                </div>
                            </div>
                        </div>
                    }
                    else if (Model.CanConvertToReceive)
                    {
                        <div class="accordion-item border-top">
                            <h2 class="accordion-header" id="headingReceive">
                                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseReceive" aria-expanded="true" aria-controls="collapseReceive">
                                    @Html.SmartLocalize("Purchase Receive")
                                </button>
                            </h2>
                            <div class="accordion-collapse collapse show" id="collapseReceive" aria-labelledby="headingReceive" data-bs-parent="#accordionExample">
                                <div class="accordion-body pt-0">
                                    <p class="fs-9">
                                        <a href="javascript:void(0)" onclick="convertToReceive(@Model.PurchaseOrderId)">@Html.SmartLocalize("Convert to Receive")</a>
                                    </p>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Send Email Section -->
                    <div class="accordion-item">
                        <h2 class="accordion-header" id="headingEmail">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseEmail" aria-expanded="true" aria-controls="collapseEmail">
                                @Html.SmartLocalize("Send Email")
                            </button>
                        </h2>
                        <div class="accordion-collapse collapse show" id="collapseEmail" aria-labelledby="headingEmail" data-bs-parent="#accordionExample">
                            <div class="accordion-body pt-0">
                                @if (Model.CanSendEmail)
                                {
                                    <a class="btn btn-subtle-primary me-1 mb-1" type="button" data-bs-toggle="modal" data-bs-target="#showSendModal"><i class="far fa-envelope" aria-hidden="true"></i></a>
                                    <a class="btn btn-subtle-primary me-1 mb-1" type="button" onclick="printPurchaseOrder(@Model.PurchaseOrderId)"><i class="fa fa-print" aria-hidden="true"></i></a>
                                }
                                else
                                {
                                    <p class="fs-9 text-muted">@Html.SmartLocalize("Already received")</p>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Status Actions -->
                    @if (Model.Status == GCTL.Core.Enums.PurchaseOrderStatus.Draft)
                    {
                        <div class="accordion-item border-top">
                            <h2 class="accordion-header" id="headingStatus">
                                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseStatus" aria-expanded="true" aria-controls="collapseStatus">
                                    @Html.SmartLocalize("Status Actions")
                                </button>
                            </h2>
                            <div class="accordion-collapse collapse show" id="collapseStatus" aria-labelledby="headingStatus" data-bs-parent="#accordionExample">
                                <div class="accordion-body pt-0">
                                    <p class="fs-9">
                                        <a href="javascript:void(0)" onclick="markAsApproved(@Model.PurchaseOrderId)">@Html.SmartLocalize("Mark as Approved")</a>
                                    </p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Send Email Modal -->
<div class="modal fade" id="showSendModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@Html.SmartLocalize("Send Purchase Order via Email")</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">@Html.SmartLocalize("Recipient Email")</label>
                    <input type="email" class="form-control" id="recipientEmail" placeholder="@Html.SmartLocalize("supplier@example.com")">
                </div>
                <div class="mb-3">
                    <label class="form-label">@Html.SmartLocalize("Subject")</label>
                    <input type="text" class="form-control" id="emailSubject" value="@Html.SmartLocalize("Purchase Order -") @Model.PurchaseOrderNumber">
                </div>
                <div class="mb-3">
                    <label class="form-label">@Html.SmartLocalize("Message")</label>
                    <textarea class="form-control" id="emailMessage" rows="5">@Html.SmartLocalize("Dear Supplier,\nPlease find attached the purchase order.\nBest regards")</textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Html.SmartLocalize("Close")</button>
                <button type="button" class="btn btn-primary" onclick="sendEmailNow(@Model.PurchaseOrderId)">@Html.SmartLocalize("Send Email")</button>
            </div>
        </div>
    </div>
</div>
