@model GCTL.Core.ViewModels.PayrollManagements.PayRollEarlyLoanpayment.SaveEarlyPaymentVM
@{
    var departments = ViewBag.DepartmentDD as List<GCTL.Core.ViewModels.CommonSelectVM>;
    var employees = ViewBag.EmployeeList as List<GCTL.Core.ViewModels.CommonSelectVM>;
}
<!-- Add Employes loan -->
<div class="modal fade" id="add_employee_loan_early_payment">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">Employes Loan Early Payment</h4>
                <button type="button" class="btn-close custom-btn-close" data-bs-dismiss="modal"
                        aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="EarlyPayemnt-Saveform" class="row g-3 mb-6">
                    <input asp-for="LoanID" type="hidden"/>
                    <div class="col-md-4">
                        <div class="mb-1">
                            <label asp-for="OrganizationID" class="form-label">Organization</label>
                            <select class="form-select choiceDD" asp-for="OrganizationID" asp-items="@ViewBag.OrganizationDD as SelectList">
                                <option value="">@Html.SmartLocalize("Select Organization")</option>
                            </select>
                            <span id="OrganizationIDError" class="text-danger" style="display:none;"></span>
                        </div>
                    </div>
                     <div class="col-md-4">
                        <div class="mb-1">
                            <label class="form-label" asp-for="DepartmentIDs">Department</label>
                            <select class="form-multi-select" asp-for="DepartmentIDs"
                                    multiple data-coreui-selection-type="counter"
                                    data-coreui-placeholder="@Html.SmartLocalize("Select Department")"
                                    data-coreui-search="true">
                                @foreach (var group in departments.GroupBy(e => e.GroupName))
                                {
                                    <optgroup label="@group.Key">
                                        @foreach (var emp in group)
                                        {
                                            <option value="@emp.Id">@emp.Name</option>
                                        }
                                    </optgroup>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="mb-1">
                            <label class="form-label req">Employee</label>
                            <select class="form-multi-select" asp-for="EmployeeIDs"
                                     data-coreui-selection-type="counter"
                                    data-coreui-placeholder="@Html.SmartLocalize("Select Employee")"
                                    data-coreui-search="true">
                                @foreach (var group in employees.GroupBy(e => e.GroupName))
                                {
                                    <optgroup label="@group.Key">
                                        @foreach (var emp in group)
                                        {
                                            <option value="@emp.Id">@emp.Name</option>
                                        }
                                    </optgroup>
                                }
                            </select>
                        </div>
                    </div> 


                    

                    <div class="col-md-3">
                        <div class="mb-1">
                            <label class="form-label" for="timepicker1">Loan Amount</label>
                            <input class="form-control" asp-for="LoanAmount" type="text" placeholder="Ex: 50000"  disabled>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="mb-1">
                            <label class="form-label" for="timepicker1">Tenure Month</label>
                           @*  <select class="form-select choiceDD" asp-for="LoanInstallmentPeriodID" asp-items="@ViewBag.LoanInstallmentDD as SelectList">
                                <option value="">Select Month</option>
                            </select> *@
                            <input class="form-control" asp-for="TenureMonth" type="text" placeholder="Ex: 50000"  disabled>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="mb-1">
                            <label class="form-label" for="timepicker1">Monthly EMI</label>
                            <input class="form-control" asp-for="MonthlyEMI" type="text" placeholder="Ex: 50000"  disabled>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="mb-1">
                            <label class="form-label req" for="timepicker1">Early Pay Amount</label>
                            <input class="form-control" asp-for="EarlyPayAmount" type="text" placeholder="Ex: 50000">
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-1">
                            <label class="form-label req" for="datepicker">Payment Date</label>
                            <input class="form-control datetimepicker flatpickr-input" asp-for="PaymentDateTime" type="text" placeholder="dd/mm/yyyy"  readonly="readonly">

                        </div>
                    </div>
                    <div class="col-12">
                        <div class="row g-3 justify-content-end">
                            <div class="col-auto">
                                <button class="btn btn-phoenix-primary px-5" type="button" id="ResetButton">Cancel</button>
                            </div>
                            <div class="col-auto">
                                <button class="btn btn-primary px-5 px-sm-5"  id="SaveButton">Save</button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

