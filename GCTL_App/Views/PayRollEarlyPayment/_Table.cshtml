<div class="card">
    <div class="card-header mb-4">
        <div class="d-flex justify-content-between">
            <h4 class="mb-1">Employee Loan Early Payment Information</h4>

            <div class="dropdown start-0">
                <a href="#" class="btn btn-outline-info  rounded-pill d-flex align-items-center" data-bs-target="#add_employee_loan_early_payment"
