            </div>

        </div>
        <div class="d-flex my-xl-auto right-content align-items-center flex-wrap row-gap-3">

            <div class="dropdown me-2">
                <select class="form-select" id="organizerSingle" data-choices="data-choices" >
                    <option value="">Select Company</option>
                </select>
            </div>

            <div class="dropdown me-2">
                <select class="form-multi-select" id="multiple-dep-select" multiple data-coreui-selection-type="counter" data-coreui-search="true">
                    <option value="">Select Department</option>
                    <option>Developer</option>
                    <option>Designer</option>
                    <option>Finance</option>
                </select>
            </div>

            <div class="dropdown me-2">
                <select class="form-multi-select" id="multiple-emp-select" multiple data-coreui-selection-type="counter" data-coreui-search="true">
                    <optgroup label="Developer">
                        <option value="2">Alam</option>
                        <option value="3">Momin</option>
                    </optgroup>
                    <optgroup label="Designer">
                        <option value="4">Name (id)</option>
                        <option value="5">Name (id)</option>
                    </optgroup>
                </select>
            </div>
        </div>
    </div>
    <div class="card-body">
        <div class="border-translucent p-3">
            <div id="employeeListTable">

                <div class="table-responsive scrollbar mx-n1 px-1">
                    <table class="table table-sm fs-9 leads-table">
                        <thead>
                            <tr>
                                <th class="sort align-middle ps-4 pe-3 text-uppercase text-nowrap" scope="col" data-sort="empId">Employee Id</th>
                                <th class="sort align-middle ps-4 pe-3 text-uppercase text-nowrap" scope="col" data-sort="empName">Employee Name</th>
                                <th class="sort align-middle ps-4 pe-3 text-uppercase text-nowrap" scope="col" data-sort="empDept">Department</th>
                                <th class="sort align-middle ps-4 pe-3 text-uppercase text-nowrap" scope="col" data-sort="empLoanAmount">Loan Amount</th>
                                <th class="sort align-middle ps-4 pe-3 text-uppercase text-nowrap" scope="col" data-sort="empEarlyPayAmount">Early Pay Amount</th>
                                <th class="sort align-middle ps-4 pe-3 text-uppercase text-nowrap" scope="col" data-sort="paymentDate">Payment Date</th>
                                <th class="sort align-middle ps-4 pe-3 text-uppercase text-nowrap" scope="col" data-sort="receivedBy">Received By</th>
