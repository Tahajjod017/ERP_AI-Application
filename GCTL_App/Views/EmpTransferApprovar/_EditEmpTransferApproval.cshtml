

<style>
    input[readonly] {
        background-color: #f4f6f9;
        pointer-events: none;
        cursor: default;
        color: #6c757d;
    }
</style>

<form method="post" id="employeeTransferFormEdit">
    <div class="modal-body pb-0">
        <div class="row">
            <input id="EmployeeTransferID" type="hidden" />
            <input id="TransferTypeEdit" type="hidden" />
            <div class="col-md-12">
                <div class="mb-3">
                    <label class="form-label req" for="organizerSingle">Name</label>
                    <select class="form-select choiceDD" id="EmployeeIDEdit" required>
                        <option value="">Select Employee</option>
                    </select>

                </div>
            </div>
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label req">From Organization</label>
                    <select class="form-select choiceDD" id="FromOrganizationIDEdit" required asp-items="@ViewBag.OrganizationDD as SelectList" disabled>
                        <option value="">Select Organization</option>
                    </select>

                </div>
            </div>
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label req">To Organization</label>
                    <select class="form-select choiceDD" id="ToOrganizationIDEdit" required asp-items="@ViewBag.OrganizationDD as SelectList">
                        <option value="">Select Organization</option>
                    </select>

                </div>
            </div>
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label req">From Organization Branch</label>
                    <select class="form-select choiceDD" id="FromOrganizationBranchIDEdit" required asp-items="@ViewBag.OrganizationBranchDD as SelectList" disabled>
                        <option value="">Select Organization</option>
                    </select>

                </div>
            </div>
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label req">To Branch</label>
                    <select class="form-select choiceDD" id="ToOrganizationBranchIDEdit" required asp-items="@ViewBag.OrganizationBranchDD as SelectList">
                        <option value="">Select Organization</option>
                    </select>

                </div>
            </div>
            <div class="col-md-6 mb-3 field-group" data-section="dept org branch">
                <label class="form-label req">From Department</label>
                <select class="form-select choiceDD" id="FromDepartmentIDEdit" asp-items="@ViewBag.DepartmentDD as SelectList" disabled>
                    <option value="">Select Department</option>
                </select>
            </div>
            <div class="col-md-6 mb-3 field-group" data-section="dept org branch">
                <label class="form-label req">To Department</label>
                <select class="form-select choiceDD" id="ToDepartmentIDEdit" asp-items="@ViewBag.DepartmentDD as SelectList">
                    <option value="">Select Department</option>
                </select>
            </div>

            <!-- Designation Fields -->
            <div class="col-md-6 mb-3 field-group" data-section="dept branch org">
                <label class="form-label req">From Designation</label>
                <select class="form-select choiceDD" id="FromDesignationIDEdit" asp-items="@ViewBag.DesignationDD as SelectList" disabled>
                    <option value="">Select Designation</option>
                </select>
            </div>
            <div class="col-md-6 mb-3 field-group" data-section="dept branch org">
                <label class="form-label req">To Designation</label>
                <select class="form-select choiceDD" id="ToDesignationIDEdit" asp-items="@ViewBag.DesignationDD as SelectList">
                    <option value="">Select Designation</option>
                </select>
            </div>
            <!-- Divs to Show/Hide -->
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label req">Transfer Date</label>
                    <div class="input-icon-end position-relative">
                        <input type="text" id="TransferDateEdit" class="form-control datetimepicker" readonly required placeholder="dd/mm/yyyy">
                        <span class="uil uil-calendar-alt position-absolute top-50 end-0 translate-middle-y me-3 text-body-tertiary"></span>

                    </div>
                    <span id="ToDateError" class="text-danger small"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label">Note</label>
                    <input id="TransferNoteEdit" class="form-control" />
                </div>
            </div>
        </div>
    </div>


 @*    <div class="d-flex justify-content-end gap-2 mt-1 mb-2 me-3">
        <button type="button" id="EmpTransferButtonResetEdit" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
        <button id="EmpTransferButtonUpdateSubmit" class="btn btn-primary">Apply</button>
    </div> *@
    <div class="d-flex justify-content-end align-items-center gap-3 mt-1 mb-4 me-3">
        <div class="form-check form-check-inline">
            <input class="form-check-input" type="radio" name="ApprovalStatus" id="approveRadio" value="true">
            <label class="form-check-label" for="approveRadio">Approve</label>
        </div>
        <div class="form-check form-check-inline">
            <input class="form-check-input" type="radio" name="ApprovalStatus" id="declineRadio" value="false">
            <label class="form-check-label" for="declineRadio">Decline</label>
        </div>

        <button id="ApplyLeaveSubmitButtonApproval" class="btn btn-primary">Approved</button>
    </div>
</form>





