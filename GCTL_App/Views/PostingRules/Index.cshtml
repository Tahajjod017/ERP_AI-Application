@model GCTL.Core.ViewModels.Finance.PostingRulesVM.CreatePostingRulesVM

@{
    ViewData["Title"] = @Html.SmartLocalize("Posting Rules");
    var bodyTabs = ViewBag.BodyTabs as List<GCTL.Data.Models.MenuTab>;
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var mainAccDD = ViewBag.MainAccDD as List<GCTL.Core.ViewModels.CommonSelectVM>;
}

@section Styles {
    <style>

    </style>
}

<ul class="nav nav-underline fs-9">
    @if (bodyTabs != null && bodyTabs.Any())
    {
        foreach (var tab in bodyTabs)
        {
            var isActive = tab.ControllerName.Equals(currentController, StringComparison.OrdinalIgnoreCase)
            ? "active" : "";

            <li class="nav-item">
                <a class="nav-link p-2 rounded-2 @isActive"
                   href="@Url.Action("Index", tab.ControllerName)">
                    @if (!string.IsNullOrEmpty(tab.Icon))
                    {
                        <i class="@tab.Icon me-1"></i>
                    }
                    @Html.SmartLocalize(tab.Title)
                </a>
            </li>
        }
    }
    else
    {
        <li class="nav-item"><span class="text-muted">No menu items found</span></li>
    }
</ul>

<div class="tab-content mt-3">
    <div class="tab-pane fade show active">
        <div class="row mb-2">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-body">
                        <form asp-controller="postingRules" asp-action="Create" method="post" enctype="multipart/form-data" id="postingRules-form">
                            <div class="row pt-2">

                                @Html.AntiForgeryToken()

                                <div class="col-md-3">
                                    <input type="hidden" asp-for="PostingRuleID" />

                                    <div class="mb-2">
                                        <label class="form-label" asp-for="ScenarioName">@Html.SmartLocalize("Scenario Name")<span style="color:red;">*&nbsp;</span></label>
                                        <input class="form-control" asp-for="ScenarioName" type="text" placeholder="@Html.SmartLocalize("Input Scenario Name")" />
                                        <span asp-validation-for="ScenarioName" id="ScenarioNameError" class="text-danger" style="display:none;"></span>
                                    </div>

                                    <div class="mb-2">
                                        <label class="form-label" asp-for="ScenarioCode">@Html.SmartLocalize("Scenario Code")<span style="color:red;">*&nbsp;</span></label>
                                        <input class="form-control bg-light" asp-for="ScenarioCode" type="text" readonly />
                                        <span asp-validation-for="ScenarioCode" id="ScenarioCodeError" class="text-danger" style="display:none;"></span>
                                    </div>
                                </div>

                                <div class="col-md-9">
                                    @for (int i = 0; i < Model.PostingRuleDetailsVMs.Count; i++)
                                    {
                                        <div class="row mb-2 PostingRuleDetailsVM">
                                            <input type="hidden" asp-for="PostingRuleDetailsVMs[@i].PostingRuleDetailID" class="detailID" />
                                            <div class="col-md-3">
                                                <label class="form-label" asp-for="PostingRuleDetailsVMs[@i].MainAccountID">@Html.SmartLocalize("Select Main Account")<span style="color:red;">*</span></label>
                                                <select class="form-select initChoices mainAccDD" asp-for="PostingRuleDetailsVMs[@i].MainAccountID">
                                                    <option value="">@Html.SmartLocalize("Select Main Account")...</option>
                                                    @foreach (var group in mainAccDD.GroupBy(e => e.GroupName))
                                                    {
                                                        <optgroup label="@group.Key">
                                                            @foreach (var emp in group)
                                                            {
                                                                <option value="@emp.Id">@emp.Name</option>
                                                            }
                                                        </optgroup>
                                                    }
                                                </select>
                                                <span asp-validation-for="PostingRuleDetailsVMs[@i].MainAccountID" id="MainAccountIDError" class="text-danger" style="display:none;"></span>
                                            </div>

                                            <div class="col-md-3">
                                                <label class="form-label" asp-for="PostingRuleDetailsVMs[@i].SubAccID">@Html.SmartLocalize("Select Sub Account")<span style="color:red;">*</span></label>
                                                <select class="form-select initChoices subAccDD" asp-for="PostingRuleDetailsVMs[@i].SubAccID">
                                                    <option value="">@Html.SmartLocalize("Select Sub Account")...</option>
                                                </select>
                                                <span asp-validation-for="PostingRuleDetailsVMs[@i].SubAccID" id="SubAccIDError" class="text-danger" style="display:none;"></span>
                                            </div>

                                            <div class="col-md-4">
                                                <label class="form-label" asp-for="PostingRuleDetailsVMs[@i].TrxAccID">@Html.SmartLocalize("Select Transaction Account")</label>
                                                <select class="form-select initChoices trxAccDD" asp-for="PostingRuleDetailsVMs[@i].TrxAccID">
                                                    <option value="">@Html.SmartLocalize("Select Transaction Account")...</option>
                                                </select>
                                            </div>

                                            <div class="col-md-2">
                                                <label class="form-label" asp-for="PostingRuleDetailsVMs[@i].DebitCredit">@Html.SmartLocalize("Select Debit/Credit")<span style="color:red;">*</span></label>
                                                <select class="form-select initDrCr" asp-for="PostingRuleDetailsVMs[@i].DebitCredit">
                                                    <option value="">@Html.SmartLocalize("Select")...</option>
                                                    <option value="D">Debit</option>
                                                    <option value="C">Credit</option>
                                                </select>
                                                <span asp-validation-for="PostingRuleDetailsVMs[@i].DebitCredit" id="DebitCreditError" class="text-danger" style="display:none;"></span>
                                            </div>
                                        </div>
                                    }
                                    <span asp-validation-for="PostingRuleDetailsVMs" id="PostingRuleDetailsVMsError" class="text-danger" style="display:none;"></span>
                                </div>

                                <div class="col-12 mb-2">
                                    <div class="row g-3 justify-content-end">
                                        <div class="col-auto">
                                            <button type="reset" class="btn btn-phoenix-primary px-5" id="postingRules-resetBtn">@Html.SmartLocalize("Reset")</button>
                                        </div>
                                        <div class="col-auto">
                                            <button type="submit" class="btn btn-primary px-5 px-sm-15" id="postingRules-saveBtn">@Html.SmartLocalize("Save")</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-body">
                        <div class="row g-3 justify-content-between align-items-end mb-4">
                            <div class="col-12 col-sm-auto">
                                <div class="d-flex align-items-center me-3" style="width: auto;">
                                    <span class="ms-2">@Html.SmartLocalize("Showing"):</span> &nbsp;
                                    <div style="width: 100%;">
                                        <select id="postingRules-pageSizeSelect" class="form-select form-select-sm" tabindex="10">
                                            <option class="dropdown-item" value="5">@Html.SmartLocalize("5")</option>
                                            <option class="dropdown-item" value="10">@Html.SmartLocalize("10")</option>
                                            <option class="dropdown-item" value="25">@Html.SmartLocalize("25")</option>
                                            <option class="dropdown-item" value="50">@Html.SmartLocalize("50")</option>
                                            <option class="dropdown-item" value="100">@Html.SmartLocalize("100")</option>
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-sm-auto">
                                <div class="d-flex align-items-center">
                                    <div class="d-none me-3" id="postingRules-bulkSelectActions">
                                        <div class="position-relative">
                                            <button type="button" class="btn btn-phoenix-danger btn-sm ms-2" id="postingRules-delSel">@Html.SmartLocalize("Delete")</button>
                                        </div>
                                    </div>

                                    <div class="search-box me-3" id="postingRules-searchBox">
                                        <form class="position-relative" id="postingRules-searchForm">
                                            <input class="form-control search-input search" id="postingRules-searchInput" type="search" placeholder="@Html.SmartLocalize("Search here")" aria-label="Search" />
                                            <span class="fas fa-search search-box-icon"></span>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="table-responsive ms-n1 ps-1 scrollbar">
                            <table class="table table-striped table-hover fs-9 mb-0 border-top border-translucent">
                                <thead>
                                    <tr>
                                        <th class="text-center text-middle align-middle ps-0" scope="col" style="width: 5%;">
                                            <input type="checkbox" class="form-check-input" id="postingRules-check-all" />
                                        </th>
                                        <th class="sort white-space-nowrap align-middle ps-0" scope="col" data-sort="SecnarioName">@Html.SmartLocalize("Scenario Name")</th>
                                        <th class="sort white-space-nowrap align-middle ps-0" scope="col" data-sort="ScenarioCode">@Html.SmartLocalize("Scenario Code")</th>
                                        <th class="white-space-nowrap align-middle ps-0" scope="col" style="width: 10%;">@Html.SmartLocalize("Action")</th>
                                    </tr>
                                </thead>
                                <tbody id="postingRules-tBody">
                                </tbody>
                            </table>
                        </div>

                        <div class="d-flex flex-wrap align-items-center justify-content-between py-3 pe-0 fs-9 border-bottom border-translucent">
                            <div class="d-flex">
                                <p class="mb-0 d-none d-sm-block me-3 fw-semibold text-body" id="postingRules-paginationInfo"></p>
                                <p class="mb-0 d-none d-sm-block me-3 fw-semibold text-body" data-list-info="data-list-info"></p>
                            </div>
                            <div class="d-flex">
                                <button class="page-link" data-list-pagination="prev" id="postingRules-prevPageBtn"><span class="fas fa-chevron-left"></span></button>
                                <ul class="mb-0 pagination" id="postingRules-paginationLinks"></ul>
                                <button class="page-link pe-0" data-list-pagination="next" id="postingRules-nextPageBtn"><span class="fas fa-chevron-right"></span></button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<partial name="_PostingRuleDetailsModal" />
<partial name="_ConfirmDelete" />

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script src="~/js/pages/finance/postingrules.js"></script>
    <script>
        $(function () {
            $.postingrules({
                baseUrl: '@Url.Action("", "PostingRules")'
            });
        });
    </script>
}