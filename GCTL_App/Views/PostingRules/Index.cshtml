@{
    ViewData["Title"] = @Html.SmartLocalize("Posting Rules");
    // var bodyTabs = ViewBag.BodyTabs as List<GCTL.Data.Models.MenuTab>;
    // var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    // var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

@section Styles {
    <style>
        
    </style>
}

