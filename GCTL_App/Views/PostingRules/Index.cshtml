<div class="tab-content mt-3">
    <div class="tab-pane fade show active">
        <form asp-controller="postingRules" asp-action="Create" method="post" enctype="multipart/form-data" id="postingRules-form">
            <div class="row pt-2">

                @Html.AntiForgeryToken()

                <div class="col-md-6">
                    <input type="hidden" asp-for="PostingRuleID" />

                    <div class="mb-3">
                        <label class="form-label" asp-for="ScenarioName">@Html.SmartLocalize("Main Account Code")<span style="color:red;">*&nbsp;</span></label>
                        <input class="form-control" asp-for="ScenarioName" type="text" placeholder="@Html.SmartLocalize("Input Main Account Code")" />
                        <span asp-validation-for="ScenarioName" id="ScenarioNameError" class="text-danger" style="display:none;"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="ScenarioCode">@Html.SmartLocalize("Scenario Code")<span style="color:red;">*&nbsp;</span></label>
                        <input class="form-control" asp-for="ScenarioCode" type="text" placeholder="@Html.SmartLocalize("Scenario Code")" />
                        <span asp-validation-for="ScenarioCode" id="ScenarioCodeError" class="text-danger" style="display:none;"></span>
                    </div>
                    
                    <div class="mb-3 d-inline-flex align-items-center">
                        @* <label class="form-check-label me-2" asp-for="IsActive">@Html.SmartLocalize("Is Active")</label>
                        <div class="form-check form-switch ">
                            <input class="form-check-input mt-2" type="checkbox" asp-for="IsActive">
                        </div> *@
                    </div>

                    <div class="col-12 mb-4">
                        <div class="row g-3 justify-content-end">
                            <div class="col-auto">
                                <button type="reset" class="btn btn-phoenix-primary px-5" id="postingRules-resetBtn">@Html.SmartLocalize("Reset")</button>
                            </div>
                            <div class="col-auto">
                                <button type="submit" class="btn btn-primary px-5 px-sm-15" id="postingRules-saveBtn">@Html.SmartLocalize("Save")</button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <table class="table fs-9 mb-0 border-top border-translucent">
                        <thead>
                            <tr>
                                <th class="white-space-nowrap align-middle ps-0" scope="col">@Html.SmartLocalize("SubDebitAccountID")</th>
                                <th class="white-space-nowrap align-middle ps-0" scope="col">@Html.SmartLocalize("SubCreditAccountID")</th>
                                <th class="white-space-nowrap align-middle ps-0" scope="col">@Html.SmartLocalize("TrxDebitAccountID")</th>
                                <th class="white-space-nowrap align-middle ps-0" scope="col">@Html.SmartLocalize("TrxCreditAccountID")</th>
                                <th class="white-space-nowrap align-middle ps-0" scope="col">@Html.SmartLocalize("IsActive")</th>
                                <th class="white-space-nowrap align-middle ps-0" scope="col">
                                    <button type="button" class="btn btn-success btn-sm" id="add-detail"><i class="fa fa-plus"></i></button>
                                </th>
                            </tr>
                        </thead>
                        <tbody id="postingRulesDetails-tBody">
                            @for (int i = 0; i < Model.PostingRuleDetailsVMs.Count; i++)
                            {
                                <tr>
                                    <td>
                                        <input type="checkbox" class="form-check-input row-check" />
                                    </td>
                                    <td>
                                        <input asp-for="PostingRuleDetailsVMs[@i].SubDebitAccountID" class="form-control" />
                                    </td>
                                    <td>
                                        <input asp-for="PostingRuleDetailsVMs[@i].SubCreditAccountID" class="form-control" />
                                    </td>
                                    <td>
                                        <input asp-for="PostingRuleDetailsVMs[@i].TrxDebitAccountID" class="form-control" />
                                    </td>
                                    <td>
                                        <input asp-for="PostingRuleDetailsVMs[@i].TrxCreditAccountID" class="form-control" />
                                    </td>
                                    <td class="text-center">
                                        <input type="checkbox" asp-for="PostingRuleDetailsVMs[@i].IsActive" class="form-check-input" />
                                    </td>
                                    <td class="text-center">
                                        <button type="button" class="btn btn-danger btn-sm remove-detail"><i class="fa fa-trash"></i></button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </form>

        <div class="row">
            <div class="col-md-12">
                <div class="card-body py-0 scrollbar to-do-list-body">
                    <div class="mx-n4 px-4 mx-lg-n6 px-lg-6 bg-body-emphasis py-5 border-y">
                        <div class="row g-3 justify-content-between align-items-end mb-4">
                            <div class="col-12 col-sm-auto">
                                <div class="d-flex align-items-center me-3" style="width: auto;">
                                    <span class="ms-2">@Html.SmartLocalize("Showing"):</span> &nbsp;
                                    <div style="width: 100%;">
                                        <select id="postingRules-pageSizeSelect" class="form-select form-select-sm" tabindex="10">
                                            <option class="dropdown-item" value="5">@Html.SmartLocalize("5")</option>
                                            <option class="dropdown-item" value="10">@Html.SmartLocalize("10")</option>
                                            <option class="dropdown-item" value="25">@Html.SmartLocalize("25")</option>
                                            <option class="dropdown-item" value="50">@Html.SmartLocalize("50")</option>
                                            <option class="dropdown-item" value="100">@Html.SmartLocalize("100")</option>
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-sm-auto">
                                <div class="d-flex align-items-center">
                                    <div class="d-none me-3" id="postingRules-bulkSelectActions">
                                        <div class="position-relative">
                                            <button type="button" class="btn btn-phoenix-danger btn-sm ms-2" id="postingRules-delSel">@Html.SmartLocalize("Delete")</button>
                                        </div>
                                    </div>

                                    <div class="search-box me-3" id="postingRules-searchBox">
                                        <form class="position-relative" id="postingRules-searchForm">
                                            <input class="form-control search-input search" id="postingRules-searchInput" type="search" placeholder="@Html.SmartLocalize("Search here")" aria-label="Search" />
                                            <span class="fas fa-search search-box-icon"></span>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="table-responsive ms-n1 ps-1 scrollbar">
                            <table class="table fs-9 mb-0 border-top border-translucent">
                                <thead>
                                    <tr>
                                        <th class="text-center text-middle align-middle ps-0" scope="col" style="width: 5%;">
                                            <input type="checkbox" class="form-check-input" id="postingRules-check-all" />
                                        </th>
                                        <th class="sort white-space-nowrap align-middle ps-0" scope="col" data-sort="SecnarioName">@Html.SmartLocalize("Scenario Name")</th>
                                        <th class="sort white-space-nowrap align-middle ps-0" scope="col" data-sort="ScenarioCode">@Html.SmartLocalize("Scenario Code")</th>
                                        <th class="sort white-space-nowrap align-middle ps-0" scope="col" data-sort="IsActive">@Html.SmartLocalize("Is Active")</th>
                                        <th class="white-space-nowrap align-middle ps-0" scope="col" style="width: 10%;">@Html.SmartLocalize("Action")</th>
                                    </tr>
                                </thead>
                                <tbody id="postingRules-tBody">
                                </tbody>
                            </table>
                        </div>

                        <div class="d-flex flex-wrap align-items-center justify-content-between py-3 pe-0 fs-9 border-bottom border-translucent">
                            <div class="d-flex">
                                <p class="mb-0 d-none d-sm-block me-3 fw-semibold text-body" id="postingRules-paginationInfo"></p>
                                <p class="mb-0 d-none d-sm-block me-3 fw-semibold text-body" data-list-info="data-list-info"></p>
                            </div>
                            <div class="d-flex">
                                <button class="page-link" data-list-pagination="prev" id="postingRules-prevPageBtn"><span class="fas fa-chevron-left"></span></button>
                                <ul class="mb-0 pagination" id="postingRules-paginationLinks"></ul>
                                <button class="page-link pe-0" data-list-pagination="next" id="postingRules-nextPageBtn"><span class="fas fa-chevron-right"></span></button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<partial name="_ConfirmDelete" />

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script src="~/js/pages/finance/postingrules.js"></script>
    <script>
        $(function () {
            $.postingrules({
                baseUrl: '@Url.Action("", "PostingRules")'
            });
        });
    </script>
}