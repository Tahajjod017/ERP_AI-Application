                                </li>

                            </ul>

                            <div class="card tab-content bg-white accordion" id="myTabContent">

                                

                                <div class="tab-pane show active fade p-2" role="educationInfo" id="educationInfo" aria-labelledby="educationInfo">

                                    <div class=" px-25 ">
                                        <div class="d-flex justify-content-center my-8 ">

                                            <div class="col-12 row flex gy-3 ">

                                                <div class="col-sm-12 col-md-4">
                                                    <div class="form-floating form-floating-advance-select">
                                                        <select class="form-select" id="organizerSingle" data-choices="data-choices"
                                                                data-options='{"removeItemButton":true,"placeholder":true}'>
                                                            <option value="none" selected disabled>Select Education Level</option>
                                                            <option value="primary">Primary School (Class 1-5)</option>
                                                            <option value="secondary">Secondary School (Class 6-10)</option>
                                                            <option value="ssc">SSC (Secondary School Certificate)</option>
                                                            <option value="hsc">HSC (Higher Secondary Certificate)</option>
                                                            <option value="diploma">Diploma/Technical Education</option>
                                                            <option value="bachelor">Bachelor's Degree</option>
                                                            <option value="masters">Master's Degree</option>
                                                            <option value="phd">PhD (Doctoral Degree)</option>
                                                            <option value="other">Other</option>
                                                        </select>
                                                        <label for="floatingSelectLitigation">Level of Education</label>
                                                    </div>
                                                </div>

                                                <div class="col-sm-12 col-md-4">
                                                    <div class="form-floating form-floating-advance-select">
                                                        <select class="form-select" id="organizerSingle" data-choices="data-choices"
