                                                                    <i class="fas fa-edit"></i>
                                                                </a>

                                                                <a href="#" class="nav-item me-2" data-bs-toggle="modal" data-bs-target="#delete_modal">
                                                                    <i class="fas fa-trash"></i>
                                                                </a>

                                                            </div>
                                                        </td>
                                                    </tr>
                                                    <tr>
                                                        <th scope="row">Diploma</th>
                                                        <td>Computer Technology</td>
                                                        <td>Jhenaidah Govt Polytechnic Institute</td>
                                                        <td>CGPA:3.79 (out of 4)</td>
                                                        <td>2014</td>
                                                        <td>4</td>
                                                        <td>Second Height CGPA in BTEB in the year of 2014 in Computer Technology.</td>
                                                        <td class="align-middle white-space-nowrap text-end pe-0 ps-4 ">
                                                            <div class="btn-reveal-trigger position-static g-3">
                                                                <a href="#" class="nav-item me-2" data-bs-toggle="modal" data-bs-target="#edit_education">
                                                                    <i class="fas fa-edit"></i>
                                                                </a>

                                                                <a href="#" class="nav-item me-2" data-bs-toggle="modal" data-bs-target="#delete_modal">
                                                                    <i class="fas fa-trash"></i>
                                                                </a>

                                                            </div>
                                                        </td>
                                                    </tr>
                                                    <tr>
                                                        <th scope="row">SSC</th>
                                                        <td>Science</td>
                                                        <td>Jhenaidah Govt High School</td>
                                                        <td>CGPA:5.00 (out of 5)</td>
                                                        <td>2009</td>
                                                        <td>2</td>
                                                        <td>-</td>
                                                        <td class="align-middle white-space-nowrap text-end pe-0 ps-4 ">
                                                            <div class="btn-reveal-trigger position-static g-3">
                                                                <a href="#" class="nav-item me-2" data-bs-toggle="modal" data-bs-target="#edit_education">
                                                                    <i class="fas fa-edit"></i>
                                                                </a>

                                                                <a href="#" class="nav-item me-2" data-bs-toggle="modal" data-bs-target="#delete_modal">
                                                                    <i class="fas fa-trash"></i>
                                                                </a>

                                                            </div>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>

                                    </div>



                                </div>

                              

                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>



</div>