@using GCTL.Core.ViewModels.Employee.EmployeeNavigtion
@model GCTL.Core.ViewModels.Employee.EmployeeEducational.EmployeeEducationalPostViewModel

<!-- Delete Modal -->
<div class="modal fade" id="delete_modal">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-body text-center">
                <span class="avatar avatar-xl bg-transparent-danger text-danger mb-3">
                    <i class="ti ti-trash-x fs-36"></i>
                </span>
                <h4 class="mb-1">Confirm Delete</h4>
                <p class="mb-3">You want to delete the item, this cant be undone once you delete.</p>
                <div class="d-flex justify-content-center">
                    <a href="javascript:void(0);" id="dismisDeleteModal" class="btn btn-light me-3" data-bs-dismiss="modal">Cancel</a>
                    <a id="confirmDeleteBtn" class="btn btn-danger">Yes, Delete</a>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- /Delete Modal -->
<!-- Edit Education -->
<div class="modal fade" id="edit_education">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content px-3">
            <div class="modal-header">
                <div class="d-flex align-items-center">
                    <h4 class="modal-title me-2">Edit Educational Info</h4>
                </div>
                <button type="button" class="btn-close custom-btn-close" data-bs-dismiss="modal" aria-label="Close">
                </button>
            </div>

            <input type="hidden" id="editEmployeeEducationalInfoID" />

            <div class="modal-body">
                <div class="col-12 row flex gy-3 ">

                    <div class="col-sm-12 col-md-4">
                        <div class="form-floating form-floating-advance-select">
                            <label>@Html.SmartLocalize("Level of Education")</label>
                            <select class="form-select choiceDD" id="editEducationLevelID" asp-items="@(new SelectList(ViewBag.EducationLevel.Items, "Value", "Text"))">
                                <option value="" selected disabled>@Html.SmartLocalize("Select Education Level")</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-sm-12 col-md-4">
                        <div class="form-floating form-floating-advance-select">
                            <label id="editDegreeID">@Html.SmartLocalize("Select Exam/Degree Title")</label>
                            <select class="form-select choiceDD" id="editDegreeID" asp-items="@(new SelectList(ViewBag.Degree.Items, "Value", "Text"))">
                                <option value="" selected disabled>@Html.SmartLocalize("Select your exam/degree title")</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-sm-12 col-md-4">
                        <div class="form-floating">
                            <input id="editMajorSubject" class="form-control" type="text" placeholder="@Html.SmartLocalize("Concentration/ Major/Group")" required />
                            <label id="editMajorSubject">@Html.SmartLocalize("Concentration/ Major/Group")</label>
                        </div>
                    </div>

                    <div class="col-sm-12 col-md-4">
                        <div class="form-floating form-floating-advance-select">
                            <label id="editEducationBoardID">@Html.SmartLocalize("Education Board")</label>
                            <select class="form-select choiceDD" id="editEducationBoardID" asp-items="@(new SelectList(ViewBag.EducationBoard.Items, "Value", "Text"))">
                                <option value="" selected disabled>@Html.SmartLocalize("Select Education Board")</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-sm-12 col-md-4">
                        <div class="form-floating">
                            <input id="editInstitutionName" class="form-control" type="text" placeholder="@Html.SmartLocalize("Institute Name")" required />
                            <label id="editInstitutionName">@Html.SmartLocalize("Institute Name")</label>
                        </div>
                    </div>

                    <div class="col-sm-12 col-md-4">
                        <div class="form-floating form-floating-advance-select">
                            <label id="editResultTypeID">@Html.SmartLocalize("Result Type")</label>
                            <select class="form-select choiceDD" id="editResultTypeID" asp-items="@(new SelectList(ViewBag.ResultType.Items, "Value", "Text"))">
                                <option value="" selected disabled>@Html.SmartLocalize("Select Result Type")</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-sm-12 col-md-4">
                        <div class="form-floating form-floating-advance-select">
                            <label id="editPassingYearID">@Html.SmartLocalize("Passing Year")</label>
                            <select class="form-select choiceDD" id="editPassingYearID" asp-items="@(new SelectList(ViewBag.PassingYear.Items, "Value", "Text"))">
                                <option value="" selected disabled>@Html.SmartLocalize("Select Passing Year")</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-sm-12 col-md-4">
                        <div class="form-floating">
                            <input id="editYearDuration" class="form-control" type="text" placeholder="@Html.SmartLocalize("Duration (Years)")" />
                            <label id="editYearDuration">@Html.SmartLocalize("Duration (Years)")</label>
                        </div>
                    </div>

                    <div class="col-sm-12 col-md-4">
                        <div class="form-floating">
                            <input id="editAchievement" class="form-control" type="text" placeholder="@Html.SmartLocalize("Achievement")" />
                            <label id="editAchievement">@Html.SmartLocalize("Achievement")</label>
                        </div>
                    </div>
                    <button class="btn btn-outline-primary rounded-pill me-1 mb-1 mx-3" id="btnEditSubmit" type="button" style="width: 100px;">Save</button>
                </div>
            </div>
        </div>
    </div>
</div>

<input type="hidden" id="initEmp" value="@ViewBag.empId" />

<div class="mb-9">
    <div class="row align-items-center justify-content-between g-3 ">
        <div class="col-auto">
        </div>
    </div>

    <div class="px-3 mb-5">
        <div class="row">
            <form asp-controller="EmployeeEducation" id="educationFrom" asp-action="Index" method="post">
                <div class="col-12">


                    <div class="row g-2 align-items-center" id="EmployeeDropDownDiv" style="display:none">

                        <div class="col-md-3">
                            <div class="position-relative">
                              
                            </div>
                        </div>
                        <div class="col-md-3"></div>
                        <div class="col-md-2">
                            <div class="form-floating form-floating-advance-select mb-2">
                                <label asp-for="EmployeePersonalId">@Html.SmartLocalize("Choose Employee")</label>
                                <select class="form-select " asp-for="EmployeePersonalId" >
                                    <option value="">@Html.SmartLocalize("Select Employee")</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2 mb-2">
                            <div class="form-floating">
                                <input asp-for="PersonalEmail" class="form-control" type="email" placeholder="@Html.SmartLocalize("Email")" />
                                <label asp-for="PersonalEmail">@Html.SmartLocalize("Email")</label>
                            </div>
                        </div>
                        <div class="col-md-2 mb-2">
                            <div class="form-floating">
                                <input asp-for="PersonalPhone" class="form-control" type="text" placeholder="@Html.SmartLocalize("Enter Phone")" />
                                <label asp-for="PersonalPhone">@Html.SmartLocalize("Phone")</label>
                            </div>
                        </div>
                    </div>

                    <div class="mx-n4 mx-lg-n6 px-lg-6  bg-body-emphasis pb-4">
                        <div class="col-12 col-xl-12 col-xxl-12">

                            @await Html.PartialAsync("Employee/_EmployeeNavigation", ViewBag.Navigation as EmployeeNavigationViewModel)

                           

                            <div class="card tab-content bg-white accordion" id="myTabContent">
                                <div class="tab-pane show active fade p-2" role="educationInfo" id="educationInfo" aria-labelledby="educationInfo">
                                    <div class=" px-25 ">

                                        <div class="d-flex justify-content-center my-8 ">
                                            <div class="col-12 row flex gy-3 ">
                                                <div class="col-sm-12 col-md-4">
                                                    <div class="form-floating form-floating-advance-select">
                                                        <label asp-for="EducationLevelID">@Html.SmartLocalize("Level of Education")</label>
                                                        <select class="form-select choiceDD" asp-for="EducationLevelID" asp-items="@(new SelectList(ViewBag.EducationLevel.Items, "Value", "Text"))">
                                                            <option value="" selected disabled>@Html.SmartLocalize("Select Education Level")</option>
                                                        </select>
                                                    </div>
                                                </div>

                                                <div class="col-sm-12 col-md-4">
                                                    <div class="form-floating form-floating-advance-select">
                                                        <label asp-for="DegreeID">@Html.SmartLocalize("Select Exam/Degree Title")</label>
                                                        <select class="form-select choiceDD" asp-for="DegreeID" asp-items="@(new SelectList(ViewBag.Degree.Items, "Value", "Text"))">
                                                            <option value="" selected disabled>@Html.SmartLocalize("Select your exam/degree title")</option>
                                                        </select>
                                                    </div>
                                                </div>

                                                <div class="col-sm-12 col-md-4">
                                                    <div class="form-floating">
                                                        <input asp-for="MajorSubject" class="form-control" type="text" placeholder="@Html.SmartLocalize("Concentration/ Major/Group")" required />
                                                        <label asp-for="MajorSubject">@Html.SmartLocalize("Concentration/ Major/Group")</label>
                                                    </div>
                                                </div>

                                                <div class="col-sm-12 col-md-4">
                                                    <div class="form-floating form-floating-advance-select">
                                                        <label asp-for="EducationBoardID">@Html.SmartLocalize("Education Board")</label>
                                                        <select class="form-select choiceDD" asp-for="EducationBoardID" asp-items="@(new SelectList(ViewBag.EducationBoard.Items, "Value", "Text"))">
                                                            <option value="" selected disabled>@Html.SmartLocalize("Select Education Board")</option>
                                                        </select>
                                                    </div>
                                                </div>

                                                <div class="col-sm-12 col-md-4">
                                                    <div class="form-floating">
                                                        <input asp-for="InstitutionName" class="form-control" type="text" placeholder="@Html.SmartLocalize("Institute Name")" required />
                                                        <label asp-for="InstitutionName">@Html.SmartLocalize("Institute Name")</label>
                                                    </div>
                                                </div>

                                                <div class="col-sm-12 col-md-4">
                                                    <div class="form-floating form-floating-advance-select">
                                                        <label asp-for="ResultTypeID">@Html.SmartLocalize("Result Type")</label>
                                                        <select class="form-select choiceDD" asp-for="ResultTypeID" asp-items="@(new SelectList(ViewBag.ResultType.Items, "Value", "Text"))">
                                                            <option value="" selected disabled>@Html.SmartLocalize("Select Result Type")</option>
                                                        </select>
                                                    </div>
                                                </div>

                                                <div class="col-sm-12 col-md-4">
                                                    <div class="form-floating form-floating-advance-select">
                                                        <label asp-for="PassingYearID">@Html.SmartLocalize("Passing Year")</label>
                                                        <select class="form-select choiceDD" asp-for="PassingYearID" asp-items="@(new SelectList(ViewBag.PassingYear.Items, "Value", "Text"))">
                                                            <option value="" selected disabled>@Html.SmartLocalize("Select Passing Year")</option>
                                                        </select>
                                                    </div>
                                                </div>

                                                <div class="col-sm-12 col-md-4">
                                                    <div class="form-floating">
                                                        <input asp-for="YearDuration" class="form-control" type="text" placeholder="@Html.SmartLocalize("Duration (Years)")" />
                                                        <label asp-for="YearDuration">@Html.SmartLocalize("Duration (Years)")</label>
                                                    </div>
                                                </div>

                                                <div class="col-sm-12 col-md-4">
                                                    <div class="form-floating">
                                                        <input asp-for="Achievement" class="form-control" type="text" placeholder="@Html.SmartLocalize("Achievement")" />
                                                        <label asp-for="Achievement">@Html.SmartLocalize("Achievement")</label>
                                                    </div>
                                                </div>
                                                <button class="btn btn-outline-primary rounded-pill me-1 mb-1 mx-3" type="submit" style="width: 100px;">
                                                    @Html.SmartLocalize("Add")
                                                </button>
                                            </div>
                                        </div>

                                        <h4 class="border-bottom">@Html.SmartLocalize("Academic Qualification Summary")</h4>

                                        <div class="col-sm-12 col-md-12 col-xl-12 px-4 mt-4">
                                            <table class="table" id="educationalTable">
                                                <thead>
                                                    <tr>
                                                        <th scope="col">@Html.SmartLocalize("Exam Title")</th>
                                                        <th scope="col">@Html.SmartLocalize("Concentration/Major")</th>
                                                        <th scope="col">@Html.SmartLocalize("Institute")</th>
                                                        <th scope="col">@Html.SmartLocalize("Result")</th>
                                                        <th scope="col">@Html.SmartLocalize("Pas.Year")</th>
                                                        <th scope="col">@Html.SmartLocalize("Duration")</th>
                                                        <th scope="col">@Html.SmartLocalize("Achievement")</th>
                                                        <th scope="col">@Html.SmartLocalize("Action")</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                   
                                                </tbody>
                                            </table>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/pages/employees/employeevalidator.js"></script>
    <script src="~/js/pages/employees/employeeeducational.js"></script>

    <script src="~/js/pages/employees/employeetabchange.js"></script>
}