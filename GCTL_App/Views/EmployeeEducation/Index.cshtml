                                                            <option value="jsc">Junior School Certificate (JSC)</option>
                                                            <option value="ssc">Secondary School Certificate (SSC) / O-Level</option>
                                                            <option value="hsc">Higher Secondary Certificate (HSC) / A-Level</option>
                                                            <option value="bachelor">Bachelor's Degree (B.A., B.Sc., B.Com., etc.)</option>
                                                            <option value="masters">Master's Degree (M.A., M.Sc., M.Com., etc.)</option>
                                                            <option value="mphil">MPhil</option>
                                                            <option value="phd">Ph.D.</option>
                                                            <option value="diploma">Diploma (e.g., Engineering, Nursing, etc.)</option>
                                                            <option value="vocational">Vocational Training Certificate</option>
                                                        </select>
                                                        <label for="floatingSelectLitigation">Select Exam/Degree Title</label>
                                                    </div>
                                                </div>

                                                <div class="col-sm-12 col-md-4">
                                                    <div class="form-floating">
                                                        <input class="form-control" id="" type="text" placeholder="Concentration/ Major/Group" required />
                                                        <label for="">Concentration/ Major/Group</label>
                                                    </div>
                                                </div>

                                                <div class="col-sm-12 col-md-4">
                                                    <div class="form-floating form-floating-advance-select">
                                                        <select class="form-select" id="organizerSingle" data-choices="data-choices"
                                                                data-options='{"removeItemButton":true,"placeholder":true}'>
                                                            <option value="">Select your education board</option>
                                                            <option value="dhaka">Dhaka Education Board</option>
                                                            <option value="chittagong">Chittagong Education Board</option>
                                                            <option value="rajshahi">Rajshahi Education Board</option>
                                                            <option value="khulna">Khulna Education Board</option>
                                                            <option value="barisal">Barisal Education Board</option>
                                                            <option value="sylhet">Sylhet Education Board</option>
                                                            <option value="comilla">Comilla Education Board</option>
                                                            <option value="dinajpur">Dinajpur Education Board</option>
                                                            <option value="madrasah">Madrasah Education Board</option>
                                                            <option value="technical">Technical Education Board</option>
                                                        </select>
                                                        <label for="floatingSelectLitigation">Select Exam/Degree Title</label>
                                                    </div>
                                                </div>

                                                <div class="col-sm-12 col-md-4">
                                                    <div class="form-floating">
                                                        <input class="form-control" id="" type="text" placeholder="Institute Name" required />
                                                        <label for="">Institute Name </label>
                                                    </div>
                                                </div>


                                                <div class="col-sm-12 col-md-4">
                                                    <div class="form-floating form-floating-advance-select">
                                                        <select class="form-select" id="organizerSingle" data-choices="data-choices"
                                                                data-options='{"removeItemButton":true,"placeholder":true}'>
                                                            <option value="">Select your education board</option>
                                                            <option value="fd">First Division/Class</option>
                                                            <option value="sd">Second Division/Class</option>
                                                            <option value="td">Third Division/Class</option>
                                                            <option value="Grade"></option>
                                                            <option value="Appeard">Appeard</option>
                                                            <option value="Enrolled">Enrolled</option>
                                                            <option value="Pass">Pass</option>
                                                        </select>
                                                        <label for="floatingSelectLitigation">Select Exam/Degree Title</label>
                                                    </div>
                                                </div>

                                                <div class="col-sm-12 col-md-4">
                                                    <div class="form-floating form-floating-advance-select">
                                                        <select class="form-select" id="organizerSingle" data-choices="data-choices"
                                                                data-options='{"removeItemButton":true,"placeholder":true}'>
                                                            <option value="">Select your year of passing</option>
                                                            <option value="2024">2024</option>
                                                            <option value="2023">2023</option>
                                                            <option value="2022">2022</option>
                                                            <option value="2021">2021</option>
                                                            <option value="2020">2020</option>
                                                            <option value="2019">2019</option>
                                                            <option value="2018">2018</option>
                                                            <option value="2017">2017</option>
                                                            <option value="2016">2016</option>
                                                            <option value="2015">2015</option>
                                                            <option value="2014">2014</option>
                                                            <option value="2013">2013</option>
                                                            <option value="2012">2012</option>
                                                            <option value="2011">2011</option>
                                                            <option value="2010">2010</option>
                                                            <option value="2009">2009</option>
                                                            <!-- Add more years if needed -->
                                                        </select>
                                                        </select>
                                                        <label for="floatingSelectLitigation">Year of Passing</label>
                                                    </div>
                                                </div>


                                                <div class="col-sm-12 col-md-4">
                                                    <div class="form-floating">
                                                        <input class="form-control" id="" type="text" placeholder="Duration" />
                                                        <label for="">Duration (Years)</label>
                                                    </div>
                                                </div>

                                                <div class="col-sm-12 col-md-4">
                                                    <div class="form-floating">
                                                        <input class="form-control" id="" type="text" placeholder="Achievement" />
                                                        <label for="">Achievement</label>
                                                    </div>
                                                </div>
                                                <button class="btn btn-outline-primary rounded-pill me-1 mb-1 mx-3" type="button"
                                                        style="width: 100px;">
                                                    Add
                                                </button>






                                            </div>
                                        </div>

