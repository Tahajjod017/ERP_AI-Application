<!-- Attendance Table -->
<div class="mb-4">
    <div class="card">
        <div class="card-header d-flex align-items-center justify-content-between flex-wrap row-gap-3 mb-1">
            <h4 class="mb-1">Manual Attendance Possible List</h4>
            <div class="d-flex my-xl-auto right-content align-items-center flex-wrap row-gap-3">
                <div class="me-3">
                    <input class="form-control" id="searchInput" type="text" placeholder="Search by Employee Name">
                </div>
                <div class="me-3">
                    <div class="input-icon-end position-relative">
                        <input class="form-control datetimepicker flatpickr-input" id="dateRangePicker" type="text" placeholder="d/m/y ">
                        <span class="uil uil-calendar-alt flatpickr-icon text-body-tertiary"></span>
                    </div>
                </div>
                <div class="dropdown me-3">
                    <select class="form-select" id="departmentFilter" data-choices="data-choices" size="1" name="departmentFilter" data-options='{"removeItemButton":true,"placeholder":true}'>
                        <option value="">Select Department</option>
                        <option>IT</option>
                        <option>HR</option>
                        <option>Finance</option>
                        <option>Marketing</option>
                        <option>Operations</option>
                    </select>
                </div>
                <div class="dropdown me-3">
                    @*<select class="form-select" id="possibleReasonFilter" data-choices="data-choices" size="1" name="statusFilter" data-options='{"removeItemButton":true,"placeholder":true}'>
                            <option value="">All Possible Reasons</option>
                            <option value="In Time Missing">In Time Missing</option>
                            <option value="Out Time Missing">Out Time Missing</option>
                            <option value="Break In Missing">Break In Missing</option>
                            <option value="Break Out Missing">Break Out Missing</option>
                            <option value="Multiple Missing">Multiple Missing</option>
                            <option value="Over Punching">Over Punching</option>
                            <option value="Complete Record">Complete Record</option>
                        </select>*@


                    <select class="form-select choiceDD" id="possibleReasonFilter" asp-items="@ViewBag.ViolationTypeList as SelectList">
                        <option value="">@Html.SmartLocalize("Select Type")</option>
                    </select>

                </div>
                <div class="dropdown me-3">
                    <select class="form-select" id="sortFilter" data-choices="data-choices" size="1" name="sortFilter" data-options='{"removeItemButton":true,"placeholder":true}'>
                        <option value="">Sort by: Latest</option>
                        <option>Latest</option>
                        <option>Oldest</option>
                        <option>Employee Name</option>
                        <option>Department</option>
                    </select>
                </div>
                <div class="dropdown me-3">
                    <select class="form-select" id="pageSizeSelect" data-choices="data-choices" size="1" name="pageSizeSelect" data-options='{"removeItemButton":true,"placeholder":true}'>
                        <option value="10">10 per page</option>
                        <option value="25">25 per page</option>
                        <option value="50">50 per page</option>
                        <option value="100">100 per page</option>
                    </select>
                </div>
                <div class="dropdown me-3">
                    <button id="btnChecked" class="btn btn-primary d-flex align-items-center">
                        <i class="ti ti-circle-plus me-2"></i>Mark as Checked
                    </button>
                </div>
            </div>
        </div>
        <div class="border-translucent p-3 pt-0">
            <div id="manualAttendanceListTable">
                <div class="table-responsive scrollbar mx-n1 px-1">
                    <table class="table table-sm fs-9 leads-table">
                        <thead>
                            <tr>
                                <th class="white-space-nowrap fs-9 align-middle ps-0" style="max-width:20px; width:18px;">
                                    <div class="form-check mb-0 fs-8">
                                        <input class="form-check-input" type="checkbox" id="checkAll" />
                                        

                                    </div>
                                </th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="employeeName">Employee</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="department">Department</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="attendanceDate">Date</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="scheduleTime">Schedule Time</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="overtime">Overtime</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="biometricHits">Biometric Hits</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="possibleReason">Possible Reason</th>
                            </tr>
                        </thead>
                        <tbody class="list" id="attendance-body">
                            <!-- Data will be populated by JavaScript -->
                        </tbody>
                    </table>
                </div>
                <div class="row align-items-center justify-content-between pe-0 fs-9">
                    <div class="col-auto d-flex">
                        <p class="mb-0 d-none d-sm-block me-3 fw-semibold text-body" data-list-info="data-list-info"></p>
                    </div>
                    <div class="col-auto d-flex">
                        <button class="page-link" data-list-pagination="prev"><span class="fas fa-chevron-left"></span></button>
                        <ul class="mb-0 pagination"></ul>
                        <button class="page-link pe-0" data-list-pagination="next"><span class="fas fa-chevron-right"></span></button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Attendance Modal -->
<div class="modal fade" id="apply_leave">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">Add/Edit Attendance</h4>
                <button type="button" class="btn-close custom-btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="manualAtd">
                <div class="modal-body pb-0">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Employee Name</label>
                                
                                <select class="form-select choiceDD" id="manualEmployeeID" name="employeeName" asp-items="@ViewBag.EmployeeDD as SelectList" required>

                                    <option value="">Select Employee</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Date</label>
                                <input type="text" class="form-control datetimepicker" id="manualAttendanceDate" name="attendanceDate" placeholder="dd/mm/yyyy" >
                            </div> 
                            <div class="mb-3">
                                <label class="form-label">Assign Shift</label>
                                <input type="text" class="form-control" id="manualAssignShift" name="assignShift"  >
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Add Time As Shift</label>
                                <input type="checkbox" id="manualChkBox"  name="chkBox"  >
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Actual In Time</label>
                                <div class="input-icon-end position-relative">
                                    <input class="form-control datetimepicker timepicker-12hr" id="manualActualInTime" name="actualInTime" type="text" placeholder="hour : minute" readonly="readonly" />
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Actual Out Time</label>
                                <div class="input-icon-end position-relative">
                                    <input class="form-control datetimepicker timepicker-12hr" id="manualActualOutTime" name="actualOutTime" type="text" placeholder="hour : minute" readonly="readonly" />
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Break Time (Add Time)</label>
                                <div class="input-icon-end position-relative">
                                    <input class="form-control datetimepicker timepicker-12hr" id="manualBreakInTime" name="breakInTime" type="text" placeholder="hour : minute" readonly="readonly" />
                                </div>
                            </div>
                            
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light me-2" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Horizontal Timeline Modal -->
<div class="modal fade" id="edit_leaves_horizontal">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">Edit Attendance</h4>
                <button type="button" class="btn-close custom-btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form>
                <div class="modal-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input id="empName" type="text" class="form-control" name="employeeName" disabled>
                                <input id="empId" type="hidden" name="empId">
                                <label for="empName" class="form-label">Employee Name</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="flatpickr-input-container">
                                <div class="form-floating">
                                    <input id="Date" class="form-control datetimepicker" type="text" name="attendanceDate" placeholder="Date" data-options='{"disableMobile":true}' disabled style="background: #f4f6f9;" />
                                    <label class="ps-6" for="Date">Date</label>
                                    <span class="uil uil-calendar-alt flatpickr-icon text-body-tertiary" style="color: #8a94ad !important;"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row mb-sm-2 mb-md-0">

                        <div class="col-md-6">
                            <div class="form-floating">
                                <input id="shiftName" type="text" class="form-control" name="shiftName" disabled>
                                <label for="shiftName" class="form-label">Shift</label>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="input-group">
                                <div class="flatpickr-input-container" style="width: 83%;">
                                    <div class="form-floating">
                                        <input id="time" class="form-control datetimepicker timepicker-12hr" type="text" name="actualInTime" placeholder="hour : minute" data-options='{"disableMobile":true}' />
                                        <label class="ps-6" for="time">Add Time</label>
                                        <span class="uil uil-clock flatpickr-icon text-body-tertiary"></span>
                                    </div>
                                </div>
                                <button type="button" class="btn btn-outline-primary" id="btnAddTime">
                                    <i class="uil uil-plus"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="mt-2">
                        <label class="form-label">Punch History</label>
                        <div class="timeline-wrapper">
                            <div class="timeline-horizontal" id="timelineContainer">
                                <!-- Timeline items inserted via JS -->
                            </div>
                        </div>
                    </div>

                    <div class="mt-2">
                        <div class="form-floating">
                            <textarea id="possibleText" type="text" class="form-control" name="possibleText" disabled></textarea>
                            <label for="possibleText" class="form-label">Possible Reason</label>
                        </div>
                    </div>

                </div>
                <div class="modal-footer">
                    <button type="button" id="hoClMo" class="btn btn-light me-2" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="confirmCloseModal" tabindex="-1" aria-labelledby="confirmCloseModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body text-center">
                <span class="avatar avatar-xl bg-transparent-danger mb-3" style="color: red;">
                    <i class="fa fa-trash fs-5"></i>
                </span>
                @* <h4 class="mb-1">Confirm Delete</h4> *@
                <h4 class="modal-title" style="color: red;">Are you sure you want to Close?</h4>
                <p class="mb-3">This action cannot be undone.</p>
                <div class="d-flex justify-content-center">
                    <a href="javascript:void(0);" class="btn btn-light me-3" data-coreui-dismiss="modal">Cancel</a>
                    <a class="btn btn-danger" id="confirmDeleteBtn">Yes, Delete</a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Vertical Timeline Modal -->
<div class="modal fade" id="edit_leaves_vertical">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">Edit Attendance</h4>
                <button type="button" class="btn-close custom-btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form>
                <div class="modal-body pb-0">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Punch History</label>
                                <div class="card">
                                    <div class="card-body">
                                        <div class="timeline" id="verticalTimelineContainer">
                                            <!-- Timeline items inserted via JS -->
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <div class="form-floating">
                                    <input id="empName2" type="text" class="form-control" name="employeeName" disabled>
                                    <label for="empName2" class="form-label">Employee Name</label>
                                </div>
                            </div>
                            <div class="mb-3">
                                <div class="flatpickr-input-container">
                                    <div class="form-floating">
                                        <input id="Date2" class="form-control datetimepicker" type="text" name="attendanceDate" placeholder="Date" data-options='{"disableMobile":true}' />
                                        <label class="ps-6" for="Date2">Date</label>
                                        <span class="uil uil-calendar-alt flatpickr-icon text-body-tertiary"></span>
                                    </div>
                                </div>
                            </div>
                            <div class="mb-3">
                                <div class="input-group">
                                    <div class="flatpickr-input-container" style="width: 83%;">
                                        <div class="form-floating">
                                            <input id="time2" class="form-control datetimepicker timepicker-12hr" type="text" name="actualInTime" placeholder="hour : minute" data-options='{"disableMobile":true}' />
                                            <label class="ps-6" for="time2">Time</label>
                                            <span class="uil uil-clock flatpickr-icon text-body-tertiary"></span>
                                        </div>
                                    </div>
                                    <button type="button" class="btn btn-outline-primary" id="btnAddTime2">
                                        <i class="uil uil-plus"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light me-2" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

