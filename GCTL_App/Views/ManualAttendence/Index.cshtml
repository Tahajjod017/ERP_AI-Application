                            <h4 id="doubleEntry">05</h4>
                        </div>
                        <div class="d-flex">
                            <div class="flex-shrink-0 me-2">
                                <span class="avatar avatar-md d-flex">
                                    <i class="ti ti-hexagonal-prism-plus fs-5 text-white"></i>
