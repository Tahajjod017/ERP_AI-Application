<link href="~/js/layout/flatpickr/flatpickr.min.css" rel="stylesheet" />

<style>
    /* Existing styles remain unchanged */
    .timeline-horizontal {
        display: flex;
        overflow-x: auto;
        padding: 20px 0;
        position: relative;
        scroll-behavior: smooth;
    }

        .timeline-horizontal::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 0;
            height: 2px;
            width: 100%;
            background: #e9ecef;
            z-index: 0;
        }

    .timeline-item-horizontal {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        min-width: 120px;
        margin-right: 30px;
        z-index: 1;
        transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1), margin 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }

        .timeline-item-horizontal.shift-left {
            transform: translateX(-50px);
        }

        .timeline-item-horizontal.shift-right {
            transform: translateX(150px);
        }

        .timeline-item-horizontal.deletable {
            position: relative;
        }

            .timeline-item-horizontal.deletable:hover::after {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: rgba(0, 0, 0, 0.1);
                border-radius: 8px;
                opacity: 0;
                transition: opacity 0.4s ease-in-out;
                z-index: 1;
            }

            .timeline-item-horizontal.deletable:hover::after {
                opacity: 1;
            }

            .timeline-item-horizontal.deletable:hover .timeline-delete-btn {
                opacity: 1;
                transform: translate(-50%, -50%);
                top: 50%;
                transition: all 0.4s ease-in-out;
            }

        .timeline-item-horizontal.slide-from-input {
            animation: slideFromInputHorizontal 0.4s ease-in-out forwards;
        }

        .timeline-item-horizontal.fly-out {
            animation: flyOut 0.4s ease-in-out forwards;
        }

    .timeline-icon {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background-color: #007bff;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 12px;
        margin-bottom: 8px;
        border: 2px solid white;
        z-index: 2;
    }

        .timeline-icon.not-punched {
            background-color: #6c757d;
            border: 2px dashed #adb5bd;
        }

    .timeline-time {
        font-weight: 600;
        color: #495057;
        font-size: 14px;
        margin-top: 5px;
    }

    .timeline-label {
        font-size: 11px;
        color: #6c757d;
        opacity: 0.6;
        font-style: italic;
    }

    .timeline-wrapper {
        border: 1px solid #e9ecef;
        background: #f8f9fa;
        border-radius: 8px;
        max-height: 180px;
        overflow-x: auto;
        overflow-y: hidden;
    }

    .timeline {
        position: relative;
        padding: 0;
        max-height: 300px;
        overflow-y: auto;
        padding-right: 10px;
    }

        .timeline::before {
            content: '';
            position: absolute;
            top: 0;
            left: 30px;
            height: 100%;
            width: 2px;
            background: #e9ecef;
        }

    .timeline-item {
        position: relative;
        padding-left: 70px;
        padding-bottom: 20px;
        transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1), margin 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }

        .timeline-item:last-child {
            padding-bottom: 0;
        }

        .timeline-item.shift-up {
            transform: translateY(-30px);
        }

        .timeline-item.shift-down {
            transform: translateY(80px);
        }

        .timeline-item.deletable {
            position: relative;
        }

            .timeline-item.deletable:hover::after {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: rgba(0, 0, 0, 0.1);
                border-radius: 8px;
                opacity: 0;
                transition: opacity 0.4s ease-in-out;
                z-index: 1;
            }

            .timeline-item.deletable:hover::after {
                opacity: 1;
            }

            .timeline-item.deletable:hover .timeline-delete-btn {
                opacity: 1;
                transform: translate(-50%, -50%);
                top: 50%;
                transition: all 0.4s ease-in-out;
            }

        .timeline-item.slide-from-input {
            animation: slideFromInputVertical 0.4s ease-in-out forwards;
        }

        .timeline-item.fly-out {
            animation: flyOut 0.4s ease-in-out forwards;
        }

        .timeline-item .timeline-icon {
            position: absolute;
            left: 18px;
            top: 0;
            width: 24px;
            height: 24px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 10px;
            color: white;
            z-index: 1;
            background-color: #007bff;
        }

            .timeline-item .timeline-icon.not-punched {
                background-color: #6c757d;
                border: 2px dashed #adb5bd;
            }

    .timeline-content {
        background: #f8f9fa;
        border: 1px solid #e9ecef;
        border-radius: 8px;
        padding: 12px 16px;
        margin-top: -2px;
    }

        .timeline-content .timeline-time {
            font-weight: 600;
            color: #495057;
            font-size: 14px;
        }

        .timeline-content .timeline-label {
            font-size: 11px;
            color: #6c757d;
            opacity: 0.6;
            font-style: italic;
            position: absolute;
            right: 10px;
            top: 12px;
        }

    .not-punched-text {
        color: #dc3545;
        font-style: italic;
        font-size: 13px;
    }

    .timeline::-webkit-scrollbar {
        width: 6px;
    }

    .timeline::-webkit-scrollbar-track {
        background: #f1f1f1;
        border-radius: 3px;
    }

    .timeline::-webkit-scrollbar-thumb {
        background: #c1c1c1;
        border-radius: 3px;
    }

        .timeline::-webkit-scrollbar-thumb:hover {
            background: #a1a1a1;
        }

    .flatpickr-calendar {
        width: 17.3% !important;
    }

    .timeline-delete-btn {
        position: absolute;
        top: -5px;
        right: -5px;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: #dc3545;
        border: 2px solid white;
        color: white;
        font-size: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 3;
        opacity: 0;
        transform: translate(-50%, -100%);
        transition: all 0.4s ease-in-out;
    }

    .timeline-item-horizontal:not(.deletable):hover,
    .timeline-item:not(.deletable):hover {
        cursor: default;
    }

    .timeline-item-horizontal:not(.deletable) .timeline-delete-btn,
    .timeline-item:not(.deletable) .timeline-delete-btn {
        display: none;
    }

    @@keyframes slideFromInputHorizontal {
        from {
            transform: translateX(var(--start-x, 0)) scale(0.8);
            opacity: 0;
        }

        to {
            transform: translateX(0) scale(1);
            opacity: 1;
        }
    }

    @@keyframes slideFromInputVertical {
        from {
            transform: translateY(var(--start-y, 0)) scale(0.8);
            opacity: 0;
        }

        to {
            transform: translateY(0) scale(1);
            opacity: 1;
        }
    }

    @@keyframes flyOut {
        from {
            opacity: 1;
            transform: translateY(0) scale(1);
        }

        to {
            opacity: 0;
            transform: translateY(-20px) scale(0.5);
        }
    }
</style>

