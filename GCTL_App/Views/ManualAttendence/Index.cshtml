<style>
        .timeline {
            position: relative;
            padding: 0;
        }

            .timeline::before {
                content: '';
                position: absolute;
                top: 0;
                left: 30px;
                height: 100%;
                width: 2px;
                background: #e9ecef;
            }

        .timeline-item {
            position: relative;
            padding-left: 70px;
            padding-bottom: 20px;
        }

            .timeline-item:last-child {
                padding-bottom: 0;
            }

        .timeline-icon {
            position: absolute;
            left: 18px;
            top: 0;
            width: 24px;
            height: 24px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 10px;
            color: white;
            z-index: 1;
        }

        .timeline-icon {
            background-color: #007bff;
        }

            .timeline-icon.not-punched {
                background-color: #6c757d;
                border: 2px dashed #adb5bd;
            }

        .timeline-content {
            background: #f8f9fa;
            border: 1px solid #e9ecef;
            border-radius: 8px;
            padding: 12px 16px;
            margin-top: -2px;
        }

        .timeline-time {
            font-weight: 600;
            color: #495057;
            font-size: 14px;
        }

        .timeline-label {
            font-size: 11px;
            color: #6c757d;
            opacity: 0.6;
            font-style: italic;
            position: absolute;
            right: 10px;
            top: 12px;
        }

        .not-punched-text {
            color: #dc3545;
            font-style: italic;
            font-size: 13px;
        }
    </style>

    <div class="modal fade" id="edit_leaves">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h4 class="modal-title">Edit Attendance</h4>
                    <button type="button" class="btn-close custom-btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form>
                    <div class="modal-body pb-0">
                        <div class="row">
                            <div class="col-md-6">



                                <div class="mb-3">
                                    <label class="form-label">Punch History</label>
                                    <div class="card">
                                        <div class="card-body">
                                            <div class="timeline">


                                                <div class="timeline-item">
                                                    <div class="timeline-icon">
                                                        <i class="fas fa-fingerprint"></i>
                                                    </div>
                                                    <div class="timeline-content">
                                                        <div class="timeline-label">in time</div>
                                                        <div class="timeline-time" name="punchHistory1">09:45 AM</div>
                                                    </div>
                                                </div>

                                                <div class="timeline-item">
                                                    <div class="timeline-icon">
                                                        <i class="fas fa-fingerprint"></i>
                                                    </div>
                                                    <div class="timeline-content">
                                                        <div class="timeline-label">break in</div>
                                                        <div class="timeline-time" name="punchHistory2">01:00 PM</div>
                                                    </div>
                                                </div>



                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div>

                            

                            <div class="col-md-6">

                                <div class="mb-3">
                                    <div class="form-floating">
                                        <input id="empName" type="text" class="form-control" name="employeeName" disabled value="Md Shefain">
                                        <label for="empName" class="form-label">@Html.SmartLocalize("Employee Name")</label>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <div class="flatpickr-input-container">
                                        <div class="form-floating">
                                            <input id="Date" class="form-control datetimepicker" type="text" name="attendanceDate" placeholder="@Html.SmartLocalize("Date")" data-options='{"disableMobile":true}' />
                                            <label class="ps-6" for="Date">@Html.SmartLocalize("Date")</label><span class="uil uil-calendar-alt flatpickr-icon text-body-tertiary"></span>
                                        </div>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <div class="input-group">
                                        <div class="flatpickr-input-container" style="width: 83%;">
                                            <div class="form-floating">
                                                <input id="time" class="form-control datetimepicker timepicker-12hr"
                                                       type="text"
                                                       name="actualInTime"
                                                       placeholder="@Html.SmartLocalize("hour : minute")"
                                                       data-options='{"disableMobile":true}' />
                                                <label class="ps-6" for="time">@Html.SmartLocalize("Time")</label>
                                                <span class="uil uil-calendar-alt flatpickr-icon text-body-tertiary"></span>


                                            </div>
                                        </div>
                                        <button type="button" class="btn btn-outline-primary" id="btnAddTime">
                                            <i class="uil uil-plus"></i>
                                        </button>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light me-2" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>





