@model GCTL.Core.ViewModels.PayrollManagements.PayrollPolicy.EmpAllowanceOrganization.EmpAllowanceTypeOrganizationSaveVM

<div class="card">
    <div class="card-header border-bottom-1">
        <div class="row justify-content-between align-items-center">
            <div class="col-auto">
                <h3 class="text-body-emphasis mt-3">@Html.SmartLocalize(" Employee Allowance Type")</h3>
            </div>
        </div>
    </div>

    <div class="card-body mt-3">
        <form  enctype="multipart/form-data" id="AllowanceType-form">
            @Html.AntiForgeryToken()
            <div class="col-sm-12 col-md-12 mb-4">
                <input type="hidden" asp-for="EmployeeAllowanceTypeID" />
                <div class="flatpickr-input-container">
                    <div class="form-floating form-floating-advance-select">
                        <select class="form-select choiceDD" asp-for="OrganizationID" required asp-items="@ViewBag.OrganizationDD as SelectList">
                            <option value="">Select Organization</option>
                        </select>
                        <label asp-for="OrganizationID">@Html.SmartLocalize("Organization Name") <span style="color: red;">*</span></label>
                    </div>
                    <span asp-validation-for="OrganizationID" class="text-danger"></span>
                    <span id="nameError" class="text-danger" style="display:none;"></span>
                </div>
            </div>
            <div class="col-sm-12 col-md-12 mb-4">

                <div class="flatpickr-input-container">
                    <div class="form-floating">
                        <input class="form-control" asp-for="EmployeeAllowanceTypeName" type="text" placeholder="@Html.SmartLocalize("AllowanceTypeName")" autocomplete="off" />
                        <label asp-for="EmployeeAllowanceTypeName">@Html.SmartLocalize("Allowance Type") <span style="color: red;">*</span></label>
                    </div>
                    <span id="nameError" class="text-danger" style="display:none;"></span>
                    <span asp-validation-for="EmployeeAllowanceTypeName" class="text-danger"></span>
                </div>
            </div>
            <div class="col-12 mb-4">
                <div class="row g-3 justify-content-end">
                    <div class="col-auto">
                        <button type="reset" class="btn btn-phoenix-primary px-5" id="AllowanceType-resetBtn">@Html.SmartLocalize("Reset")</button>
                    </div>
                    <div class="col-auto">
                        <button type="button" class="btn btn-primary px-5 px-sm-15" id="AllowanceType-saveBtn">@Html.SmartLocalize("Save")</button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
