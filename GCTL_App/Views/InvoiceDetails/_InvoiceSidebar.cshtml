@using GCTL.Core.ViewModels.POS.Sales.InvoiceDetailsF
@model InvoiceSidebarDetailsViewModel

<div class="col-md-3 mb-4 ps-1 pe-1">
    <div class="card mb-3" style="min-height: 1050px;">
        <div class="card-body">
            <div class="invoice-card">
                <div>
                    @if (Model.IsDraft)
                    {
                        <div class="alert alert-subtle-warning" role="alert">
                            @Html.SmartLocalize("Invoice in draft mode")
                        </div>
                    }
                    else if (Model.IsFullyPaid)
                    {
                        <div class="alert alert-subtle-success" role="alert">
                            @Html.SmartLocalize("Invoice fully paid")
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-subtle-danger" role="alert">
                            @Html.SmartLocalize("Outstanding balance:") @Model.DueAmount.ToString("N2") BDT
                        </div>
                    }
                </div>

                <div class="accordion" id="accordionExample">
                    <!-- Create Section -->
                    <div class="accordion-item border-top">
                        <h2 class="accordion-header" id="headingCreate">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseCreate" aria-expanded="true" aria-controls="collapseCreate">
                                @Html.SmartLocalize("Create")
                            </button>
                        </h2>
                        <div class="accordion-collapse collapse show" id="collapseCreate" aria-labelledby="headingCreate" data-bs-parent="#accordionExample">
                            <div class="accordion-body pt-0">
                                <p class="fs-9" id="createPerson">
                                    <strong>@Html.SmartLocalize("Created By:")</strong> @Model.CreatedByName <br />
                                    <strong>@Html.SmartLocalize("Created At:")</strong> @Model.CreatedAt?.ToString("MMM dd, yyyy hh:mm tt")
                                    @if (!string.IsNullOrEmpty(Model.UpdatedByName))
                                    {
                                        <br />
                                        <strong>@Html.SmartLocalize("Updated By:")</strong> @Model.UpdatedByName <br />
                                        <strong>@Html.SmartLocalize("Updated At:")</strong> @Model.UpdatedAt?.ToString("MMM dd, yyyy hh:mm tt")
                                    }
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Payment Status Section -->
                    <div class="accordion-item border-top">
                        <h2 class="accordion-header" id="headingPayment">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapsePayment" aria-expanded="true" aria-controls="collapsePayment">
                                @Html.SmartLocalize("Payment Status")
                            </button>
                        </h2>
                        <div class="accordion-collapse collapse show" id="collapsePayment" aria-labelledby="headingPayment" data-bs-parent="#accordionExample">
                            <div class="accordion-body pt-0">
                                <p class="fs-9 mb-0">
                                    <strong>@Html.SmartLocalize("Total Amount:")</strong> @Model.TotalAmount.ToString("N2") BDT<br>
                                    <strong>@Html.SmartLocalize("Paid Amount:")</strong> <span class="text-success">@Model.PaidAmount.ToString("N2") BDT</span><br>
                                    <strong>@Html.SmartLocalize("Due Amount:")</strong> <span class="text-danger">@Model.DueAmount.ToString("N2") BDT</span><br>
                                    @if (!Model.IsFullyPaid && !Model.IsDraft)
                                    {
                                        
                                        <a href="javascript:void(0)" onclick="addPayment(@Model.InvoiceId)" class="btn btn-sm btn-phoenix-primary ">
                                            <i class="fa fa-plus me-1"></i> @Html.SmartLocalize("Add Payment")
                                        </a>
                                    }
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Edit Section -->
                    <div class="accordion-item border-top">
                        <h2 class="accordion-header" id="headingEdit">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseEdit" aria-expanded="true" aria-controls="collapseEdit">
                                @Html.SmartLocalize("Edit")
                            </button>
                        </h2>
                        <div class="accordion-collapse collapse show" id="collapseEdit" aria-labelledby="headingEdit" data-bs-parent="#accordionExample">
                            <div class="accordion-body pt-0">
                                <p class="fs-9">
                                    @Html.SmartLocalize("Invoice Number:") @Model.InvoiceNumber <br>
                                    @if (Model.CanEdit)
                                    {
                                        <a href="@Url.Action("Edit", "InvoiceDetails", new { id = Model.InvoiceId })">@Html.SmartLocalize("Edit Invoice")</a>
                                    }
                                    else
                                    {
                                        @foreach (var item in Model.InvoiceIdList)
                                        {
                                            <a href="@Url.Action("Edit", "InvoiceDetails", new { id = item.id })">@Html.SmartLocalize("Edit Invoice") @item.version</a> @item.draftSign @item.finalSign <br>
                                        }
                                    }
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Duplicate Section -->
                    @*<div class="accordion-item border-top">
            <h2 class="accordion-header" id="headingDuplicate">
                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseDuplicate" aria-expanded="true" aria-controls="collapseDuplicate">
                    @Html.SmartLocalize("Duplicate")
                </button>
            </h2>
            <div class="accordion-collapse collapse show" id="collapseDuplicate" aria-labelledby="headingDuplicate" data-bs-parent="#accordionExample">
                <div class="accordion-body pt-0">
                    <p class="fs-9">
                        @Html.SmartLocalize("Invoice Number:") @Model.InvoiceNumber <br>
                        <a href="javascript:void(0)" onclick="duplicateInvoice(@Model.InvoiceId)">@Html.SmartLocalize("Create Duplicate")</a>
                    </p>
                </div>
            </div>
        </div>*@

                    <!-- Source Sales Order Section -->
                    @if (!string.IsNullOrEmpty(Model.SalesOrderNumber))
                    {
                        <div class="accordion-item border-top">
                            <h2 class="accordion-header" id="headingSalesOrder">
                                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseSalesOrder" aria-expanded="true" aria-controls="collapseSalesOrder">
                                    @Html.SmartLocalize("Sales Order")
                                </button>
                            </h2>
                            <div class="accordion-collapse collapse show" id="collapseSalesOrder" aria-labelledby="headingSalesOrder" data-bs-parent="#accordionExample">
                                <div class="accordion-body pt-0">
                                    <span class="fs-9">
                                        @Html.SmartLocalize("Sales Order Number: ")
                                    <a href="@Url.Action("index", "SalesOrderDetails", new { id = Model.SalesOrderId })">@Model.SalesOrderNumber</a>

                                </span>
                            </div>
                        </div>
                    </div>
                }


                    <div class="accordion-item border-top">
                        <div class="accordion-header" id="headingShipment">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseShipment" aria-expanded="true" aria-controls="collapseShipment">
                                @Html.SmartLocalize("Challan")



                                @if (Model.IsFullyShipped)
                                {
                                    <span class="ms-3 badge badge-phoenix badge-phoenix-primary">
                                        <i class="fas fa-check-circle me-2"></i>
                                        @Html.SmartLocalize("Fully Shipped")
                                    </span>
                                }
                                else if (Model.HasShipmentsStarted)
                                {
                                    <div class="ms-3 badge badge-phoenix badge-phoenix-secondary">
                                        <i class="fas fa-shipping-fast me-2"></i>
                                        @Html.SmartLocalize("Partially Challaned")
                                    </div>
                                }
                            </button>



                        </div>



                        <div class="accordion-collapse collapse show" id="collapseShipment" aria-labelledby="headingShipment" data-bs-parent="#accordionExample">
                            <div class="accordion-body pt-0">
                                @if (Model.CanCreateShipment && !Model.IsFullyShipped)
                                {
                                    <p class="fs-9">
                                        <a href="/Challan/Index?salesOrderId=@Model.SalesOrderId" class="btn btn-sm btn-phoenix-primary w-100">
                                            <i class="fas fa-shipping-fast me-2"></i>
                                            @Html.SmartLocalize("Create Challan")
                                        </a>
                                    </p>
                                }





                                @if (Model.HasShipments && Model.Shipments != null && Model.Shipments.Any())
                                {
                                    <hr class="my-2" />
                                    <p class="fs-9 fw-bold mb-2">@Html.SmartLocalize("Existing Challan:")</p>
                                    @foreach (var shipment in Model.Shipments)
                                    {
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <a href="/ChallanDetails/Index/@shipment.ShipmentId" class="fs-9 text-decoration-none">
                                                @shipment.ShipmentNumber
                                            </a>


                                            <span class="badge badge-phoenix badge-phoenix-@shipment.StatusClass fs-10">
                                                @shipment.Status
                                            </span>





                                        </div>
                                    }
                                }
                                else if (!Model.CanCreateShipment)
                                {
                                    <p class="fs-9 text-muted">@Html.SmartLocalize("No Challan available")</p>
                                }
                            </div>
                        </div>
                    </div>


                    <!-- Send Email Section -->
                    <div class="accordion-item">
                        <h2 class="accordion-header" id="headingEmail">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseEmail" aria-expanded="true" aria-controls="collapseEmail">
                                @Html.SmartLocalize("Send Email")
                            </button>
                        </h2>
                        <div class="accordion-collapse collapse show" id="collapseEmail" aria-labelledby="headingEmail" data-bs-parent="#accordionExample">
                            <div class="accordion-body pt-0">
                                @if (Model.CanSendEmail)
                                {
                                    <a class="btn btn-subtle-primary me-1 mb-1" type="button" data-bs-toggle="modal" data-bs-target="#showSendModal"><i class="far fa-envelope" aria-hidden="true"></i></a>
                                    <a class="btn btn-subtle-primary me-1 mb-1" type="button" onclick="printInvoice(@Model.InvoiceId)"><i class="fa fa-print" aria-hidden="true"></i></a>
                                }
                            </div>
                        </div>
                    </div>

                    @if (Model.CanEdit)
                    {
                        <div class="accordion-item border-top">
                            <h2 class="accordion-header" id="headingStatus">
                                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseStatus" aria-expanded="true" aria-controls="collapseStatus">
                                    @Html.SmartLocalize("Status Actions")
                                </button>
                            </h2>
                            <div class="accordion-collapse collapse show" id="collapseStatus" aria-labelledby="headingStatus" data-bs-parent="#accordionExample">
                                <div class="accordion-body pt-0">
                                    <p class="fs-9">
                                        <a href="javascript:void(0)" onclick="markAsApproved(@Model.InvoiceId)">@Html.SmartLocalize("Mark as Approved")</a>
                                    </p>
                                </div>
                            </div>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
</div>

<!-- Send Email Modal -->
<div class="modal fade" id="showSendModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@Html.SmartLocalize("Send Invoice via Email")</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">@Html.SmartLocalize("Recipient Email")</label>
                    <input type="email" class="form-control" id="recipientEmail" placeholder="@Html.SmartLocalize("customer@example.com")">
                </div>
                <div class="mb-3">
                    <label class="form-label">@Html.SmartLocalize("Subject")</label>
                    <input type="text" class="form-control" id="emailSubject" value="@Html.SmartLocalize("Invoice -") @Model.InvoiceNumber">
                </div>
                <div class="mb-3">
                    <label class="form-label">@Html.SmartLocalize("Message")</label>
                    <textarea class="form-control" id="emailMessage" rows="5">@Html.SmartLocalize("Dear Customer,\nPlease find attached the invoice for your review.\nBest regards")</textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Html.SmartLocalize("Close")</button>
                <button type="button" class="btn btn-primary" onclick="sendEmailNow(@Model.InvoiceId)">@Html.SmartLocalize("Send Email")</button>
            </div>
        </div>
    </div>
</div>

<script>

    function markAsApproved(invoiceId) {
        if (confirm('Mark this Sales Order as Approved?')) {
            $.ajax({
                url: '/InvoiceDetails/UpdateStatus',
                method: 'POST',
                data: {
                    id: invoiceId,
                    status: 3 // QuotationStatus.Approved
                },
                success: function (response) {
                    if (response.success) {
                        toastr.success('Quotation marked as Approved!');
                        location.reload();
                    } else {
                        toastr.warning('Failed to update status: ' + response.message);
                    }
                },
                error: function () {
                    toastr.error('Failed to update status. Please try again.');
                }
            });
        }
    }

    function duplicateInvoice(invoiceId) {
        if (confirm('@Html.SmartLocalize("Are you sure you want to duplicate this invoice?")')) {
            $.ajax({
                url: '/InvoiceDetails/Duplicate',
                method: 'POST',
                data: { id: invoiceId },
                success: function (response) {
                    if (response.success) {
                        toastr.success('@Html.SmartLocalize("Invoice duplicated successfully!")');
                        window.location.href = '/InvoiceDetails/Index/' + response.newInvoiceId;
                    } else {
                        toastr.error('@Html.SmartLocalize("Failed to duplicate:") ' + response.message);
                    }
                },
                error: function () {
                    toastr.error('@Html.SmartLocalize("Failed to duplicate invoice.")');
                }
            });
        }
    }

    function sendEmailNow(invoiceId) {
        const recipient = $('#recipientEmail').val();
        const subject = $('#emailSubject').val();
        const message = $('#emailMessage').val();
        if (!recipient) {
            toastr.warning('@Html.SmartLocalize("Please enter recipient email address")');
            return;
        }
        $.ajax({
            url: '/InvoiceDetails/SendEmail',
            method: 'POST',
            data: {
                id: invoiceId,
                recipientEmail: recipient,
                subject: subject,
                message: message
            },
            success: function (response) {
                if (response.success) {
                    toastr.success('@Html.SmartLocalize("Email sent successfully!")');
                    $('#showSendModal').modal('hide');
                } else {
                    toastr.error('@Html.SmartLocalize("Failed to send email:") ' + response.message);
                }
            },
            error: function () {
                toastr.error('@Html.SmartLocalize("Failed to send email.")');
            }
        });
    }

    function printInvoice(invoiceId) {
        window.open('/InvoiceDetails/PrintPDF/' + invoiceId, '_blank');
    }

    function addPayment(invoiceId) {
        window.location.href = '/Payment/Create?invoiceId=' + invoiceId;
    }
</script>