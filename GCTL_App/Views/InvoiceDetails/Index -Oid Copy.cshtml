                        + Add an Item
                    </a>
                </td>
            </tr>
            <tr>
                <td colspan="4" class="text-end fs-9 fw-bold">Sub Total Taka.</td>
                <td colspan="2" class="text-center fs-9 fw-bold" id="subTotal">@Model.SubTotal.ToString("N2")</td>
            </tr>
            <tr>
                <td colspan="4" class="text-end fs-9 py-2">
                    <div class="d-flex justify-content-end">
                        <div class="mx-2 mt-2">VAT (%)</div>
                        <div><input asp-for="VatPercent" id="vatPercent" class="form-control" type="number" step="any" /></div>
                    </div>
                </td>
                <td colspan="2" class="text-center fs-9" id="vatAmount">@Model.VatAmount.ToString("N2")</td>
            </tr>
            <tr>
                <td colspan="4" class="text-end h5">Grand Total Taka</td>
                <td colspan="2" class="text-center h5" id="grandTotal">@Model.GrandTotal.ToString("N2")</td>
            </tr>
        </tbody>*@
                            </table>
                        </div>



                        <!-- BILLING ADDRESS -->
                        <div class="row col-xl-12 mb-3 mt-4">
                            <p class="mb-1 fw-bold fs-8">Billing Address</p>
                            <div class="border-bottom border-2 mb-3"></div>
                            <div class="row">
                                <div class="col-xl-6">
                                    <div class="mb-3">
                                        <label class="form-label">First Name</label>
                                        <input asp-for="BillingAddress.FirstName" id="billingFirstName" class="form-control" />
                                    </div>
                                </div>
                                <div class="col-xl-6">
                                    <div class="mb-3">
                                        <label class="form-label">Last Name</label>
                                        <input asp-for="BillingAddress.LastName" id="billingLastName" class="form-control" />
                                    </div>
                                </div>
                                <div class="col-xl-6">
                                    <div class="mb-3">
                                        <label class="form-label">Phone</label>
                                        <input asp-for="BillingAddress.Phone" id="billingPhone" class="form-control" />
                                    </div>
                                </div>
                                <div class="col-xl-6">
                                    <div class="mb-3">
                                        <label class="form-label">Email</label>
                                        <input asp-for="BillingAddress.Email" id="billingEmail" class="form-control" />
                                    </div>
                                </div>
                                <div class="col-xl-12">
                                    <div class="mb-3">
                                        <label class="form-label">Address</label>
                                        <input asp-for="BillingAddress.FullAddress" id="billingAddress" class="form-control" />
                                    </div>
                                </div>
                                <div class="col-xl-4">
                                    <div class="mb-3">
                                        <label class="form-label">City</label>
                                        <input asp-for="BillingAddress.City" id="billingCity" class="form-control" />
                                    </div>
                                </div>
                                <div class="col-xl-4">
                                    <div class="mb-3">
                                        <label class="form-label">State</label>
                                        <input asp-for="BillingAddress.State" id="billingState" class="form-control" />
                                    </div>
                                </div>
                                <div class="col-xl-4">
                                    <div class="mb-3">
                                        <label class="form-label">Postal Code</label>
                                        <input asp-for="BillingAddress.PostalCode" id="billingPostalCode" class="form-control" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- SHIPPING ADDRESS -->
                        <div class="row col-xl-12 mb-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <p class="mb-1 fw-bold fs-8">Shipping Address</p>
                                <button type="button" class="btn btn-sm btn-secondary" id="copyBillingToShipping">
                                    <i class="fa fa-copy me-1"></i> Copy from Billing
                                </button>
                            </div>
                            <div class="border-bottom border-2 mb-3"></div>
                            <div class="row">
                                <div class="col-xl-6">
                                    <div class="mb-3">
                                        <label class="form-label">First Name</label>
                                        <input asp-for="ShippingAddress.FirstName" id="shippingFirstName" class="form-control" />
                                    </div>
                                </div>
                                <div class="col-xl-6">
                                    <div class="mb-3">
                                        <label class="form-label">Last Name</label>
                                        <input asp-for="ShippingAddress.LastName" id="shippingLastName" class="form-control" />
                                    </div>
                                </div>
                                <div class="col-xl-6">
                                    <div class="mb-3">
                                        <label class="form-label">Phone</label>
                                        <input asp-for="ShippingAddress.Phone" id="shippingPhone" class="form-control" />
                                    </div>
                                </div>
                                <div class="col-xl-6">
                                    <div class="mb-3">
                                        <label class="form-label">Email</label>
                                        <input asp-for="ShippingAddress.Email" id="shippingEmail" class="form-control" />
                                    </div>
                                </div>
                                <div class="col-xl-12">
                                    <div class="mb-3">
                                        <label class="form-label">Address</label>
                                        <input asp-for="ShippingAddress.FullAddress" id="shippingAddress" class="form-control" />
                                    </div>
                                </div>
                                <div class="col-xl-4">
                                    <div class="mb-3">
                                        <label class="form-label">City</label>
                                        <input asp-for="ShippingAddress.City" id="shippingCity" class="form-control" />
                                    </div>
                                </div>
                                <div class="col-xl-4">
                                    <div class="mb-3">
                                        <label class="form-label">State</label>
                                        <input asp-for="ShippingAddress.State" id="shippingState" class="form-control" />
                                    </div>
                                </div>
                                <div class="col-xl-4">
                                    <div class="mb-3">
                                        <label class="form-label">Postal Code</label>
                                        <input asp-for="ShippingAddress.PostalCode" id="shippingPostalCode" class="form-control" />
                                    </div>
                                </div>
                            </div>
                        </div>





                        <!-- Note -->
                        <div class="col-xl-12 mb-3">
                            <p class="mb-1 fw-bold fs-8">Note</p>
                            <div class="">
                                <textarea asp-for="InvoiceNote" class="form-control" rows="3" placeholder="Add any additional notes here..."></textarea>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="col-xl-12 mb-3">
                            <div class="d-flex justify-content-end">
                                <a href="@Url.Action("Index", "InvoiceDetails", new { id = Model.Id })" class="btn btn-secondary me-2">Cancel</a>
                                <button type="submit" class="btn btn-primary">Save Invoice</button>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Sidebar -->
                @if (sidebarData != null)
                {
                    <partial name="_InvoiceSidebar" model="sidebarData" />
                }
            </div>
        </form>
    }
    else
    {
        <!-- READ-ONLY MODE - Display only -->
        <div class="row mb-4">
            <div class="col-xl-9">
                <div class="card pt-4 p-5 mb-3" style="min-height: 1000px;">

                    <div class="row col-xl-12">
                        <p class="mb-1 fw-bold fs-7">Invoice Details</p>
                        <div class="border-bottom border-2"></div>
                    </div>

                    <div class="row mb-3 mt-3">
                        <div class="col-md-12">
                            <div class="row">
                                <!-- Customer Info -->
                                <div class="col-xl-6">
                                    <div class="card mb-3" style="min-height: 165px;">
                                        <div class="card-body">
                                            <h5 class="card-title mb-2">Customer Information</h5>
                                            <p class="mb-1 fs-9"><strong>Company:</strong> @Model.CustomerData.CompanyName</p>
                                            <p class="mb-1 fs-9"><strong>Address:</strong> @Model.CustomerData.AddressLine1</p>
                                            <p class="mb-1 fs-9"><strong>Phone:</strong> @Model.CustomerData.Phone</p>
                                            <p class="mb-1 fs-9"><strong>Email:</strong> @Model.CustomerData.Email</p>
                                        </div>
                                    </div>
                                </div>

                                <!-- Invoice Info -->
                                <div class="col-xl-6">
                                    <div class="card pb-1 ps-2 p-3 mb-3" style="min-height: 165px;">
                                        <div class="row">
                                            <div class="col-4">
                                                <div class="">
                                                    <label class="form-label fw-bold">Invoice Number</label>
                                                    <p class="fs-8 ms-3">@Model.InvoiceNumber</p>
                                                </div>
                                            </div>
                                            <div class="col-4">
                                                <div class="mb-3">
                                                    <label class="form-label fw-bold">Invoice Date</label>
                                                    <p class="fs-8 ms-3">@Model.InvoiceDate.ToString("MMM dd, yyyy")</p>
                                                </div>
                                            </div>

                                            <div class="col-4">
                                                <div class="mb-3">
                                                    <label class="form-label fw-bold">Status</label>
                                                    <p class="fs-8 ms-3">
                                                        @if (Model.IsDraft)
                                                        {
                                                            <span class="badge badge-phoenix badge-phoenix-warning">Draft</span>
                                                        }
                                                        else if (Model.GrandTotal - Model.PaidAmount <= 0)
                                                        {
                                                            <span class="badge badge-phoenix badge-phoenix-success">Paid</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge badge-phoenix badge-phoenix-danger">Unpaid</span>
                                                        }
                                                    </p>
                                                </div>
                                            </div>

                                            @if (!string.IsNullOrEmpty(Model.OtherReference))
                                            {
                                                <div class="col-4">
                                                    <div class="mb-3">
                                                        <label class="form-label fw-bold">Reference</label>
                                                        <p class="fs-8 ms-3">@Model.OtherReference</p>
                                                    </div>
                                                </div>
                                            }
                                            @if (!string.IsNullOrEmpty(Model.SalesOrderNumber))
                                            {
                                                <div class="col-4">
                                                    <div class="mb-3">
                                                        <label class="form-label fw-bold">Sales Order</label>
                                                        <p class="fs-8 ms-3">@Model.SalesOrderNumber</p>
                                                    </div>
                                                </div>
                                            }


                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Billing & Shipping Addresses -->
                    @if (Model.BillingAddress != null || Model.ShippingAddress != null)
                    {
                        <div class="row mb-3">
                            @if (Model.BillingAddress != null)
                            {
                                <div class="col-xl-6">
                                    <div class="card mb-3">
                                        <div class="card-body">
                                            <h5 class="card-title mb-2">Billing Address</h5>
                                            <p class="mb-1 fs-9">@Model.BillingAddress.FirstName @Model.BillingAddress.LastName</p>
                                            <p class="mb-1 fs-9">@Model.BillingAddress.FullAddress</p>
                                            <p class="mb-1 fs-9">@Model.BillingAddress.City, @Model.BillingAddress.State @Model.BillingAddress.PostalCode</p>
                                            <p class="mb-1 fs-9">@Model.BillingAddress.Phone</p>
                                            <p class="mb-1 fs-9">@Model.BillingAddress.Email</p>
                                        </div>
                                    </div>
                                </div>
                            }
                            @if (Model.ShippingAddress != null)
                            {
                                <div class="col-xl-6">
                                    <div class="card mb-3">
                                        <div class="card-body">
                                            <h5 class="card-title mb-2">Shipping Address</h5>
                                            <p class="mb-1 fs-9">@Model.ShippingAddress.FirstName @Model.ShippingAddress.LastName</p>
                                            <p class="mb-1 fs-9">@Model.ShippingAddress.FullAddress</p>
                                            <p class="mb-1 fs-9">@Model.ShippingAddress.City, @Model.ShippingAddress.State @Model.ShippingAddress.PostalCode</p>
                                            <p class="mb-1 fs-9">@Model.ShippingAddress.Phone</p>
                                            <p class="mb-1 fs-9">@Model.ShippingAddress.Email</p>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    <!-- Items Table (Read-only) -->
                    <div class="col-xl-12 mt-3">
                        <table class="table" style="border-bottom: 0px solid #ffffff00;">
                            <thead>
                                <tr>
                                    <th style="width: 50px;">SL</th>
                                    <th>Product</th>
                                    <th class="text-center">Quantity</th>
                                    <th class="text-center">Unit Price</th>
                                    <th class="text-center">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.Items.Count; i++)
                                {
                                    <tr>
                                        <td class="fs-8 text-center align-middle">@(i + 1)</td>
                                        <td>@Model.Items[i].ProductName</td>
                                        <td class="text-center">@Model.Items[i].Quantity.ToString("N2")</td>
                                        <td class="text-center">@Model.Items[i].UnitPrice.ToString("N2")</td>
                                        <td class="text-end">@Model.Items[i].Amount.Value.ToString("N2")</td>
                                    </tr>
                                }
                                <tr>
                                    <td colspan="4" class="text-end fs-9 fw-bold">Sub Total Taka.</td>
                                    <td class="text-end fs-9 fw-bold">@Model.SubTotal.ToString("N2")</td>
                                </tr>
                                <tr>
                                    <td colspan="4" class="text-end fs-9">VAT - @Model.VatPercent%</td>
                                    <td class="text-end fs-9">@Model.VatAmount.ToString("N2")</td>
                                </tr>
                                <tr>
                                    <td colspan="4" class="text-end h5">Grand Total Taka</td>
                                    <td class="text-end h5">@Model.GrandTotal.ToString("N2")</td>
                                </tr>
                                <tr>
                                    <td colspan="4" class="text-end fs-9 text-success fw-bold">Paid Amount</td>
                                    <td class="text-end fs-9 text-success fw-bold">@Model.PaidAmount.ToString("N2")</td>
                                </tr>
                                <tr>
                                    <td colspan="4" class="text-end fs-9 text-danger fw-bold">Due Amount</td>
                                    <td class="text-end fs-9 text-danger fw-bold">@((Model.GrandTotal - Model.PaidAmount).ToString("N2"))</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- Payment History -->
                    @if (Model.PaymentHistory != null && Model.PaymentHistory.Any())
                    {
                        <div class="col-xl-12 mt-4">
                            <p class="mb-1 fw-bold fs-8">Payment History</p>
                            <div class="border-bottom border-2 mb-3"></div>
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Ref No</th>
                                        <th>Payment Method</th>
                                        <th class="text-end">Amount</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var payment in Model.PaymentHistory)
                                    {
                                        <tr>
                                            <td>@payment.TransactionDate.ToString("MMM dd, yyyy")</td>
                                            <td>@payment.TransactionRefNo</td>
                                            <td>@payment.PaymentMethodName</td>
                                            <td class="text-end">@payment.Amount.ToString("N2")</td>
                                            <td>
                                                @if (payment.Status == "Completed")
                                                {
                                                    <span class="badge badge-phoenix badge-phoenix-success">@payment.Status</span>
                                                }
                                                else if (payment.Status == "Pending")
                                                {
                                                    <span class="badge badge-phoenix badge-phoenix-warning">@payment.Status</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-phoenix badge-phoenix-danger">@payment.Status</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    <!-- Note (Read-only) -->
                    @if (!string.IsNullOrEmpty(Model.InvoiceNote))
                    {
                        <div class="col-xl-12 mb-3">
                            <p class="mb-1 fw-bold fs-8">Note</p>
                            <div class="">
                                <p class="fs-9">@Model.InvoiceNote</p>
                            </div>
                        </div>
                    }

                    <div class="">
                        <div class="d-flex justify-content-end gap-2 align-items-center">
                            @*@if (!isEditMode && sidebarData != null && sidebarData.CanEdit)*@
                            @if (!Model.Finalized)
                            {
                                <a href="@Url.Action("Edit", "InvoiceDetails", new { id = Model.Id })" class="btn btn-primary">
                                    <i class="fa fa-edit me-1"></i> Edit Invoice
                                </a>
                            }

                        </div>
                    </div>

                </div>
            </div>

            <!-- Sidebar -->
            @if (sidebarData != null)
            {
                <partial name="_InvoiceSidebar" model="sidebarData" />
            }
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/pages/Sales/InvoiceDetails.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
}