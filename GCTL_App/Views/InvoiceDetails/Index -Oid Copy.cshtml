@using GCTL.Core.ViewModels.POS.Sales.InvoiceDetailsF
@model InvoiceDetailsViewModel
@{
    var sidebarData = ViewBag.SidebarData as GCTL.Core.ViewModels.POS.Sales.InvoiceDetailsF.InvoiceSidebarDetailsViewModel;
    var isEditMode = ViewBag.IsEditMode ?? false;
}

<div class="row">
    <div class="row col-xl-12 border-2">
        <div class="d-flex justify-content-between align-items-center">
            <p class="mb-1 fw-lighter fs-5">Invoice</p>
        </div>
    </div>
</div>

<div class="">
    @if (isEditMode)
    {
        <!-- EDIT MODE - Form with editable fields -->
        <form asp-action="Save" method="post" id="invoiceForm">
            <input asp-for="Id" type="hidden" />

            <div class="row mb-4">
                <div class="col-xl-9">
                    <div class="card pt-4 p-5 mb-3" style="min-height: 1000px;">

                        <div class="row col-xl-12">
                            <p class="mb-1 fw-bold fs-7">Invoice</p>
                            <p class="mb-2 fw-lighter fs-9">
                                Edit invoice details.
                            </p>
                            <div class="border-bottom border-2"></div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-12">
                                <div class="row justify-content-between">

                                    <!-- Customer Dropdown -->
                                    @*<div class="col-xl-5">
                                            <div class="mt-2">
                                                <input asp-for="SelectedCustomerId" type="hidden" id="selectedCustomerId" />
                                                <input type="hidden" id="preSelectedCustomerId" value="@(Model.SelectedCustomerId?.ToString() ?? "")" />

                                                <div id="userInfo" class="card mb-3 mt-3">
                                                    <div class="card-body">
                                                        <h5 class="card-title mb-2">Customer Information</h5>
                                                        <div class="d-flex">
                                                            <div class="me-auto">
                                                                <p class="mb-1 fs-9 info-company"></p>
                                                                <p class="mb-1 fs-9 info-addr1"></p>
                                                                <p class="mb-1 fs-9 info-addr2"></p>
                                                            </div>
                                                            <div class="mx-auto">
                                                                <p class="mb-1 fs-9 info-tax"></p>
                                                                <p class="mb-1 fs-9 info-phone"></p>
                                                                <p class="mb-1 fs-9 info-email"></p>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>*@

                                    <div class="col-xl-5">
                                        <div class="mt-2">
                                            <div class="d-flex gap-3">
                                                <div class="col-md-12">
                                                    <input asp-for="SelectedCustomerId" type="hidden" id="selectedCustomerId" />

                                                    <button type="button" class="btn border border-github py-5 px-10 mt-4" id="showUserDropdownBtn">
                                                        <i class="fa fa-user fs-3 mb-2"></i>
                                                        <p>+ Add User</p>
                                                    </button>

                                                    <div id="userDropdownContainer" style="display:none;">
                                                        <label class="form-label">Select Customer</label>
                                                        <select id="customerDropdown" class="form-select">
                                                            <option value="">-- Select Customer --</option>
                                                        </select>
                                                    </div>

                                                    <script type="application/json" id="customersData">
                                                        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Customers))
                                                    </script>
                                                    <input type="hidden" id="preSelectedCustomerId" value="@(Model.SelectedCustomerId?.ToString() ?? "")" />

                                                    <div id="userInfo" class="card mb-3 mt-3" style="display:none;">
                                                        <div class="card-body">
                                                            <h5 class="card-title mb-2">Customer Information</h5>
                                                            <div class="d-flex">
                                                                <div class="me-auto">
                                                                    <p class="mb-1 fs-9 info-company"></p>
                                                                    <p class="mb-1 fs-9 info-addr1"></p>
                                                                    <p class="mb-1 fs-9 info-addr2"></p>
                                                                </div>
                                                                <div class="mx-auto">
                                                                    <p class="mb-1 fs-9 info-tax"></p>
                                                                    <p class="mb-1 fs-9 info-phone"></p>
                                                                    <p class="mb-1 fs-9 info-email"></p>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>




                                    <!-- Invoice Details -->
                                    <div class="col-xl-7">
                                        <div class="row mt-3">
                                            <div class="col-xl-12">
                                                <div class="mb-3">
                                                    <label class="form-label">Invoice Number</label>
                                                    <input asp-for="InvoiceNumber" class="form-control" readonly />
                                                </div>
                                            </div>

                                            <div class="col-xl-6">
                                                <div class="mb-3">
                                                    <label class="form-label">Invoice Date</label>
                                                    <input asp-for="InvoiceDate" class="form-control" type="date" />
                                                </div>
                                            </div>

                                            <div class="col-xl-6">
                                                <div class="mb-3">
                                                    <label class="form-label">Other Reference</label>
                                                    <input asp-for="OtherReference" class="form-control" />
                                                </div>
                                            </div>

                                            @if (!string.IsNullOrEmpty(Model.SalesOrderNumber))
                                            {
                                                <div class="col-xl-6">
                                                    <div class="mb-3">
                                                        <label class="form-label">Linked Sales Order</label>
                                                        <input value="@Model.SalesOrderNumber" class="form-control" readonly />
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Items Table (Editable) -->
                        <div class="col-xl-12 mt-3">
                            <table class="table" id="itemsTable" style="border-bottom: 0px solid #ffffff00;">

                                <thead>
                                    <tr>
                                        <th style="width: 50px;">SL</th>
                                        <th>Product</th>
                                        <th class="text-center">Quantity</th>
                                        <th class="text-center">Unit Price</th>
                                        @if (Model.ShowTaxColumn && (Model.IsItemPriceIncludingVat || Model.IsPriceWithoutVat))
                                        {
                                            <th class="text-center">VAT Amount</th>
                                        }
                                        <th class="text-center">Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < Model.Items.Count; i++)
                                    {
                                        <tr>
                                            <td class="fs-8 text-center align-middle">@(i + 1)</td>
                                            <td>@Model.Items[i].ProductName</td>
                                            <td class="text-center">@Model.Items[i].Quantity.ToString("N2")</td>
                                            <td class="text-center">@Model.Items[i].UnitPrice.ToString("N2")</td>
                                            @if (Model.ShowTaxColumn && (Model.IsItemPriceIncludingVat || Model.IsPriceWithoutVat))
                                            {
                                                <td class="text-center">@Model.Items[i].VatAmount.ToString("N2")</td>
                                            }
                                            <td class="text-end">@Model.Items[i].Amount.Value.ToString("N2")</td>
                                        </tr>
                                    }
                                    <tr>
                                        <td colspan="@(Model.ShowTaxColumn ? "5" : "4")" class="text-end fs-9 fw-bold">Sub Total Taka.</td>
                                        <td class="text-end fs-9 fw-bold">@Model.SubTotal.ToString("N2")</td>
                                    </tr>
                                    @if (Model.ShowTaxColumn)
                                    {
                                        <tr>
                                            <td colspan="@(Model.ShowTaxColumn ? "5" : "4")" class="text-end fs-9">VAT - @Model.VatPercent%</td>
                                            <td class="text-end fs-9">@Model.VatAmount.ToString("N2")</td>
                                        </tr>
                                    }
                                    @if (Model.IsAit)
                                    {
                                        <tr>
                                            <td colspan="@(Model.ShowTaxColumn ? "5" : "4")" class="text-end fs-9">AIT - @Model.AitPercent%</td>
                                            <td class="text-end fs-9">@Model.AitAmount.ToString("N2")</td>
                                        </tr>
                                    }
                                    <tr>
                                        <td colspan="@(Model.ShowTaxColumn ? "5" : "4")" class="text-end h5">Grand Total Taka</td>
                                        <td class="text-end h5">@Model.GrandTotal.ToString("N2")</td>
                                    </tr>
                                </tbody>


                                @*<thead>
            <tr>
                <th style="width: 50px;">SL</th>
                <th class="text-center">Product</th>
                <th class="text-center">Quantity</th>
                <th class="text-center">Unit Price</th>
                <th class="text-center">Amount</th>
                <th style="width: 50px;"></th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Items.Count; i++)
            {
