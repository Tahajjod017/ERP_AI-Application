@inject IBrandingAssetService BrandingAssetService
@inject GCTL.Service.Language.ILanguageTableService TranslationService
@inject IHttpContextAccessor HttpContextAccessor
@using GCTL.Core.Helpers.FeviconDynamic
@using GCTL_App.ViewComponents
@{
    // Access HttpContext via HttpContextAccessor
    var languageCode = HttpContextAccessor.HttpContext?.Items["Language"] as string ?? "en";
    var logoPath = await BrandingAssetService.GetLogoPathForUserAsync(User);
    ViewData["LogoPath"] = logoPath;
}

@{
