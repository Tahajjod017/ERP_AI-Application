            <a class="navbar-brand me-1 me-sm-3" asp-area="" asp-controller="Home" asp-action="Index">
                <div class="d-flex align-items-center">
                    <div class="d-flex align-items-center">
                        @Html.LogoImage(ViewData["LogoPath"]?.ToString(), "Logo", 50)
                        <h5 class="logo-text ms-2 d-none d-sm-block">@Html.SmartLocalize("HRM")</h5>
                    </div>
                </div>
            </a>
        </div>

