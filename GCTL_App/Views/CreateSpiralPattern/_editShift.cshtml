<!-- Modal  for edit shift  used-->
<div class="modal fade" id="editShiftModal" tabindex="-1" aria-labelledby="editShiftModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="shiftModalLabel">@Html.SmartLocalize("Edit shift")</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="OrganizationIdEdit" />
                <p id="shiftModalDetails" class="mb-3 text-muted"></p>
                <div class="row mb-3">
                    <div class="col">
                        <label class="form-label" for="organizerSingle">@Html.SmartLocalize("Select Shift")</label>
                        <select class="form-select" id="editShiftModalShiftID" asp-items="@ViewBag.ShiftDD as SelectList">
                            <option value="">@Html.SmartLocalize("Select Shift")...</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Html.SmartLocalize("Close")</button>
                <button type="button" class="btn btn-primary" id="saveShift">@Html.SmartLocalize("Update Shift")</button>
            </div>
        </div>
    </div>
</div>