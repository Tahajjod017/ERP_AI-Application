@model GCTL_App.ViewModels.AttendanceManagement.ScheduleManagement.CreateSpiralPattern.CreateSpiralPatternPageVM

@{
    ViewData["Title"] = @Html.SmartLocalize("Create Spiral Pattern");
}

@section Styles{
    <style>

        #hiddenDiv {
            display: none; /* Initially hidden */
        }

        #div2 {
            display: none;
        }

        .disabled {
            pointer-events: none;
            opacity: 0.5;
        }

        .add-shift-btn {
            display: none;
            align-items: center;
        }

        .day-block {
            background: repeating-linear-gradient( 135deg, #e5e5e5, #e5e5e5 10px, #f7f7f7 10px, #f7f7f7 20px );
            border-radius: .4rem;
            padding: 5px 0 5px 0;
        }

        .editBtn {
            display: none;
            align-items: center;
        }

            .deleteBtn {
                display: none;
                align-items: center;
            }

        .startTime:hover .editBtn {
            display: inline-block;
            background-color: white;
            color: black;
        }

        .startTime:hover .deleteBtn {
            display: inline-block;
            background-color: white;
            color: black;
        }

        .startTime:hover .add-shift-btn {
            display: inline-block;
            background-color: white;
            color: black;
        }

    </style>
}

<partial name="_Form" model="Model.Create" />
<partial name="_WeeklyTable" />
<partial name="_FortnightlyTable" />
<partial name="_MonthlyTable" />

<partial name="_addShift" model="Model.AddWeekly" />
<partial name="_addFortMonthlyShift" model="Model.AddSpiralFortMonthly" />
<partial name="_editShift" model="Model.Edit" /> 
<partial name="_ConfirmDelete" />

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
	<script src="~/js/pages/attendancemanagement/schedulemanagement/createspiralpattern.js"></script>
    <script>
        $(function () {
            var options = {
                baseUrl: '@Url.Action("", "CreateSpiralPattern")'
            };
            options.load = () => { };
            $.createSpiralPattern(options);
        });
    </script>
}