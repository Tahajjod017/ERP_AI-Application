<div class="modal fade" id="resignation_approval_modal" tabindex="-1" aria-labelledby="resignationApprovalModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="resignationApprovalModalLabel">@Html.SmartLocalize("Review Resignation Request")</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                @*<button type="button" class="btn-close btnCloseMainModal" aria-label="Close"></button>*@
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">@Html.SmartLocalize("Department")</label>
                            <input type="text" class="form-control" id="modalDepartment" value="Finance" readonly>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">@Html.SmartLocalize("Current Position")</label>
                            <input type="text" class="form-control" id="modalPosition" value="Senior Accountant" readonly>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">@Html.SmartLocalize("Employee ID")</label>
                            <input type="text" class="form-control" id="modalEmployeeId" value="EMP-001" readonly>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">@Html.SmartLocalize("Notice Date")</label>
                            <input type="text" class="form-control" id="modalNoticeDate" value="15 Jan 2024" readonly>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">@Html.SmartLocalize("Years of Service")</label>
                            <input type="text" class="form-control" id="modalYearsOfService" value="4 Years 6 Months" readonly>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">@Html.SmartLocalize("Proposed Last Working Day")</label>
                            <input type="text" class="form-control" id="modalLastWorkingDay" value="15 Feb 2024" readonly>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">@Html.SmartLocalize("Notice Period")</label>
                            <input type="text" class="form-control" id="modalNoticePeriod" value="30 Days" readonly>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">@Html.SmartLocalize("Current Salary")</label>
                            <input type="text" class="form-control" id="modalCurrentSalary" value="৳65,000" readonly>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">@Html.SmartLocalize("Pending Dues")</label>
                            <input type="text" class="form-control" id="modalPendingDues" value="৳0" readonly>
                        </div>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">@Html.SmartLocalize("Reason for Resignation")</label>
                    <textarea class="form-control" id="modalResignationReason" rows="3" readonly>I have received an offer for a senior position at another company that aligns better with my career goals and provides opportunities for professional growth. This decision was not made lightly, and I am grateful for the experience gained here.</textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">@Html.SmartLocalize("HR Comments (Optional)")</label>
                    <textarea class="form-control" id="modalHRComments" rows="3" placeholder="@Html.SmartLocalize("Add your comments here...")"></textarea>
                </div>
                @*<div class="mb-3">
                    <label class="form-label">@Html.SmartLocalize("Handover Status")</label>
                    <select class="form-select" id="modalHandoverStatus">
                        <option value="pending">@Html.SmartLocalize("Pending")</option>
