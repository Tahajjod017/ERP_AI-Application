                    </select>
                </div>
                <div class="mb-3">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="assetReturnCheck">
                        <label class="form-check-label" for="assetReturnCheck">
                            @Html.SmartLocalize("All company assets returned")
                        </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="clearanceCheck">
                        <label class="form-check-label" for="clearanceCheck">
                            @Html.SmartLocalize("Department clearance completed")
                        </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="documentsCheck">
                        <label class="form-check-label" for="documentsCheck">
                            @Html.SmartLocalize("Exit documents prepared")
                        </label>
                    </div>
                </div>*@


            </div>

            <div class="modal-footer">
                @*<button type="button"  class="btn btn-secondary btnCloseMainModal">@Html.SmartLocalize("Close")</button>*@
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Html.SmartLocalize("Close")</button>

                @*<button type="button" class="btn btn-warning me-2" data-action="hold" data-resignation-id="">@Html.SmartLocalize("Hold for Review")</button>*@
                <button type="button" class="btn btn-warning me-2" data-action="hold" data-resignation-id="">@Html.SmartLocalize("View Settlement Details")</button>

                <button type="button" class="btn btn-danger me-2" data-action="decline" data-resignation-id="">@Html.SmartLocalize("Decline")</button>
