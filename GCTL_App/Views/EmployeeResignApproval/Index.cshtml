<div class="mb-4">
    <div class="card">
        <div class="card-header d-flex align-items-center justify-content-between flex-wrap row-gap-3 mb-1">
            <h4 class="mb-1">@Html.SmartLocalize("Waiting for Resignation Approval")</h4>
            <div class="d-flex my-xl-auto right-content align-items-center flex-wrap row-gap-3">
                <div class="dropdown me-3">
                    <div class="input-icon-end position-relative">
                        <input class="form-control" id="pendingSearch" type="text" placeholder="@Html.SmartLocalize("Search...")">
                    </div>
                </div>
                <div class="dropdown me-3">
                    <div class="input-icon-end position-relative">
                        <input class="form-control datetimepicker flatpickr-input" id="timepicker2" type="text" placeholder="@Html.SmartLocalize("d/m/y to d/m/y")" data-options='{"mode":"range","dateFormat":"d/m/y","disableMobile":true}' readonly="readonly">
                    </div>
                </div>
                <div class="dropdown me-3">
                    <select class="form-select choiceDD" id="processedDepartment" data-choices="data-choices" size="1" required="required" name="processedDepartment" asp-items="@ViewBag.DepartmentDD">
                        <option value="">@Html.SmartLocalize("Select department")</option>
                    </select>
                </div>
                <div class="dropdown me-3">
                    <select class="form-select choiceDD" id="processedDesignation" data-choices="data-choices" size="1" required="required" name="processedDesignation" asp-items="@ViewBag.DesignationDD">
                        <option value="">@Html.SmartLocalize("Select designation")</option>
                    </select>
                </div>
                <div class="dropdown me-3">
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text">@Html.SmartLocalize("Showing")</span>
                        </div>
                        <select class="form-select" id="pageSizeSelectPending" data-choices="data-choices" size="1" name="pageSizeSelectPending" data-options='{"removeItemButton":true,"placeholder":true}'>
                            <option value="5">5</option>
                            <option value="10">10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                            <option value="100">100</option>
                        </select>
                    </div>
                </div>


            </div>
        </div>

        <div class="border-translucent p-3">
            <div id="resignationApprovalTable">
                <div class="table-responsive scrollbar mx-n1 px-1">
                    <table class="table table-sm fs-9 leads-table dyn-table shefain" id="resignPending">
                        <thead>
                            <tr>
                                <th class="white-space-nowrap fs-9 align-middle ps-0" style="max-width:20px; width:18px;">
                                    <div class="form-check mb-0 fs-8">
                                        <input class="form-check-input" type="checkbox" data-bulk-select='{"body":"resignation-approval-body"}' />
                                    </div>
                                </th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="employeeName" data-column="0">@Html.SmartLocalize("Employee Name")</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="department" data-column="1">@Html.SmartLocalize("Department")</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="position" data-column="2">@Html.SmartLocalize("Position")</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="reason" data-column="3">@Html.SmartLocalize("Reason")</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="noticeDate" data-column="4">@Html.SmartLocalize("Notice Date")</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="lastWorkingDay" data-column="5">@Html.SmartLocalize("Last Working Day")</th>
                                <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="decision" data-column="6">@Html.SmartLocalize("Decision")</th>
                            </tr>
                        </thead>
                        <tbody class="list" id="pending-resignation-body">
                            <!-- Pending resignation rows will be populated here -->
                        </tbody>
                    </table>
                </div>

                <div class="row align-items-center justify-content-between pe-0 fs-9">
                    <div class="col-auto d-flex">
                        <p class="mb-0 d-none d-sm-block me-3 fw-semibold text-body totalPending" id="totalPending" data-list-info="data-list-info"></p>
                    </div>
                    <div class="col-auto d-flex">
                        <button class="page-link" data-list-pagination="prev"><span class="fas fa-chevron-left"></span></button>
                        <ul class="mb-0 pagination" id="paginationPending"></ul>
                        <button class="page-link pe-0" data-list-pagination="next"><span class="fas fa-chevron-right"></span></button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

