<div class="modal fade" id="confirmation_modal" tabindex="-1" aria-labelledby="confirmationModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="confirmationModalLabel">@Html.SmartLocalize("Confirm Action")</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p id="confirmation_message">@Html.SmartLocalize("Are you sure you want to") <span id="confirmation_action"></span> @Html.SmartLocalize("this resignation request?")</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Html.SmartLocalize("Cancel")</button>
                <button type="button" class="btn btn-primary" id="confirm_action">@Html.SmartLocalize("Confirm")</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="final_settlement_modal" tabindex="-1" aria-labelledby="finalSettlementModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="finalSettlementModalLabel">@Html.SmartLocalize("Final Settlement Details")</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-6">
                        <h6 class="mb-3 text-success">@Html.SmartLocalize("Payable Amount")</h6>
                        <div class="mb-2 d-flex justify-content-between">
                            <span>@Html.SmartLocalize("Remaining Salary"):</span>
                            <span>৳32,500</span>
                        </div>
                        <div class="mb-2 d-flex justify-content-between">
                            <span>@Html.SmartLocalize("Unused Leave"):</span>
                            <span>৳8,500</span>
                        </div>
                        <div class="mb-2 d-flex justify-content-between">
                            <span>@Html.SmartLocalize("Bonus (If any)"):</span>
                            <span>৳0</span>
                        </div>
                        <div class="mb-2 d-flex justify-content-between">
                            <span>@Html.SmartLocalize("Gratuity"):</span>
                            <span>৳45,000</span>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between fw-bold text-success">
                            <span>@Html.SmartLocalize("Total Payable"):</span>
                            <span>৳86,000</span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <h6 class="mb-3 text-danger">@Html.SmartLocalize("Deductible Amount")</h6>
                        <div class="mb-2 d-flex justify-content-between">
                            <span>@Html.SmartLocalize("Advance Salary"):</span>
                            <span>৳0</span>
                        </div>
                        <div class="mb-2 d-flex justify-content-between">
                            <span>@Html.SmartLocalize("Loan Outstanding"):</span>
                            <span>৳15,000</span>
                        </div>
                        <div class="mb-2 d-flex justify-content-between">
                            <span>@Html.SmartLocalize("Notice Period Shortage"):</span>
                            <span>৳0</span>
                        </div>
                        <div class="mb-2 d-flex justify-content-between">
                            <span>@Html.SmartLocalize("Other Deductions"):</span>
                            <span>৳2,000</span>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between fw-bold text-danger">
                            <span>@Html.SmartLocalize("Total Deductible"):</span>
                            <span>৳17,000</span>
                        </div>
                    </div>
                </div>
                <hr>
                <div class="row">
                    <div class="col-12">
                        <div class="d-flex justify-content-between align-items-center bg-light p-3 rounded">
