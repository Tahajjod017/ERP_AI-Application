@model GCTL_App.ViewModels.AttendanceManagement.ScheduleManagement.Shift.ShiftsPageVM

@{
    ViewData["Title"] = @Html.SmartLocalize("Add Shift");
}

@section Styles{
    <style>
        .time-icon {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            color: #6c757d;
            pointer-events: none;
        }
    </style>
}

<partial name="_Form" model="Model.Setup" />

<partial name="_Table" />

<partial name="_EditShiftModal" model="Model.Update" />
<partial name="_ConfirmDelete" />

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
	<script src="~/js/pages/attendancemanagement/schedulemanagement/addshift.js"></script>
    <script type="text/javascript">
        $(function () {
            var options = {
                baseUrl: '@Url.Action("", "AddShift")'
            };
            options.load = () => {

            };

            $.addshift(options);
        });
    </script>
}