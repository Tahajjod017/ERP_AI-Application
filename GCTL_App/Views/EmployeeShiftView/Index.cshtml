                <script>
                    // JavaScript to handle table visibility
                    document.getElementById('timeFrame').addEventListener('change', function() {
                      // Hide all tables
                      document.querySelectorAll('.table-container-dif-days').forEach(function(table) {
                        table.style.display = 'none';
                      });

                      // Show the selected table
                      const selectedTable = document.getElementById(this.value);
                      if (selectedTable) {
                        selectedTable.style.display = 'block';
                      }
                    });

                    // Show the default table on page load
                    document.addEventListener('DOMContentLoaded', function() {
                      document.getElementById('day7').style.display = 'block'; // Show Week table by default
                    });


                    document.addEventListener('DOMContentLoaded', function() {
                        const headerRow7day = document.getElementById('headerRow7day');
                        const headerRow14day = document.getElementById('headerRow14day');
                        const headerRowAmonth = document.getElementById('headerRowAmonth');
                        const daysShort = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
                        const monthsShort = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

                        const today = new Date();

                        // ৭ দিনের জন্য লুপ চালানো
                        for (let i = 0; i < 7; i++) {
                            const date = new Date();
                            date.setDate(today.getDate() + i);

                            const dayName = daysShort[date.getDay()];
                            const monthName = monthsShort[date.getMonth()];
                            const dateNum = date.getDate();

                            // কলাম হেডার তৈরি
                            const th = document.createElement('th');
                            th.textContent = `${dayName} ${monthName} ${dateNum}`;
                            headerRow7day.appendChild(th);
                        }

                        // ১৪ দিনের জন্য লুপ চালানো
                        for (let i = 0; i < 14; i++) {
                            const date = new Date();
                            date.setDate(today.getDate() + i);

                            const dayName = daysShort[date.getDay()];
                            const monthName = monthsShort[date.getMonth()];
                            const dateNum = date.getDate();

                            // কলাম হেডার তৈরি
                            const th = document.createElement('th');
                            th.textContent = `${dayName} ${monthName} ${dateNum}`;
                            headerRow14day.appendChild(th);
                        }

                        // ১ মাসের জন্য লুপ চালানো
                        for (let i = 0; i < 30; i++) {
                            const date = new Date();
                            date.setDate(today.getDate() + i);

                            const dayName = daysShort[date.getDay()];
                            const monthName = monthsShort[date.getMonth()];
                            const dateNum = date.getDate();

                            // কলাম হেডার তৈরি
                            const th = document.createElement('th');
                            th.textContent = `${dayName} ${monthName} ${dateNum}`;
                            headerRowAmonth.appendChild(th);
                        }
                    });

