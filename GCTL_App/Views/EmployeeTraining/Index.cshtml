@model GCTL.Core.ViewModels.Employee.EmployeeTraining.EmployeeTrainingPostViewModel

<div class="mb-9">
    <div class="row align-items-center justify-content-between g-3 mb-4">
        <div class="col-auto">
        </div>
    </div>

    <div class="px-3 mb-5">
        <div class="row">
            <form asp-controller="EmployeeTraining" asp-action="Index" method="post" id="trainingForm">
                <div class="col-12">
                    <input type="hidden" asp-for="EmployeeTranningInfoID" />

                    <div class="row g-2 align-items-center">
                        <div class="col-md-3">
                            <div class="position-relative">
                                <input class="form-control search-input search" type="search" placeholder="@Html.SmartLocalize("Employee Name / Phone / Email")" aria-label="Search" />
                                <span class="fas fa-search search-box-icon position-absolute top-50 end-0 translate-middle-y me-3"></span>
                            </div>
                        </div>
                        <div class="col-md-3"></div>
                        <div class="col-md-2">
                            <div class="form-floating form-floating-advance-select mb-2">
                                <label asp-for="EmployeePersonalId">@Html.SmartLocalize("Choose Employee")</label>
                                <select class="form-select" asp-for="EmployeePersonalId" asp-items="@ViewBag.EmployeeDD as SelectList">
                                    <option value="">@Html.SmartLocalize("Select Employee")</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-floating">
                                <input asp-for="PersonalEmail" class="form-control" type="email" placeholder="@Html.SmartLocalize("Email")" />
                                <label asp-for="PersonalEmail">@Html.SmartLocalize("Email")</label>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-floating">
                                <input asp-for="PersonalPhone" class="form-control" type="text" placeholder="@Html.SmartLocalize("Enter Phone")" />
                                <label asp-for="PersonalPhone">@Html.SmartLocalize("Phone")</label>
                            </div>
                        </div>
                    </div>

                    <div class="mx-n4 mx-lg-n6 px-lg-6 bg-body-emphasis pb-4">
                        <div class="col-12 col-xl-12 col-xxl-12">
                            <ul class="nav nav-underline fs-9 deal-details scrollbar flex-nowrap w-100 py-2 mb-2 mx-2" id="myTab" role="tablist">
                                <li class="nav-item text-nowrap me-2" role="presentation" id="headingPInfo">
                                    <a class="nav-link" href="/EmployeePersonal/index" role="tab" aria-selected="false" aria-controls="empPersonalInfo"> <span class="fa-solid fa-user me-2 tab-icon-color"></span>@Html.SmartLocalize("Personal Info.")</a>
                                </li>
                                <li class="nav-item text-nowrap me-2" role="presentation" id="headingEmpOfficialInfo">
                                    <a class="nav-link" href="/EmployeeOfficial/index" role="tab" aria-selected="false" aria-controls="empOfficialInfo"> <span class="fa-solid fa-file-alt me-2 tab-icon-color"></span>@Html.SmartLocalize("Official Info.")</a>
                                </li>
                                <li class="nav-item text-nowrap me-2" role="presentation" id="headingempPayroleInfo">
                                    <a class="nav-link" href="/EmployeeSalary/index" role="tab" aria-selected="false" aria-controls="empPayroleInfo"> <span class="fa-solid fa-file-alt me-2 tab-icon-color"></span>@Html.SmartLocalize("Payroll Info.")</a>
                                </li>
                                <li class="nav-item text-nowrap me-2" role="presentation" id="headingAdditionalInfo">
                                    <a class="nav-link" href="/EmployeeAdditional/index" role="tab" aria-selected="false" aria-controls="additionalInfo"> <span class="fa-solid fa-square-check me-2 tab-icon-color"></span>@Html.SmartLocalize("Additional Info.")</a>
                                </li>
                                <li class="nav-item text-nowrap me-2" role="presentation" id="headingeducationInfo">
                                    <a class="nav-link" href="/EmployeeEducation/index" role="tab" aria-selected="false" aria-controls="educationInfo"> <span class="fa-solid fa-square-check me-2 tab-icon-color"></span>@Html.SmartLocalize("Education Info.")</a>
                                </li>
                                <li class="nav-item text-nowrap me-2" role="presentation" id="headingTranningInfo">
                                    <a class="nav-link active" href="/EmployeeTraining/index" role="tab" aria-selected="true" aria-controls="tranningInfo"> <span class="fa-solid fa-square-check me-2 tab-icon-color"></span>@Html.SmartLocalize("Training Info.")</a>
                                </li>
                                <li class="nav-item text-nowrap me-2" role="presentation" id="headingFamilyInfo">
                                    <a class="nav-link" href="/EmployeeFamily/index" role="tab" aria-selected="false" aria-controls="familyInfo"> <span class="fa-solid fa-square-check me-2 tab-icon-color"></span>@Html.SmartLocalize("Family Info.")</a>
                                </li>
                            </ul>

                            <div class="card tab-content bg-white accordion" id="myTabContent">
                                <div class="tab-pane show active fade p-2" role="tranningInfo" id="tranningInfo" aria-labelledby="tranningInfo">
                                    <div class="px-25">
                                        <div class="d-flex justify-content-center my-8">
                                            <div class="col-12 row flex gy-3">
                                                <div class="col-sm-6 col-md-6">
                                                    <div class="form-floating">
                                                        <input asp-for="TranningTitle" class="form-control" type="text" placeholder="@Html.SmartLocalize("Training Title")" required />
                                                        <label asp-for="TranningTitle">@Html.SmartLocalize("Training Title")</label>
                                                    </div>
                                                </div>

                                                <div class="col-sm-6 col-md-6">
                                                    <div class="form-floating form-floating-advance-select">
                                                        <label asp-for="CountryID">@Html.SmartLocalize("Country")</label>
                                                        <select class="form-select choiceDD" asp-for="CountryID" asp-items="@(new SelectList(ViewBag.Country.Items, "Value", "Text"))">
                                                            <option value="" selected disabled>@Html.SmartLocalize("Select Country")</option>
                                                        </select>
                                                    </div>
                                                </div>

                                                <div class="col-sm-6 col-md-6">
                                                    <div class="form-floating">
                                                        <input asp-for="TopicCovered" class="form-control" type="text" placeholder="@Html.SmartLocalize("Topics Covered")" required />
                                                        <label asp-for="TopicCovered">@Html.SmartLocalize("Topics Covered")</label>
                                                    </div>
                                                </div>

                                                <div class="col-sm-6 col-md-6">
                                                    <div class="form-floating form-floating-advance-select">
                                                        <label asp-for="TrainingYearID">@Html.SmartLocalize("Training Year")</label>
                                                        <select class="form-select choiceDD" asp-for="TrainingYearID" asp-items="@(new SelectList(ViewBag.TrainingYear.Items, "Value", "Text"))">
                                                            <option value="" selected disabled>@Html.SmartLocalize("Select Training Year")</option>
                                                        </select>
                                                    </div>
                                                </div>

                                                <div class="col-sm-6 col-md-6">
                                                    <div class="form-floating">
                                                        <input asp-for="InstituteName" class="form-control" type="text" placeholder="@Html.SmartLocalize("Institute Name")" required />
                                                        <label asp-for="InstituteName">@Html.SmartLocalize("Institute Name")</label>
                                                    </div>
                                                </div>

                                                <div class="col-sm-6 col-md-6">
                                                    <div class="form-floating">
                                                        <input asp-for="YearDuration" class="form-control" type="text" placeholder="@Html.SmartLocalize("Duration")" />
                                                        <label asp-for="YearDuration">@Html.SmartLocalize("Duration (Years)")</label>
                                                    </div>
                                                </div>

                                                <div class="col-sm-12 col-md-12">
                                                    <div class="form-floating">
                                                        <input asp-for="LocationName" class="form-control" type="text" placeholder="@Html.SmartLocalize("Location")" />
                                                        <label asp-for="LocationName">@Html.SmartLocalize("Location")</label>
                                                    </div>
                                                </div>

                                                <button class="btn btn-outline-primary rounded-pill me-1 mb-1 mx-3" type="submit" style="width: 100px;">
                                                    @Html.SmartLocalize("Add")
                                                </button>
                                            </div>
                                        </div>

                                        <h4 class="border-bottom">@Html.SmartLocalize("Training Summary")</h4>

                                        <div class="col-sm-12 col-md-12 col-xl-12 px-4 mt-4">
                                            <table class="table" id="employeeTrainingTable">
                                                <thead>
                                                    <tr>
                                                        <th scope="col">@Html.SmartLocalize("Training Title")</th>
                                                        <th scope="col">@Html.SmartLocalize("Topic")</th>
                                                        <th scope="col">@Html.SmartLocalize("Institute")</th>
                                                        <th scope="col">@Html.SmartLocalize("Country")</th>
                                                        <th scope="col">@Html.SmartLocalize("Location")</th>
                                                        <th scope="col">@Html.SmartLocalize("Year")</th>
                                                        <th scope="col">@Html.SmartLocalize("Duration")</th>
                                                        <th scope="col">@Html.SmartLocalize("Action")</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <!-- Table content will be populated dynamically -->
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/pages/employees/employeevalidator.js"></script>
	</script><script src="~/js/pages/employees/employeetraining.js"></script>
}