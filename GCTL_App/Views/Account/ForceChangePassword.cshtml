@{
    Layout = "~/Views/Shared/_LayoutForceChangePassword.cshtml";
}
@await Html.PartialAsync("_Alerts")
<main class="main" id="top">
    <div class="container">
        <div class="row flex-center min-vh-100 py-5">
            <div class="col-sm-10 col-md-8 col-lg-5 col-xl-5 col-xxl-3">

                <!-- Logo -->
                <a class="d-flex flex-column align-items-center text-decoration-none mb-4" href="#">
                    <img src="~/media/logo/logo.png" alt="HRM" width="90" />
                    <span class="fw-semibold fs-7 text-muted mt-2">HRM</span>
                </a>

                <!-- Heading -->
                <div class="text-center mb-7">
                    <h3 class="text-body-highlight">Change Your Password</h3>
                    <p class="text-body-tertiary">You must update your password before accessing the system.</p>
                </div>

                <!-- Form Start -->
                <form asp-controller="Account" asp-action="ForceChangePassword" method="post" novalidate>
                    @Html.AntiForgeryToken()

                    <!-- Validation Summary -->
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <!-- Current Password -->
 @*                    <div class="mb-3 text-start">
                        <label class="form-label" for="currentPassword">Current Password</label>
                        <div class="form-icon-container">
                            <input name="OldPassword" class="form-control form-icon-input" id="currentPassword" type="password" placeholder="Enter current password" required />
                            <span class="fas fa-lock text-body fs-9 form-icon"></span>
                        </div>
                    </div> *@

                    <!-- New Password -->
                    <div class="mb-3 text-start">
                        <label class="form-label" for="newPassword">New Password</label>
                        <div class="form-icon-container" data-password="data-password">
                            <input name="NewPassword" class="form-control form-icon-input pe-6" id="newPassword" type="password" placeholder="Enter new password" data-password-input="data-password-input" required />
                            <span class="fas fa-key text-body fs-9 form-icon"></span>
                            <button type="button" class="btn px-3 py-0 h-100 position-absolute top-0 end-0 fs-7 text-body-tertiary" data-password-toggle="data-password-toggle">
                                <span class="uil uil-eye show"></span><span class="uil uil-eye-slash hide"></span>
                            </button>
                        </div>
                    </div>

                    <!-- Confirm New Password -->
                    <div class="mb-3 text-start">
                        <label class="form-label" for="confirmNewPassword">Confirm New Password</label>
                        <div class="form-icon-container" data-password="data-password">
                            <input name="ConfirmPassword" class="form-control form-icon-input pe-6" id="confirmNewPassword" type="password" placeholder="Confirm new password" data-password-input="data-password-input" required />
                            <span class="fas fa-key text-body fs-9 form-icon"></span>
                            <button type="button" class="btn px-3 py-0 h-100 position-absolute top-0 end-0 fs-7 text-body-tertiary" data-password-toggle="data-password-toggle">
                                <span class="uil uil-eye show"></span><span class="uil uil-eye-slash hide"></span>
                            </button>
                        </div>
                    </div>

                    <!-- Submit Button -->
                    <button class="btn btn-primary w-100 mb-3" type="submit">Update Password</button>

                </form>
                <!-- Form End -->

            </div>
        </div>
    </div>
</main>
