@{
    Layout = "~/Views/Shared/LoginLayouts/_LayoutEmailOtpPage.cshtml";
}
@await Html.PartialAsync("_Alerts")
@if (TempData["EmailError"] != null)
{
    <div class="alert alert-danger text-center mt-3" style="font-size: 15px;">
        @TempData["EmailError"]
    </div>
}
<div class="container">
    <div class="row flex-center min-vh-100 py-3">
        <div class="col-sm-10 col-md-8 col-lg-5 col-xxl-4">
            <a class="d-flex flex-center text-decoration-none mb-4">
                <div class="d-flex align-items-center fw-bolder fs-3 d-inline-block">
                    <img src="" alt="phoenix" width="58" />
                </div>
            </a>
            <div class="px-xxl-5">
                <div class="text-center mb-6">
                    <h4 class="text-body-highlight">Forgot your password?</h4>
                    <p class="text-body-tertiary mb-0">Enter your email address to receive a 6-digit verification code.</p>
                    <p class="fs-10 mb-5">Don't remember your email? <a href="#!">Contact support</a></p>

                    <form asp-action="SendOtpToEmail" method="post" class="verification-form">
                        <div class="mb-3">
                            <input type="email" name="Email" class="form-control text-center" placeholder="Enter your email" required />
                        </div>
                        <button type="submit" class="btn btn-primary w-100 mb-5">Send OTP</button>
                        <a class="fs-9" href="/Account/Login">Back to login</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>


