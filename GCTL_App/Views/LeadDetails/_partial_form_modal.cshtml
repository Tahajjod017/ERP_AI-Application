<!-- Date and Time Field -->
<div class="mb-3" id="dateField">
    <div class="row g-3">
        <input type="hidden" id="leadDetailID" value="0" />
        <div class="col-md-6">
            <label class="form-label fw-semibold">Set Date and Time</label>
            <div class="input-group">
                <input class="form-control datetimepicker"
                       id="aDate"
                       name="aDate"
                       type="text"
                       placeholder="dd/mm/yyyy hh:mm AM/PM" />
                <span class="input-group-text">
                    <span class="fa-solid fa-calendar"></span>
                </span>
            </div>

        </div>

        <div class="col-md-6" id="contact-field" style="display:none;">
            <label class="form-label fw-semibold">Contact Person Phone</label>
            <select id="ContectPersonId" class="select2" multiple="multiple">
                <option></option>
            </select>
            <div id="contactPhoneList" class="mt-1 text-muted small"></div>
        </div>

        <div class="col-md-6" id="email-field" style="display:none;">
            <label class="form-label fw-semibold">Contact Person Email</label>
            <select id="ContectPersonEmailId" class="select2" multiple="multiple">
                <option></option>
            </select>
        </div>

        <div class="col-md-6" id="file-field" style="display:none;">
            <label class="form-label fw-semibold">Attach File</label>
            <input class="form-control" type="file" id="aFile">
        </div>
    </div>
</div>

<!-- Note Field -->
<div class="mb-3" id="note-Field">
    <label class="form-label fw-semibold">Note</label>
    <textarea class="form-control" id="aNote" rows="3" placeholder="Add your notes here..."></textarea>
</div>

<!-- Action Buttons -->
<div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
    <div>
        <button type="submit" id="addLActivity" class="btn btn-primary px-4">
            <span class="fa-solid fa-plus me-2"></span>Add Activity
        </button>
        <div class="d-flex align-items-center d-none gap-2" id="won-fonfirm-div">
            <span class="fw-semibold">Transfer To Field Service</span>
            <div class="btn-group">
                <button class="btn btn-success btn-xs" id="wonYes">Yes</button>
                <button class="btn btn-warning btn-xs" id="wonNo">No</button>
                <button class="btn btn-danger btn-xs" id="won-btn-cancel">Cancel</button>
            </div>
        </div>
    </div>

    <div class="d-flex align-items-center flex-wrap gap-2" id="activity-btn-div">
        @foreach (var item in ViewBag.LeadActivityTypes2)
        {
            <button class="btn btn-phoenix-secondary rounded-pill special-btn option-btn"
                    type="button"
                    data-id="@item.LeadActivityTypeID"
                    data-usefor="@item.UseFor">
                <span class="fa-solid @item.LeadActivityIcon me-2"></span>
                @item.LeadActivityName
            </button>
        }
        <button class="btn btn-outline-danger rounded-pill border-danger d-none" id="restoreBtn2">
            <span class="fa-solid fa-rotate-right me-2"></span>Restart
        </button>
    </div>
</div>