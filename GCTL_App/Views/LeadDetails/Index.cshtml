                                <span class="fa-solid fa-plus me-2"></span>Add Activity
                            </button>
                            <div class="d-flex align-items-center d-none gap-2" id="won-fonfirm-div">
                                <span class="fw-semibold">Transfer To Field Service</span>
                                <div class="btn-group">
                                    <button class="btn btn-success btn-xs" id="wonYes">Yes</button>
                                    <button class="btn btn-warning btn-xs" id="wonNo">No</button>
                                    <button class="btn btn-danger btn-xs" id="won-btn-cancel">Cancel</button>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex align-items-center flex-wrap gap-2" id="activity-btn-div">
                            @foreach (var item in ViewBag.LeadActivityTypes2)
                            {
                                <button class="btn btn-phoenix-secondary rounded-pill special-btn option-btn"
                                        type="button"
                                        data-id="@item.LeadActivityTypeID"
                                        data-usefor="@item.UseFor">
                                    <span class="fa-solid @item.LeadActivityIcon me-2"></span>
                                    @item.LeadActivityName
                                </button>
                            }
                            <button class="btn btn-outline-danger rounded-pill d-none" id="restoreBtn2">
                                <span class="fa-solid fa-rotate-right me-2"></span>Restart
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Upcoming Activities -->
            <div class="card d-none" id="upcomming-div">
                <div class="card-header">
                    <h4 class="mb-0">Upcoming Activities</h4>
                </div>
                <div class="card-body">
                    <div class="timeline-container">
                        <div id="upcoming-activity" class="timeline-wrapper" data-timeline-type="upcoming">
                            <div class="vertical-timeline-line"></div>
                            <!-- Activities will be loaded here dynamically -->
                        </div>
                    </div>
                </div>
            </div>

            <!-- All Activities -->
            <div class="d-none" id="all-activity-div">
                <ul class="nav nav-underline mb-4" id="myTab" role="tablist">
                    <li class="nav-item" role="presentation">
                        <a class="nav-link active" id="activity-tab" data-filter="all">
                            <span class="fa-solid fa-chart-line me-2"></span>All Activity
                        </a>
                    </li>
                    @foreach (var item in ViewBag.LeadActivityTypes)
                    {
                        var safeName = item.LeadActivityName.Replace(" ", "-");
                        <li class="nav-item" role="presentation">
                            <a class="nav-link" id="@safeName-tab" data-usefor="@item.LeadActivityName" data-filter="@item.LeadActivityName.ToLower()">
                                <span class="fa-solid @item.LeadActivityIcon me-2"></span>@item.LeadActivityName
                            </a>
                        </li>
                    }
                </ul>

                <div class="card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-3">
                            <h4 class="mb-0" id="activity-label">Activity Timeline</h4>
                            <div class="search-box">
                                <form class="position-relative">
                                    <input class="form-control search-input"
                                           id="search-activity"
                                           type="search"
                                           placeholder="Search activities..."
                                           aria-label="Search" />
                                    <span class="fas fa-search search-box-icon"></span>
                                </form>
                            </div>
                        </div>
                        <div class="timeline-container">
                            <div id="activity-list" class="timeline-wrapper" data-timeline-type="all">
                                <div class="vertical-timeline-line"></div>
                                <!-- Activities will be loaded here dynamically -->
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Custom Toaster -->
<div id="customToaster"></div>

<!-- Confirmation Modal -->
<div id="customConfirmModal">
    <div class="modal-content">
        <img id="modalIcon" class="confirm-icon" alt="Icon">
        <h2 class="confirm-title">Confirmation</h2>
        <p id="confirmMessage" class="confirm-message">Are you sure you want to proceed?</p>
        <div class="confirm-actions">
            <button id="confirmYes" class="confirm-btn confirm-btn-yes">Yes</button>
            <button id="confirmNo" class="confirm-btn confirm-btn-no">No</button>
        </div>
    </div>
</div>

<!-- File Preview Modal -->
<div class="modal fade" id="filePreviewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">File Preview</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="min-height:500px">
                <div id="filePreviewContainer" class="w-100 h-100 d-flex justify-content-center align-items-center">
                    <!-- Content will load here -->
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Reopen Confirmation Modal -->
<div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Reopen Lead</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">Are you sure you want to reopen this lead?</p>
