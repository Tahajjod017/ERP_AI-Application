@using GCTL.Core.ViewModels.CRM
@model CustomerInfoVM

<style>
    :root {
        --primary-color: #0d6efd;
        --success-color: #10b981;
        --danger-color: #ef4444;
        --warning-color: #f59e0b;
        --info-color: #3b82f6;
        --secondary-color: #6b7280;
        --border-color: #e5e7eb;
        --bg-subtle: #f9fafb;
        --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        --transition-base: all 0.2s ease;
    }

    /* ====== Timeline Styling ====== */
    .timeline-container {
        position: relative;
        padding-left: 45px;
        overflow-y: auto;
        scrollbar-width: thin;
        scrollbar-color: var(--border-color) transparent;
    }

        .timeline-container::-webkit-scrollbar {
            width: 6px;
        }

        .timeline-container::-webkit-scrollbar-track {
            background: transparent;
        }

        .timeline-container::-webkit-scrollbar-thumb {
            background-color: var(--border-color);
            border-radius: 3px;
        }

    #upcoming-activity {
        max-height: 400px;
    }

    #activity-list {
        max-height: 600px;
        margin-top: 1.5rem;
    }

    .vertical-line {
        position: absolute;
        top: 0;
        left: 51px;
        width: 2px;
        height: 100%;
        background: linear-gradient(to bottom, var(--primary-color), transparent);
        z-index: 0;
    }

    .activity-item {
        position: relative;
        z-index: 1;
        margin-bottom: 1.5rem;
        opacity: 0;
        transform: translateY(20px);
        animation: slideIn 0.4s ease-out forwards;
    }

    @@keyframes slideIn {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .activity-icon {
        position: relative;
        z-index: 2;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 0 0 4px #fff;
        transition: var(--transition-base);
    }

    .activity-item:hover .activity-icon {
        transform: scale(1.15);
        box-shadow: 0 0 0 4px #fff, var(--shadow-md);
    }

    /* ====== Card Enhancements ====== */
    .card {
        border: 1px solid var(--border-color);
        border-radius: 12px;
        box-shadow: var(--shadow-sm);
        transition: var(--transition-base);
    }

        .card:hover {
            box-shadow: var(--shadow-md);
        }

    .card-header {
        background: var(--bg-subtle);
        border-bottom: 1px solid var(--border-color);
        padding: 1.25rem 1.5rem;
        border-radius: 12px 12px 0 0;
    }

    .card-body {
        padding: 1.5rem;
    }

    /* ====== Professional Badges ====== */
    .badge-phoenix {
        padding: 0.375rem 0.75rem;
        font-size: 0.813rem;
        font-weight: 600;
        border-radius: 6px;
        letter-spacing: 0.025em;
        transition: var(--transition-base);
    }

    .badge-phoenix-success {
        background-color: #d1fae5;
        color: #065f46;
    }

    .badge-phoenix-danger {
        background-color: #fee2e2;
        color: #991b1b;
    }

    .badge-phoenix-secondary {
        background-color: #e5e7eb;
        color: #374151;
    }

    /* ====== Button Improvements ====== */
    .btn {
        font-weight: 500;
        border-radius: 8px;
        padding: 0.625rem 1.25rem;
        transition: var(--transition-base);
        border: 1px solid transparent;
    }

    .btn-primary {
        background: linear-gradient(135deg, var(--primary-color), #0a58ca);
        border-color: var(--primary-color);
        box-shadow: 0 2px 4px rgba(13, 110, 253, 0.15);
    }

        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 8px rgba(13, 110, 253, 0.25);
        }

    .btn-phoenix-secondary {
        background-color: #fff;
        border-color: var(--border-color);
        color: var(--secondary-color);
    }

        .btn-phoenix-secondary:hover {
            background-color: var(--bg-subtle);
            border-color: var(--primary-color);
            color: var(--primary-color);
        }

    .option-btn {
        position: relative;
        overflow: hidden;
        min-width: 100px;
        padding: 0.75rem 1rem;
        font-size: 0.875rem;
    }

        .option-btn::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            border-radius: 50%;
            background: rgba(13, 110, 253, 0.1);
            transform: translate(-50%, -50%);
            transition: width 0.4s, height 0.4s;
        }

        .option-btn:hover::before {
            width: 300px;
            height: 300px;
        }

        .option-btn.active {
            background: linear-gradient(135deg, var(--primary-color), #0a58ca);
            color: white;
            border-color: var(--primary-color);
            box-shadow: 0 4px 8px rgba(13, 110, 253, 0.25);
        }

    .special-btn.active2 {
        background: linear-gradient(135deg, var(--primary-color), #0a58ca);
        color: white;
        border-color: var(--primary-color);
    }

    .btn-xs {
        padding: 0.25rem 0.625rem !important;
        font-size: 0.75rem !important;
        line-height: 1.4 !important;
        border-radius: 6px;
    }

    /* ====== Form Controls ====== */
    .form-control, .form-select {
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 0.625rem 0.875rem;
        transition: var(--transition-base);
        font-size: 0.938rem;
    }

        .form-control:focus, .form-select:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.1);
        }

    .form-label {
        font-weight: 600;
        color: #374151;
        margin-bottom: 0.5rem;
        font-size: 0.875rem;
    }

    /* ====== Range Input Styling ====== */
    .form-range {
        height: 6px;
        background: linear-gradient(to right, var(--primary-color) 0%, var(--primary-color) var(--value, 0%), #e5e7eb var(--value, 0%), #e5e7eb 100%);
        border-radius: 3px;
    }

        .form-range::-webkit-slider-thumb {
            width: 18px;
            height: 18px;
            background: var(--primary-color);
            border: 3px solid #fff;
            box-shadow: var(--shadow-md);
            transition: var(--transition-base);
        }

            .form-range::-webkit-slider-thumb:hover {
                transform: scale(1.15);
                box-shadow: var(--shadow-lg);
            }

    /* ====== Customer Information Table ====== */
    .info-table {
        width: 100%;
    }

        .info-table tr {
            transition: var(--transition-base);
        }

            .info-table tr:hover {
                background-color: var(--bg-subtle);
            }

        .info-table td {
            padding: 0.625rem 0;
            vertical-align: middle;
        }

    .info-icon {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: var(--transition-base);
    }

    .info-table tr:hover .info-icon {
        transform: scale(1.1);
    }

    /* ====== Select2 Customization ====== */
    .select2-selection {
        border-color: var(--border-color) !important;
        border-radius: 8px !important;
        min-height: 42px !important;
    }

    .select2-container--default .select2-selection--multiple {
        border: 1px solid var(--border-color) !important;
    }

    /* ====== Nav Tabs Enhancement ====== */
    .nav-underline .nav-link {
        padding: 0.75rem 1.25rem;
        color: var(--secondary-color);
        border-bottom: 2px solid transparent;
        transition: var(--transition-base);
        font-weight: 500;
        cursor: pointer;
    }

        .nav-underline .nav-link:hover {
            color: var(--primary-color);
            border-bottom-color: var(--primary-color);
        }

        .nav-underline .nav-link.active {
            color: var(--primary-color);
            border-bottom-color: var(--primary-color);
        }

    /* ====== Professional Toast ====== */
    #customToaster {
        position: fixed;
        top: 20px;
        left: 50%;
        transform: translateX(-50%) translateY(-80px);
        min-width: 320px;
        max-width: 400px;
        background: #fff;
        color: #1f2937;
        font-weight: 600;
        font-size: 1rem;
        padding: 1.5rem;
        border-radius: 12px;
        box-shadow: var(--shadow-xl);
        opacity: 0;
        pointer-events: none;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        z-index: 9999;
        border: 1px solid var(--border-color);
    }

        #customToaster.show-toast {
            opacity: 1;
            transform: translateX(-50%) translateY(0);
        }

        #customToaster.hide-toast {
            opacity: 0;
            transform: translateX(-50%) translateY(-80px);
        }

        #customToaster img.toast-icon {
            width: 64px;
            height: 64px;
        }

        #customToaster .spinner {
            border: 4px solid #f3f4f6;
            border-top: 4px solid var(--primary-color);
            border-radius: 50%;
            width: 48px;
            height: 48px;
            animation: spin 1s linear infinite;
        }

    @@keyframes spin {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    /* ====== Confirmation Modal Enhancement ====== */
    #customConfirmModal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        backdrop-filter: blur(4px);
        display: none;
        justify-content: center;
        align-items: center;
        z-index: 10000;
        animation: fadeIn 0.3s ease;
    }

        #customConfirmModal.active {
            display: flex;
        }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    #customConfirmModal .modal-content {
        background: #fff;
        padding: 2rem;
        border-radius: 16px;
        box-shadow: var(--shadow-xl);
        text-align: center;
        max-width: 440px;
        width: 90%;
        display: flex;
        flex-direction: column;
        align-items: center;
        animation: slideUp 0.3s ease;
    }

    @@keyframes slideUp {
        from {
            transform: translateY(30px);
            opacity: 0;
        }

        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    #customConfirmModal .confirm-icon {
        width: 72px;
        height: 72px;
        margin-bottom: 1.25rem;
    }

        #customConfirmModal .confirm-icon.spin {
            animation: spinIcon 1.5s linear infinite;
        }

    @@keyframes spinIcon {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    #customConfirmModal .confirm-title {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 0.75rem;
        color: #111827;
    }

    #customConfirmModal .confirm-message {
        font-size: 1rem;
        color: #6b7280;
        line-height: 1.6;
    }

    #customConfirmModal .confirm-actions {
        margin-top: 1.5rem;
        display: flex;
        justify-content: center;
        gap: 1rem;
    }

    #customConfirmModal .confirm-btn {
        padding: 0.75rem 2rem;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-size: 1rem;
        font-weight: 600;
        color: #fff;
        transition: var(--transition-base);
        min-width: 100px;
    }

        #customConfirmModal .confirm-btn:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg);
        }

    #customConfirmModal .confirm-btn-yes {
        background: linear-gradient(135deg, var(--success-color), #059669);
    }

    #customConfirmModal .confirm-btn-no {
        background: linear-gradient(135deg, var(--danger-color), #dc2626);
    }

    /* ====== Sticky Sidebar ====== */
    .sticky-leads-sidebar {
        position: sticky;
        top: 20px;
    }

    /* ====== Avatar Enhancement ====== */
    .avatar {
        position: relative;
    }

        .avatar img {
            border: 3px solid #fff;
            box-shadow: var(--shadow-md);
        }

    /* ====== Section Headers ====== */
    .section-header {
        border-bottom: 2px solid var(--border-color);
        padding-bottom: 0.75rem;
        margin-bottom: 1.25rem;
        font-weight: 700;
        color: #111827;
    }

    /* ====== Dropdown Enhancements ====== */
    .dropdown-menu {
        border: 1px solid var(--border-color);
        border-radius: 12px;
        box-shadow: var(--shadow-lg);
        padding: 0.5rem;
    }

    .dropdown-item {
        border-radius: 8px;
        padding: 0.625rem 1rem;
        transition: var(--transition-base);
    }

        .dropdown-item:hover {
            background-color: var(--bg-subtle);
        }

    /* ====== Progress Bar Enhancement ====== */
    .progress {
        background-color: #f3f4f6;
        border-radius: 8px;
        box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.1);
    }

    /* ====== Search Box ====== */
    .search-box .form-control {
        padding-left: 2.5rem;
        border-radius: 10px;
    }

    .search-box .search-box-icon {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--secondary-color);
    }

    /* ====== Responsive Adjustments ====== */
    @@media (max-width: 768px) {
        .card-body {
            padding: 1rem;
        }

        .option-btn {
            min-width: 80px;
            padding: 0.5rem 0.75rem;
            font-size: 0.813rem;
        }

        .sticky-leads-sidebar {
            position: relative;
        }
    }

    /* ====== Loading States ====== */
    .loading-shimmer {
        background: linear-gradient(90deg, #f3f4f6 0%, #e5e7eb 50%, #f3f4f6 100%);
        background-size: 200% 100%;
        animation: shimmer 1.5s infinite;
    }

    @@keyframes shimmer {
        0% {
            background-position: -200% 0;
        }

        100% {
            background-position: 200% 0;
        }
    }

    /* ====== Utility Classes ====== */
    .text-muted-light {
        color: #9ca3af;
    }

    .border-subtle {
        border-color: var(--border-color) !important;
    }

    .bg-subtle {
        background-color: var(--bg-subtle);
    }

    /* ====== Icon Colors ====== */
    .tab-icon-color {
        color: var(--primary-color);
    }

    .text-success-dark {
        color: #065f46;
    }

    /* ====== Modal Improvements ====== */
    .modal-content {
        border-radius: 16px;
        border: none;
        box-shadow: var(--shadow-xl);
    }

    .modal-header {
        border-bottom: 1px solid var(--border-color);
        padding: 1.5rem;
        background-color: var(--bg-subtle);
    }

    .modal-body {
        padding: 1.5rem;
    }

    .modal-footer {
        border-top: 1px solid var(--border-color);
        padding: 1.25rem 1.5rem;
        background-color: var(--bg-subtle);
    }

    /* very label Capitalize */

    .form-label {
        text-transform: capitalize !important;
        font-size: 14px;
    }
</style>

<div class="pb-4">
    <!-- Page Header -->
    <div class="row align-items-center justify-content-between g-3 mb-4">
        <div class="col-12 col-md-auto">
            <h2 class="mb-0 fw-bold text-dark">Lead Details</h2>
        </div>
        <div class="col-12 col-md-auto d-flex gap-2">
            <a class="btn btn-phoenix-secondary px-4" id="openCreateLeadModal" role="button">Create Lead</a>

            @* <button class="btn btn-phoenix-secondary px-4" id="editModalBtn">
                <span class="fa-solid fa-edit me-2"></span>
                <span>Create Lead</span>
            </button> *@
            <button class="btn btn-phoenix-secondary px-4" id="editModalBtn">
                <span class="fa-solid fa-edit me-2"></span>
                <span>Edit Lead</span>
            </button>
        </div>
    </div>

    <div class="row g-4 g-xl-4">
        <!-- Left Sidebar -->
        <div class="col-xl-5 col-xxl-4">
            <div class="sticky-leads-sidebar">
                <!-- Lead Overview Card -->
                <div class="card mb-3">
                    <div class="card-body">
                        <div class="row align-items-center g-3">
                            <div class="col-12">
                                <h3 class="fw-bold mb-3">@Model.LeadName</h3>

                                <!-- Owner Info -->
                                <div class="d-flex align-items-center mb-4">
                                    <div class="avatar avatar-xl me-3">
                                        <i class="fa-regular fa-user"></i>
                                    </div>
                                    <div>
                                        <h5 class="mb-1">@Model.FullName</h5>
                                        <div class="dropdown">
                                            <a class="text-muted dropdown-toggle text-decoration-none" href="#!" data-bs-toggle="dropdown" aria-expanded="false">
                                                Lead Owner<span class="fa-solid fa-caret-down ms-2 fs-9"></span>
                                            </a>
                                            <div class="dropdown-menu shadow" style="min-width:20rem">
                                                <div class="p-3">
                                                    <h5 class="mb-3 fw-bold">Switch Ownership</h5>
                                                    <label class="form-label">Deal Owner</label>
                                                    <select class="form-select mb-3">
                                                        <option selected>Select Owner</option>
                                                        <option value="1">Jerry Seinfield</option>
                                                        <option value="2">Anthoney Michael</option>
                                                        <option value="3">Ansolo Lazinatov</option>
                                                    </select>
                                                    <div class="d-flex justify-content-end gap-2">
                                                        <button class="btn btn-sm btn-link text-danger" type="button">Cancel</button>
                                                        <button class="btn btn-sm btn-primary px-4" type="button">Save</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Status Badges -->
                                <div class="mb-4">
                                    <span class="badge badge-phoenix badge-phoenix-success me-2">
                                        Success <span id="successPercentage">0</span>%
                                    </span>
                                    <span class="badge badge-phoenix badge-phoenix-danger me-2">
                                        Lost <span id="lostPercentage">0</span>%
                                    </span>
                                    <span class="badge badge-phoenix badge-phoenix-secondary">
                                        Cancel <span id="cancelPercentage">0</span>%
                                    </span>
                                </div>

                                <!-- Probability Slider -->
                                <div class="mb-3">
                                    <div class="d-flex align-items-center justify-content-between mb-2">
                                        <label class="form-label mb-0 fw-semibold">Probability</label>
                                        <span id="completionValue" class="text-primary fw-bold fs-7">@Model.Probability%</span>
                                    </div>
                                    <input type="range"
                                           class="form-range"
                                           min="0"
                                           max="100"
                                           step="1"
                                           id="probabilityPercentage"
                                           value="@Model.Probability"
                                           oninput="completionValue.innerText = this.value + '%'"
                                           style="--value: @Model.Probability%">
                                </div>

                                <!-- Created Date -->
                                <div class="d-flex align-items-center text-muted-light">
                                    <span class="fa-solid fa-clock me-2"></span>
                                    <span class="small">Created @Model.Created</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Customer Information Card -->
                <div class="card">
                    <div class="card-body">
                        <h4 class="section-header">Customer Information</h4>
                        <table class="info-table">
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="info-icon bg-success-subtle me-3">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                                 class="text-success-dark">
                                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                                <circle cx="9" cy="7" r="4"></circle>
                                                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                                                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                                            </svg>
                                        </div>
                                        <span class="fw-semibold">Contact Name</span>
                                    </div>
                                </td>
                                <td class="text-center px-3">:</td>
                                <td><span class="text-dark">@Model.FullName</span></td>
                            </tr>

                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="info-icon bg-primary-subtle me-3">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                                 class="text-primary">
                                                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                                            </svg>
                                        </div>
                                        <span class="fw-semibold">Phone</span>
                                    </div>
                                </td>
                                <td class="text-center px-3">:</td>
                                <td><span class="text-dark">@Model.Phone</span></td>
                            </tr>

                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="info-icon bg-secondary-subtle me-3">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                                 class="text-secondary">
                                                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                                                <polyline points="22,6 12,13 2,6"></polyline>
                                            </svg>
                                        </div>
                                        <span class="fw-semibold">Email</span>
                                    </div>
                                </td>
                                <td class="text-center px-3">:</td>
                                <td><span class="text-dark">@Model.Email</span></td>
                            </tr>

                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="info-icon bg-info-subtle me-3">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                                 class="text-info">
                                                <circle cx="12" cy="12" r="10"></circle>
                                                <polyline points="12 6 12 12 16 14"></polyline>
                                            </svg>
                                        </div>
                                        <span class="fw-semibold">Create Date</span>
                                    </div>
                                </td>
                                <td class="text-center px-3">:</td>
                                <td><span class="text-dark">@Model.Created</span></td>
                            </tr>

                            <tr class="d-none" id="closingDateDiv">
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="info-icon bg-warning-subtle me-3">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                                 class="text-warning">
                                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                                <line x1="16" y1="2" x2="16" y2="6"></line>
                                                <line x1="8" y1="2" x2="8" y2="6"></line>
                                                <line x1="3" y1="10" x2="21" y2="10"></line>
                                            </svg>
                                        </div>
                                        <span class="fw-semibold">Closing Date</span>
                                    </div>
                                </td>
                                <td class="text-center px-3">:</td>
                                <td><span id="closingDateResult" class="text-dark"></span></td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Content Area -->
        <div class="col-xl-7 col-xxl-8">
            <!-- Lead Properties Card -->
            <div class="card mb-4">
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Lead Source</label>
                            <select class="form-select" id="leadSource" asp-for="LeadSourceID" asp-items="@ViewBag.LeadSourceDD as SelectList" required>
                                <option value="" disabled selected>Select Source</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Priority</label>
                            <select class="form-select" id="leadPriority" asp-for="PriorityID" asp-items="@ViewBag.LeadPriorities as SelectList">
                                <option value="" disabled selected>Select Priority</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Stage</label>
                            <select class="form-select" id="lead-status" asp-for="LeadStatusID" asp-items="@ViewBag.LeadStatus as SelectList">
                                <option value="" disabled selected>Select Status</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <input id="CustomerId" type="number" value="@Model.CustomerId" hidden />
            <input id="BranchId" type="number" value="@Model.BranchId" hidden />
            <input type="number" id="leadID" value="@Model.LeadID" hidden />

            <!-- Activity Management Card -->
            <div class="card mb-4">
                <div class="card-body">
                    <!-- Activity Type Buttons -->
                    <div class="mb-4" id="optionBtnDiv">
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var item in ViewBag.LeadActivityTypes)
                            {
                                <button class="btn btn-phoenix-secondary option-btn"
                                        type="button"
                                        data-id="@item.LeadActivityTypeID"
                                        data-usefor="@item.LeadActivityName">
                                    <span class="fa-solid @item.LeadActivityIcon me-2"></span>
                                    @item.LeadActivityName
                                </button>
                            }
                        </div>
                    </div>

                    <!-- Date and Time Field -->
                    <div class="mb-3" id="dateField">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Set Date and Time</label>
                                <div class="input-group">
                                    <input class="form-control datetimepicker"
                                           id="aDate"
                                           type="text"
                                           placeholder="dd/mm/yyyy hour : minute"
                                           data-options='{"enableTime":true,"dateFormat":"d/m/y H:i","disableMobile":true}' />
                                    <span class="input-group-text">
                                        <span class="fa-solid fa-calendar"></span>
                                    </span>
                                </div>
                            </div>

                            <div class="col-md-6" id="contact-field" style="display:none;">
                                <label class="form-label fw-semibold">Contact Person Phone</label>
                                <select id="ContectPersonId" class="select2" multiple="multiple">
                                    <option></option>
                                </select>
                            </div>

                            <div class="col-md-6" id="email-field" style="display:none;">
                                <label class="form-label fw-semibold">Contact Person Email</label>
                                <select id="ContectPersonEmailId" class="select2" multiple="multiple">
                                    <option></option>
                                </select>
                            </div>

                            <div class="col-md-6" id="file-field" style="display:none;">
                                <label class="form-label fw-semibold">Attach File</label>
                                <input class="form-control" type="file" id="aFile">
                            </div>
                        </div>
                    </div>

                    <!-- Note Field -->
                    <div class="mb-3" id="note-Field">
                        <label class="form-label fw-semibold">Note</label>
                        <textarea class="form-control" id="aNote" rows="3" placeholder="Add your notes here..."></textarea>
                    </div>

                    <!-- Action Buttons -->
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                        <div>
                            <button type="submit" id="addLActivity" class="btn btn-primary px-4">
                                <span class="fa-solid fa-plus me-2"></span>Add Activity
                            </button>
                            <div class="d-flex align-items-center gap-2 d-none" id="won-fonfirm-div">
                                <span class="fw-semibold">Transfer To Field Service</span>
                                <div class="btn-group">
                                    <button class="btn btn-success btn-xs" id="wonYes">Yes</button>
                                    <button class="btn btn-warning btn-xs" id="wonNo">No</button>
                                    <button class="btn btn-danger btn-xs" id="won-btn-cancel">Cancel</button>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex align-items-center flex-wrap gap-2" id="activity-btn-div">
                            @foreach (var item in ViewBag.LeadActivityTypes2)
                            {
                                <button class="btn btn-phoenix-secondary rounded-pill special-btn option-btn"
                                        type="button"
                                        data-id="@item.LeadActivityTypeID"
                                        data-usefor="@item.UseFor">
                                    <span class="fa-solid @item.LeadActivityIcon me-2"></span>
                                    @item.LeadActivityName
                                </button>
                            }
                            <button class="btn btn-outline-danger rounded-pill d-none" id="restoreBtn2">
                                <span class="fa-solid fa-rotate-right me-2"></span>Restart
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Upcoming Activities -->
            <div class="card d-none" id="upcomming-div">
                <div class="card-header">
                    <h4 class="mb-0">Upcoming Activities</h4>
                </div>
                <div class="card-body">
                    <div id="upcoming-activity" class="timeline-container">
                        <div class="vertical-line"></div>
                    </div>
                </div>
            </div>

            <!-- All Activities -->
            <div class="d-none" id="all-activity-div">
                <ul class="nav nav-underline mb-4" id="myTab" role="tablist">
                    <li class="nav-item" role="presentation">
                        <a class="nav-link active" id="activity-tab">
                            <span class="fa-solid fa-chart-line me-2"></span>All Activity
                        </a>
                    </li>
                    @foreach (var item in ViewBag.LeadActivityTypes)
                    {
                        var safeName = item.LeadActivityName.Replace(" ", "-");
                        <li class="nav-item" role="presentation">
                            <a class="nav-link" id="@safeName-tab" data-usefor="@item.LeadActivityName">
                                <span class="fa-solid @item.LeadActivityIcon me-2"></span>@item.LeadActivityName
                            </a>
                        </li>
                    }
                </ul>

                <div class="card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h4 class="mb-0" id="activity-label">Activity Timeline</h4>
                            <div class="search-box">
                                <form class="position-relative">
                                    <input class="form-control search-input"
                                           id="search-activity"
                                           type="search"
                                           placeholder="Search activities..."
                                           aria-label="Search" />
                                    <span class="fas fa-search search-box-icon"></span>
                                </form>
                            </div>
                        </div>
                        <div id="activity-list" class="timeline-container">
                            <div class="vertical-line"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Custom Toaster -->
<div id="customToaster"></div>

<!-- Confirmation Modal -->
<div id="customConfirmModal">
    <div class="modal-content">
        <img id="modalIcon" class="confirm-icon" alt="Icon">
        <h2 class="confirm-title">Confirmation</h2>
        <p id="confirmMessage" class="confirm-message">Are you sure you want to proceed?</p>
        <div class="confirm-actions">
            <button id="confirmYes" class="confirm-btn confirm-btn-yes">Yes</button>
            <button id="confirmNo" class="confirm-btn confirm-btn-no">No</button>
        </div>
    </div>
</div>

<!-- File Preview Modal -->
<div class="modal fade" id="filePreviewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">File Preview</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="min-height:500px">
                <div id="filePreviewContainer" class="w-100 h-100 d-flex justify-content-center align-items-center">
                    <!-- Content will load here -->
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Reopen Confirmation Modal -->
<div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Reopen Lead</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">Are you sure you want to reopen this lead?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" id="modalNoBtn" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="modalYesBtn">Yes, Reopen</button>
            </div>
        </div>
    </div>
</div>

<!-- Edit Lead Modal -->
<div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Lead Information</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <input type="hidden" id="leadID" />

                    <div class="col-md-6">
                        <label class="form-label">Lead Name</label>
                        <input class="form-control" id="leadName" type="text" placeholder="Enter lead name" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Status</label>
                        <select class="form-select" id="leadStatusID" asp-items="@ViewBag.LeadStatus as SelectList">
                            <option value="" disabled selected>Select Status</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Lead Owner</label>
                        <select class="form-select" id="leadOwnerId">
                            <option value="" selected disabled>Select Owner</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Lead Source</label>
                        <select class="form-select" id="leadSourceID" asp-items="@ViewBag.LeadSourceDD as SelectList" required>
                            <option value="" disabled>Select Source</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Priority</label>
                        <select class="form-select" id="leadPriorityID" asp-items="@ViewBag.LeadPriorities as SelectList">
                            <option value="" disabled>Select Priority</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Approximate Deal Value</label>
                        <input class="form-control" id="approximateDealValue" type="text" placeholder="Enter amount" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Service Type</label>
                        <select class="form-multi-select" multiple id="serviceTypes" asp-items="@ViewBag.ServiceDD as SelectList">
                            <option value="" disabled>Select Services...</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Probability (%)</label>
                        <div class="d-flex align-items-center">
                            <input type="range"
                                   class="form-range"
                                   min="0"
                                   max="100"
                                   step="1"
                                   id="probabilityPercentage2"
                                   value="0"
                                   oninput="completionValue2.innerText = this.value + '%'">
                            <span id="completionValue2" class="text-primary fw-bold ps-3 fs-7" style="min-width: 55px;">0%</span>
                        </div>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" id="descriptionText" rows="4" placeholder="Enter lead description..."></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" id="editBtn" class="btn btn-primary px-4">Save Changes</button>
            </div>
        </div>
    </div>
</div>

<!-- Customer Modal -->
<div class="modal fade" id="customerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content" id="customerModalContent">
            <!-- Dynamic content loaded here -->
        </div>
    </div>
</div>
<!-- FIRST MODAL -->
<div class="modal fade" id="createLeadModalToggle" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Create Lead</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="create-lead-modal-body"></div>
        </div>
    </div>
</div>

<!-- SECOND MODAL -->
<div class="modal fade" id="openCustomerModalToggle" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Create Customer</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="customer-modal-content"></div>
        </div>
    </div>
</div>

@section Scripts { 
    <script src="~/js/pages/CRM/customeToaster.js"></script>
    <script src="~/js/pages/CRM/leadDetails.js"></script>
}
