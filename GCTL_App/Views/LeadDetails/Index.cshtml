@using GCTL.Core.ViewModels.CRM
@model CustomerInfoVM

<style>
    :root {
        --primary-color: #0d6efd;
        --success-color: #10b981;
        --danger-color: #ef4444;
        --warning-color: #f59e0b;
        --info-color: #3b82f6;
        --secondary-color: #6b7280;
        --purple-color: #8b5cf6;
        --indigo-color: #6366f1;
        --border-color: #e5e7eb;
        --bg-subtle: #f9fafb;
        --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        --transition-base: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* ====== Card Enhancements ====== */
    .card {
        border: 1px solid var(--border-color);
        border-radius: 12px;
        box-shadow: var(--shadow-sm);
        transition: var(--transition-base);
    }

        .card:hover {
            box-shadow: var(--shadow-md);
        }

    .card-header {
        background: var(--bg-subtle);
        border-bottom: 1px solid var(--border-color);
        padding: 1.25rem 1.5rem;
        border-radius: 12px 12px 0 0;
    }

    .card-body {
        padding: 1.5rem;
    }

    /* ====== Professional Badges ====== */
    .badge-phoenix {
        padding: 0.375rem 0.75rem;
        font-size: 0.813rem;
        font-weight: 600;
        border-radius: 6px;
        letter-spacing: 0.025em;
        transition: var(--transition-base);
    }

    .badge-phoenix-success {
        background-color: #d1fae5;
        color: #065f46;
    }

    .badge-phoenix-danger {
        background-color: #fee2e2;
        color: #991b1b;
    }

    .badge-phoenix-secondary {
        background-color: #e5e7eb;
        color: #374151;
    }

    /* ====== Button Improvements ====== */
    .btn {
        font-weight: 500;
        border-radius: 8px;
        padding: 0.625rem 1.25rem;
        transition: var(--transition-base);
        border: 1px solid transparent;
    }

    .btn-primary {
        background: linear-gradient(135deg, var(--primary-color), #0a58ca);
        border-color: var(--primary-color);
        box-shadow: 0 2px 4px rgba(13, 110, 253, 0.15);
    }

        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 8px rgba(13, 110, 253, 0.25);
        }

    .btn-phoenix-secondary {
        background-color: #fff;
        border-color: var(--border-color);
        color: var(--secondary-color);
    }

        .btn-phoenix-secondary:hover {
            background-color: var(--bg-subtle);
            border-color: var(--primary-color);
            color: var(--primary-color);
        }

    .option-btn {
        position: relative;
        overflow: hidden;
        min-width: 100px;
        padding: 0.75rem 1rem;
        font-size: 0.875rem;
    }

        .option-btn::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            border-radius: 50%;
            background: rgba(13, 110, 253, 0.1);
            transform: translate(-50%, -50%);
            transition: width 0.4s, height 0.4s;
        }

        .option-btn:hover::before {
            width: 300px;
            height: 300px;
        }

        .option-btn.active {
            background: linear-gradient(135deg, var(--primary-color), #0a58ca);
            color: white;
            border-color: var(--primary-color);
            box-shadow: 0 4px 8px rgba(13, 110, 253, 0.25);
        }

    .special-btn.active2 {
        background: linear-gradient(135deg, var(--primary-color), #0a58ca);
        color: white;
        border-color: var(--primary-color);
    }

    .btn-xs {
        padding: 0.25rem 0.625rem !important;
        font-size: 0.75rem !important;
        line-height: 1.4 !important;
        border-radius: 6px;
    }

    /* ====== Form Controls ====== */
    .form-control, .form-select {
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 0.625rem 0.875rem;
        transition: var(--transition-base);
        font-size: 0.938rem;
    }

        .form-control:focus, .form-select:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.1);
        }

    .form-label {
        font-weight: 600;
        color: #374151;
        margin-bottom: 0.5rem;
        font-size: 0.875rem;
        text-transform: capitalize !important;
    }

    /* ====== Range Input Styling ====== */
    .form-range {
        height: 6px;
        background: linear-gradient(to right, var(--primary-color) 0%, var(--primary-color) var(--value, 0%), #e5e7eb var(--value, 0%), #e5e7eb 100%);
        border-radius: 3px;
    }

        .form-range::-webkit-slider-thumb {
            width: 18px;
            height: 18px;
            background: var(--primary-color);
            border: 3px solid #fff;
            box-shadow: var(--shadow-md);
            transition: var(--transition-base);
        }

            .form-range::-webkit-slider-thumb:hover {
                transform: scale(1.15);
                box-shadow: var(--shadow-lg);
            }

    /* ====== Customer Information Table ====== */
    .info-table {
        width: 100%;
    }

        .info-table tr {
            transition: var(--transition-base);
        }

            .info-table tr:hover {
                background-color: var(--bg-subtle);
            }

        .info-table td {
            padding: 0.625rem 0;
            vertical-align: middle;
        }

    .info-icon {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: var(--transition-base);
    }

    .info-table tr:hover .info-icon {
        transform: scale(1.1);
    }

    /* ====== Select2 Customization ====== */
    .select2-selection {
        border-color: var(--border-color) !important;
        border-radius: 8px !important;
        min-height: 42px !important;
    }

    .select2-container--default .select2-selection--multiple {
        border: 1px solid var(--border-color) !important;
    }

    /* ====== Nav Tabs Enhancement ====== */
    .nav-underline .nav-link {
        padding: 0.75rem 1.25rem;
        color: var(--secondary-color);
        border-bottom: 2px solid transparent;
        transition: var(--transition-base);
        font-weight: 500;
        cursor: pointer;
    }

        .nav-underline .nav-link:hover {
            color: var(--primary-color);
            border-bottom-color: var(--primary-color);
        }

        .nav-underline .nav-link.active {
            color: var(--primary-color);
            border-bottom-color: var(--primary-color);
        }

    /* ====== Professional Toast ====== */
    #customToaster {
        position: fixed;
        top: 20px;
        left: 50%;
        transform: translateX(-50%) translateY(-80px);
        min-width: 320px;
        max-width: 400px;
        background: #fff;
        color: #1f2937;
        font-weight: 600;
        font-size: 1rem;
        padding: 1.5rem;
        border-radius: 12px;
        box-shadow: var(--shadow-xl);
        opacity: 0;
        pointer-events: none;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        z-index: 9999;
        border: 1px solid var(--border-color);
    }

        #customToaster.show-toast {
            opacity: 1;
            transform: translateX(-50%) translateY(0);
        }

        #customToaster.hide-toast {
            opacity: 0;
            transform: translateX(-50%) translateY(-80px);
        }

        #customToaster img.toast-icon {
            width: 64px;
            height: 64px;
        }

        #customToaster .spinner {
            border: 4px solid #f3f4f6;
            border-top: 4px solid var(--primary-color);
            border-radius: 50%;
            width: 48px;
            height: 48px;
            animation: spin 1s linear infinite;
        }

    @@keyframes spin {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    /* ====== Confirmation Modal Enhancement ====== */
    #customConfirmModal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        backdrop-filter: blur(4px);
        display: none;
        justify-content: center;
        align-items: center;
        z-index: 10000;
        animation: fadeIn 0.3s ease;
    }

        #customConfirmModal.active {
            display: flex;
        }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    #customConfirmModal .modal-content {
        background: #fff;
        padding: 2rem;
        border-radius: 16px;
        box-shadow: var(--shadow-xl);
        text-align: center;
        max-width: 440px;
        width: 90%;
        display: flex;
        flex-direction: column;
        align-items: center;
        animation: slideUp 0.3s ease;
    }

    @@keyframes slideUp {
        from {
            transform: translateY(30px);
            opacity: 0;
        }

        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    #customConfirmModal .confirm-icon {
        width: 72px;
        height: 72px;
        margin-bottom: 1.25rem;
    }

        #customConfirmModal .confirm-icon.spin {
            animation: spinIcon 1.5s linear infinite;
        }

    @@keyframes spinIcon {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    #customConfirmModal .confirm-title {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 0.75rem;
        color: #111827;
    }

    #customConfirmModal .confirm-message {
        font-size: 1rem;
        color: #6b7280;
        line-height: 1.6;
    }

    #customConfirmModal .confirm-actions {
        margin-top: 1.5rem;
        display: flex;
        justify-content: center;
        gap: 1rem;
    }

    #customConfirmModal .confirm-btn {
        padding: 0.75rem 2rem;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-size: 1rem;
        font-weight: 600;
        color: #fff;
        transition: var(--transition-base);
        min-width: 100px;
    }

        #customConfirmModal .confirm-btn:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg);
        }

    #customConfirmModal .confirm-btn-yes {
        background: linear-gradient(135deg, var(--success-color), #059669);
    }

    #customConfirmModal .confirm-btn-no {
        background: linear-gradient(135deg, var(--danger-color), #dc2626);
    }

    /* ====== Sticky Sidebar ====== */
    .sticky-leads-sidebar {
        position: sticky;
        top: 20px;
    }

    /* ====== Avatar Enhancement ====== */
    .avatar {
        position: relative;
    }

        .avatar img {
            border: 3px solid #fff;
            box-shadow: var(--shadow-md);
        }

    /* ====== Section Headers ====== */
    .section-header {
        border-bottom: 2px solid var(--border-color);
        padding-bottom: 0.75rem;
        margin-bottom: 1.25rem;
        font-weight: 700;
        color: #111827;
    }

    /* ====== Dropdown Enhancements ====== */
    .dropdown-menu {
        border: 1px solid var(--border-color);
        border-radius: 12px;
        box-shadow: var(--shadow-lg);
        padding: 0.5rem;
    }

    .dropdown-item {
        border-radius: 8px;
        padding: 0.625rem 1rem;
        transition: var(--transition-base);
    }

        .dropdown-item:hover {
            background-color: var(--bg-subtle);
        }

    /* ====== Progress Bar Enhancement ====== */
    .progress {
        background-color: #f3f4f6;
        border-radius: 8px;
        box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.1);
    }

    /* ====== Search Box ====== */
    .search-box .form-control {
        padding-left: 2.5rem;
        border-radius: 10px;
    }

    .search-box .search-box-icon {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--secondary-color);
    }

    /* ====== PROFESSIONAL ACTIVITY TIMELINE STYLES - FIXED ====== */
    .timeline-container {
        position: relative;
    }

    .timeline-wrapper {
        position: relative;
        max-height: 600px;
        overflow-y: auto;
        overflow-x: hidden;
        scrollbar-width: thin;
        scrollbar-color: rgba(0, 0, 0, 0.2) transparent;
        padding-left: 70px;
        padding-right: 10px;
        padding-top: 10px;
        padding-bottom: 10px;
    }

        .timeline-wrapper::-webkit-scrollbar {
            width: 6px;
        }

        .timeline-wrapper::-webkit-scrollbar-track {
            background: transparent;
        }

        .timeline-wrapper::-webkit-scrollbar-thumb {
            background-color: rgba(0, 0, 0, 0.2);
            border-radius: 3px;
            transition: all 0.3s ease;
        }

            .timeline-wrapper::-webkit-scrollbar-thumb:hover {
                background-color: rgba(0, 0, 0, 0.3);
            }

    /* Vertical Timeline Line - FIXED */
    .vertical-timeline-line {
        position: absolute;
        top: 0;
        left: 24px;
        width: 3px;
        height: 100%;
        min-height: 100%;
        background: linear-gradient(to bottom, #0d6efd 0%, #3b82f6 50%, rgba(13, 110, 253, 0.3) 100%);
        border-radius: 2px;
        z-index: 1;
        pointer-events: none;
    }

    /* Activity Timeline Item */
    .timeline-activity-item {
        position: relative;
        z-index: 2;
        margin-bottom: 32px;
        padding-left: 0;
        opacity: 0;
        transform: translateX(-20px);
        animation: slideInTimeline 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }

        .timeline-activity-item:last-child {
            margin-bottom: 8px;
        }

    @@keyframes slideInTimeline {
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    /* Stagger animation */
    .timeline-activity-item:nth-child(2) { animation-delay: 0.05s; }
    .timeline-activity-item:nth-child(3) { animation-delay: 0.1s; }
    .timeline-activity-item:nth-child(4) { animation-delay: 0.15s; }
    .timeline-activity-item:nth-child(5) { animation-delay: 0.2s; }
    .timeline-activity-item:nth-child(6) { animation-delay: 0.25s; }
    .timeline-activity-item:nth-child(n+7) { animation-delay: 0.3s; }

    /* Activity Icon Circle - FIXED */
    .timeline-activity-icon {
        position: absolute;
        left: -46px;
        top: 0;
        z-index: 10;
        width: 48px;
        height: 48px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 0 0 5px #ffffff, 0 4px 12px rgba(0, 0, 0, 0.15);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        font-size: 18px;
        color: white;
        cursor: pointer;
    }

    /* Icon Background Colors - VIBRANT GRADIENTS */
    .timeline-icon-call {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
    }

    .timeline-icon-meeting {
        background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
    }

    .timeline-icon-email {
        background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
    }

    .timeline-icon-note {
        background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
    }

    .timeline-icon-task {
        background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
    }

    .timeline-icon-success {
        background: linear-gradient(135deg, #10b981 0%, #047857 100%);
    }

    .timeline-icon-lost {
        background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
    }

    .timeline-icon-cancel {
        background: linear-gradient(135deg, #6b7280 0%, #4b5563 100%);
    }

    .timeline-icon-default {
        background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
    }

    /* Icon Hover Effect */
    .timeline-activity-item:hover .timeline-activity-icon {
        transform: scale(1.15) rotate(8deg);
        box-shadow: 0 0 0 6px #ffffff, 0 8px 20px rgba(0, 0, 0, 0.25);
    }

    /* Pulse Animation for Upcoming */
    .timeline-icon-pulse {
        animation: timelinePulse 2s infinite;
    }

    @@keyframes timelinePulse {
        0%, 100% {
            box-shadow: 0 0 0 5px #ffffff, 0 4px 12px rgba(0, 0, 0, 0.15);
        }

        50% {
            box-shadow: 0 0 0 8px #ffffff, 0 4px 12px rgba(0, 0, 0, 0.15), 0 0 0 14px rgba(13, 110, 253, 0.3);
        }
    }

    /* Activity Content Card */
    .timeline-activity-content {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 22px 26px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.05), 0 1px 2px 0 rgba(0, 0, 0, 0.03);
        position: relative;
        overflow: hidden;
    }

        .timeline-activity-content::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 5px;
            height: 100%;
            background: linear-gradient(to bottom, #0d6efd 0%, #3b82f6 100%);
            opacity: 0;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

    .timeline-activity-item:hover .timeline-activity-content {
        border-color: #0d6efd;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
        transform: translateX(8px) translateY(-2px);
    }

        .timeline-activity-item:hover .timeline-activity-content::before {
            opacity: 1;
        }

    /* Activity Header */
    .timeline-activity-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 16px;
        gap: 14px;
        flex-wrap: wrap;
        padding-bottom: 14px;
        border-bottom: 1px solid #f3f4f6;
    }

    .timeline-activity-title {
        font-size: 18px;
        font-weight: 700;
        color: #111827;
        margin: 0;
        line-height: 1.4;
        flex: 1;
        min-width: 0;
        letter-spacing: -0.025em;
    }

    .timeline-activity-badge {
        display: inline-flex;
        align-items: center;
        padding: 7px 16px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        white-space: nowrap;
        flex-shrink: 0;
        border: 1px solid transparent;
        transition: all 0.3s ease;
    }

    .timeline-badge-call {
        background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
        color: #065f46;
        border-color: #10b981;
    }

    .timeline-badge-meeting {
        background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
        color: #1e40af;
        border-color: #3b82f6;
    }

    .timeline-badge-email {
        background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%);
        color: #3730a3;
        border-color: #6366f1;
    }

    .timeline-badge-note {
        background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
        color: #92400e;
        border-color: #f59e0b;
    }

    .timeline-badge-task {
        background: linear-gradient(135deg, #ede9fe 0%, #ddd6fe 100%);
        color: #5b21b6;
        border-color: #8b5cf6;
    }

    .timeline-badge-success {
        background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
        color: #065f46;
        border-color: #10b981;
    }

    .timeline-badge-lost {
        background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
        color: #991b1b;
        border-color: #ef4444;
    }

    /* Activity Meta Info */
    .timeline-activity-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        margin-bottom: 14px;
        font-size: 13px;
        color: #6b7280;
    }

    .timeline-meta-item {
        display: flex;
        align-items: center;
        gap: 7px;
    }

        .timeline-meta-item i {
            font-size: 14px;
            color: #0d6efd;
            flex-shrink: 0;
        }

    /* Activity Description with Show More */
    .timeline-activity-description {
        font-size: 14px;
        color: #4b5563;
        line-height: 1.7;
        margin-bottom: 14px;
        position: relative;
    }

        .timeline-activity-description p {
            margin: 0;
        }

    .timeline-description-text {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

        .timeline-description-text.collapsed {
            display: -webkit-box;
            -webkit-box-orient: vertical;
            -webkit-line-clamp: 3;
            overflow: hidden;
        }

        .timeline-description-text.expanded {
            display: block;
        }

    .timeline-show-more-btn {
        background: none;
        border: none;
        color: #0d6efd;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        padding: 6px 0;
        margin-top: 8px;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

        .timeline-show-more-btn:hover {
            color: #0a58ca;
            text-decoration: underline;
        }

        .timeline-show-more-btn i {
            font-size: 10px;
            transition: transform 0.3s;
        }

        .timeline-show-more-btn.expanded i {
            transform: rotate(180deg);
        }

    /* Activity Footer */
    .timeline-activity-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 12px;
        padding-top: 14px;
        border-top: 1px solid #e5e7eb;
    }

    .timeline-activity-status {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
        border: 1px solid transparent;
        transition: all 0.3s ease;
    }

        .timeline-activity-status i {
            font-size: 12px;
        }

    .timeline-status-completed {
        background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
        color: #065f46;
        border-color: #10b981;
    }

    .timeline-status-pending {
        background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
        color: #92400e;
        border-color: #f59e0b;
    }

    .timeline-status-overdue {
        background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
        color: #991b1b;
        border-color: #ef4444;
    }

    .timeline-status-upcoming {
        background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
        color: #1e40af;
        border-color: #3b82f6;
    }

    .timeline-activity-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .timeline-action-btn {
        padding: 8px 18px;
        border: 1.5px solid #e5e7eb;
        background: linear-gradient(135deg, #ffffff 0%, #f9fafb 100%);
        border-radius: 8px;
        font-size: 13px;
        color: #6b7280;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: inline-flex;
        align-items: center;
        gap: 7px;
        font-weight: 600;
    }

        .timeline-action-btn:hover {
            background: linear-gradient(135deg, #0d6efd 0%, #3b82f6 100%);
            border-color: #0d6efd;
            color: #ffffff;
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(13, 110, 253, 0.25);
        }

        .timeline-action-btn i {
            font-size: 12px;
        }

    /* Activity Attachments */
    .timeline-activity-attachments {
        margin-top: 14px;
        padding-top: 14px;
        border-top: 1px solid #e5e7eb;
    }

    .timeline-attachment-item {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 6px;
        font-size: 13px;
        color: #6b7280;
        margin-right: 8px;
        margin-bottom: 8px;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

        .timeline-attachment-item:hover {
            background: white;
            border-color: #0d6efd;
            color: #0d6efd;
            transform: translateY(-2px);
            box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        }

        .timeline-attachment-item i {
            font-size: 14px;
        }

    /* Empty State */
    .timeline-empty-state {
        text-align: center;
        padding: 80px 20px;
        color: #6b7280;
    }

        .timeline-empty-state i {
            font-size: 72px;
            color: #d1d5db;
            margin-bottom: 20px;
            opacity: 0.5;
        }

        .timeline-empty-state h4 {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 8px;
            color: #374151;
        }

        .timeline-empty-state p {
            font-size: 14px;
            color: #6b7280;
            margin: 0;
        }

    /* Loading State */
    .timeline-loading {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 60px 20px;
    }

    .timeline-spinner {
        width: 40px;
        height: 40px;
        border: 4px solid #e5e7eb;
        border-top-color: #0d6efd;
        border-radius: 50%;
        animation: timelineSpin 1s linear infinite;
    }

    @@keyframes timelineSpin {
        to {
            transform: rotate(360deg);
        }
    }

    /* Responsive Design */
    @@media (max-width: 768px) {
        .timeline-wrapper {
            padding-left: 60px;
        }

        .timeline-activity-icon {
            left: -42px;
            width: 44px;
            height: 44px;
            font-size: 16px;
        }

        .vertical-timeline-line {
            left: 20px;
        }

        .timeline-activity-item:hover .timeline-activity-icon {
            transform: scale(1.1) rotate(5deg);
        }

        .timeline-activity-content {
            padding: 16px 18px;
        }

        .timeline-activity-title {
            font-size: 16px;
        }

        .timeline-activity-meta {
            font-size: 12px;
            gap: 12px;
        }

        .timeline-activity-description {
            font-size: 13px;
        }
    }

    @@media (max-width: 576px) {
        .timeline-wrapper {
            padding-left: 55px;
        }

        .timeline-activity-icon {
            left: -40px;
            width: 40px;
            height: 40px;
            font-size: 15px;
        }

        .vertical-timeline-line {
            left: 18px;
        }

        .timeline-activity-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .timeline-activity-footer {
            flex-direction: column;
            align-items: flex-start;
        }

        .timeline-wrapper {
            max-height: 500px;
        }
    }

    /* Utility Classes */
    .text-muted-light {
        color: #9ca3af;
    }

    .border-subtle {
        border-color: var(--border-color) !important;
    }

    .bg-subtle {
        background-color: var(--bg-subtle);
    }

    /* Modal Improvements */
    .modal-content {
        border-radius: 16px;
        border: none;
        box-shadow: var(--shadow-xl);
    }

    .modal-header {
        border-bottom: 1px solid var(--border-color);
        padding: 1.5rem;
        background-color: var(--bg-subtle);
    }

    .modal-body {
        padding: 1.5rem;
    }

    .modal-footer {
        border-top: 1px solid var(--border-color);
        padding: 1.25rem 1.5rem;
        background-color: var(--bg-subtle);
    }
</style>

<div class="pb-4">
    <!-- Page Header -->
    <div class="row align-items-center justify-content-between g-3 mb-4">
