                                                <polyline points="22,6 12,13 2,6"></polyline>
                                            </svg>
                                        </div>
                                        <span class="fw-semibold">Email</span>
                                    </div>
                                </td>
                                <td class="px-3 text-center">:</td>
                                <td><span class="text-dark">@Model.Email</span></td>
                            </tr>

                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="info-icon bg-info-subtle me-3">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                                 class="text-info">
                                                <circle cx="12" cy="12" r="10"></circle>
                                                <polyline points="12 6 12 12 16 14"></polyline>
                                            </svg>
                                        </div>
                                        <span class="fw-semibold">Create Date</span>
                                    </div>
                                </td>
                                <td class="px-3 text-center">:</td>
                                <td><span class="text-dark">@Model.Created</span></td>
                            </tr>
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="info-icon bg-info-subtle me-3">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                                 class="text-info">
                                                <circle cx="12" cy="12" r="10"></circle>
                                                <polyline points="12 6 12 12 16 14"></polyline>
                                            </svg>
                                        </div>
                                        <span class="fw-semibold">Services</span>
                                    </div>
                                </td>
                                <td class="px-3 text-center">:</td>
                                <td><span class="text-dark">@string.Join(",", Model.ServiceNames)</span></td>
                            </tr>

                            <tr class="d-none" id="closingDateDiv">
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="info-icon bg-warning-subtle me-3">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                                 class="text-warning">
                                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                                <line x1="16" y1="2" x2="16" y2="6"></line>
                                                <line x1="8" y1="2" x2="8" y2="6"></line>
                                                <line x1="3" y1="10" x2="21" y2="10"></line>
                                            </svg>
                                        </div>
                                        <span class="fw-semibold">Closing Date</span>
                                    </div>
                                </td>
                                <td class="px-3 text-center">:</td>
                                <td><span id="closingDateResult" class="text-dark"></span></td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Content Area -->
        <div class="col-xl-7 col-xxl-8">
            <!-- Lead Properties Card -->
            <div class="card mb-4">
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Lead Source</label>
                            <select class="form-select" id="leadSource" asp-for="LDLeadSourceID" asp-items="@ViewBag.LeadSourceDD as SelectList" required>
                                <option value="" disabled selected>Select Source</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Priority</label>
                            <select class="form-select" id="leadPriority" asp-for="PriorityID" asp-items="@ViewBag.LeadPriorities as SelectList">
                                <option value="" disabled selected>Select Priority</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Stage</label>
                            <select class="form-select" id="lead-status" asp-for="LDLeadStatusID" asp-items="@ViewBag.LeadStatus as SelectList">
                                <option value="" disabled selected>Select Status</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <input id="CustomerId2" type="number" value="@Model.CustomerId" hidden />
            <input id="BranchId" type="number" value="@Model.BranchId" hidden />
            <input type="number" id="leadID" value="@Model.LeadID" hidden />

            <!-- Activity Management Card -->
            <div class="card mb-4">
                <div class="card-body">
                    <!-- Activity Type Buttons -->
                    <div class="mb-4" id="optionBtnDiv">
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var item in ViewBag.LeadActivityTypes)
                            {
                                <button class="btn btn-phoenix-secondary option-btn"
                                        type="button"
                                        data-id="@item.LeadActivityTypeID"
