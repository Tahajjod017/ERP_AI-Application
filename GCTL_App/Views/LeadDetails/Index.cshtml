                                <td class="px-3 text-center">:</td>
                                <td><span class="text-dark">@Model.FullName</span></td>
                            </tr>

                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="info-icon bg-primary-subtle me-3">
