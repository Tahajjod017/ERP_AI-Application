                        <div class="row g-3">
                            @* <div class="col-md-6">
                                <label class="form-label fw-semibold">Set Date and Time</label>
                                <div class="input-group">
                                    <input class="form-control datetimepicker"
                                           id="aDate"
                                           type="text"
                                           placeholder="dd/mm/yyyy hour : minute"
                                           data-options='{"enableTime":true,"dateFormat":"d/m/y H:i","disableMobile":true}' 
                                           />
                                    <span class="input-group-text">
                                        <span class="fa-solid fa-calendar"></span>
                                    </span>
                                </div>
                            </div> *@

                            <div class="col-md-6" id="contact-field" style="display:none;">
                                <label class="form-label fw-semibold">Contact Person Phone</label>
                                <select id="ContectPersonId" class="select2" multiple="multiple">
                                    <option></option>
                                </select>
                            </div>

                            <div class="col-md-6" id="email-field" style="display:none;">
                                <label class="form-label fw-semibold">Contact Person Email</label>
                                <select id="ContectPersonEmailId" class="select2" multiple="multiple">
                                    <option></option>
                                </select>
                            </div>

                            <div class="col-md-6" id="file-field" style="display:none;">
                                <label class="form-label fw-semibold">Attach File</label>
                                <input class="form-control" type="file" id="aFile">
                            </div>
                        </div>
                    </div>

                    <!-- Note Field -->
                    <div class="mb-3" id="note-Field">
                        <label class="form-label fw-semibold">Note</label>
                        <textarea class="form-control" id="aNote" rows="3" placeholder="Add your notes here..."></textarea>
                    </div>

                    <!-- Action Buttons -->
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
