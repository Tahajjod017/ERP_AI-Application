                </div>
                <div class="col-auto d-flex">
                    <button class="page-link" data-list-pagination="prev"><span class="fas fa-chevron-left"></span></button>
                    <ul class="mb-0 pagination"></ul>
                    <button class="page-link pe-0" data-list-pagination="next"><span class="fas fa-chevron-right"></span></button>
                </div>
            </div>

        </div>
    </div>

</div>


<!-- Add Employes Salary -->
<div class="modal fade" id="add_employee_salary">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">Add Employes Salary</h4>
                <button type="button" class="btn-close custom-btn-close" data-bs-dismiss="modal"
                        aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form action="add-shift-ui.html" class="row g-3 mb-6">



                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label" for="organizerSingle">Company Name</label>
                            <select class="form-multi-select" id="multiple-select-tag" multiple
                                    data-coreui-selection-type="tags" data-coreui-search="true">
                                <option value="0">Select Company...</option>
                                <option value="1">CSL</option>
                                <option value="2">GCTL</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label" for="organizerSingle">Deparment</label>
                            <select class="form-multi-select" id="multiple-dep-select" multiple data-coreui-selection-type="counter" data-coreui-search="true">
                                <option value="">Select Department</option>
                                <option>Developer</option>
                                <option>Designer</option>
                                <option>Finance</option>
                            </select>
                        </div>
                    </div>


                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label" for="organizerSingle">Employee Name</label>
                            <select class="form-multi-select" id="multiple-emp-select" multiple data-coreui-selection-type="counter" data-coreui-search="true">
                                <optgroup label="Developer">
                                    <option value="2">Alam</option>
                                    <option value="3">Momin</option>
                                </optgroup>
                                <optgroup label="Designer">
                                    <option value="4">Name (id)</option>
                                    <option value="5">Name (id)</option>
                                </optgroup>
                            </select>
                        </div>
                    </div>



                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label" for="timepicker1">Salary</label>
                            <input class="form-control" id="timepicker1" type="text" placeholder="25000">
                        </div>
                    </div>


                    <div class="col-12">
                        <div class="row g-3 justify-content-end">
                            <div class="col-auto">
                                <button class="btn btn-phoenix-primary px-3">Cancel</button>
                            </div>
                            <div class="col-auto">
                                <button class="btn btn-primary px-3 px-sm-10">Edit Salary</button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
