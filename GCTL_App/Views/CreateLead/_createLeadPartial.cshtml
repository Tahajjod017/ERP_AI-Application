@model GCTL.Core.ViewModels.CRM.LeadsVM
<div class="row col-md-12 m-0">
    <form class="bg-body-heighlight form-control p-0 shadow-sm" id="leadForm">
        @Html.AntiForgeryToken()
        <div class="modal-body pb-2">
            <div class="row gy-3">
                <!-- Customer -->
                <div class="col-md-6">
                    <label class="form-label">
                        Customer Name <span class="text-danger">*</span> <button class="icon-circle-btn success" id="editCustomerBtn">
                            <i class="fa-solid fa-pen"></i>
                        </button>
                    </label>
                    <select id="CustomerId" name="CustomerId" class="form-select">
                        <option value="">Select Customer</option>
                    </select>
                </div>

                <!-- Branch - Hidden by default, NO space taken -->
                <div class="col-md-6 d-none" id="branchContainer">
                    <label class="form-label">Branch Name <span class="text-danger">*</span></label>
                    <select id="BranchId" name="BranchId" class="form-select">
                        <option value="">Select Branch</option>
                    </select>
                </div>

                <!-- Lead Name -->
                <div class="col-md-6">
                    <label class="form-label">Lead Name <span class="text-danger">*</span></label>
                    <input id="LeadName" name="LeadName" class="form-control" type="text" placeholder="Enter lead name" />
                </div>

                <!-- Lead Source -->
                <div class="col-md-6">
                    <label class="form-label">Lead Source <span class="text-danger">*</span></label>
                    <select id="LeadSourceID" name="LeadSourceID" class="form-select">
                        <option value="">Select Lead Source</option>
                    </select>
                </div>

                <!-- Lead Status -->
                <div class="col-md-6">
                    <label class="form-label">Lead Status <span class="text-danger">*</span></label>
                    <select id="LeadStatusID" name="LeadStatusID" class="form-select">
                        <option value="">Select Lead Status</option>
                    </select>
                </div>

                <!-- Priority -->
                <div class="col-md-6">
                    <label class="form-label">Priority <span class="text-danger">*</span></label>
                    <select id="PriorityID" name="PriorityID" class="form-select">
                        <option value="">Select Priority</option>
                    </select>
                </div>

                <!-- Lead Owner -->
                <div class="col-md-6">
                    <label class="form-label">Lead Owner <span class="text-danger">*</span></label>
                    <select id="LeadOwnerID" name="LeadOwnerID" class="form-select">
                        <option value="">Select Lead Owner</option>
                    </select>
                </div>

                <!-- Approximate Deal Value -->
                <div class="col-md-6">
                    <label class="form-label">Approximate Deal Value</label>
                    <input id="ApproximateDealValue" name="ApproximateDealValue" class="form-control" type="text" placeholder="0.00" />
                </div>

                <!-- Service Types -->
                <div class="col-md-6">
                    <label class="form-label">Service Types</label>
                    <select id="ServiceTypeIds" name="ServiceTypeIds" class="form-select" multiple="multiple">
                        <option value="">Select Service Types</option>
                    </select>
                </div>

                <!-- Probability -->
                <div class="col-md-6">
                    <label class="form-label p-0">Probability (%)</label>
                    <div class="d-flex align-items-center">
                        <input type="range" class="form-range" id="ProbabilityPercentage" name="ProbabilityPercentage"
                               min="0" max="100" step="1" value="0"
                               oninput="document.getElementById('completionValue').innerText = this.value + '%'">
                        <span id="completionValue" class="text-primary fw-bold fs-8 ps-2" style="width: 55px;">0%</span>
                    </div>
                </div>

                <!-- Description -->
                <div class="col-md-12">
                    <label class="form-label">Description</label>
                    <textarea id="LeadDescription" name="LeadDescription" class="form-control h-100" rows="3" placeholder="Enter lead description"></textarea>
                </div>
            </div>
        </div>
        <div class="modal-footer mt-4">
            <button type="button" class="btn btn-light me-2" data-bs-dismiss="modal">Cancel</button>
            <button type="button" id="indexSaveBtn" class="btn btn-primary">
                <i class="fa-solid fa-save me-2"></i>Save Lead
            </button>
        </div>
    </form>
</div>

<style>
    /* Validation error styles */
    .is-invalid {
        border-color: #dc3545 !important;
    }

    .select2-container .select2-selection.is-invalid {
        border-color: #dc3545 !important;
    }

    /* Required field indicator */
    .text-danger {
        color: #dc3545;
    }
</style>
