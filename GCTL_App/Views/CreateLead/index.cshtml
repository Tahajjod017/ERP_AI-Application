<div class="container p-0 d-flex flex-column align-items-center">

    <div class="row col-md-12 mb-2">
        <nav class="mb-3 alig " aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="#!">Page 1</a></li>
                <li class="breadcrumb-item"><a href="#!">Page 2</a></li>
                <li class="breadcrumb-item active">Default</li>
            </ol>
        </nav>
        <h3 class="fs-4 mb-3">@Html.SmartLocalize("Create Lead")</h3>
        <form class="bg-white py-4 form-control shadow-sm" action="shift-roster-ui.html">
            <div class="modal-body pb-2">
                <div class="row gy-3 ">
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input class="form-control" id="exampleFormControlInput" type="text" placeholder="" />
                            <label class="form-label" for="exampleFormControlInput">@Html.SmartLocalize("Lead Name")</label>
                        </div>
                    </div>


                    <div class="col-md-6">
                        <div class="form-floating">
                            <select class="form-multi-select" id="ms1" multiple data-coreui-search="global">
                                <option value="">@Html.SmartLocalize("Select Service type")</option>
                                <option value="0">Angular</option>
                                <option value="1">Bootstrap</option>
                                <option value="2">React.js</option>
                                <option value="3">React1.js</option>
                                <option value="4">React2.js</option>
                                <option value="5">Vue.js</option>
                               
                            </select>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-floating form-floating-advance-select">
                            <label class="form-label" for="exampleFormControlInput">@Html.SmartLocalize("Contact Name")</label>
                            <select class="form-select" id="organizerSingle2" data-choices="data-choices" size="1" required="required" name="organizerSingle" data-options='{"removeItemButton":true,"placeholder":true}'>

                                <option>Mahamudul Hasan</option>
                                <option>Mashum Billah</option>
                                <option>Abdul Motin</option>
                            </select>
                        </div>
                    </div>


                    <div class="col-md-6">
                        <div class="row">
                            <div class="col-md-5">
                                <div class="form-floating form-floating-advance-select">
                                    <label class="form-label" for="organizerMultiple">@Html.SmartLocalize("Country code")</label>
                                    <select class="form-select form-select-sm" id="organizerSingle2" data-choices="data-choices" size="1" required="required" name="organizerSingle" data-options='{"removeItemButton":true,"placeholder":true}'>
                                        <option value="">@Html.SmartLocalize("Select code")</option>
                                        <option>+91</option>
                                        <option>+92</option>
                                        <option>+880</option>
                                    </select>
                                </div>
                            </div>

                            <div class="col-md-7">
                                <div class="form-floating">
                                    <input class="form-control" id="exampleFormControlInput" type="text" placeholder="" />
                                    <label class="form-label" for="exampleFormControlInput">@Html.SmartLocalize("Phone Number")</label>
                                </div>
                            </div>
                        </div>

                    </div>

                    <div class="col-md-6">
                        <div class="form-floating">

                            <input class="form-control" id="exampleFormControlInput" type="text" placeholder="" />
                            <label class="form-label" for="exampleFormControlInput">@Html.SmartLocalize("Email Address")</label>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-floating form-floating-advance-select">
                            <label class="form-label" for="exampleFormControlInput">@Html.SmartLocalize("Company")</label>
                            <select class="form-select focus-color-disable" id="organizerSingle2" data-choices="data-choices" size="1" required="required" name="organizerSingle" data-options='{"removeItemButton":true,"placeholder":true}'>
                                <option value="">@Html.SmartLocalize("Select Company")</option>
                                <option>ABC Corp</option>
                                <option>XYZ Inc</option>
                                <option>XYZ Corp</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-floating form-floating-advance-select">
                            <label class="form-label" for="organizerMultiple">@Html.SmartLocalize("Lead Sources") </label>
                            <select class="form-select" id="organizerSingle2" data-choices="data-choices" size="1" required="required" name="organizerSingle" data-options='{"removeItemButton":true,"placeholder":true}'>
                                <option value="">@Html.SmartLocalize("Select Sources")...</option>
                                <option>Email</option>
                                <option>Phone</option>
                                <option>Social Media</option>
                                <option>Web Form</option>
                                <option>Manual Entry</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-floating form-floating-advance-select">
                            <label class="form-label" for="organizerMultiple">@Html.SmartLocalize("Status Name")</label>
                            <select class="form-select" id="organizerSingle2" data-choices="data-choices" size="1" required="required" name="organizerSingle" data-options='{"removeItemButton":true,"placeholder":true}'>
                                <option value="">@Html.SmartLocalize("Select Status")</option>
                                <option>New</option>
                                <option>Not Contacted</option>
                                <option>Contacted</option>
                                <option>Nurturing</option>
                                <option>Qualified</option>
                                <option>Unqualified</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-floating form-floating-advance-select">
                            <label class="form-label" for="organizerMultiple">@Html.SmartLocalize("Lead Owner Name")</label>
                            <select class="form-select" id="organizerSingle2" data-choices="data-choices" size="1" required="required" name="organizerSingle" data-options='{"removeItemButton":true,"placeholder":true}'>
                                <option value="">@Html.SmartLocalize("Select Status")</option>
                                <option>Juel Rana</option>
                                <option>Hasan</option>
                                <option>Juzayer</option>
                                <option>Robiul</option>
                                <option>Karim</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-floating">

                            <input class="form-control" id="exampleFormControlInput" type="text" placeholder="" />
                            <label class="form-label" for="exampleFormControlInput">@Html.SmartLocalize("Approximate Deal Value")</label>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-floating">

                            <input class="form-control" id="exampleFormControlInput" type="text" placeholder="" />
                            <label class="form-label" for="exampleFormControlInput">@Html.SmartLocalize("Probability (%)")</label>
                        </div>
                    </div>



                    <div class="col-md-12">
                        <div class="form-floating">
                            <textarea class="form-control h-100" id="" rows="3" placeholder=""></textarea>
                            <label class="form-label" for="exampleFormControlInput">@Html.SmartLocalize("Description")</label>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light me-2" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
</div>
@section Scripts{
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/js/all.min.js" defer></script>
}