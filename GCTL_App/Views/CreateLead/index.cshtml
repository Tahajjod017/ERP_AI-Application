                            <div class="col-md-6 ps-1 col-sm-6">
                                <div class="mb-3 form-floating">
                                    <input type="text" id="stateShippingIndex" class="form-control" placeholder="" required>
                                    <label class="form-label req">State/Province</label>
                                    <span class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-12">
                        <div class="row">
                            <div class="col-md-6 pe-1 col-sm-6">
                                <div class="mb-3 form-floating">
                                    <input id="postalCodeShippingIndex" type="text" class="form-control" placeholder="" required>
                                    <label class="form-label req">Zip/Postal Code</label>
                                    <span class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6 ps-1 col-sm-6">
                                <div class="mb-3 form-floating">
                                    <input id="countryShippingIndex" type="text" class="form-control" placeholder="" required>
                                    <label class="form-label req">Country</label>
                                    <span class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-12">
                        <div class="row">
                            <div class="col-md-6 pe-1 col-sm-6">
                                <div class="mb-3 form-floating">
                                    <input type="text" id="latitudeShippingIndex" class="form-control" placeholder="" required>
                                    <label class="form-label req">Latitude</label>
                                    <span class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6 ps-1 col-sm-6">
                                <div class="mb-3 form-floating">
                                    <input type="text" id="longitudeShippingIndex" class="form-control" placeholder="" required>
                                    <label class="form-label req">Longitude</label>
                                    <span class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Right Section -->
                <div class="col-md-6">
                    <div class="row">
                        <div class="col-md-6 pe-1 col-sm-6">
                            <div class="mb-3 form-floating">
                                <input type="text" id="firstNameShippingIndex" class="form-control" placeholder="" required>
                                <label class="form-label req">First Name</label>
                                <span class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6 ps-1 col-sm-6">
                            <div class="mb-3 form-floating">
                                <input type="text" id="lastNameShippingIndex" class="form-control" placeholder="" required>
                                <label class="form-label req">Last Name</label>
                                <span class="text-danger small"></span>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 mb-3">
                        <input class="form-control" id="phone5Index" type="tel" placeholder="Phone Number" />
                    </div>
                    <div class="col-12 mb-3">
                        <input class="form-control" id="phone6Index" type="tel" placeholder="Other Phone" />
                    </div>
                    <div class="col-12">
                        <div class="mb-3 form-floating">
                            <input type="text" id="emailShippingIndex" class="form-control" placeholder="" required>
                            <label class="form-label req">Email</label>
                            <span class="text-danger small"></span>
                        </div>
                    </div>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-light me-2">Cancel</button>
                <button type="submit" id="indexSaveBtn" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="addCustomerModal" tabindex="-1" aria-labelledby="addCustomerModalLabel" aria-hidden="true">
    <partial name="_companyView" />
</div>



