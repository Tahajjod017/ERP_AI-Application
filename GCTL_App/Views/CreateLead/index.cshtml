@model GCTL.Core.ViewModels.CRM.LeadsVM
<style>
    .is-invalid {
        border: 2px solid red !important;
        box-shadow: 0 0 5px rgba(255, 0, 0, 1);
    }

    .select2-selection {
        height: 37px !important;
        padding: 0 0 0 11px !important;
    }

        .select2-selection.is-invalid {
            border: 2px solid red !important;
        }
    /* Timeline container */
    .timeline {
        position: relative;
        margin: 2rem 0;
    }

        /* Vertical line */
        .timeline::before {
            content: '';
            position: absolute;
            top: 0;
            left: 40px;
            width: 4px;
            height: 100%;
            background: #dee2e6;
        }

    /* Timeline item */
    .timeline-item {
        position: relative;
        display: flex;
        align-items: flex-start;
        margin-bottom: 2rem;
    }

    /* Timeline icon */
    .timeline-icon {
        flex-shrink: 0;
        width: 50px;
        height: 50px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        color: #fff;
        margin-right: 1rem;
        position: relative;
        z-index: 1;
    }

        /* Activity type colors */
        .timeline-icon.call {
            background-color: #198754;
        }

        .timeline-icon.email {
            background-color: #0d6efd;
        }

        .timeline-icon.meeting {
            background-color: #ffc107;
            color: #212529;
        }

        .timeline-icon.task {
            background-color: #dc3545;
        }

    /* Timeline card */
    .timeline-card {
        flex-grow: 1;
        background: #fff;
        padding: 1rem 1.5rem;
        border-radius: 0.75rem;
        box-shadow: 0 0.25rem 0.5rem rgba(0,0,0,0.1);
    }

        .timeline-card h6 {
            margin-bottom: 0.5rem;
            font-weight: 600;
        }

        .timeline-card p {
            margin-bottom: 0.5rem;
            color: #495057;
        }

        .timeline-card small {
            color: #6c757d;
        }

    @@media (max-width: 576px) {
        .timeline::before

    {
        left: 25px;
    }

    .timeline-icon {
        width: 40px;
        height: 40px;
        font-size: 18px;
        margin-right: 0.5rem;
    }

    }
</style>
<div class="container p-0 d-flex flex-column align-items-center">
    <div class="row col-md-12 mb-2">
        <h3 class="fs-4 mb-3">@Html.SmartLocalize("Create Lead")</h3>
        <form class="bg-body-heighlight py-4 form-control shadow-sm" action="shift-roster-ui.html" id="leadForm">
            @Html.AntiForgeryToken()
            <div class="modal-body pb-2">
                <div class="row gy-3 ">

                    <div class="col-md-6">
                        <label class="form-label">Customer Name</label>
                        <select asp-for="CustomerId" class="select2">
                        </select>
                    </div>
                    <div class="col-md-6" id="branchContainer" style="display:none">
                        <label class="form-label">Branch Name</label>
                        <select asp-for="BranchId" class="select2">
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">@Html.SmartLocalize("Lead Name")</label>
                        <input class="form-control" asp-for="LeadName" type="text" placeholder="" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Lead Source</label>
                        <select asp-for="LeadSourceID" class="select2">
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Lead Status</label>
                        <select asp-for="LeadStatusID" class="select2">
                        </select>
                        
                    </div>
                    
                    <div class="col-md-6">
                        <label class="form-label">Priority Name</label>
                        <select asp-for="PriorityID" class="select2">
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Lead Owner Name</label>
                        <select asp-for="LeadOwnerID" class="form-select-lg">
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">@Html.SmartLocalize("Approximate Deal Value")</label>
                        <input class="form-control" asp-for="ApproximateDealValue" type="text" placeholder="" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">@Html.SmartLocalize("Service Type")</label>
                        <select asp-for="ServiceTypeIds"  class="form-select select2-multi" multiple="multiple"> </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label p-0">@Html.SmartLocalize("Probability (%)")</label>
                        <div class="d-flex align-items-center">
                            <input type="range" class="form-range" asp-for="ProbabilityPercentage" min="0" max="100" step="1" value="0"
                                   oninput="document.getElementById('completionValue').innerText = this.value + '%'">
                            <span id="completionValue" class="text-primary fw-bold ps-2 fs-8" style="width: 55px;">0%</span>
                        </div>
                    </div>
                    <div class="col-md-12">
                        <label class="form-label">@Html.SmartLocalize("Description")</label>
                        <textarea class="form-control h-100" asp-for="LeadDescription" rows="3" placeholder=""></textarea>
                    </div>

                </div>
            </div>
            <div id="customerInfoContainer" class="mt-5" style="display: none;">
                <h5 class="mb-2 ms-2 text-body-highlight my-3 fs-7" id="informationTitle"></h5>
                <div class="border-top pb-0 mb-3"></div>
                <div class="row p-0">
                    <div class="col-md-6 col-sm-12">
                        <div class="row">
                            <div class="col-md-12">
                                <div class="mb-3 form-floating">
                                    <input type="text" id="iFullAddress" class="form-control" placeholder="Customer name" readonly>
                                    <label class="form-label req">Full Address</label>
                                    <span class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-12">
                                <div class="row">
                                    <div class="col-md-6 pe-1 col-sm-6">
                                        <div class="mb-3 form-floating">
                                            <input type="text" id="iStreet" class="form-control" placeholder="Street" readonly>
                                            <label class="form-label req">Street</label>
                                            <span class="text-danger small"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6 ps-1 col-sm-6">
                                        <div class="mb-3 form-floating">
                                            <input type="text" id="iCity" class="form-control" placeholder="City" readonly>
                                            <label class="form-label req">City</label>
                                            <span class="text-danger small"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-12">
                                <div class="row">
                                    <div class="col-md-6 pe-1 col-sm-6">
                                        <div class="mb-3 form-floating">
                                            <input type="text" id="iAdditionalAddress" class="form-control" placeholder="" readonly>
                                            <label class="form-label req">Additional Address</label>
                                            <span class="text-danger small"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6 ps-1 col-sm-6">
                                        <div class="mb-3 form-floating">
                                            <input type="text" id="iState" class="form-control" placeholder="" readonly>
                                            <label class="form-label req">State/Province</label>
                                            <span class="text-danger small"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-12">
                                <div class="row">
                                    <div class="col-md-6 pe-1 col-sm-6">
                                        <div class="mb-3 form-floating">
                                            <input id="PostalCode" type="text" class="form-control" placeholder="" readonly>
                                            <label class="form-label req">Zip/Postal Code</label>
                                            <span class="text-danger small"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6 ps-1 col-sm-6">
                                        <div class="form-floating form-floating-advance-select">
                                            <label class="form-label">@Html.SmartLocalize("Country")</label>
                                            <select class="form-select choiceDD" id="iCountry" asp-items="@ViewBag.CountryDD as SelectList" disabled>
                                                <option value="" selected>@Html.SmartLocalize("Select Country")</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-12">
                                <div class="row">
                                    <div class="col-md-6 pe-1 col-sm-6">
                                        <div class="mb-3 form-floating">
                                            <input type="text" id="iLatitude" class="form-control" placeholder="" readonly>
                                            <label class="form-label req">Latitude</label>
                                        </div>
                                    </div>
                                    <div class="col-md-6 ps-1 col-sm-6">
                                        <div class="mb-3 form-floating">
                                            <input type="text" id="iLongitude" class="form-control" placeholder="" readonly>
                                            <label class="form-label req">Longitude</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-sm-12">
                        <div class="row">
                            <div class="col-md-12">
                                <div class="row">
                                    <div class="col-md-6 pe-1 col-sm-6">
                                        <div class="mb-3 form-floating">
                                            <input type="text" id="iFirstName" class="form-control" placeholder="" readonly>
                                            <label class="form-label req">First Name</label>
                                            <span class="text-danger small"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6 ps-1 col-sm-6">
                                        <div class="mb-3 form-floating">
                                            <input type="text" id="iLastName" class="form-control" placeholder="" readonly>
                                            <label class="form-label req">Last Name</label>
                                            <span class="text-danger small"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 mb-3">
                                <input class="form-control" id="iPhone" type="tel" placeholder="Phone Number" readonly />
                                <div class="text-danger" id="errorShow"></div>
                            </div>
                            <div class="col-12 mb-3">
                                <input class="form-control" id="iOtherPhone" type="tel" placeholder="Other Phone" readonly />
                                <div class="text-danger" id="errorShow"></div>
                            </div>

                            <div class="col-12">
                                <div class="mb-3 form-floating">
                                    <input type="text" id="iEmail" class="form-control" placeholder="" readonly>
                                    <label class="form-label req">Email</label>
                                    <span class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer mt-4">
                <button type="button" class="btn btn-light me-2">Cancel</button>
                <button type="submit" id="indexSaveBtn" class="btn btn-primary">Save</button>
            </div>
        </form>
            

    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="addCustomerModal" tabindex="-1" aria-labelledby="addCustomerModalLabel" aria-hidden="true">
    <partial name="_companyView" />
</div>

<!-- Modal -->
<div class="modal fade" id="customerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content" id="customerModalContent">
        </div>
    </div>
</div>

@section Scripts{
    <script async defer src="https://maps.googleapis.com/maps/api/js?key=AIzaSyBgZTw6AA9Lc3EKX47xObpNOdJ2vFQ0B0w&libraries=places"></script>
    <script src="~/js/pages/CRM/intlTelInput.min.js"></script>
    <script src="~/js/pages/CRM/utils.js"></script>
    <script src="~/js/pages/crm/createlead.js"></script>
}