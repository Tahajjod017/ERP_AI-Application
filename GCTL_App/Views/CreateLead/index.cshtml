@model GCTL.Core.ViewModels.CRM.CreateLeadVM
@using Microsoft.AspNetCore.Mvc.Rendering

<style>

    /*create lead customer command person modal */

    .nav-tabs .nav-link.active {
        color: #0d6efd;
        border-color: #0d6efd;
        border-bottom: 1px solid #0d6efd;
    }

    .nav-tabs .nav-link {
        color: black;
    }

        .nav-tabs .nav-link:hover {
            border-color: #0d6efd;
            color: #0d6efd;
        }

    .nav-tabs .nav-link {
    }

    .form-label.req::after {
        content: ' *';
        color: red;
    }

    .input-icon-end {
        position: relative;
    }

        .input-icon-end .fa {
            position: absolute;
            top: 50%;
            right: 15px;
            transform: translateY(-50%);
            color: #6c757d;
            pointer-events: none;
        }

    .card {
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
    }

    .readonly {
        background-color: #f8f9fa;
    }

    /*//create lead mobiel field css*/
    #iti-0__dropdown-content,
    #iti-2__dropdown-content,
    #iti-1__dropdown-content,
    #iti-3__dropdown-content,
    #iti-4__dropdown-content {
        z-index: 111;
    }

    .iti--allow-dropdown {
        width: 100%;
    }

    .iti__tel-input {
        height: 46px;
    }


    /*#companySubTab ul li a .fa-solid {
            padding-right: 54px !important;
        }*/
    /*for fixing modal google map loading problem*/

    div.pac-container {
        z-index: 99999999999 !important;
    }


    /*createLead table subtab*/
    /* Sidebar container */
    #customeInnerDiv {
        border-top: 1px;
        border-bottom: 1px;
        border-right: 0;
        border-left: 0;
        border-style: solid;
        border-color: rgb(203, 208, 221);
        margin-bottom: -1px;
    }

    #customeSubTab {
        padding-top: 1rem;
    }

    .custom-sidebar li a {
        font-size: 12px;
        font-weight: 500;
        color: #6c757d;
        padding: 10px 15px;
        display: flex;
        align-items: center;
        transition: all 0.15s ease-in-out;
        border: 1px solid rgb(203, 208, 221);
        text-decoration: none;
        cursor: pointer;
        margin-top: -1px;
        margin-right: -1px;
        margin-bottom: -1px;
    }

        .custom-sidebar li a .svg-inline--fa {
            margin-right: 6px;
            width: 20px;
            text-align: center;
        }

    .custom-sidebar a:hover {
        background-color: #e9ecef;
        color: #000;
    }


    .custom-sidebar a:not(.active) .svg-inline--fa {
        color: rgb(203, 208, 221);
    }

    .custom-sidebar a.active, .custom-sidebar li a .svg-inline--fa {
        color: #000;
        font-weight: 700;
    }

    .iti__selected-country {
        padding-left: 8% !important;
    }

    .iti__country-container {
        padding-left: 3% !important;
    }

    .iti__tel-input {
        padding-left: 11%;
    }

    #personCustomerSearchMainDiv {
        position: relative;
    }
    

    #personCustomerList {
        position: absolute;
        bottom: 0;

    }
    /* for selecting search item using arrow keygen */
    .selected {
        background-color: #e0e0e0 !important;
        color: #000 !important;
    }

    .companyName-item.active {
        background-color: #007bff;
        color: white;
    }
</style>



<div class="container p-0 d-flex flex-column align-items-center">

    <div class="row col-md-12 mb-2">
        @* <nav class="mb-3 alig " aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="#!">Page 1</a></li>
                <li class="breadcrumb-item"><a href="#!">Page 2</a></li>
                <li class="breadcrumb-item active">Default</li>
            </ol>
        </nav> *@
        <h3 class="fs-4 mb-3">@Html.SmartLocalize("Create Lead New")</h3>
        <form class="bg-white py-4 form-control shadow-sm" action="shift-roster-ui.html">
            <div class="modal-body pb-2">
                <div class="row gy-3 ">

                    <div class="col-sm-12 customerDiv col-md-6">
                        <div class="form-floating mbs-4 position-relative">
                            <input type="text" id="ContactNameSearch" class="form-control searchField" required placeholder="@Html.SmartLocalize("Search ContactName...")">
                            <input type="hidden" id="customerID" class="idBank">
                            <input type="hidden" id="customerType">

                            <label for="floatingSelectLitigation"><i class="fa-solid fa-magnifying-glass"></i> @Html.SmartLocalize("Customer Search")</label>

                            <div class="list-group position-absolute bg-white p-0 border" id="customerList" style="display: none; width:100%; z-index:10012;">
                                <!-- ContactName items will be populated here by JavaScript -->
                            </div>
                            <div class="no-results position-absolute bg-white p-2 border" id="noResults" style="display: none; width:100%; z-index:1000;">
                                @Html.SmartLocalize("Item Not Found. Are you add new item?")
                                <button type="button" class="btn btn-sm btn-link p-0" id="addNewContactNameBtn">@Html.SmartLocalize("Business")</button>
                                <span>Or</span>
                                <button type="button" class="btn btn-sm btn-link p-0" id="addNewContactNameBtn2">@Html.SmartLocalize("Person")</button>
                            </div>
                        </div>

                       
                    </div>
                    
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input class="form-control" id="leadName" type="text" placeholder="" required />
                            <label class="form-label" for="exampleFormControlInput">@Html.SmartLocalize("Lead Name")</label>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-floating form-floating-advance-select">
                            <label class="form-label" for="organizerMultiple">@Html.SmartLocalize("Lead Sources") </label>
                            <select class="form-select choiceDD" id="leadSourceId" asp-items="@ViewBag.LeadSourceDD as SelectList" required>
                                <option value="" selected>@Html.SmartLocalize("Select Sources")...</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-floating form-floating-advance-select">
                            <label class="form-label" for="organizerMultiple">@Html.SmartLocalize("Status Name")</label>
                            <select class="form-select choiceDD" id="leadStatusId" asp-items="@ViewBag.LeadStatusDD as SelectList" required>
                                <option value="" selected>@Html.SmartLocalize("Select Status")</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-floating form-floating-advance-select">
                            <label class="form-label" for="organizerMultiple">@Html.SmartLocalize("Lead Owner Name")</label>
                            <select class="form-select choiceDD" id="leadOwnerId" asp-items="@ViewBag.EmployeeDD as SelectList" required>
                                <option value="" selected>@Html.SmartLocalize("Select Lead Owner")</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-floating">

                            <input class="form-control" id="approximateDealValue" type="text" placeholder="" />
                            <label class="form-label" for="exampleFormControlInput">@Html.SmartLocalize("Approximate Deal Value")</label>
                        </div>
                    </div>

                    @* <div class="col-md-6">
                        <div class="form-floating">

                            <input class="form-control" id="probabilityPercentage" type="text" placeholder="" />
                            <label class="form-label" for="exampleFormControlInput">@Html.SmartLocalize("Probability (%)")</label>
                        </div>
                    </div> *@
                    <div class="col-md-6">
                        <label for="completion" class="form-label p-0">@Html.SmartLocalize("Probability (%)")</label>
                        <div class="d-flex align-items-center">
                            <input type="range" class="form-range" min="0" max="100" step="1" id="probabilityPercentage" value="0" oninput="completionValue.innerText = this.value + '%'">
                            <span id="completionValue" class="text-primary fw-bold ps-2 fs-8" style="width: 55px;">0%</span>
                        </div>
                                            </div>
                    <div class="col-md-12">
                        <div class="form-floating">
                            <textarea class="form-control h-100" id="descriptionText" rows="3" placeholder=""></textarea>
                            <label class="form-label" for="exampleFormControlInput">@Html.SmartLocalize("Description")</label>
                        </div>
                    </div>

                </div>
            </div>

            <div id="customerInfoContainer" style="display: none;">
