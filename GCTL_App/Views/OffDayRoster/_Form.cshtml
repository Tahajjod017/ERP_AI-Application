@model GCTL.Core.ViewModels.AttendanceManagement.ScheduleManagement.OffDayRoster.RosterInOffDaySetupVM

@{
    var employees = ViewBag.EmployeeList as List<GCTL.Core.ViewModels.CommonSelectVM>;
}

<form asp-controller="OffDayRoster" asp-action="Create" id="rosterInOffDay-form" enctype="multipart/form-data">
    <div class="modal-body pb-0">

        <div class="row g-3 mb-3">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="RosterInOffDayID" />

            <div class="col-md">
                <label class="form-label" asp-for="OrganizationID">@Html.SmartLocalize("Organization Name")<span style="color:red;">&nbsp;*</span></label>
                <select class="form-select" asp-for="OrganizationID">
                    <option value="">@Html.SmartLocalize("Select Organization")...</option>
                </select>
                <span id="OrganizationIDError" class="text-danger" style="display:none;"></span>
            </div>

            <div class="col-md branch">
                <label class="form-label" asp-for="BranchIDs">@Html.SmartLocalize("Branch Name")</label>
                <select class="form-multi-select"
                        asp-for="BranchIDs"
                        asp-items="@ViewBag.BrnchDD as SelectList"
                        multiple data-coreui-multiple="true"
                        data-coreui-selection-type="counter"
                        data-coreui-search="true"
                        data-coreui-placeholder="@Html.SmartLocalize("Select Branch")...">
                </select>
            </div>

            <div class="col-md department">
                <label class="form-label" asp-for="DepartmentIDs">@Html.SmartLocalize("Department Name")</label>
                <select class="form-multi-select"
                        asp-for="DepartmentIDs"
                        asp-items="@ViewBag.DepartmentDD as SelectList"
                        multiple data-coreui-multiple="true"
                        data-coreui-selection-type="counter"
                        data-coreui-search="true"
                        data-coreui-placeholder="@Html.SmartLocalize("Select Department")...">
                </select>
            </div>

            <div class="col-md employee">
                <label class="form-label" asp-for="EmployeeIDs">@Html.SmartLocalize("Employee Name")</label>
                <select class="form-multi-select"
                        asp-for="EmployeeIDs"
                        multiple data-coreui-multiple="true"
                        data-coreui-selection-type="counter"
                        data-coreui-search="true"
                        data-coreui-placeholder="@Html.SmartLocalize("Select Employee")...">
                    @foreach (var group in employees.GroupBy(e => e.GroupName))
                    {
                        <optgroup label="@group.Key">
                            @foreach (var emp in group)
                            {
                                <option value="@emp.Id">@emp.Name</option>
                            }
                        </optgroup>
                    }
                </select>
            </div>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-md">
                <label class="form-label" asp-for="ShiftID">@Html.SmartLocalize("Shift Name")<span style="color:red;">&nbsp;*</span></label>
                <select class="form-select" asp-items="@ViewBag.ShiftDD as SelectList" asp-for="ShiftID">
                    <option value="">@Html.SmartLocalize("Select Shift")...</option>
                </select>
                <span id="ShiftIDError" class="text-danger" style="display:none;"></span>
            </div>

            <div class="col-md">
                <label class="form-label" asp-for="StartDate">@Html.SmartLocalize("Start Date")<span style="color:red;">&nbsp;*</span></label>
                <input class="form-control datetimepicker" asp-for="StartDate" type="text" placeholder="DD/MM/YYYY" />
                <span id="StartDateError" class="text-danger" style="display:none;"></span>
            </div>

            <div class="col-md">
                <label class="form-label" asp-for="EndDate">@Html.SmartLocalize("End Date")<span style="color:red;">&nbsp;*</span></label>
                <input class="form-control datetimepicker" asp-for="EndDate" type="text" placeholder="DD/MM/YYYY" />
                <span id="EndDateError" class="text-danger" style="display:none;"></span>
            </div>

            @* <input type="text" id="basic-daterange" class="form-control date-input" placeholder="d/m/y to d/m/y" readonly>
            <input type="hidden" asp-for="StartDate" name="StartDate" />
            <input type="hidden" asp-for="EndDate" name="EndDate" /> *@
        </div>
        <div class="col-12">
            <div class="row g-3 justify-content-end">
                <div class="col-auto">
                    <button type="reset" class="btn btn-phoenix-primary px-5" id="rosterInOfficeDays-resetBtn">@Html.SmartLocalize("Reset")</button>
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary px-5 px-sm-10" id="rosterInOfficeDays-saveBtn">@Html.SmartLocalize("Save")</button>
                </div>
            </div>
        </div>
        <div class="row">

            <div class="col-md-2">
                <div class="mb-3">
                    <label class="form-label" for="organizerSingle">Company Name</label>
                    <select class="form-multi-select" id="multiple-department-select" multiple data-coreui-selection-type="counter" data-coreui-search="true">
                        <option value="">Select Company</option>
                        <option>CSL</option>
                        <option>GCTL</option>
                    </select>
                </div>
            </div>

            <div class="col-md-2">
                <div class="mb-3">
                    <label class="form-label" for="organizerSingle">Select Department</label>
                    <select class="form-multi-select" id="multiple-department-select" multiple data-coreui-selection-type="counter" data-coreui-search="true">
                        <option value="0">Software Developer</option>
                        <option value="1">Software Designer</option>
                        <option value="2">Finance</option>
                        <option value="3">IT Manager</option>
                    </select>
                </div>
            </div>

            <div class="col-md-2">
                <div class="mb-3">
                    <label class="form-label" for="organizerSingle">Employee</label>
                    <select class="form-multi-select" id="multiple-employee-select" multiple data-coreui-selection-type="counter" data-coreui-search="true">
                        <optgroup label="Developer">
                            <option>Hasan Ali</option>
                            <option>Korim</option>
                        </optgroup>
                        <optgroup label="Designer">
                            <option>Jueal Rana</option>
                            <option>Kolim Ullah</option>
                        </optgroup>
                    </select>
                </div>
            </div>

            <div class="col-md-2">
                <div class="mb-3">
                    <label class="form-label" for="organizerSingle">Select Shift</label>
                    <select class="form-select" id="organizerSingle" data-choices="data-choices" data-options='{"removeItemButton":true,"placeholder":true}'>
                        <option value="">Select Roster...</option>
                        <option>Shift 1</option>
                        <option>Shift 2</option>
                        <option>Shift 3</option>
                        <option>Shift 4</option>
                    </select>
                </div>
            </div>

            <div class="col-md-2">
                <div class="mb-3">
                    <div class="">
                        <label for="datepickerf" class="form-label">Select Date</label>
                        <input type="text" class="form-control" id="datepickerf" placeholder="yyy/mm/dd" data-options='{"disableMobile":true,"dateFormat":"Y-m-d"}'>

                    </div>
                </div>
            </div>

            <div class="col-md-2">
                <div class="mb-3">
                    <label class="form-label" for="organizerSingle">Compensation Type</label>
                    <select class="form-select" id="leaveType">
                        <option value="overtime">Overtime</option>
                        <option value="compensation">Compensation Leave</option>
                        <option value="dayexchange1">Day Exchange</option>
                    </select>
                </div>
            </div>

            <!-- Modal for Day Exchange -->
            <div class="modal fade" id="dayExchangeModal" tabindex="-1" aria-labelledby="dayExchangeModalLabel" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="dayExchangeModalLabel">Day Exchange Details</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <p>Day Exchange For:</p>
                            <span class="badge badge-phoenix badge-phoenix-success">2025/04/12</span>
                            <span class="badge badge-phoenix badge-phoenix-success">2025/04/19</span>

                            <div class="mb-3">
                                <label for="datepicker2" class="form-label">Exchange Date</label>
                                <input type="text" class="form-control" id="datepicker2" placeholder="yyy/mm/dd" data-options='{"disableMobile":true,"dateFormat":"Y-m-d"}'>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                            <button type="button" class="btn btn-primary">Submit</button>
                        </div>
                    </div>
                </div>
            </div>

            <script>
                document.getElementById('leaveType').addEventListener('change', function () {
                  if (this.value === 'dayexchange1') {
                    const modal = new bootstrap.Modal(document.getElementById('dayExchangeModal'));
                    modal.show();
                  }
                });
            </script>

            <div id="dateSelect" class="">
                @* <script>
                    flatpickr("#datepicker2", {
                      mode: "multiple", // allow multiple selections
                      dateFormat: "Y-m-d",
                      enable: [
                        function(date) {
                          // Enable only Fridays (Friday = 5)
                          return date.getDay() !== 5;
                        }
                      ]
                    });
                </script> *@
            </div>

            <script>
                const leaveType = document.getElementById('leaveType');
                const dateSelect = document.getElementById('dateSelect');

                leaveType.addEventListener('change', function () {
                  if (this.value === 'dayexchange') {
                    dateSelect.style.display = 'block';
                  } else {
                    dateSelect.style.display = 'none';
                  }
                });
            </script>
        </div>
    </div>
</form>