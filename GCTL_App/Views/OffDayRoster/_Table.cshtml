    <script>
        // JavaScript to handle table visibility
        document.getElementById('timeFrame').addEventListener('change', function() {
          // Hide all tables
          document.querySelectorAll('.table-container').forEach(function(table) {
            table.style.display = 'none';
          });

          // Show the selected table
          const selectedTable = document.getElementById(this.value);
          if (selectedTable) {
            selectedTable.style.display = 'block';
          }
        });

        // Show the default table on page load
        document.addEventListener('DOMContentLoaded', function() {
          document.getElementById('day7').style.display = 'block'; // Show Week table by default
        });
    </script>
