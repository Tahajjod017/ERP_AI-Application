@model GCTL.Core.ViewModels.AdminSettingsVM.CompanySettingsVM
@{
    var mainTab = "CompanySetting";
    var subTab = "Company";
}
<style>
    /* Styling for the dropdown */
    .dropdown-menu {
        min-width: 200px;
        padding: 10px;
    }

    .column-toggle {
        margin-right: 10px;
    }
 

</style>

<partial name="~/Views/Shared/AdminsettingsNavs/CompanySettingsNavs/_MainSettingsTabPartial.cshtml" model="mainTab" />
<partial name="~/Views/Shared/AdminsettingsNavs/CompanySettingsNavs/_NavCompanySettingsPartial.cshtml" model="subTab" />
<div class="tab-content mt-3" id="myTabContent1">
    <div class="tab-pane fade show active" id="tab-companySettingCompany" role="tabpanel" aria-labelledby="companySettingCompany-tab">
        <div class="col-xl-12">
            <div class="card mb-4">
                <div class="card-body">
                    <div class="border-bottom mb-3 pb-3">
                        <h4>Organization Settings</h4>
                    </div>
                    <form id="companySettingsForm" asp-controller="CompanySettings" asp-action="Create" method="post" enctype="multipart/form-data">
                        <div class="mb-3">
                            <div class="row">
                                <div class="col-md-12">
                                    <div>
                                        <h6 class="mb-3">Basic Information</h6>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label" for="OrganizationName">Organization Name</label>
                                        <input class="form-control" asp-for="OrganizationName" id="OrganizationName" type="text" name="OrganizationName" placeholder="Organization Name" />
                                        <span asp-validation-for="OrganizationName" class="text-danger"></span>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label" for="EmailAddress">Email Address</label>
                                        <input class="form-control" id="EmailAddress" type="email" name="EmailAddress" placeholder="company@email.com" />
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label" for="Phone">Phone</label>
                                        <input class="form-control" id="Phone" type="number" name="Phone" placeholder="xxxx xxx xx" />
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label" for="Fax">Fax</label>
                                        <input class="form-control" id="Fax" type="text" name="Fax" placeholder="xxxx xxx xxx" />
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label" for="WebAddress">Web</label>
                                        <input class="form-control" id="WebAddress" type="text" name="WebAddress" placeholder="www.company.com" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="border-bottom mb-3">
                            <h6 class="mb-3">Organization Images</h6>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="d-flex justify-content-between bg-light p-3 mb-4">
                                        <div class="me-2">
                                            <img id="logoPreview" src="~/img/logo-small.svg" style="width: 100px; height: 100px;">
                                        </div>
                                        <i id="clearLogo" class="fas fa-times-circle" style="color: red; position: absolute; top: 0; right: 0; display: none; cursor: pointer;"></i>
                                        <div class="">
                                            <div class="mb-2">
                                                <h6 class="mb-1">Logo</h6>
                                                <p class="fs-12">Recommended image size is 160px x 50px</p>
                                                <input type="file" class="form-control image-sign" id="logoUpload" name="LogoLinkIform" multiple="">
                                                <p id="logoWarning" class="text-danger mt-2" style="display:none;"></p> <!-- Warning message -->
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="d-flex justify-content-between bg-light p-3 mb-4">
                                        <div class="me-2">
                                            <img id="faviconPreview" src="~/img/logo-small.svg" style="width: 100px; height: 100px;">
                                        </div>
                                        <div class="">
                                            <div class="mb-2">
                                                <h6 class="mb-1">Favicon</h6>
                                                <p class="fs-12">Recommended image size is 128px x 128px</p>
                                                <input type="file" class="form-control image-sign" id="faviconUpload" name="FaviconLinkIform" multiple="">
                                                <p id="faviconWarning" class="text-danger mt-2" style="display:none;"></p> <!-- Warning message -->
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="border-bottom mb-3">
                            <h6 class="mb-3">Address Information</h6>
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="mb-3">
                                        <label class="form-label" for="FullAddress">Full Address</label>
                                        <input class="form-control" id="FullAddress" type="text" name="FullAddress" placeholder="Search for an address" />
                                    </div>
                                </div>
                                <div class="col-md-12">
                                    <div class="mb-3">
                                        <label class="form-label" for="Address">Address</label>
                                        <input class="form-control" id="Address" type="text" name="Address" placeholder="www.company.com" />
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label" for="CountryID">Country</label>
                                        <select class="form-select choiceDD" id="CountryID" name="CountryID">
                                            <option value="">Select Country</option>
                                            @foreach (var cntry in ViewBag.CountriesDropDown)
                                            {
                                                <option value="@cntry.Value">@cntry.Text</option>
                                            }
                                        </select>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label" for="Street">Street</label>
                                        <input class="form-control" id="Street" type="text" name="Street" placeholder="" />
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label" for="City">City</label>
                                        <input class="form-control" id="City" type="text" name="City" placeholder="" />
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label" for="PostCode">Postal Code</label>
                                        <input class="form-control" id="PostCode" type="text" name="PostCode" placeholder="" />
                                    </div>
                                </div>

                                <!-- Google Map Container -->
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label" for="Latitude">Latitude</label>
                                        <input class="form-control" id="Latitude" type="text" name="Latitude" placeholder="Latitude"  />
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label" for="Longitude">Longitude</label>
                                        <input class="form-control" id="Longitude" type="text" name="Longitude" placeholder="Longitude"  />
                                    </div>
                                </div>

                                <!-- Google Map Container -->
                                <div class="col-md-12">
                                    <div id="map" style="height: 400px; width: 100%;"></div> <!-- Set a height for the map -->
                                </div>

                                <div class="col-md-12">
                                    <a href="https://www.latlong.net/" id="getLocation" class="icon-link mt-3 mb-3" target="_blank">Latitude and Longitude Finder</a>
                                </div>
                                
                            </div>
                        </div>

                        <div class="d-flex align-items-center justify-content-end">
                            <button type="reset" class="btn btn-outline-secondary me-3">Reset</button>
                            <button type="submit" class="btn btn-primary">Save</button>
                        </div>
                    </form>

                </div>
            </div>
           
        </div>
    </div>
</div>

<partial name="_organizationTableList" />
<partial name="_editOrganizationSettings" />
<partial name="_ConfirmDelete" />


@section Scripts { 
    <script src="~/js/pages/adminsettings/organizationsettings/companysetting.js"></script>

    <script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyChjt63jehy9gPiaf9Nwan4PT72TmaHdio&libraries=places&callback=initMap" async defer></script>

}

