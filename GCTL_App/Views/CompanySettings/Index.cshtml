                    </div>
                </div>

            </div> *@
            <div class="card mt-4 mb-4">
                <div class="card-header d-flex align-items-center justify-content-between flex-wrap row-gap-3 mb-4">
                    <h4 class="mb-1">@Html.SmartLocalize("Company List")</h4>
                    @* <div class="d-flex my-xl-auto right-content align-items-center flex-wrap row-gap-3">
                                <div class="dropdown me-3">
                                    <select class="form-select" id="addEmailConfig-dd-search" asp-items="ViewBag.OrganizationDD as SelectList" data-choices="data-choices" size="1" required="required" name="organizerSingle" data-options='{"removeItemButton":true,"placeholder":true}'>
                                        <option value="">@Html.SmartLocalize("Company Name")</option>
