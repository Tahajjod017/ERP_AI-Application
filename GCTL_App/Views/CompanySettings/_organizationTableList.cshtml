
<div class="card mt-4 mb-4">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap row-gap-3 mb-4">
        <h4 class="mb-1">@Html.SmartLocalize("Company List")</h4>
        @* <div class="d-flex my-xl-auto right-content align-items-center flex-wrap row-gap-3">
                                <div class="dropdown me-3">
                                    <select class="form-select" id="addEmailConfig-dd-search" asp-items="ViewBag.OrganizationDD as SelectList" data-choices="data-choices" size="1" required="required" name="organizerSingle" data-options='{"removeItemButton":true,"placeholder":true}'>
                                        <option value="">@Html.SmartLocalize("Company Name")</option>
                                    </select>
                                </div>
                            </div> *@
    </div>

    <div class="border-translucent p-3">
        <div class="row g-3 justify-content-between align-items-end mb-4">
            <div class="col-12 col-sm-auto">
                <div class="d-flex align-items-center me-3" style="width: auto;">
                    <span class="ms-2">@Html.SmartLocalize("Showing"):</span> &nbsp;
                    <div style="width: 100%;">
                        <select id="addCompanySettings-pageSizeSelect" class="form-select form-select-sm" tabindex="10">
                            <option class="dropdown-item" value="5">@Html.SmartLocalize("5")</option>
                            <option class="dropdown-item" value="10">@Html.SmartLocalize("10")</option>
                            <option class="dropdown-item" value="25">@Html.SmartLocalize("25")</option>
                            <option class="dropdown-item" value="50">@Html.SmartLocalize("50")</option>
                            <option class="dropdown-item" value="100">@Html.SmartLocalize("100")</option>
                            <option class="dropdown-item" value="0">@Html.SmartLocalize("All")</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-auto">
                <div class="d-flex align-items-center">
                    <div class="d-none me-3" id="addCompanySettings-bulkSelectActions">
                        <div class="position-relative">
                            <button type="button" class="btn btn-phoenix-danger btn-sm ms-2" id="addCompanySettings-bulkDelBtn">@Html.SmartLocalize("Delete")</button>
                        </div>
                    </div>

                    <div class="search-box me-3" id="addCompanySettings-searchBox">
                        <form class="position-relative" id="addCompanySettings-searchForm">
                            <input class="form-control search-input search" id="addCompanySettings-searchInput" type="search" placeholder="@Html.SmartLocalize("Search here")" aria-label="Search" />
                            <span class="fas fa-search search-box-icon"></span>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        <div class="dropdown">
           @*  <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" id="toggleColumnsBtn" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="fas fa-columns"></i> <!-- Columns Icon -->
            </button> *@
            <ul class="dropdown-menu" aria-labelledby="toggleColumnsBtn">
                <li><input type="checkbox" class="column-toggle" data-column="CompanyName" checked /> Company Name</li>
                <li><input type="checkbox" class="column-toggle" data-column="Address" checked /> Address</li>
                <li><input type="checkbox" class="column-toggle" data-column="Country" checked /> Country</li>
                <li><input type="checkbox" class="column-toggle" data-column="Email" checked /> Email</li>
                <li><input type="checkbox" class="column-toggle" data-column="Phone" checked /> Phone</li>
            </ul>
        </div>

        <div class="table-responsive scrollbar mx-n1 px-1">
            <table class="table table-sm fs-9 leads-table">
                <thead>
                    <tr>
                        <th class="text-center text-middle align-middle ps-0" scope="col" style="width: 5%;">
                            <input type="checkbox" class="form-check-input" id="addCompanySettings-check-all" />
                        </th>
                        <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="Serial">@Html.SmartLocalize("SL")</th>
                        <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="CompanyName">@Html.SmartLocalize("Company Name")</th>
                        <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="Address">@Html.SmartLocalize("Address")</th>
                        <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="Country">@Html.SmartLocalize("Country")</th>
                        <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="Email">@Html.SmartLocalize("Email")</th>
                        <th class="sort align-middle ps-4 pe-5 text-uppercase text-nowrap" scope="col" data-sort="Phone">@Html.SmartLocalize("Phone")</th>
                        <th class="text-end align-middle pe-0 ps-5 text-uppercase" scope="col">@Html.SmartLocalize("Action")</th>
                    </tr>
                </thead>
                <tbody id="addCompanySettings-tBody">
                </tbody>
            </table>
        </div>

        <div class="d-flex flex-wrap align-items-center justify-content-between py-3 pe-0 fs-9 border-bottom border-translucent">
            <div class="d-flex">
                <p class="mb-0 d-none d-sm-block me-3 fw-semibold text-body" id="addCompanySettings-paginationInfo"></p>

                <p class="mb-0 d-none d-sm-block me-3 fw-semibold text-body" data-list-info="data-list-info"></p>
            </div>
            <div class="d-flex">
                <button class="page-link" data-list-pagination="prev" id="addCompanySettings-prevPageBtn"><span class="fas fa-chevron-left"></span></button>
                <ul class="mb-0 pagination" id="addCompanySettings-paginationLinks"></ul>
                <button class="page-link pe-0" data-list-pagination="next" id="addCompanySettings-nextPageBtn"><span class="fas fa-chevron-right"></span></button>
            </div>
        </div>
    </div>
</div>