@model GCTL_App.ViewModels.AttendanceManagement.ScheduleManagement.AssignDefaultShift.AssignDefaultShiftPageVM

@{
    var employees = ViewBag.EmployeeList as List<GCTL.Core.ViewModels.AttendanceManagement.ScheduleManagement.AssignDefaultShift.AssignDefaultShiftSetupVM>;
}

<div class="card mb-2">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap row-gap-3">
        <h4>@Html.SmartLocalize("Assign Default Shift")</h4>
    </div>
    <div class="card-body">
        <partial name="_Form" model="Model.Setup" />
    </div>
</div>

<partial name="_Table" />

<partial name="_ConfirmEditModal" />

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script src="~/js/pages/attendancemanagement/schedulemanagement/assigndefaultshift.js"></script>
    <script>
        $(function () {
            var options = {
                baseUrl: '@Url.Action("", "AssignDefaultShift")'
            };
            options.load = () => { };
            $.assigndefaultshift(options);
        });
    </script>
}