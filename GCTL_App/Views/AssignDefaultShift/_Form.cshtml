@model GCTL.Core.ViewModels.AttendanceManagement.ScheduleManagement.AssignDefaultShift.AssignDefaultShiftSetupVM

@{
    var employees = ViewBag.EmployeeList as List<GCTL.Core.ViewModels.CommonSelectVM>;
}

<form asp-action="Create" asp-controller="AssignDefaultShift" id="assignDefaultShift-addForm" enctype="multipart/form-data">
    <div class="row g-3">
        @Html.AntiForgeryToken()

        <div class="col-md-3">
            <label class="form-label" asp-for="OrganizationID">@Html.SmartLocalize("Organization Name")<span style="color:red;">&nbsp;*</span></label>
            <select class="form-select" asp-for="OrganizationID" asp-items="@ViewBag.OrganizationDD as SelectList">
                <option value="">@Html.SmartLocalize("Select Organization")...</option>
            </select>
            <span id="OrganizationIDError" class="text-danger" style="display:none;"></span>
        </div>

        <div class="col-md-3 branch">
            <label class="form-label" asp-for="BranchIDs">@Html.SmartLocalize("Branch Name")</label>
            <select class="form-multi-select"
                    asp-for="BranchIDs"
                    asp-items="@ViewBag.BrnchDD as SelectList"
                    multiple data-coreui-multiple="true"
                    data-coreui-selection-type="counter"
                    data-coreui-search="true"
                    data-coreui-placeholder="@Html.SmartLocalize("Select Branch")...">
            </select>
        </div>

        <div class="col-md-3 department">
            <label class="form-label" asp-for="DepartmentIDs">@Html.SmartLocalize("Department Name")</label>
            <select class="form-multi-select"
                    asp-for="DepartmentIDs"
                    asp-items="@ViewBag.DepartmentDD as SelectList"
                    multiple data-coreui-multiple="true"
                    data-coreui-selection-type="counter"
                    data-coreui-search="true"
                    data-coreui-placeholder="@Html.SmartLocalize("Select Department")...">
            </select>
        </div>

        <div class="col-md-3 employee">
            <label class="form-label" asp-for="EmployeeIDs">@Html.SmartLocalize("Employee Name")</label>
            <select class="form-multi-select"
                    asp-for="EmployeeIDs"
                    multiple data-coreui-multiple="true"
                    data-coreui-selection-type="counter"
                    data-coreui-search="true"
                    data-coreui-placeholder="@Html.SmartLocalize("Select Employee")...">
                @foreach (var group in employees.GroupBy(e => e.GroupName))
                {
                    <optgroup label="@group.Key">
                        @foreach (var emp in group)
                        {
                            <option value="@emp.Id">@emp.Name</option>
                        }
                    </optgroup>
                }
            </select>
        </div>

        <div class="col-md-12">
            <label class="form-label" asp-for="ShiftID">@Html.SmartLocalize("Select Shift")<span style="color:red;">&nbsp;*</span></label>
            <select class="form-select" asp-for="ShiftID" asp-items="ViewBag.ShiftDD as SelectList">
                <option value="">@Html.SmartLocalize("Select Shift")...</option>
            </select>
            <span id="ShiftIDError" class="text-danger" style="display:none;"></span>
        </div>
    </div>

    <div class="col-12">
        <div class="row g-3 justify-content-end">
            <div class="col-auto">
                <button type="reset" class="btn btn-phoenix-primary px-5" id="assignDefaultShift-resetBtn">@Html.SmartLocalize("Reset")</button>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary px-5 px-sm-15" id="assignDefaultShift-saveBtn">@Html.SmartLocalize("Save")</button>
            </div>
        </div>
    </div>
</form>