{
  "version": "3.0",
  "defaultProvider": "cdnjs",
  "libraries": [
    {
      "library": "bootstrap-multiselect@1.1.2",
      "destination": "wwwroot/lib/bootstrap-multiselect/"
    },
    {
      "library": "jquery-date-range-picker@0.21.1",
      "destination": "wwwroot/js/layout/jquery-date-range-picker/"
    },
    {
      "library": "moment.js@2.30.1",
      "destination": "wwwroot/js/layout/moment.js/",
      "files": [
        "moment.min.js"
      ]
    },
    {
      "library": "flatpickr@4.6.13",
      "destination": "wwwroot/js/layout/flatpickr/",
      "files": [
        "flatpickr.min.js",
        "flatpickr.min.css"
      ]
    },
    {
      "library": "intl-tel-input@25.5.2",
      "destination": "wwwroot/lib/intl-tel-input/"
    },
    {
      "library": "select2@4.0.13",
      "destination": "wwwroot/lib/select2/",
      "files": [
        "js/select2.min.js",
        "css/select2.css",
        "css/select2.min.css",
        "js/select2.full.js",
        "js/select2.full.min.js",
        "js/select2.js"
      ]
    }
  ]
}