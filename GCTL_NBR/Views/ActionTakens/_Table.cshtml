<div class="card mb-2">
    <div class="card-header border-bottom-1">
        <div class="row justify-content-between align-items-center">
            <div class="col-auto">
                <h3 class="text-body-emphasis mt-3">Information's of Action Taken</h3>
            </div>
        </div>
    </div>

    <div class="card-body py-0 scrollbar to-do-list-body">
        <div class="mx-n4 px-4 mx-lg-n6 px-lg-6 bg-body-emphasis py-5 border-y">
            <div class="row g-3 justify-content-between align-items-end mb-4">
                <div class="col-12 col-sm-auto">
                    <div class="dropdown me-3">
                        <button class="btn btn-phoenix-secondary dropdown-toggle" type="button" id="actionTaken-pageSizeDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                            Showing: <span id="selectedPageSize">5</span>
                        </button>
                        <ul class="dropdown-menu" aria-labelledby="actionTaken-pageSizeDropdown">
                            <li><a class="dropdown-item" href="#" data-size="5">5</a></li>
                            <li><a class="dropdown-item" href="#" data-size="10">10</a></li>
                            <li><a class="dropdown-item" href="#" data-size="25">25</a></li>
                            <li><a class="dropdown-item" href="#" data-size="50">50</a></li>
                            <li><a class="dropdown-item" href="#" data-size="100">100</a></li>
                        </ul>
                    </div>
                </div>

                <div class="col-12 col-sm-auto">
                    <div class="d-flex align-items-center">
                        <div class="d-none me-3" id="actionTaken-bulkSelectActions">
                            <div class="position-relative">
                                <button type="button" class="btn btn-phoenix-danger btn-sm ms-2" id="actionTaken-bulkDelBtn">Delete</button>
                            </div>
                        </div>

                        <div class="search-box me-3" id="actionTaken-searchBox">
                            <form class="position-relative" id="actionTaken-searchForm">
                                <input class="form-control search-input search" id="actionTaken-searchInput" type="search" placeholder="Search here" aria-label="Search" />
                                <span class="fas fa-search search-box-icon"></span>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <div class="table-responsive ms-n1 ps-1 scrollbar">
                <table class="table fs-9 mb-0 border-top border-translucent">
                    <thead>
                        <tr>
                            <th class="text-center text-middle align-middle ps-0" scope="col" style="width: 5%;">
                                <input type="checkbox" class="form-check-input" id="actionTaken-check-all" />
                            </th>
                            <th class="text-center text-middle align-middle ps-0" scope="col" style="width: 10%;">Sl. No</th>
                            <th class="sort white-space-nowrap align-middle ps-0" scope="col" data-sort="ActionTakenName">Action Taken Name</th>
                            <th class="sort white-space-nowrap align-middle ps-0" scope="col" data-sort="Action" style="width: 10%;">Action</th>
                        </tr>
                    </thead>
                    <tbody id="actionTaken-tBody">
                    </tbody>
                </table>
            </div>

            <div class="d-flex flex-wrap align-items-center justify-content-between py-3 pe-0 fs-9 border-bottom border-translucent">
                <div class="d-flex">
                    <p class="mb-0 d-none d-sm-block me-3 fw-semibold text-body" id="actionTaken-paginationInfo"></p>

                    <p class="mb-0 d-none d-sm-block me-3 fw-semibold text-body" data-list-info="data-list-info"></p>
                </div>
                <div class="d-flex">
                    <button class="page-link" data-list-pagination="prev" id="actionTaken-prevPageBtn"><span class="fas fa-chevron-left"></span></button>
                    <ul class="mb-0 pagination" id="actionTaken-paginationLinks"></ul>
                    <button class="page-link pe-0" data-list-pagination="next" id="actionTaken-nextPageBtn"><span class="fas fa-chevron-right"></span></button>
                </div>
            </div>
        </div>
    </div>
</div>



