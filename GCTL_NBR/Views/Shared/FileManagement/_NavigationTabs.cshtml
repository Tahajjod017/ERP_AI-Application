}


@if (activeTab == "showTaxIncomeActiveTab")
{
    <ul class="nav nav-underline fs-9 deal-details scrollbar flex-nowrap w-100 py-2 mb-3 mx-2 border-bottom" id="myTab" role="tablist">

        <li class="nav-item text-nowrap me-2">
            <a class="nav-link @(innerTab == "taxpayerExpenditureInnerTab" ? "active" : "")"
               href="/ShowTaxIncome/Index">
                <span class="fa-solid fa-user me-2 tab-icon-color"></span> প্রদর্শিত কর
            </a>
        </li>

        <li class="nav-item text-nowrap me-2">
            <a class="nav-link @(innerTab == "showTaxIncomeInnerTab" ? "active" : "")"
               href="/TaxpayerExpenditure/Index">
                <span class="fa-solid fa-user me-2 tab-icon-color"></span> করদাতার ব্যয়
            </a>
        </li>


        <li class="nav-item text-nowrap me-2">
            <a class="nav-link @(innerTab == "concealmentActiveTab" ? "active" : "")"
               href="/Concealment/Index">
                <span class="fa-solid fa-user me-2 tab-icon-color"></span> অপ্রদর্শিত করযোগ্য আয়
            </a>
        </li>

     
    </ul>
}
