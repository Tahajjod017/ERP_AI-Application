                <span class="fa-solid fa-user me-2 tab-icon-color"></span> অন্যান্য হিসাবের তথ্য
            </a>
        </li>
        <li class="nav-item text-nowrap me-2">
            <a class="nav-link @(innerTab == "expenditureInfo" ? "active" : "")"
               href="/ExpenseInformation/Index">
                <span class="fa-solid fa-user me-2 tab-icon-color"></span> ব্যায় সংক্রান্ত তথ্য
            </a>
        </li>
