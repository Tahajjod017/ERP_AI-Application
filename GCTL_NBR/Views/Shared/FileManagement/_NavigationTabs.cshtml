@using GCTL.Service
@inject PermissionService PermissionService

@{
    var activeTab = ViewBag.ActiveTab as string ?? "";
    var innerTab = ViewBag.InnerTab as string ?? "";
    Func<string, Task<bool>> canViewAsync = controller => PermissionService.CanViewAsync(controller);
}

<!-- Main Tab Row -->
<ul class="nav nav-underline fs-9 deal-details scrollbar flex-nowrap w-100 py-2 mb-2 mx-2 border-bottom" id="myTab" role="tablist">
    <li class="nav-item text-nowrap me-2">
        <a class="nav-link @(activeTab == "empPersonalInfo" ? "active" : "")"
           href="/GeneralTaxPayerInfoEdit/Index">
            <span class="fa-solid fa-user me-2 tab-icon-color"></span> সাধারণ তথ্য
        </a>
    </li>

        <li class="nav-item text-nowrap me-2">
            <a class="nav-link @(activeTab == "familyInfo" ? "active" : "")"
               href="/FamilyInfo/Index">
                <span class="fa-solid fa-users me-2 tab-icon-color"></span> পরিবারের তথ্য
            </a>
        </li>


    <li class="nav-item text-nowrap me-2">
        <a class="nav-link @(activeTab == "aggrAssetInfo" ? "active" : "")"
           href="/AgriAssetInfo/Index">
            <span class="fa-solid fa-dollar-sign me-2 tab-icon-color"></span> কৃষি সম্পদের তথ্য
        </a>
    </li>

    <li class="nav-item text-nowrap me-2">
        <a class="nav-link @(activeTab == "assetInfo" ? "active" : "")"
           href="/NonAgriAssetInfo/Index">
            <span class="fa-solid fa-dollar me-2 tab-icon-color"></span> অকৃষি সম্পদের তথ্য
        </a>
    </li>

    <li class="nav-item text-nowrap me-2">
        <a class="nav-link @(activeTab == "bankInfo" ? "active" : "")"
           href="/FinancialInfo/Index">
            <span class="fa-solid fa-home me-2 tab-icon-color"></span> আর্থিক লেনদেনের তথ্য
        </a>
    </li>
    <li class="nav-item text-nowrap me-2">
        <a class="nav-link @(activeTab == "taxActionInfo" ? "active" : "")"
           href="/TaxInfoAndActionTaken/Index">
            <span class="fa-solid fa-home me-2 tab-icon-color"></span> কর সংক্রান্ত তথ্য ও গৃহীত পদক্ষেপ
        </a>
    </li>


    <li class="nav-item text-nowrap me-2">
        <a class="nav-link @(activeTab == "showTaxIncomeActiveTab" ? "active" : "")"
           href="/ShowTaxIncome/Index">
            <span class="fa-solid fa-home me-2 tab-icon-color"></span>অন্যান্য  তথ্য
        </a>
    </li>


    <li class="nav-item text-nowrap me-2">
        <a class="nav-link @(activeTab == "LetterIssueActiveTab" ? "active" : "")"
           href="/LetterIssue/Index">
            <span class="fa-solid fa-home me-2 tab-icon-color"></span> চিঠি ইস্যু
        </a>
    </li>
    <li class="nav-item text-nowrap me-2">
        <a class="nav-link @(activeTab == "caseInfo" ? "active" : "")"
           href="/CaseInformtion/Index">
            <span class="fa-solid fa-home me-2 tab-icon-color"></span> মামলার তথ্য
        </a>
    </li>
    <li class="nav-item text-nowrap me-2">
        <a class="nav-link @(activeTab == "fileInfo" ? "active" : "")"
           href="/FileStatus/Index">
            <span class="fa-solid fa-square-check me-2 tab-icon-color"></span> ফাইলের অবস্থা
        </a>
    </li>

   
</ul>

<!-- Nested Tab Row (Only visible when assetInfo is active) -->
@if (activeTab == "assetInfo")
{
    <ul class="nav nav-underline fs-9 deal-details scrollbar flex-nowrap w-100 py-2 mb-3 mx-2 border-bottom" id="myTab" role="tablist">
        <li class="nav-item text-nowrap me-2">
            <a class="nav-link @(innerTab == "companyInfo" ? "active" : "")"
               href="/NonAgriCompanyInfo/Index">
                <span class="fa-solid fa-user me-2 tab-icon-color"></span> কোম্পানির তথ্য
            </a>
        </li>

        <li class="nav-item text-nowrap me-2">
            <a class="nav-link @(innerTab == "apartmentsInfo" ? "active" : "")"
               href="/NonAgriApartmentInfo/Index">
                <span class="fa-solid fa-building me-2 tab-icon-color"></span> এপার্টমেন্টের তথ্য
            </a>
        </li>

        <li class="nav-item text-nowrap me-2">
            <a class="nav-link @(innerTab == "vehicleInfo" ? "active" : "")"
               href="/NonAgriVehicleInfo/Index">
                <span class="fa-solid fa-car me-2 tab-icon-color"></span> যানবাহনের তথ্য
            </a>
        </li>

        <li class="nav-item text-nowrap me-2">
            <a class="nav-link @(innerTab == "landInfo" ? "active" : "")"
               href="/NonAgriLandInfo/Index">
                <span class="fa-solid fa-tree me-2 tab-icon-color"></span> জমির তথ্য
            </a>
        </li>
    </ul>
}
<!-- Nested Tab Row (Only visible when assetInfo is active) -->
@if (activeTab == "bankInfo")
{
    <ul class="nav nav-underline fs-9 deal-details scrollbar flex-nowrap w-100 py-2 mb-3 mx-2 border-bottom" id="myTab" role="tablist">
        <li class="nav-item text-nowrap me-2">
            <a class="nav-link @(innerTab == "bankAccountInfo" ? "active" : "")"
               href="/BankAccount/Index">
                <span class="fa-solid fa-user me-2 tab-icon-color"></span> ব্যাংক হিসাব
            </a>
        </li>

        <li class="nav-item text-nowrap me-2">
            <a class="nav-link @(innerTab == "fdrAccountInfo" ? "active" : "")"
               href="/FixedDepositReceipt/Index">
                <span class="fa-solid fa-building me-2 tab-icon-color"></span> এফডিআর হিসাব
            </a>
        </li>

        <li class="nav-item text-nowrap me-2">
            <a class="nav-link @(innerTab == "efdrAccountInfo" ? "active" : "")"
               href="/DPSAccount/Index">
                <span class="fa-solid fa-user me-2 tab-icon-color"></span> ডিপিএস হিসাব
            </a>
        </li>

        <li class="nav-item text-nowrap me-2">
            <a class="nav-link @(innerTab == "loanAccountInfo" ? "active" : "")"
               href="/LoanAccount/Index">
                <span class="fa-solid fa-user me-2 tab-icon-color"></span> ঋণ হিসাব
            </a>
        </li>
        <li class="nav-item text-nowrap me-2">
            <a class="nav-link @(innerTab == "shareAccountInfo" ? "active" : "")"
               href="/ShareAccountInformation/Index">
                <span class="fa-solid fa-user me-2 tab-icon-color"></span> শেয়ার হিসাবের তথ্য
            </a>
        </li>
        <li class="nav-item text-nowrap me-2">
            <a class="nav-link @(innerTab == "othersAccountInfo" ? "active" : "")"
