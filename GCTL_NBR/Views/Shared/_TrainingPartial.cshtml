
        <div class="px-25">
            <div class="d-flex justify-content-center my-8">
                <div class="col-12 row gy-3">

            <div class="container mt-3">
                <div class="card shadow-sm">
                    <div class="card-body p-0" style="background: #d2d9e970">
                        <div class="d-flex justify-content-center mt-2">
                            <div class="col-12 row flex gy-3 pb-3">

                                <input id="empIdMain4" type="hidden" />
                                <input id="empCode" type="hidden" />

                                <div class="col-sm-4 col-md-4">
                                    <div class="form-floating">
                                        <select class="form-select" id="empCodePass4">
                                            <option selected="selected">Select Employee</option>
                                        </select>
                                        <label for="floatingSelectLitigation"></label>
                                    </div>
                                </div>

                                <div class="col-sm-4 col-md-4">
                                    <div class="form-floating">
                                        <input class="form-control" id="NidPass4" type="text" placeholder="" readonly />
                                        <label for="">National ID</label>
                                    </div>
                                </div>

                                <div class="col-sm-4 col-md-4">
                                    <div class="form-floating">
                                        <input class="form-control" id="BirthCertiPass4" type="text" placeholder="" readonly />
                                        <label for="">Birth Certificate</label>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            </div>


         

                    @* <partial name="_EmployeeInfoPartial" /> *@

                     <input type="hidden" id="empTrainingInfoId"> 
                    <input type="hidden" id="employeeId">

                    <div class="col-sm-6 col-md-6">
                        <div class="form-floating">
                            <input class="form-control" id="trainingTitle" type="text" placeholder="Training Title" required />
                            <label for="trainingTitle">Training Title</label>
                        </div>
                    </div>
                    <div class="col-sm-6 col-md-6">
                        <div class="form-floating">
                            <input class="form-control" id="country" type="text" placeholder="Country" required />
                            <label for="country">Country</label>
                        </div>
                    </div>
                    <div class="col-sm-6 col-md-6">
                        <div class="form-floating">
                            <input class="form-control" id="topicsCovered" type="text" placeholder="Topics Covered" required />
                            <label for="topicsCovered">Topics Covered</label>
                        </div>
                    </div>
                    <div class="col-sm-6 col-md-6">
                        <div class="form-floating">
                            <select class="form-select" id="yearPassing" name="year-of-passing" required>
                                <option value="" selected disabled>Select Training Year</option>
                                @for (int year = DateTime.Now.Year - 5; year <= DateTime.Now.Year; year++)
                                {
                                    <option value="@year">@year</option>
                                }
                            </select>
                            <label for="yearPassing">Training Year</label>
                        </div>
                    </div>
                    <div class="col-sm-6 col-md-6">
                        <div class="form-floating">
                            <input class="form-control" id="instituteNameTrain" type="text" placeholder="Institute Name" required />
                            <label for="instituteNameTrain">Institute Name</label>
                        </div>
                    </div>
                    <div class="col-sm-6 col-md-6">
                        <div class="form-floating">
                            <input class="form-control" id="duration" type="text" placeholder="Duration" />
                            <label for="duration">Duration (Years)</label>
                        </div>
                    </div>
                    <div class="col-sm-12 col-md-12">
                        <div class="form-floating">
                            <input class="form-control" id="location" type="text" placeholder="Location" />
                            <label for="location">Location</label>
                        </div>
                    </div>
                    <button class="btn btn-outline-primary rounded-pill me-1 mb-1 mx-3" id="btnAddTraining" type="button" style="width: 100px;">Add</button>
                </div>
            </div>
            <h4 class="border-bottom">Training Summary</h4>
            <div class="col-sm-12 col-md-12 col-xl-12 px-4 mt-4">
                <table class="table">
                    <thead>
                        <tr>
                            <th scope="col">Training Title</th>
                            <th scope="col">Topic</th>
                            <th scope="col">Institute</th>
                            <th scope="col">Country</th>
                            <th scope="col">Location</th>
                            <th scope="col">Year</th>
                            <th scope="col">Duration</th>
                            <th scope="col">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="trainingTable"></tbody>
                </table>
            </div>
    <button class="btn btn-outline-primary rounded-pill me-1 mb-1 mx-3" id="btnSaveTraining" type="button" style="width: 100px;">Save</button>
        </div>
  







<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script src="~/js/pages/employeetraining.js"></script>
